{% extends 'back/base.html.twig' %}

{% block title %}Paniers - Admin{% endblock %}
{% block breadcrumb %}Paniers Actifs{% endblock %}

{% block content %}
<div style="padding:2rem;">
  <div style="margin-bottom:2rem;">
    <h2 style="font-size:1.5rem;color:var(--pg-text);margin:0;">Paniers Actifs</h2>
  </div>

  <div class="dash-panel">
    {% if paniers|length > 0 %}
      <div style="overflow-x:auto;">
        <table style="width:100%;color:var(--pg-text);">
          <thead>
            <tr style="border-bottom:1px solid var(--pg-border);background:var(--pg-surface2);">
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Client</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Articles</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Total</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Date Création</th>
              <th style="text-align:center;padding:1rem;font-weight:700;color:var(--pg-muted);">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for panier in paniers %}
              <tr style="border-bottom:1px solid var(--pg-border);transition:background 0.2s;">
                <td style="padding:1rem;font-weight:600;">
                  {% if panier.client %}
                    {{ panier.client.fullName|default('Client #' ~ panier.idClient) }}
                  {% else %}
                    Client #{{ panier.idClient }}
                  {% endif %}
                </td>
                <td style="padding:1rem;text-align:center;">{{ panier.articles|length }}</td>
                <td style="padding:1rem;font-weight:700;color:#fbbf24;">{{ (panier.articles|reduce(0, (sum, art) => sum + (art.produit.prix * art.quantite)))|number_format(3, '.', '') }} TND</td>
                <td style="padding:1rem;color:var(--pg-muted);">{{ panier.createdAt|date('d/m/Y H:i')|default('-') }}</td>
                <td style="padding:1rem;text-align:center;">
                  <div style="display:flex;gap:0.5rem;justify-content:center;">
                    <button type="button" onclick="showPanierDetails({{ panier.idPanier }})" style="background:#17a2b8;color:white;padding:0.4rem 0.8rem;border:none;border-radius:4px;font-size:0.85rem;font-weight:700;cursor:pointer;transition:background 0.2s;">Voir</button>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <p style="text-align:center;padding:2rem;color:var(--pg-muted);">Aucun panier actif.</p>
    {% endif %}
  </div>
</div>

<!-- Modal de détails du panier -->
<div id="panierModal" style="display:none;position:fixed;z-index:1000;left:0;top:0;width:100%;height:100%;overflow:auto;background-color:rgba(0,0,0,0.6);">
  <div style="background:var(--pg-surface);margin:5% auto;padding:2rem;border:1px solid var(--pg-border);width:80%;max-width:500px;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,0.5);">
    <span onclick="closePanierModal()" style="color:#aaa;float:right;font-size:28px;font-weight:bold;cursor:pointer;line-height:20px;">×</span>
    <h3 id="panierTitle" style="margin-top:0;color:var(--pg-text);">Détails du Panier</h3>
    <div id="panierDetails" style="max-height:400px;overflow-y:auto;"></div>
  </div>
</div>

<script>
function showPanierDetails(panierId) {
  document.getElementById('panierModal').style.display = 'block';
  document.getElementById('panierTitle').textContent = 'Détails du Panier #' + panierId;
  document.getElementById('panierDetails').innerHTML = '<p style="text-align:center;padding:1rem;color:var(--pg-muted);">Contenu du panier chargement...</p>';
}

function closePanierModal() {
  document.getElementById('panierModal').style.display = 'none';
}

window.onclick = function(event) {
  const modal = document.getElementById('panierModal');
  if (event.target === modal) {
    modal.style.display = 'none';
  }
}
</script>
{% endblock %}
