{% extends 'back/base.html.twig' %}

{% block title %}Marketplace Dashboard - Admin{% endblock %}
{% block breadcrumb %}Marketplace Dashboard{% endblock %}

{% block content %}
<div style="padding:2rem;">
  <div style="margin-bottom:2rem;">
    <h2 style="font-size:1.5rem;color:var(--pg-text);margin:0 0 0.5rem 0;">Marketplace Dashboard</h2>
    <p style="color:var(--pg-muted);margin:0;">Visualisation et gestion complète du marketplace</p>
  </div>

  <!-- Stats Grid -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:1.5rem;margin-bottom:2rem;">
    <div style="background:var(--pg-surface2);padding:1.5rem;border-radius:8px;border-left:4px solid #5b6ef5;">
      <div style="font-size:2rem;font-weight:700;color:#5b6ef5;margin-bottom:0.5rem;">{{ stats.total_produits }}</div>
      <div style="font-size:0.85rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Produits Total</div>
    </div>
    <div style="background:var(--pg-surface2);padding:1.5rem;border-radius:8px;border-left:4px solid #06d6a0;">
      <div style="font-size:2rem;font-weight:700;color:#06d6a0;margin-bottom:0.5rem;">{{ stats.produits_dispo }}</div>
      <div style="font-size:0.85rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Disponibles</div>
    </div>
    <div style="background:var(--pg-surface2);padding:1.5rem;border-radius:8px;border-left:4px solid #8b5cf6;">
      <div style="font-size:2rem;font-weight:700;color:#8b5cf6;margin-bottom:0.5rem;">{{ stats.total_commandes }}</div>
      <div style="font-size:0.85rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Commandes Total</div>
    </div>
    <div style="background:var(--pg-surface2);padding:1.5rem;border-radius:8px;border-left:4px solid #fbbf24;">
      <div style="font-size:2rem;font-weight:700;color:#fbbf24;margin-bottom:0.5rem;">{{ stats.en_attente }}</div>
      <div style="font-size:0.85rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">En Attente</div>
    </div>
    <div style="background:var(--pg-surface2);padding:1.5rem;border-radius:8px;border-left:4px solid #34d399;">
      <div style="font-size:2rem;font-weight:700;color:#34d399;margin-bottom:0.5rem;">{{ stats.confirmees }}</div>
      <div style="font-size:0.85rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Confirmées</div>
    </div>
    <div style="background:var(--pg-surface2);padding:1.5rem;border-radius:8px;border-left:4px solid #f472b6;">
      <div style="font-size:2rem;font-weight:700;color:#f472b6;margin-bottom:0.5rem;">{{ stats.paniers_actifs }}</div>
      <div style="font-size:0.85rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Paniers Actifs</div>
    </div>
  </div>

  <!-- Main Grid -->
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;">
    <!-- Statuts Table -->
    <div class="dash-panel">
      <div style="padding:0 0 1rem 0;border-bottom:1px solid var(--pg-border);">
        <h3 style="margin:0;font-size:1.1rem;color:var(--pg-text);">Statuts des Commandes</h3>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;color:var(--pg-text);">
          <thead>
            <tr style="border-bottom:1px solid var(--pg-border);background:var(--pg-surface2);">
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Statut</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Nombre</th>
            </tr>
          </thead>
          <tbody>
            {% for statut, count in statuts %}
              <tr style="border-bottom:1px solid var(--pg-border);">
                <td style="padding:1rem;">
                  <span style="display:inline-block;background:rgba(91,110,245,0.15);color:#5b6ef5;padding:0.3rem 0.8rem;border-radius:4px;font-size:0.85rem;font-weight:700;text-transform:capitalize;">
                    {{ statut }}
                  </span>
                </td>
                <td style="padding:1rem;font-weight:700;">{{ count }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="dash-panel">
      <div style="padding:0 0 1rem 0;border-bottom:1px solid var(--pg-border);">
        <h3 style="margin:0;font-size:1.1rem;color:var(--pg-text);">Actions Rapides</h3>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.75rem;">
        <a href="{{ path('admin_marketplace_produits_new') }}" style="background:#5b6ef5;color:white;padding:0.75rem 1rem;border-radius:4px;text-decoration:none;font-weight:700;text-align:center;transition:background 0.2s;">+ Nouveau Produit</a>
        <a href="{{ path('admin_marketplace_produits_index') }}" style="background:#8b5cf6;color:white;padding:0.75rem 1rem;border-radius:4px;text-decoration:none;font-weight:700;text-align:center;transition:background 0.2s;">📋 Tous les Produits</a>
        <a href="{{ path('admin_marketplace_commandes_index') }}" style="background:#06d6a0;color:#000;padding:0.75rem 1rem;border-radius:4px;text-decoration:none;font-weight:700;text-align:center;transition:background 0.2s;">📦 Commandes</a>
        <a href="{{ path('admin_marketplace_paniers_index') }}" style="background:#fbbf24;color:#000;padding:0.75rem 1rem;border-radius:4px;text-decoration:none;font-weight:700;text-align:center;transition:background 0.2s;">🛒 Paniers</a>
      </div>
    </div>
  </div>
</div>
{% endblock %}
