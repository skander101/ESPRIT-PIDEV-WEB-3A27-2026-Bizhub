{% extends 'back/base.html.twig' %}

{% block title %}Gestion des Projets{% endblock %}
{% block breadcrumb %}Investissement / Projets{% endblock %}

{% block content %}
<div style="padding:2rem;">

  {# ── Dashboard stats ── #}
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem;">
    <div class="dash-panel" style="text-align:center;">
      <div style="font-size:2rem;font-weight:800;color:var(--nb-accent);">{{ total_projets }}</div>
      <div style="font-size:0.8rem;color:var(--pg-muted);margin-top:0.25rem;text-transform:uppercase;font-weight:600;">Total Projets</div>
    </div>
    <div class="dash-panel" style="text-align:center;">
      <div style="font-size:2rem;font-weight:800;color:#f97316;">{{ projets_attente }}</div>
      <div style="font-size:0.8rem;color:var(--pg-muted);margin-top:0.25rem;text-transform:uppercase;font-weight:600;">En attente</div>
    </div>
    <div class="dash-panel" style="text-align:center;">
      <div style="font-size:2rem;font-weight:800;color:#10b981;">{{ total_investments }}</div>
      <div style="font-size:0.8rem;color:var(--pg-muted);margin-top:0.25rem;text-transform:uppercase;font-weight:600;">Investissements</div>
    </div>
    <div class="dash-panel" style="text-align:center;">
      <div style="font-size:2rem;font-weight:800;color:#8b5cf6;">{{ montant_total|number_format(0, ',', ' ') }} TND</div>
      <div style="font-size:0.8rem;color:var(--pg-muted);margin-top:0.25rem;text-transform:uppercase;font-weight:600;">Montant total investi</div>
    </div>
  </div>

  {# ── Header ── #}
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
    <h2 style="font-size:1.4rem;color:var(--pg-text);margin:0;">Projets</h2>
  </div>

  {# ── Flash messages ── #}
  {% for type, messages in app.flashes %}
    {% for msg in messages %}
      <div style="padding:0.8rem 1.2rem;border-radius:6px;margin-bottom:1rem;background:{{ type == 'success' ? 'rgba(6,214,160,0.15)' : 'rgba(239,68,68,0.15)' }};color:{{ type == 'success' ? '#06d6a0' : '#f87171' }};border:1px solid {{ type == 'success' ? 'rgba(6,214,160,0.3)' : 'rgba(239,68,68,0.3)' }};">
        {{ msg }}
      </div>
    {% endfor %}
  {% endfor %}

  {# ── Table ── #}
  <div class="dash-panel" style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;">
      <thead>
        <tr style="border-bottom:1px solid var(--pg-border);">
          <th style="padding:0.8rem 1rem;text-align:left;font-size:0.75rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">#</th>
          <th style="padding:0.8rem 1rem;text-align:left;font-size:0.75rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Titre</th>
          <th style="padding:0.8rem 1rem;text-align:left;font-size:0.75rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Startup</th>
          <th style="padding:0.8rem 1rem;text-align:left;font-size:0.75rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Secteur</th>
          <th style="padding:0.8rem 1rem;text-align:left;font-size:0.75rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Budget</th>
          <th style="padding:0.8rem 1rem;text-align:left;font-size:0.75rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Statut</th>
          <th style="padding:0.8rem 1rem;text-align:left;font-size:0.75rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Créé le</th>
          <th style="padding:0.8rem 1rem;text-align:left;font-size:0.75rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for projet in projets %}
          {% set statusColor = {
            'pending':     '#f97316',
            'in_progress': '#3b82f6',
            'funded':      '#10b981',
            'completed':   '#6b7280'
          } %}
          {% set statusLabel = {
            'pending':     'En attente',
            'in_progress': 'En cours',
            'funded':      'Financé',
            'completed':   'Terminé'
          } %}
          <tr style="border-bottom:1px solid var(--pg-border);transition:background .15s;" onmouseover="this.style.background='var(--pg-surface2)'" onmouseout="this.style.background=''">
            <td style="padding:0.9rem 1rem;color:var(--pg-muted);font-size:0.85rem;">{{ projet.project_id }}</td>
            <td style="padding:0.9rem 1rem;">
              <a href="{{ path('app_admin_projet_show', {id: projet.project_id}) }}" style="color:var(--pg-text);font-weight:600;text-decoration:none;">
                {{ projet.title|length > 40 ? projet.title|slice(0, 40) ~ '…' : projet.title }}
              </a>
            </td>
            <td style="padding:0.9rem 1rem;color:var(--pg-muted);font-size:0.9rem;">
              {{ projet.user ? projet.user.fullName : '—' }}
            </td>
            <td style="padding:0.9rem 1rem;color:var(--pg-muted);font-size:0.9rem;text-transform:capitalize;">{{ projet.secteur ?? '—' }}</td>
            <td style="padding:0.9rem 1rem;color:var(--pg-text);font-size:0.9rem;">{{ projet.requiredBudget|number_format(0, ',', ' ') }} TND</td>
            <td style="padding:0.9rem 1rem;">
              <span style="display:inline-block;padding:0.25rem 0.7rem;border-radius:4px;font-size:0.78rem;font-weight:700;background:{{ statusColor[projet.status] ?? '#6b7280' }}22;color:{{ statusColor[projet.status] ?? '#6b7280' }};">
                {{ statusLabel[projet.status] ?? projet.status }}
              </span>
            </td>
            <td style="padding:0.9rem 1rem;color:var(--pg-muted);font-size:0.85rem;">
              {{ projet.createdAt ? projet.createdAt|date('d/m/Y') : '—' }}
            </td>
            <td style="padding:0.9rem 1rem;">
              <a href="{{ path('app_admin_projet_show', {id: projet.project_id}) }}" style="background:var(--nb-accent);color:#fff;padding:0.35rem 0.8rem;border-radius:5px;font-size:0.8rem;text-decoration:none;font-weight:600;">Voir</a>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="8" style="padding:2rem;text-align:center;color:var(--pg-muted);">Aucun projet trouvé.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
