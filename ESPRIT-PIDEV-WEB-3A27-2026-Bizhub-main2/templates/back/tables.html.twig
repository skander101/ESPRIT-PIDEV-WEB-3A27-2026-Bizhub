        <div class="nb-badge"></div>
      </div>
      <div class="nb-icon-btn" title="Messages">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.8">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <div class="nb-badge blue"></div>
      </div>
      <div class="nb-divider"></div>
      <div class="nb-user-pill" id="nbUserPill" onclick="nbToggleDropdown()">
        <div class="nb-avatar">AJ</div>
