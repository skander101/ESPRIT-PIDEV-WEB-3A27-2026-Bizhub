<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="shortcut icon" href="{{ asset('assets/back/images/favicon.svg') }}" type="image/x-icon" />
  <title>Tables | BizHub</title>
  <link rel="stylesheet" href="{{ asset('assets/back/css/bootstrap.min.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/lineicons.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/materialdesignicons.min.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/main.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/custom.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/dark-mode.css') }}" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>

  <style>
    /* ═══════════════════════════════════════
       GLOBAL TOKENS
    ═══════════════════════════════════════ */
    :root {
      --nb-bg:      #0f1117;
      --nb-surface: #1a1d27;
      --nb-border:  #2a2d3a;
      --nb-accent:  #5b6ef5;
      --nb-accent2: #8b5cf6;
      --nb-accent3: #06d6a0;
      --nb-text:    #e2e8f0;
      --nb-muted:   #64748b;
      --nb-hover:   #242736;

      --pg-bg:      #080b12;
      --pg-surface: #0e1220;
      --pg-surface2:#141826;
      --pg-border:  rgba(255,255,255,0.07);
      --pg-border2: rgba(255,255,255,0.12);
      --pg-text:    #f0f2ff;
      --pg-muted:   #6b7280;
      --pg-muted2:  #9ca3af;
    }

    *, *::before, *::after { box-sizing: border-box; }

    body.dark-mode {
      background: var(--pg-bg) !important;
      font-family: 'DM Sans', sans-serif;
    }

    /* ── Preloader ── */
    #preloader {
      position: fixed; inset: 0; z-index: 9999;
      background: var(--pg-bg);
      display: flex; align-items: center; justify-content: center;
      transition: opacity .5s ease;
    }
    #preloader.hidden { opacity: 0; pointer-events: none; }
    .spinner {
      width: 36px; height: 36px;
      border: 2px solid rgba(255,255,255,.08);
      border-top-color: var(--nb-accent);
      border-radius: 50%;
      animation: spin .8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ═══════════════════════════════════════
       NEW NAVBAR
    ═══════════════════════════════════════ */
    .plain-navbar {
      width: 100%;
      background: var(--nb-bg);
      border-bottom: 1px solid var(--nb-border);
      display: flex;
      align-items: center;
      height: 64px;
      padding: 0 1.5rem;
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1100;
      font-family: 'DM Sans', sans-serif;
    }
    .plain-navbar::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, var(--nb-accent), var(--nb-accent2), transparent);
      opacity: .5;
    }

    /* Left */
    .nb-left { display: flex; align-items: center; gap: 14px; flex: 0 0 auto; }
    .nb-logo {
      width: 38px; height: 38px; border-radius: 10px;
      background: linear-gradient(135deg, var(--nb-accent), var(--nb-accent2));
      display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
    }
    .nb-site-title {
      font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700;
      color: var(--nb-text); letter-spacing: -.3px;
    }
    .nb-site-title span { color: var(--nb-accent); font-weight: 400; }

    .nb-breadcrumb {
      display: flex; align-items: center; gap: 7px;
      margin-left: 18px; padding-left: 18px;
      border-left: 1px solid var(--nb-border);
    }
    .nb-breadcrumb a {
      font-size: 13px; color: var(--nb-muted); text-decoration: none; transition: color .2s;
    }
    .nb-breadcrumb a:hover { color: var(--nb-text); }
    .nb-breadcrumb .sep { color: var(--nb-border); }
    .nb-breadcrumb .current { font-size: 13px; color: var(--nb-text); font-weight: 500; }

    /* Center */
    .nb-center { flex: 1; display: flex; justify-content: center; }
    .nb-search { position: relative; width: 280px; }
    .nb-search svg {
      position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
      opacity: .4; pointer-events: none;
    }
    .nb-search input {
      width: 100%; height: 38px;
      background: var(--nb-surface); border: 1px solid var(--nb-border);
      border-radius: 9px; color: var(--nb-text);
      font-size: 13px; font-family: 'DM Sans', sans-serif;
      padding: 0 12px 0 36px; outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .nb-search input::placeholder { color: var(--nb-muted); }
    .nb-search input:focus {
      border-color: var(--nb-accent);
      box-shadow: 0 0 0 3px rgba(91,110,245,.12);
    }

    /* Right */
    .nb-right { display: flex; align-items: center; gap: 6px; flex: 0 0 auto; }

    .nb-icon-btn {
      width: 38px; height: 38px; border-radius: 9px;
      background: var(--nb-surface); border: 1px solid var(--nb-border);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background .2s, border-color .2s; position: relative;
    }
    .nb-icon-btn:hover { background: var(--nb-hover); border-color: #3a3d50; }
    .nb-icon-btn svg { opacity: .7; transition: opacity .2s; }
    .nb-icon-btn:hover svg { opacity: 1; }
    .nb-badge {
      position: absolute; top: 6px; right: 6px;
      width: 7px; height: 7px; border-radius: 50%;
      background: #ef4444; border: 1.5px solid var(--nb-bg);
    }
    .nb-badge.blue { background: var(--nb-accent); }

    .nb-quick-actions {
      display: flex; align-items: center; gap: 3px;
      background: var(--nb-surface); border: 1px solid var(--nb-border);
      border-radius: 9px; padding: 3px;
    }
    .nb-qa-btn {
      padding: 5px 11px; border-radius: 6px; font-size: 12px; font-weight: 500;
      color: var(--nb-muted); cursor: pointer; transition: all .2s; white-space: nowrap;
      border: none; background: transparent; font-family: 'DM Sans', sans-serif;
    }
    .nb-qa-btn:hover { color: var(--nb-text); background: var(--nb-hover); }
    .nb-qa-btn.active { color: #fff; background: var(--nb-accent); }

    .nb-divider { width: 1px; height: 22px; background: var(--nb-border); margin: 0 4px; }

    .nb-toggle-wrap {
      display: flex; align-items: center; gap: 8px;
      background: var(--nb-surface); border: 1px solid var(--nb-border);
      border-radius: 9px; padding: 5px 11px; cursor: pointer; transition: border-color .2s;
    }
    .nb-toggle-wrap:hover { border-color: #3a3d50; }
    .nb-toggle-label { font-size: 12px; color: var(--nb-muted); font-weight: 500; }
    .nb-toggle {
      width: 30px; height: 16px; background: #2a2d3a; border-radius: 20px;
      position: relative; transition: background .3s;
    }
    .nb-toggle.on { background: var(--nb-accent); }
    .nb-toggle-knob {
      width: 12px; height: 12px; background: #fff; border-radius: 50%;
      position: absolute; top: 2px; left: 2px; transition: transform .3s;
    }
    .nb-toggle.on .nb-toggle-knob { transform: translateX(14px); }

    .nb-user-pill {
      display: flex; align-items: center; gap: 9px;
      background: var(--nb-surface); border: 1px solid var(--nb-border);
      border-radius: 9px; padding: 4px 10px 4px 6px;
      cursor: pointer; transition: border-color .2s, background .2s; position: relative;
    }
    .nb-user-pill:hover { border-color: #3a3d50; background: var(--nb-hover); }
    .nb-avatar {
      width: 28px; height: 28px; border-radius: 7px;
      background: linear-gradient(135deg, var(--nb-accent), var(--nb-accent2));
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 600; color: #fff; flex-shrink: 0;
    }
    .nb-user-info { display: flex; flex-direction: column; line-height: 1.2; }
    .nb-user-name { font-size: 13px; font-weight: 500; color: var(--nb-text); }
    .nb-user-role { font-size: 11px; color: var(--nb-muted); }
    .nb-chevron { opacity: .4; transition: opacity .2s, transform .3s; }
    .nb-user-pill:hover .nb-chevron { opacity: .8; }
    .nb-user-pill.open .nb-chevron { transform: rotate(180deg); }

    .nb-dropdown {
      position: absolute; top: calc(100% + 8px); right: 0;
      background: var(--nb-surface); border: 1px solid var(--nb-border);
      border-radius: 11px; width: 185px; overflow: hidden;
      opacity: 0; transform: translateY(-6px); pointer-events: none;
      transition: opacity .2s, transform .2s; z-index: 999;
      box-shadow: 0 10px 30px rgba(0,0,0,.5);
    }
    .nb-dropdown.open { opacity: 1; transform: translateY(0); pointer-events: all; }
    .nb-dd-item {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 14px; font-size: 13px; color: var(--nb-muted);
      cursor: pointer; transition: background .15s, color .15s;
    }
    .nb-dd-item:hover { background: var(--nb-hover); color: var(--nb-text); }
    .nb-dd-item.danger:hover { color: #ef4444; }
    .nb-dd-sep { height: 1px; background: var(--nb-border); margin: 2px 0; }

    /* ═══════════════════════════════════════
       LAYOUT
    ═══════════════════════════════════════ */
    .page-wrapper {
      display: flex;
      padding-top: 64px; /* navbar height */
      min-height: 100vh;
    }

    /* Keep existing sidebar, just adjust top */
    .sidebar-nav-wrapper {
      position: fixed !important;
      top: 64px !important;
      height: calc(100vh - 64px) !important;
    }

    .main-wrapper {
      margin-left: 260px; /* sidebar width */
      flex: 1;
      min-height: calc(100vh - 64px);
      background: var(--pg-bg);
      padding: 0;
    }

    /* ═══════════════════════════════════════
       TABLE PAGE STYLES
    ═══════════════════════════════════════ */

    /* Hero header */
    .table-page-hero {
      padding: 2.5rem 2rem 1.5rem;
      border-bottom: 1px solid var(--pg-border2);
      display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;
      flex-wrap: wrap;
    }
    .table-hero-badge {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(91,110,245,.1); border: 1px solid rgba(91,110,245,.2);
      border-radius: 6px; padding: 3px 12px;
      font-size: 11px; font-weight: 500; color: #a5b4fc;
      letter-spacing: .5px; text-transform: uppercase; margin-bottom: .75rem;
    }
    .table-page-hero h1 {
      font-family: 'Syne', sans-serif; font-size: 1.8rem; font-weight: 800;
      color: var(--pg-text); letter-spacing: -.4px; margin-bottom: .4rem; margin-top: 0;
    }
    .table-page-hero > div > p {
      font-size: 14px; color: var(--pg-muted2); font-weight: 300; margin: 0;
    }
    .hero-actions { display: flex; gap: 10px; align-items: center; margin-top: .25rem; }

    .btn-outline-nb {
      height: 40px; padding: 0 18px;
      background: var(--pg-surface); border: 1px solid var(--pg-border2);
      border-radius: 9px; color: var(--pg-muted2);
      font-size: 13px; font-weight: 500; font-family: 'DM Sans', sans-serif;
      cursor: pointer; transition: all .2s; display: flex; align-items: center; gap: 7px;
    }
    .btn-outline-nb:hover { border-color: rgba(255,255,255,.22); color: var(--pg-text); }

    .btn-accent-nb {
      height: 40px; padding: 0 18px;
      background: linear-gradient(135deg, var(--nb-accent), var(--nb-accent2));
      border: none; border-radius: 9px; color: #fff;
      font-size: 13px; font-weight: 600; font-family: 'Syne', sans-serif;
      cursor: pointer; transition: all .2s; display: flex; align-items: center; gap: 7px;
      box-shadow: 0 3px 14px rgba(91,110,245,.3);
    }
    .btn-accent-nb:hover { opacity: .9; transform: translateY(-1px); }

    /* Content area */
    .table-content { padding: 2rem; }

    /* Stat cards row */
    .stat-row {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 2rem;
    }
    .stat-card {
      background: var(--pg-surface); border: 1px solid var(--pg-border2);
      border-radius: 12px; padding: 1.1rem 1.25rem;
      position: relative; overflow: hidden;
    }
    .stat-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--nb-accent), var(--nb-accent2));
      opacity: 0; transition: opacity .3s;
    }
    .stat-card:hover::before { opacity: 1; }
    .stat-card-label { font-size: 12px; color: var(--pg-muted); font-weight: 500; margin-bottom: 8px; letter-spacing: .3px; }
    .stat-card-val {
      font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 700; color: var(--pg-text); margin-bottom: 4px;
    }
    .stat-card-sub { font-size: 12px; color: var(--nb-accent3); }

    /* Table card */
    .tbl-card {
      background: var(--pg-surface); border: 1px solid var(--pg-border2);
      border-radius: 14px; overflow: hidden; margin-bottom: 2rem;
    }
    .tbl-card-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--pg-border2);
      flex-wrap: wrap; gap: 12px;
    }
    .tbl-card-title {
      font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700;
      color: var(--pg-text); margin: 0;
    }
    .tbl-card-sub { font-size: 13px; color: var(--pg-muted); margin: 2px 0 0; }
    .tbl-tools { display: flex; gap: 10px; align-items: center; }

    .tbl-search {
      position: relative;
    }
    .tbl-search svg {
      position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
      opacity: .4; pointer-events: none;
    }
    .tbl-search input {
      height: 36px; width: 210px;
      background: var(--pg-bg); border: 1px solid var(--pg-border2);
      border-radius: 8px; color: var(--pg-text);
      font-size: 13px; font-family: 'DM Sans', sans-serif;
      padding: 0 12px 0 32px; outline: none; transition: border-color .2s;
    }
    .tbl-search input::placeholder { color: var(--pg-muted); }
    .tbl-search input:focus { border-color: var(--nb-accent); }

    .tbl-filter-btn {
      height: 36px; padding: 0 14px;
      background: var(--pg-bg); border: 1px solid var(--pg-border2);
      border-radius: 8px; color: var(--pg-muted2);
      font-size: 13px; font-family: 'DM Sans', sans-serif;
      cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all .2s;
    }
    .tbl-filter-btn:hover { border-color: rgba(255,255,255,.2); color: var(--pg-text); }

    /* Tables */
    .tbl-wrap { overflow-x: auto; }

    .nb-table {
      width: 100%; border-collapse: collapse;
      font-size: 13.5px;
    }
    .nb-table thead tr {
      border-bottom: 1px solid var(--pg-border2);
    }
    .nb-table thead th {
      padding: 12px 16px;
      font-size: 11px; font-weight: 600; color: var(--pg-muted);
      text-transform: uppercase; letter-spacing: .7px;
      text-align: left; white-space: nowrap;
      background: var(--pg-bg);
    }
    .nb-table tbody tr {
      border-bottom: 1px solid var(--pg-border);
      transition: background .15s;
    }
    .nb-table tbody tr:last-child { border-bottom: none; }
    .nb-table tbody tr:hover { background: rgba(255,255,255,.03); }
    .nb-table tbody td {
      padding: 13px 16px;
      color: var(--pg-muted2); vertical-align: middle;
    }
    .nb-table tbody td:first-child { color: var(--pg-text); font-weight: 500; }

    /* Status badges */
    .nb-badge-status {
      display: inline-block; padding: 3px 11px;
      border-radius: 100px; font-size: 11px; font-weight: 600;
      letter-spacing: .3px;
    }
    .nb-badge-status.active  { background: rgba(6,214,160,.12); color: #06d6a0; }
    .nb-badge-status.pending { background: rgba(91,110,245,.12); color: #818cf8; }
    .nb-badge-status.done    { background: rgba(99,214,6,.12);   color: #84cc16; }
    .nb-badge-status.close   { background: rgba(239,68,68,.12);  color: #f87171; }
    .nb-badge-status.info    { background: rgba(14,165,233,.12); color: #38bdf8; }

    /* Action btn */
    .tbl-action-btn {
      width: 30px; height: 30px; border-radius: 7px;
      background: rgba(239,68,68,.08); border: 1px solid rgba(239,68,68,.15);
      color: #f87171; cursor: pointer; transition: all .2s;
      display: flex; align-items: center; justify-content: center; font-size: 14px;
    }
    .tbl-action-btn:hover { background: rgba(239,68,68,.15); border-color: rgba(239,68,68,.3); }

    /* User cell */
    .tbl-user { display: flex; align-items: center; gap: 10px; }
    .tbl-avatar {
      width: 32px; height: 32px; border-radius: 8px; overflow: hidden; flex-shrink: 0;
    }
    .tbl-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .tbl-avatar-initials {
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, var(--nb-accent), var(--nb-accent2));
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 600; color: #fff; flex-shrink: 0;
    }
    .tbl-email { color: var(--pg-muted) !important; font-weight: 400 !important; }

    /* Checkbox */
    .nb-check {
      width: 15px; height: 15px; accent-color: var(--nb-accent); cursor: pointer;
    }

    /* Grid of 2 tables */
    .tbl-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }

    /* Footer */
    .nb-footer {
      padding: 1.25rem 2rem;
      border-top: 1px solid var(--pg-border2);
      display: flex; align-items: center; justify-content: space-between;
      font-size: 12px; color: var(--pg-muted);
    }
    .nb-footer a { color: var(--pg-muted); text-decoration: none; transition: color .2s; margin-left: 16px; }
    .nb-footer a:hover { color: var(--pg-text); }

    /* Pagination */
    .tbl-pagination {
      display: flex; align-items: center; justify-content: flex-end; gap: 6px;
      padding: 12px 1.5rem; border-top: 1px solid var(--pg-border);
    }
    .pg-btn {
      width: 30px; height: 30px; border-radius: 7px;
      background: transparent; border: 1px solid var(--pg-border2);
      color: var(--pg-muted2); font-size: 12px; cursor: pointer; transition: all .2s;
      display: flex; align-items: center; justify-content: center;
    }
    .pg-btn:hover { border-color: var(--nb-accent); color: var(--nb-accent); }
    .pg-btn.active { background: var(--nb-accent); border-color: var(--nb-accent); color: #fff; font-weight: 600; }

    @media (max-width: 1100px) { .stat-row { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 768px) {
      .main-wrapper { margin-left: 0; }
      .tbl-grid { grid-template-columns: 1fr; }
      .stat-row { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
