  <script>
    /* Preloader */
    window.addEventListener('load', () => {
      setTimeout(() => document.getElementById('preloader').classList.add('hidden'), 400);
    });

    /* Navbar: quick actions */
    function nbSetActive(el) {
      el.closest('.nb-quick-actions').querySelectorAll('.nb-qa-btn').forEach(b => b.classList.remove('active'));
      el.classList.add('active');
    }

    /* Dark / Light toggle */
    let nbDark = true;
    function nbToggleDark() {
      nbDark = !nbDark;
      document.getElementById('nbToggle').classList.toggle('on', nbDark);
      document.getElementById('nbToggleLabel').textContent = nbDark ? 'Sombre' : 'Clair';
    }

    /* Dropdown */
    let nbDdOpen = false;
    function nbToggleDropdown() {
      nbDdOpen = !nbDdOpen;
      document.getElementById('nbDropdown').classList.toggle('open', nbDdOpen);
      document.getElementById('nbUserPill').classList.toggle('open', nbDdOpen);
    }
    document.addEventListener('click', function(e) {
      const pill = document.getElementById('nbUserPill');
      if (pill && !pill.contains(e.target)) {
        nbDdOpen = false;
        document.getElementById('nbDropdown').classList.remove('open');
        pill.classList.remove('open');
      }
    });

    /* Table search filter */
    function filterTable(query) {
      const rows = document.querySelectorAll('#contactTable tbody tr');
      const q = query.toLowerCase();
      rows.forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    }

    /* Select all checkboxes */
    function toggleAll(master) {
      document.querySelectorAll('.row-check').forEach(cb => cb.checked = master.checked);
    }

    /* Pagination */
    document.querySelectorAll('.pg-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.pg-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
      });
    });
  </script>
