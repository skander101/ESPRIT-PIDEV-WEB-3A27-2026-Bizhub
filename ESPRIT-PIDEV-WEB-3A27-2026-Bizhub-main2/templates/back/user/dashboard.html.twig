{% extends 'back/base.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block breadcrumb %}Dashboard{% endblock %}

{% block content %}
<div style="padding:2rem;">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;margin-bottom:2rem;">
        <div class="dash-stat">
            <div class="dash-stat-icon"><i class="mdi mdi-account-multiple"></i></div>
            <div>
                <div class="dash-stat-num">{{ total_users }}</div>
                <div class="dash-stat-label">Total Users</div>
            </div>
        </div>
        <div class="dash-stat">
            <div class="dash-stat-icon"><i class="mdi mdi-star"></i></div>
            <div>
                <div class="dash-stat-num">{{ total_avis }}</div>
                <div class="dash-stat-label">Total Reviews</div>
            </div>
        </div>
        <div class="dash-stat">
            <div class="dash-stat-icon"><i class="mdi mdi-check-circle"></i></div>
            <div>
                <div class="dash-stat-num">{{ verified_avis }}</div>
                <div class="dash-stat-label">Verified Reviews</div>
            </div>
        </div>
        <div class="dash-stat">
            <div class="dash-stat-icon"><i class="mdi mdi-account-check"></i></div>
            <div>
                <div class="dash-stat-num">{{ active_users }}</div>
                <div class="dash-stat-label">Active Users</div>
            </div>
        </div>
    </div>

    <div class="dash-grid">
        <div class="dash-panel">
            <h5>Recent Users</h5>
            {% if recent_users %}
                <div style="display:flex;flex-direction:column;gap:0.5rem;">
                    {% for user in recent_users|slice(0, 5) %}
                        <a href="{{ path('app_admin_user_show', {'id': user.userId}) }}" style="display:flex;align-items:center;gap:0.8rem;padding:0.8rem;background:rgba(255,190,51,0.05);border-radius:6px;text-decoration:none;color:var(--dark);transition:background 0.2s;">
                            <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:0.9rem;">
                                {{ user.fullName|first|upper }}
                            </div>
                            <div style="flex:1;">
                                <div style="font-weight:700;font-size:0.9rem;">{{ user.fullName }}</div>
                                <div style="font-size:0.8rem;color:#666;">{{ user.userType }}</div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p style="color:#666;font-size:0.9rem;padding:1rem;text-align:center;">No users yet</p>
            {% endif %}
        </div>

        <div class="dash-panel">
            <h5>Quick Actions</h5>
            <a href="{{ path('app_admin_user_index') }}" class="quick-link">
                <div class="quick-link-icon"><i class="mdi mdi-account-multiple"></i></div> Manage Users
            </a>
            <a href="#" class="quick-link">
                <div class="quick-link-icon"><i class="mdi mdi-star"></i></div> Review Moderations
            </a>
            <a href="{{ path('app_user_profile') }}" class="quick-link">
                <div class="quick-link-icon"><i class="mdi mdi-account"></i></div> My Profile
            </a>
            <a href="{{ path('app_logout') }}" class="quick-link">
                <div class="quick-link-icon"><i class="mdi mdi-logout"></i></div> Logout
            </a>
        </div>
    </div>
</div>
{% endblock %}
