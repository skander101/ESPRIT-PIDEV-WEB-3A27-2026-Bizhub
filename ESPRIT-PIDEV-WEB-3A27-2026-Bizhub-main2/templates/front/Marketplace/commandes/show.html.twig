{% extends 'front/Marketplace/base_marketplace.html.twig' %}

{% block title %}Commande #{{ commande.idCommande }}{% endblock %}
{% block hero_eyebrow %}Détails{% endblock %}
{% block hero_title %}Commande <span>#{{ commande.idCommande }}</span>{% endblock %}
{% block breadcrumb_extra %}
  <i class="fa fa-chevron-right" style="font-size:.55rem"></i> Détails
{% endblock %}

{% block body %}
<div style="max-width:1000px; margin:0 auto; padding:60px 5%;">

  {# HEADER #}
  <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:2rem; flex-wrap:wrap; gap:1rem;">
    <div>
      <h2 style="font-family:'Lora',serif; font-weight:700; font-size:1.5rem; margin-bottom:0.5rem;">Commande #{{ commande.idCommande }}</h2>
      <div style="display:flex; gap:2rem; font-size:0.9rem; color:var(--muted);">
        <span><i class="fa fa-calendar"></i> {{ commande.dateCommande|date('d/m/Y H:i') }}</span>
        <span><i class="fa fa-package"></i> {{ commande.lignes|length }} article{{ commande.lignes|length != 1 ? 's' : '' }}</span>
      </div>
    </div>
    <a href="{{ app.user.userType == 'investisseur' ? path('commande_investisseur_recues') : path('commande_index') }}" class="btn-outline">
      <i class="fa fa-arrow-left"></i> Retour
    </a>
  </div>

  {# INFO COMMANDE #}
  <div style="background:var(--white); border-radius:14px; border:1.5px solid var(--border); overflow:hidden; margin-bottom:2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.07);">
    <div style="padding:24px; display:grid; grid-template-columns:1fr 1fr 1fr; gap:1.5rem; border-bottom:1px solid var(--border);">
      <div>
        <div style="font-family:'Josefin Sans',sans-serif; font-size:0.7rem; font-weight:700; color:var(--muted); text-transform:uppercase; margin-bottom:8px; letter-spacing:0.1em;">Statut</div>
        {% set sl = commande.statut|trim|lower %}
        <span style="display:inline-flex; align-items:center; gap:4px; padding:8px 12px; border-radius:6px; background:{{ sl == 'en_attente' ? 'rgba(255,193,7,0.12)' : (sl == 'confirmee' ? 'rgba(34,197,94,0.12)' : (sl == 'livree' ? 'rgba(13,110,253,0.12)' : 'rgba(220,53,69,0.12)')) }}; color:{{ sl == 'en_attente' ? '#92400e' : (sl == 'confirmee' ? '#15803d' : (sl == 'livree' ? '#084298' : '#991b1b')) }}; font-size:0.85rem; font-weight:700; text-transform:uppercase;">
          <i class="fa fa-{{ sl == 'en_attente' ? 'clock' : (sl == 'confirmee' ? 'check-circle' : (sl == 'livree' ? 'truck' : 'times-circle')) }}"></i>
          {{ commande.statut }}
        </span>
      </div>
      <div>
        <div style="font-family:'Josefin Sans',sans-serif; font-size:0.7rem; font-weight:700; color:var(--muted); text-transform:uppercase; margin-bottom:8px; letter-spacing:0.1em;">Paiement</div>
        <span style="display:inline-flex; align-items:center; gap:4px; padding:8px 12px; border-radius:6px; background:{{ commande.estPayee ? 'rgba(34,197,94,0.12)' : 'rgba(255,193,7,0.12)' }}; color:{{ commande.estPayee ? '#15803d' : '#92400e' }}; font-size:0.85rem; font-weight:700; text-transform:uppercase;">
          <i class="fa fa-{{ commande.estPayee ? 'check-circle' : 'hourglass' }}"></i>
          {{ commande.estPayee ? 'Payée' : 'En attente' }}
        </span>
      </div>
      <div>
        <div style="font-family:'Josefin Sans',sans-serif; font-size:0.7rem; font-weight:700; color:var(--muted); text-transform:uppercase; margin-bottom:8px; letter-spacing:0.1em;">Montant Total</div>
        <div style="font-family:'Josefin Sans',sans-serif; font-size:1.3rem; font-weight:800; color:var(--primary);">
          {{ commande.totalTtc }} <span style="font-size:0.8rem; color:var(--muted);">TND</span>
        </div>
      </div>
    </div>

    <div style="padding:20px; background:var(--light-bg);">
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:1rem; font-size:0.9rem;">
        <div>
          <span style="color:var(--muted); font-family:'Josefin Sans',sans-serif;">Total HT:</span>
          <span style="font-weight:700; margin-left:0.5rem;">{{ commande.totalHt }} TND</span>
        </div>
        <div>
          <span style="color:var(--muted); font-family:'Josefin Sans',sans-serif;">TVA (19%):</span>
          <span style="font-weight:700; margin-left:0.5rem;">{{ commande.totalTva }} TND</span>
        </div>
        <div>
          <span style="color:var(--muted); font-family:'Josefin Sans',sans-serif;">TTC:</span>
          <span style="font-weight:700; margin-left:0.5rem; color:var(--primary);">{{ commande.totalTtc }} TND</span>
        </div>
      </div>
    </div>
  </div>

  {# ARTICLES #}
  <div style="background:var(--white); border-radius:14px; border:1.5px solid var(--border); overflow:hidden; margin-bottom:2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.07);">
    <div style="padding:24px; border-bottom:1px solid var(--border);">
      <h3 style="font-family:'Lora',serif; font-size:1.1rem; font-weight:700; margin-bottom:1.5rem;">Articles commandés</h3>

      <table style="width:100%; border-collapse:collapse;">
        <thead>
          <tr style="background:var(--light-bg); border-bottom:1px solid var(--border);">
            <th style="padding:12px; text-align:left; font-family:'Josefin Sans',sans-serif; font-size:0.7rem; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em;">Produit</th>
            <th style="padding:12px; text-align:center; font-family:'Josefin Sans',sans-serif; font-size:0.7rem; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em;">Quantité</th>
            <th style="padding:12px; text-align:center; font-family:'Josefin Sans',sans-serif; font-size:0.7rem; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em;">Prix Unit. HT</th>
            <th style="padding:12px; text-align:right; font-family:'Josefin Sans',sans-serif; font-size:0.7rem; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em;">Total HT</th>
          </tr>
        </thead>
        <tbody>
          {% for detail in lignes_detail %}
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:16px; font-weight:600;">
                {% if detail.produit %}
                  <div style="font-weight:700;">{{ detail.produit.nom }}</div>
                  {% if detail.produit.categorie %}<div style="font-size:0.8rem; color:var(--muted);">{{ detail.produit.categorie }}</div>{% endif %}
                {% else %}
                  <div style="color:#999; font-style:italic;">Produit supprimé</div>
                {% endif %}
              </td>
              <td style="padding:16px; text-align:center; font-family:'Josefin Sans',sans-serif; font-weight:700;">{{ detail.ligne.quantite }}</td>
              <td style="padding:16px; text-align:center;">{{ detail.ligne.prixHtUnitaire }} TND</td>
              <td style="padding:16px; text-align:right; font-family:'Josefin Sans',sans-serif; font-weight:800;">{{ (detail.ligne.prixHtUnitaire|number_format(3, '.', '') * detail.ligne.quantite)|number_format(3, '.', '') }} TND</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  {# ACTIONS #}
  <div style="display:flex; gap:1rem; flex-wrap:wrap;">
    {% if app.user.userType == 'investisseur' %}
      {% if commande.statut == 'en_attente' %}
        <form method="POST" action="{{ path('commande_confirmer', {id: commande.idCommande}) }}"
              data-confirm="Confirmer la commande #{{ commande.idCommande }} ? Le stock des produits sera décrémenté automatiquement."
              data-confirm-type="success">
          <input type="hidden" name="_token" value="{{ csrf_token('confirmer_' ~ commande.idCommande) }}">
          <button type="submit" class="btn-yellow" style="justify-content:center;">
            <i class="fa fa-check-circle"></i> Confirmer la commande
          </button>
        </form>
        <form method="POST" action="{{ path('commande_refuser', {id: commande.idCommande}) }}"
              data-confirm="Annuler la commande #{{ commande.idCommande }} ? Elle sera marquée comme annulée."
              data-confirm-type="danger">
          <input type="hidden" name="_token" value="{{ csrf_token('refuser_' ~ commande.idCommande) }}">
          <button type="submit" class="btn-danger" style="justify-content:center;">
            <i class="fa fa-times-circle"></i> Annuler la commande
          </button>
        </form>
      {% elseif commande.statut == 'confirmee' %}
        <form method="POST" action="{{ path('commande_livrer', {id: commande.idCommande}) }}"
              data-confirm="Marquer la commande #{{ commande.idCommande }} comme livrée ? Le client sera notifié du changement de statut."
              data-confirm-type="deliver">
          <input type="hidden" name="_token" value="{{ csrf_token('livrer_' ~ commande.idCommande) }}">
          <button type="submit" style="background:#0d6efd; color:white; border:none; padding:12px 24px; border-radius:8px; cursor:pointer; font-weight:700; font-family:'Josefin Sans',sans-serif; font-size:0.82rem; text-transform:uppercase; letter-spacing:0.08em; display:inline-flex; align-items:center; gap:8px; transition:background 0.2s;">
            <i class="fa fa-truck"></i> Marquer comme livrée
          </button>
        </form>
      {% else %}
        <div style="padding:12px 24px; background:var(--light-bg); border-radius:8px; color:var(--muted); font-weight:700;">
          <i class="fa fa-info-circle"></i> Commande traitée — aucune action possible
        </div>
      {% endif %}
    {% elseif app.user.userType == 'startup' %}
      {% if commande.statut == 'en_attente' %}
        <form method="POST" action="{{ path('commande_annuler', {id: commande.idCommande}) }}"
              data-confirm="Annuler la commande #{{ commande.idCommande }} ? Cette action est irréversible."
              data-confirm-type="warning">
          <input type="hidden" name="_token" value="{{ csrf_token('annuler_' ~ commande.idCommande) }}">
          <button type="submit" class="btn-danger" style="justify-content:center;">
            <i class="fa fa-times-circle"></i> Annuler la commande
          </button>
        </form>
      {% else %}
        <div style="padding:12px 24px; background:var(--light-bg); border-radius:8px; color:var(--muted); font-weight:700;">
          <i class="fa fa-info-circle"></i> Commande traitée — aucune action possible
        </div>
      {% endif %}
    {% endif %}
  </div>

</div>
{% endblock %}
