{% extends 'front/base.html.twig' %}

{% block title %}Edit Review - BizHub{% endblock %}

{% block content %}
<div style="max-width:800px;margin:0 auto;padding:40px 5%;">
    <a href="{{ path('app_avis_show', {'id': avis.avisId}) }}" style="color:var(--primary);text-decoration:none;font-weight:700;margin-bottom:1.5rem;display:inline-flex;align-items:center;gap:0.5rem;">
        <i class="fa fa-arrow-left"></i> Back to Review
    </a>

    <h2 style="font-size:1.8rem;color:var(--dark);margin-bottom:0.5rem;font-family:'Lora',serif;">Edit Your Review</h2>
    <p style="color:var(--text-muted);margin-bottom:2rem;">Update your feedback and rating</p>

    <div class="biz-form">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="form-group">
            {{ form_label(form.formation) }}
            {{ form_widget(form.formation) }}
            {% if form.formation.vars.errors|length %}
                <div style="color:#c33;font-size:0.85rem;margin-top:0.4rem;">
                    {% for error in form.formation.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="form-group">
            {{ form_label(form.rating) }}
            {{ form_widget(form.rating) }}
            {% if form.rating.vars.errors|length %}
                <div style="color:#c33;font-size:0.85rem;margin-top:0.4rem;">
                    {% for error in form.rating.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="form-group">
            {{ form_label(form.comment) }}
            {{ form_widget(form.comment) }}
            <p style="font-size:0.8rem;color:var(--text-muted);margin-top:0.4rem;">Max 1000 characters</p>
            {% if form.comment.vars.errors|length %}
                <div style="color:#c33;font-size:0.85rem;margin-top:0.4rem;">
                    {% for error in form.comment.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="form-group">
                {{ form_label(form.is_verified) }}
                {{ form_widget(form.is_verified) }}
                <p style="font-size:0.8rem;color:var(--text-muted);margin-top:0.4rem;">Admin only: Mark this review as verified</p>
            </div>
        {% endif %}

        <div style="display:flex;gap:1rem;margin-top:2rem;">
            <button type="submit" class="form-submit" style="flex:1;">Save Changes</button>
            <a href="{{ path('app_avis_show', {'id': avis.avisId}) }}" class="btn-outline-dark" style="flex:1;text-align:center;padding:15px 0;">Cancel</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
