{# ─────────────────────────────────────────────────────────────────────────────
   Widget : Dernières actualités mondiales
   Variables attendues :
     news      array   articles normalisés (peut être vide)
     news_category (optionnel)  'business' | 'technology' | 'world'
   ───────────────────────────────────────────────────────────────────────────── #}

{# Placeholder fallback images par catégorie #}
{% set fallback_img = {
    'business':   'https://images.unsplash.com/photo-1526304640581-d334cdbbf45e?w=640&q=70&auto=format',
    'technology': 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=640&q=70&auto=format',
    'world':      'https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=640&q=70&auto=format'
} %}
{% set cat = news_category|default('business') %}
{% set fb  = fallback_img[cat]|default(fallback_img['business']) %}

<style>
/* ── News Widget ─────────────────────────────────────────────────────── */
.news-section { margin-top: 2.5rem; }
.news-section-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.4rem; flex-wrap: wrap; gap: 0.6rem;
}
.news-section-title {
    font-family: 'Josefin Sans', sans-serif; font-size: 1rem; font-weight: 800;
    color: var(--dark); display: flex; align-items: center; gap: 9px;
    text-transform: uppercase; letter-spacing: 0.07em;
}
.news-section-title i { color: var(--primary); }
.news-filter-tabs {
    display: flex; gap: 6px; flex-wrap: wrap;
}
.news-tab {
    padding: 5px 14px; border-radius: 20px; font-size: 0.72rem; font-weight: 700;
    font-family: 'Josefin Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.06em;
    border: 1.5px solid var(--border); background: transparent; color: var(--text-muted);
    cursor: pointer; transition: all 0.18s; text-decoration: none;
}
.news-tab:hover    { border-color: var(--primary); color: var(--dark); background: rgba(255,190,51,0.08); }
.news-tab.active   { background: var(--primary); color: var(--dark); border-color: var(--primary); }

/* Grid layout : 1 featured (2-col) + 5 small */
.news-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1rem;
}
.news-card {
    background: var(--white); border: 1.5px solid var(--border); border-radius: 14px;
    overflow: hidden; box-shadow: 0 2px 14px rgba(0,0,0,0.05);
    transition: transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column;
}
.news-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,0.1); }

/* Featured card spans 2 columns */
.news-card.featured {
    grid-column: 1 / 3;
    flex-direction: row;
}
.news-card.featured .news-img-wrap { width: 52%; flex-shrink: 0; height: auto; min-height: 200px; }
.news-card.featured .news-body     { flex: 1; padding: 22px 20px; display: flex; flex-direction: column; }
.news-card.featured .news-title    { font-size: 1.05rem; -webkit-line-clamp: 3; }
.news-card.featured .news-desc     { display: block; }

/* Regular card */
.news-img-wrap {
    width: 100%; height: 160px; overflow: hidden; position: relative;
    background: #f3f4f6;
}
.news-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.35s ease;
}
.news-card:hover .news-img { transform: scale(1.04); }

.news-source-bar {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);
    padding: 16px 12px 8px;
    display: flex; align-items: center; gap: 6px;
}
.news-source-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--primary); flex-shrink: 0; }
.news-source-name { font-size: 0.68rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; color: #fff; text-transform: uppercase; letter-spacing: 0.06em; }

.news-body { padding: 14px 16px 16px; display: flex; flex-direction: column; flex: 1; }
.news-title {
    font-size: 0.88rem; font-weight: 700; color: var(--dark); line-height: 1.45;
    margin: 0 0 8px;
    display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2;
    overflow: hidden;
}
.news-desc {
    font-size: 0.78rem; color: var(--text-muted); line-height: 1.55;
    margin: 0 0 12px; flex: 1;
    display: none;
    display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2;
    overflow: hidden;
}
.news-foot {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: auto; padding-top: 10px; border-top: 1px solid #f3f4f6;
    flex-wrap: wrap; gap: 6px;
}
.news-date { font-size: 0.72rem; color: var(--text-muted); display: flex; align-items: center; gap: 5px; }
.news-date i { font-size: 0.65rem; }
.news-read-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 7px; font-size: 0.72rem; font-weight: 700;
    font-family: 'Josefin Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.05em;
    background: var(--primary); color: var(--dark); text-decoration: none;
    transition: background 0.18s, transform 0.18s;
}
.news-read-btn:hover { background: var(--primary-dark, #e6a800); transform: translateY(-1px); }

/* Empty / error state */
.news-empty {
    grid-column: 1 / -1; text-align: center; padding: 3rem 2rem;
    background: var(--white); border: 1.5px solid var(--border); border-radius: 14px;
    color: var(--text-muted);
}
.news-empty i { font-size: 2.2rem; opacity: 0.3; display: block; margin-bottom: 0.8rem; }
.news-empty p { font-size: 0.88rem; margin: 0; }

/* Refresh hint */
.news-refresh-hint {
    text-align: right; margin-top: 0.8rem;
    font-size: 0.72rem; color: var(--text-muted);
    display: flex; align-items: center; justify-content: flex-end; gap: 5px;
}

/* Responsive */
@media (max-width: 900px) {
    .news-grid { grid-template-columns: 1fr 1fr; }
    .news-card.featured { grid-column: 1 / -1; flex-direction: column; }
    .news-card.featured .news-img-wrap { width: 100%; height: 200px; }
}
@media (max-width: 600px) {
    .news-grid { grid-template-columns: 1fr; }
    .news-card.featured { grid-column: 1; }
}
</style>

{# ── Section wrapper ──────────────────────────────────────────────── #}
<section class="news-section">

  {# Header avec titre + onglets de filtre #}
  <div class="news-section-head">
    <div class="news-section-title">
      <i class="fa fa-globe-africa"></i> Dernières actualités mondiales
    </div>
    <div class="news-filter-tabs">
      <a href="?news_cat=business"
         class="news-tab {{ cat == 'business' ? 'active' : '' }}">
        <i class="fa fa-briefcase"></i> Business
      </a>
      <a href="?news_cat=technology"
         class="news-tab {{ cat == 'technology' ? 'active' : '' }}">
        <i class="fa fa-microchip"></i> Tech
      </a>
      <a href="?news_cat=world"
         class="news-tab {{ cat == 'world' ? 'active' : '' }}">
        <i class="fa fa-globe"></i> Monde
      </a>
    </div>
  </div>

  {# Articles grid #}
  <div class="news-grid">

    {% if news is empty %}

      {# Empty / API unavailable state #}
      <div class="news-empty">
        <i class="fa fa-satellite-dish"></i>
        <p>Actualités indisponibles pour le moment.<br>
           <small>Vérifiez votre clé GNews API ou réessayez plus tard.</small>
        </p>
      </div>

    {% else %}

      {% for article in news %}
        {% set isFirst = loop.first %}
        <article class="news-card{{ isFirst ? ' featured' : '' }}">

          {# Image #}
          <div class="news-img-wrap">
            <img
              src="{{ article.image ?? fb }}"
              alt="{{ article.title|slice(0,60) }}"
              class="news-img"
              loading="lazy"
              onerror="this.src='{{ fb }}'">
            <div class="news-source-bar">
              <span class="news-source-dot"></span>
              <span class="news-source-name">{{ article.source }}</span>
            </div>
          </div>

          {# Body #}
          <div class="news-body">
            <h3 class="news-title">{{ article.title }}</h3>
            {% if article.description %}
              <p class="news-desc">{{ article.description }}</p>
            {% endif %}
            <div class="news-foot">
              <span class="news-date">
                <i class="fa fa-clock"></i>
                {% if article.published_at %}
                  {{ article.published_at|date('d/m/Y') }}
                {% else %}
                  Récent
                {% endif %}
              </span>
              {% if article.url %}
                <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer"
                   class="news-read-btn">
                  <i class="fa fa-external-link-alt"></i> Lire plus
                </a>
              {% endif %}
            </div>
          </div>

        </article>
      {% endfor %}

    {% endif %}

  </div>

  {# Refresh hint #}
  <div class="news-refresh-hint">
    <i class="fa fa-sync-alt"></i>
    Actualisé toutes les 30 minutes · Source : GNews
  </div>

</section>
