{% extends 'front/base.html.twig' %}

{% block title %}Modifier — {{ projet.title }} — BizHub{% endblock %}

{% block extra_styles %}
.page-header { background: linear-gradient(135deg, var(--dark) 0%, var(--dark2) 100%); padding: 60px 5% 40px; }
.page-header h1 { font-size: 1.8rem; color: var(--white); font-family: 'Josefin Sans', sans-serif; font-weight: 700; }
.page-header p { color: rgba(255,255,255,0.55); margin-top: 0.4rem; font-size: 0.9rem; }
.page-body { max-width: 820px; margin: 0 auto; padding: 40px 5%; }
.back-link { display: inline-flex; align-items: center; gap: 6px; color: var(--text-muted); text-decoration: none; font-size: 0.85rem; margin-bottom: 1.5rem; transition: color 0.2s; font-family: 'Josefin Sans', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }
.back-link:hover { color: var(--primary); }
/* ── Sections ── */
.proj-section { background: var(--white); border: 1.5px solid var(--border); border-radius: 14px; padding: 24px 28px; margin-bottom: 1.4rem; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
.proj-section-head { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 20px; padding-bottom: 14px; border-bottom: 1.5px solid #f0f2f5; }
.proj-section-num { width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: var(--dark); display: flex; align-items: center; justify-content: center; font-family: 'Josefin Sans', sans-serif; font-size: 0.85rem; font-weight: 800; flex-shrink: 0; margin-top: 2px; }
.proj-section-title { font-family: 'Josefin Sans', sans-serif; font-size: 0.88rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.09em; color: var(--dark); display: flex; align-items: center; gap: 7px; }
.proj-section-title i { color: var(--primary); }
.proj-section-sub { font-size: 0.79rem; color: var(--text-muted); margin-top: 2px; }
.form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
.optional-badge { display: inline-flex; align-items: center; gap: 4px; background: rgba(99,102,241,0.1); color: #4f46e5; border-radius: 100px; padding: 2px 9px; font-size: 0.65rem; font-weight: 700; font-family: 'Josefin Sans',sans-serif; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 5px; }
.field-badge { margin-left: 6px; vertical-align: middle; }
@media(max-width:640px) { .form-row-3 { grid-template-columns: 1fr; } }
{% endblock %}

{% block content %}
<div class="page-header">
    <div style="max-width:700px;margin:0 auto;">
        <h1><i class="fa fa-pen" style="color:var(--primary);margin-right:0.5rem;"></i>Modifier le projet</h1>
        <p>{{ projet.title }}</p>
    </div>
</div>

<div class="page-body">
    <a href="{{ path('app_front_projet_show', {'id': projet.project_id}) }}" class="back-link"><i class="fa fa-arrow-left"></i> Retour au projet</a>
    {% include 'front/projet/_form.html.twig' with {
        'form': form,
        'submitIcon': 'save',
        'submitLabel': 'Enregistrer les modifications'
    } %}
</div>
{% endblock %}
