# Normalize text files across platforms
* text=auto eol=lf

# Scripts
*.sh text eol=lf

# Common source/config/templates
*.php text eol=lf
*.twig text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.sql text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
