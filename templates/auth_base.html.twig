<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% block title %}BizHub Auth{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --auth-blue: #1877F2;
            --auth-blue-ring: rgba(24, 119, 242, 0.15);
            --auth-text: #1c1e21;
            --auth-muted: #606770;
            --auth-border: #dadde1;
            --auth-link: #F5A623;
            --auth-error: #e53935;
            --auth-success: #2e7d32;
            --auth-bg: #ffffff;
        }

        @keyframes auth-fade-up {
            from {
                opacity: 0;
                transform: translateY(14px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes hero-glow {
            0% {
                transform: translate(-50%, -50%) scale(1);
                opacity: 0.45;
            }

            50% {
                transform: translate(-50%, -50%) scale(1.08);
                opacity: 0.75;
            }

            100% {
                transform: translate(-50%, -50%) scale(1);
                opacity: 0.45;
            }
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            width: 100%;
            margin: 0;
            padding: 0;
            font-family: 'Source Sans 3', system-ui, -apple-system, Segoe UI, sans-serif;
            color: var(--auth-text);
            background: radial-gradient(circle at 10% 20%, #eef5ff 0%, #fdfefe 48%, #ffffff 100%);
        }

        .auth-wrapper {
            display: flex;
            min-height: 100vh;
            width: 100%;
            position: relative;
            overflow: hidden;
        }

        .auth-hero {
            width: 55%;
            background: #fff url('/assets/front/images/hero-bg1.png') center center / cover no-repeat;
            position: relative;
            overflow: hidden;
        }

        .auth-hero-video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            object-position: center center;
            z-index: 0;
        }

        .auth-hero::after {
            content: "";
            position: absolute;
            top: 48%;
            left: 52%;
            width: min(48vw, 540px);
            aspect-ratio: 1;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0) 68%);
            animation: hero-glow 7s ease-in-out infinite;
            pointer-events: none;
            z-index: 1;
        }

        .auth-form-col {
            width: 45%;
            display: flex;
            flex-direction: column;
            background: linear-gradient(170deg, rgba(255, 255, 255, 0.98), rgba(248, 251, 255, 0.98));
            backdrop-filter: blur(6px);
            padding: 28px 38px 20px;
            box-shadow: -16px 0 48px rgba(28, 30, 33, 0.1);
        }

        .auth-topbar {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 14px;
        }

        .auth-logo {
            display: block;
            width: 100%;
            text-align: center;
            font-size: clamp(2.2rem, 3vw, 3rem);
            font-weight: 700;
            letter-spacing: 0.04em;
            font-family: 'Sora', 'Source Sans 3', sans-serif;
            color: var(--auth-text);
            text-decoration: none;
        }

        .auth-logo span {
            color: var(--auth-link);
        }

        .gear-button {
            width: 34px;
            height: 34px;
            border: 1px solid var(--auth-border);
            border-radius: 999px;
            display: none;
            align-items: center;
            justify-content: center;
            color: var(--auth-muted);
            background: #fff;
            text-decoration: none;
            font-size: 18px;
        }

        .auth-main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: auth-fade-up 0.55s ease both;
        }

        .auth-card {
            width: min(100%, 420px);
            text-align: center;
        }

        .auth-heading {
            margin: 0;
            font-size: clamp(2rem, 2.6vw, 2.35rem);
            font-weight: 600;
            font-family: 'Sora', 'Source Sans 3', sans-serif;
            color: var(--auth-text);
            line-height: 1.2;
            text-align: center;
        }

        .auth-subtext {
            margin: 10px 0 22px;
            color: var(--auth-muted);
            font-size: clamp(1.08rem, 1.5vw, 1.2rem);
            line-height: 1.45;
            text-align: center;
        }

        .field-group {
            margin-bottom: 14px;
        }

        .field-label {
            display: block;
            margin-bottom: 8px;
            font-size: 15px;
            color: var(--auth-muted);
            font-weight: 500;
            text-align: center;
        }

        .input-field,
        .select-field {
            width: 100%;
            height: 52px;
            border: 1.5px solid var(--auth-border);
            border-radius: 8px;
            padding: 0 16px;
            font-size: 16px;
            color: var(--auth-text);
            background: #fff;
            outline: none;
            transition: border-color 0.18s ease, box-shadow 0.18s ease;
        }

        .input-field:focus,
        .select-field:focus {
            border-color: var(--auth-blue);
            box-shadow: 0 0 0 3px var(--auth-blue-ring);
        }

        .input-field.input-error,
        .select-field.input-error {
            border-color: var(--auth-error);
        }

        .field-error {
            margin-top: 6px;
            font-size: 13px;
            color: var(--auth-error);
            line-height: 1.3;
        }

        .field-with-icon {
            position: relative;
        }

        .field-with-icon .input-field {
            padding-right: 48px;
        }

        .password-toggle {
            position: absolute;
            top: 50%;
            right: 12px;
            transform: translateY(-50%);
            border: 0;
            background: transparent;
            color: var(--auth-muted);
            font-size: 15px;
            cursor: pointer;
            padding: 4px;
            line-height: 1;
        }

        .btn-primary,
        .btn-secondary {
            width: 100%;
            height: 48px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            transition: filter 0.2s ease, border-color 0.2s ease;
        }

        .btn-primary {
            border: 0;
            background: var(--auth-blue);
            color: #fff;
        }

        .btn-secondary {
            border: 1.5px solid var(--auth-border);
            background: #fff;
            color: var(--auth-text);
        }

        .btn-primary:hover,
        .btn-secondary:hover {
            filter: brightness(0.95);
        }

        .link-brand {
            color: var(--auth-link);
            text-decoration: none;
            font-weight: 600;
        }

        .link-brand:hover {
            text-decoration: underline;
        }

        .divider-text {
            position: relative;
            margin: 16px 0;
            text-align: center;
            color: var(--auth-muted);
            font-size: 14px;
        }

        .divider-text::before,
        .divider-text::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 42%;
            height: 1px;
            background: var(--auth-border);
        }

        .divider-text::before {
            left: 0;
        }

        .divider-text::after {
            right: 0;
        }

        .muted-center {
            text-align: center;
            color: var(--auth-muted);
            font-size: 15px;
            line-height: 1.4;
        }

        .social-stack {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .section-separator {
            border: 0;
            border-top: 1px solid var(--auth-border);
            margin: 18px 0 14px;
        }

        .two-col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .auth-footer {
            margin-top: auto;
            font-size: 14px;
            color: #8a8d91;
            line-height: 1.4;
            text-align: center;
        }

        .auth-footer a {
            color: #8a8d91;
            text-decoration: none;
        }

        .auth-footer a:hover {
            text-decoration: underline;
        }

        .toast {
            position: fixed;
            right: 20px;
            bottom: 20px;
            background: #e8f5e9;
            border: 1px solid #c8e6c9;
            color: var(--auth-success);
            border-radius: 8px;
            padding: 11px 14px;
            font-size: 14px;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transform: translateY(8px);
            transition: opacity 0.2s ease, transform 0.2s ease;
        }

        .toast.show {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }

        @media (max-width: 767px) {
            .auth-wrapper {
                flex-direction: column;
            }

            .auth-hero {
                width: 100%;
                height: 220px;
            }

            .auth-form-col {
                width: 100%;
                min-height: calc(100vh - 220px);
                padding: 18px 16px 16px;
            }

            .auth-card {
                width: 100%;
            }

            .gear-button {
                display: none;
            }

            .btn-primary,
            .btn-secondary {
                width: 100%;
            }

            .two-col {
                grid-template-columns: 1fr;
            }
        }

        {% block auth_page_styles %}{% endblock %}
    </style>
</head>
<body>
<div class="auth-wrapper">
    <aside class="auth-hero" aria-hidden="true">
        <video class="auth-hero-video" autoplay muted loop playsinline preload="metadata" poster="{{ asset('assets/front/images/hero-bg1.png') }}">
            <source src="{{ asset('assets/front/images/hero-bg.mp4') }}" type="video/mp4">
        </video>
    </aside>

    <section class="auth-form-col">
        <div class="auth-topbar">
            <a href="{{ path('app_index') }}" class="auth-logo">Biz<span>Hub</span></a>
            <a href="#" class="gear-button" aria-label="Parametres">&#9881;</a>
        </div>

        <main class="auth-main">
            <div class="auth-card">
                {% block auth_content %}{% endblock %}
            </div>
        </main>

        <footer class="auth-footer">
            &copy; 2026 BizHub · <a href="#">Conditions</a> · <a href="#">Confidentialite</a>
        </footer>
    </section>
</div>

{% block auth_scripts %}{% endblock %}
</body>
</html>
