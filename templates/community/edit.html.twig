{% extends 'front/base.html.twig' %}

{% block title %}Modifier le post - BizHub{% endblock %}

{% block flash_messages %}
  <div class="container" style="margin-top: 16px; max-width: 860px; padding: 0 16px;">
    {% for message in app.flashes('error') %}
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endfor %}
    {% for message in app.flashes('success') %}
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endfor %}
  </div>
{% endblock %}

{% block extra_styles %}
  /* Minimal bootstrap-like utilities for edit page too */
  .mb-3{ margin-bottom: 1rem; }
  .shadow-sm{ box-shadow: var(--shadow-sm); }
  .card{ background: var(--white); border-radius: var(--radius-lg); border: 1.5px solid var(--border); overflow:hidden; }
  .card-body{ padding: 18px; }
  .form-control, .form-select{
    width: 100%;
    background: var(--light-bg);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 11px 14px;
    font-family: 'Inter', sans-serif;
    font-size: 0.92rem;
    color: var(--text);
    outline: none;
  }
  .form-control:focus, .form-select:focus{
    border-color: var(--primary);
    background: var(--white);
    box-shadow: var(--shadow-glow);
  }
  textarea.form-control{ resize: vertical; min-height: 140px; line-height: 1.6; }
  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    padding: 10px 16px;
    border-radius: var(--radius-md);
    border: 1.5px solid transparent;
    cursor:pointer;
    text-decoration:none;
    font-family:'Josefin Sans', sans-serif;
    font-weight:800;
    letter-spacing:0.07em;
    text-transform:uppercase;
    font-size:0.78rem;
    transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .btn:hover{ transform: translateY(-1px); }
  .btn-primary{ background: var(--primary); color: var(--dark); }
  .btn-primary:hover{ background: var(--primary-dark); }
  .btn-secondary{ background:#fff; color: var(--text-muted); border-color: var(--border); }
  .btn-secondary:hover{ border-color:#cbd5e1; color: var(--text); }
  .alert{
    border-radius: var(--radius-lg);
    padding: 12px 14px;
    border: 1px solid var(--border);
    background: var(--white);
    box-shadow: var(--shadow-sm);
    margin-bottom: 10px;
    position: relative;
  }
  .alert.alert-danger{ background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.22); color: #7f1d1d; }
  .alert.alert-success{ background: rgba(16,185,129,0.10); border-color: rgba(16,185,129,0.22); color: #065f46; }
  .btn-close{
    position:absolute; top:10px; right:10px;
    width:28px; height:28px;
    border:none; background: rgba(255,255,255,0.6);
    border-radius: 10px; cursor:pointer; color: inherit;
  }
  .btn-close::before{ content:'×'; font-size:18px; font-weight:900; line-height:28px; display:block; text-align:center; opacity:0.75; }
  .btn-close:hover::before{ opacity:1; }
{% endblock %}

{% block content %}
<div class="container mt-4" style="max-width: 860px; padding: 0 16px; margin-left: auto; margin-right: auto;">
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 style="font-family:'Josefin Sans',sans-serif;margin-bottom:14px;">Modifier le post</h2>
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">Titre</label>
                    <input type="text" name="title" class="form-control" value="{{ post.title }}">
                </div>
                <div class="mb-3">
                    <label class="form-label">Contenu</label>
                    <textarea name="content" class="form-control" rows="5">{{ post.content }}</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Catégorie</label>
                    <select name="category" class="form-select">
                        <option value="General" {% if post.category == 'General' %}selected{% endif %}>General</option>
                        <option value="Business" {% if post.category == 'Business' %}selected{% endif %}>Business</option>
                        <option value="Investment" {% if post.category == 'Investment' %}selected{% endif %}>Investment</option>
                        <option value="Other" {% if post.category == 'Other' %}selected{% endif %}>Other</option>
                    </select>
                </div>
                <div class="mb-3" style="position:relative;">
                    <label class="form-label">📍 Lieu (optionnel)</label>
                    <input type="text" name="location" class="form-control" value="{{ post.location ?? '' }}" autocomplete="off" data-location-input>
                    <input type="hidden" name="location_lat" value="{{ post.locationLat ?? '' }}" data-location-lat>
                    <input type="hidden" name="location_lon" value="{{ post.locationLon ?? '' }}" data-location-lon>
                    <div data-location-suggest style="position:absolute;left:0;right:0;top: calc(100% + 6px); z-index:60; display:none;"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Media (image/video, optionnel)</label>
                    {% if post.mediaUrl %}
                      <div style="margin-bottom:8px;">
                        {% if post.mediaType and post.mediaType starts with 'video/' %}
                          <video controls preload="metadata" style="max-width:320px; border-radius:10px; border:1px solid var(--border); display:block;">
                            <source src="{{ asset(post.mediaUrl) }}" type="{{ post.mediaType }}">
                            Votre navigateur ne supporte pas la lecture video.
                          </video>
                        {% else %}
                          <img src="{{ asset(post.mediaUrl) }}" alt="Post image" style="max-width:220px; border-radius:10px; border:1px solid var(--border); display:block;">
                        {% endif %}
                      </div>
                    {% endif %}
                    <input type="file" name="media" accept="image/*,video/*" class="form-control">
                </div>
                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                  <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> Enregistrer</button>
                  <a href="{{ path('community_index') }}" class="btn btn-secondary"><i class="fa fa-arrow-left"></i> Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
  <script>
    (function(){
      // Dismiss alerts (si Bootstrap JS absent)
      document.querySelectorAll('.alert .btn-close').forEach(btn => {
        btn.addEventListener('click', () => btn.closest('.alert')?.remove());
      });

      const input = document.querySelector('[data-location-input]');
      const latEl = document.querySelector('[data-location-lat]');
      const lonEl = document.querySelector('[data-location-lon]');
      const suggest = document.querySelector('[data-location-suggest]');
      let debounceTimer = null;
      let lastQuery = '';

      function closeSuggest(){
        if (!suggest) return;
        suggest.style.display = 'none';
        suggest.innerHTML = '';
      }
      function renderSuggest(items){
        if (!suggest) return;
        if (!items || items.length === 0) { closeSuggest(); return; }
        suggest.style.display = 'block';
        suggest.innerHTML = '';
        const card = document.createElement('div');
        card.className = 'card shadow-sm';
        const body = document.createElement('div');
        body.className = 'card-body';
        body.style.padding = '10px';
        body.style.display = 'grid';
        body.style.gap = '6px';
        items.forEach(it => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'btn btn-secondary';
          btn.style.justifyContent = 'flex-start';
          btn.style.textTransform = 'none';
          btn.style.letterSpacing = 'normal';
          btn.style.fontFamily = 'Inter, sans-serif';
          btn.style.fontWeight = '700';
          btn.textContent = it.display_name;
          btn.addEventListener('click', () => {
            input.value = it.display_name;
            latEl.value = it.lat;
            lonEl.value = it.lon;
            closeSuggest();
          });
          body.appendChild(btn);
        });
        card.appendChild(body);
        suggest.appendChild(card);
      }

      async function fetchLocations(q){
        const res = await fetch(`/community/location-search?q=${encodeURIComponent(q)}`, {
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        if (!res.ok) return [];
        return await res.json();
      }

      if (input && suggest && latEl && lonEl){
        input.addEventListener('input', () => {
          latEl.value = '';
          lonEl.value = '';
          const q = input.value.trim();
          if (q.length < 3){ closeSuggest(); return; }
          lastQuery = q;
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(async () => {
            const data = await fetchLocations(q);
            if (input.value.trim() !== lastQuery) return;
            renderSuggest(data);
          }, 300);
        });
        document.addEventListener('click', (e) => {
          if (!suggest.contains(e.target) && e.target !== input) closeSuggest();
        });
      }
    })();
  </script>
{% endblock %}
