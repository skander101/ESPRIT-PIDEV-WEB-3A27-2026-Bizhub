{% extends 'back/base.html.twig' %}

{% block title %}Investissement #{{ investment.investment_id }}{% endblock %}
{% block breadcrumb %}Investissement / Investissements / #{{ investment.investment_id }}{% endblock %}

{% block content %}
{% set statutColor = {
  'en_attente':    '#f97316',
  'en_negociation':'#3b82f6',
  'accepte':       '#10b981',
  'refuse':        '#ef4444',
  'contrat_genere':'#8b5cf6',
  'signe':         '#06b6d4',
  'termine':       '#6b7280'
} %}
{% set statutLabel = {
  'en_attente':    'En attente',
  'en_negociation':'En négociation',
  'accepte':       'Accepté',
  'refuse':        'Refusé',
  'contrat_genere':'Contrat généré',
  'signe':         'Signé',
  'termine':       'Terminé'
} %}

<div style="padding:2rem;">

  {# ── Actions header ── #}
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
    <h2 style="font-size:1.4rem;color:var(--pg-text);margin:0;">Investissement #{{ investment.investment_id }}</h2>
    <div style="display:flex;gap:0.7rem;">
      <a href="{{ path('app_admin_investment_index') }}" style="background:var(--pg-surface);color:var(--pg-text);padding:0.6rem 1.2rem;border-radius:6px;text-decoration:none;font-weight:600;border:1px solid var(--pg-border);">← Retour</a>
      <form method="post" action="{{ path('app_admin_investment_delete', {id: investment.investment_id}) }}" onsubmit="return confirm('Supprimer cet investissement ? Cette action est irréversible.');" style="margin:0;">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_investment_' ~ investment.investment_id) }}">
        <button type="submit" style="background:#dc2626;color:#fff;padding:0.6rem 1.2rem;border-radius:6px;border:none;font-weight:600;cursor:pointer;">Supprimer</button>
      </form>
    </div>
  </div>

  {# ── Flash messages ── #}
  {% for type, messages in app.flashes %}
    {% for msg in messages %}
      <div style="padding:0.8rem 1.2rem;border-radius:6px;margin-bottom:1rem;background:{{ type == 'success' ? 'rgba(6,214,160,0.15)' : 'rgba(239,68,68,0.15)' }};color:{{ type == 'success' ? '#06d6a0' : '#f87171' }};border:1px solid {{ type == 'success' ? 'rgba(6,214,160,0.3)' : 'rgba(239,68,68,0.3)' }};">
        {{ msg }}
      </div>
    {% endfor %}
  {% endfor %}

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;">

    {# ── Infos investissement ── #}
    <div style="display:flex;flex-direction:column;gap:1.5rem;">

      <div class="dash-panel">
        <h5 style="margin-bottom:1.2rem;">Détails de l'investissement</h5>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;">
          <div>
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Montant</div>
            <div style="color:#10b981;font-weight:700;font-size:1.1rem;">{{ investment.amount|number_format(0, ',', ' ') }} TND</div>
          </div>
          <div>
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Statut</div>
            <span style="display:inline-block;padding:0.25rem 0.7rem;border-radius:4px;font-size:0.82rem;font-weight:700;background:{{ statutColor[investment.statut] ?? '#6b7280' }}22;color:{{ statutColor[investment.statut] ?? '#6b7280' }};">
              {{ statutLabel[investment.statut] ?? investment.statut }}
            </span>
          </div>
          <div>
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Type d'investissement</div>
            <div style="color:var(--pg-text);text-transform:capitalize;">{{ investment.typeInvestissement ?? '—' }}</div>
          </div>
          <div>
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Mode de paiement</div>
            <div style="color:var(--pg-text);text-transform:capitalize;">{{ investment.paymentMode ?? '—' }}</div>
          </div>
          <div>
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Durée souhaitée</div>
            <div style="color:var(--pg-text);">{{ investment.dureeSouhaitee ?? '—' }}</div>
          </div>
          <div>
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Date d'investissement</div>
            <div style="color:var(--pg-muted);">{{ investment.investmentDate ? investment.investmentDate|date('d/m/Y') : '—' }}</div>
          </div>
          <div>
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Créé le</div>
            <div style="color:var(--pg-muted);">{{ investment.createdAt|date('d/m/Y H:i') }}</div>
          </div>
          {% if investment.contractUrl %}
          <div>
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Contrat</div>
            <a href="{{ investment.contractUrl }}" target="_blank" style="color:var(--nb-accent);font-size:0.9rem;">Voir le contrat</a>
          </div>
          {% endif %}
        </div>
        {% if investment.commentaire %}
          <div style="margin-top:1.2rem;">
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Commentaire</div>
            <div style="color:var(--pg-text);line-height:1.6;font-size:0.9rem;">{{ investment.commentaire }}</div>
          </div>
        {% endif %}
        {% if investment.conditionsParticulieres %}
          <div style="margin-top:1.2rem;">
            <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.4rem;">Conditions particulières</div>
            <div style="color:var(--pg-text);line-height:1.6;font-size:0.9rem;">{{ investment.conditionsParticulieres }}</div>
          </div>
        {% endif %}
      </div>

      {# Projet lié #}
      {% if investment.project %}
      <div class="dash-panel">
        <h5 style="margin-bottom:1rem;">Projet lié</h5>
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <div>
            <div style="color:var(--pg-text);font-weight:600;font-size:1rem;">{{ investment.project.title }}</div>
            <div style="color:var(--pg-muted);font-size:0.85rem;margin-top:0.3rem;">{{ investment.project.secteur ?? '' }} · {{ investment.project.requiredBudget|number_format(0, ',', ' ') }} TND</div>
          </div>
          <a href="{{ path('app_admin_projet_show', {id: investment.project.project_id}) }}" style="background:var(--pg-surface);color:var(--pg-text);padding:0.5rem 1rem;border-radius:6px;text-decoration:none;font-size:0.85rem;font-weight:600;border:1px solid var(--pg-border);">Voir le projet</a>
        </div>
      </div>
      {% endif %}

    </div>

    {# ── Panneau latéral ── #}
    <div style="display:flex;flex-direction:column;gap:1.5rem;">

      {# Investisseur #}
      <div class="dash-panel">
        <h5 style="margin-bottom:1rem;">Investisseur</h5>
        {% if investment.user %}
          <div style="display:flex;flex-direction:column;gap:0.8rem;">
            <div>
              <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.3rem;">Nom</div>
              <div style="color:var(--pg-text);font-weight:500;">{{ investment.user.fullName }}</div>
            </div>
            <div>
              <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.3rem;">Email</div>
              <div style="color:var(--pg-muted);">{{ investment.user.email }}</div>
            </div>
            {% if investment.user.companyName %}
            <div>
              <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-bottom:0.3rem;">Entreprise</div>
              <div style="color:var(--pg-text);">{{ investment.user.companyName }}</div>
            </div>
            {% endif %}
          </div>
        {% else %}
          <p style="color:var(--pg-muted);font-size:0.9rem;">Aucun investisseur assigné.</p>
        {% endif %}
      </div>

      {# Changement de statut #}
      <div class="dash-panel">
        <h5 style="margin-bottom:1rem;">Changer le statut</h5>
        <form method="post" action="{{ path('app_admin_investment_statut', {id: investment.investment_id}) }}">
          <input type="hidden" name="_token" value="{{ csrf_token('statut_investment_' ~ investment.investment_id) }}">
          <select name="statut" style="width:100%;background:var(--pg-surface);border:1px solid var(--pg-border);color:var(--pg-text);padding:0.65rem 0.9rem;border-radius:6px;margin-bottom:0.8rem;">
            <option value="en_attente"    {{ investment.statut == 'en_attente'    ? 'selected' : '' }}>En attente</option>
            <option value="en_negociation"{{ investment.statut == 'en_negociation'? 'selected' : '' }}>En négociation</option>
            <option value="accepte"       {{ investment.statut == 'accepte'       ? 'selected' : '' }}>Accepté</option>
            <option value="refuse"        {{ investment.statut == 'refuse'        ? 'selected' : '' }}>Refusé</option>
            <option value="contrat_genere"{{ investment.statut == 'contrat_genere'? 'selected' : '' }}>Contrat généré</option>
            <option value="signe"         {{ investment.statut == 'signe'         ? 'selected' : '' }}>Signé</option>
            <option value="termine"       {{ investment.statut == 'termine'       ? 'selected' : '' }}>Terminé</option>
          </select>
          <button type="submit" style="width:100%;background:var(--nb-accent);color:#fff;padding:0.7rem;border-radius:6px;border:none;font-weight:700;cursor:pointer;">Appliquer</button>
        </form>
      </div>

    </div>
  </div>
</div>
{% endblock %}
