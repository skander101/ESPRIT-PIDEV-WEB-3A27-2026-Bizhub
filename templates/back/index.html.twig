<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="shortcut icon" href="{{ asset('assets/back/images/logo_dark.png') }}" type="image/png" />
  <title>Dashboard | BizHub</title>
  <link rel="stylesheet" href="{{ asset('assets/back/css/bootstrap.min.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/lineicons.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/materialdesignicons.min.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/main.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/dark-mode.css') }}" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    /* ═══════════════════════════════
       TOKENS
    ═══════════════════════════════ */
    :root {
      --nb-bg:#0f1117; --nb-surface:#1a1d27; --nb-border:#2a2d3a;
      --nb-accent:#5b6ef5; --nb-accent2:#8b5cf6; --nb-accent3:#06d6a0;
      --nb-text:#e2e8f0; --nb-muted:#64748b; --nb-hover:#242736;
      --pg-bg:#080b12; --pg-surface:#0e1220; --pg-surface2:#141826;
      --pg-border:rgba(255,255,255,.07); --pg-border2:rgba(255,255,255,.12);
      --pg-text:#f0f2ff; --pg-muted:#6b7280; --pg-muted2:#9ca3af;
    }
    *,*::before,*::after{box-sizing:border-box;}
    html,body{height:100%;margin:0;padding:0;}
    body.dark-mode{background:var(--pg-bg)!important;font-family:'DM Sans',sans-serif;overflow-x:hidden;}

    /* Hide preloader completely */
    #preloader{display:none !important;opacity:0 !important;pointer-events:none !important;}
    .spinner{width:36px;height:36px;border:2px solid rgba(255,255,255,.08);border-top-color:var(--nb-accent);border-radius:50%;animation:spin .8s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg);}}

    /* Page Transition Animation */
    @keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
    .main-wrapper{opacity:0;transition:opacity 0.5s cubic-bezier(0.4,0,0.2,1);}
    .main-wrapper.visible{opacity:1;}

    /* Dropdown Animation */
    @keyframes slideDown{from{opacity:0;transform:translateY(-10px);}to{opacity:1;transform:translateY(0);}}
    .collapse{max-height:0;overflow:hidden;opacity:0;transition:max-height .4s ease,opacity .4s ease;}
    .collapse.show{max-height:none;opacity:1;overflow:visible;animation:slideDown .4s ease-out;transition:none;}
    .dropdown-nav li{transition:background .15s ease;}

    /* ═══════════════════════════════
       NAVBAR
    ═══════════════════════════════ */
    .plain-navbar{
      width:100%;background:var(--nb-bg);border-bottom:1px solid var(--nb-border);
      display:flex;align-items:center;height:64px;padding:0 1.5rem;
      position:fixed;top:0;left:0;right:0;z-index:1100;font-family:'DM Sans',sans-serif;
    }
    .plain-navbar::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--nb-accent),var(--nb-accent2),transparent);opacity:.5;}
    .nb-left{display:flex;align-items:center;gap:14px;flex:0 0 auto;}
    .nb-logo{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--nb-accent),var(--nb-accent2));display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
    .nb-site-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--nb-text);letter-spacing:-.3px;}
    .nb-site-title span{font-weight:400;}
    .nb-breadcrumb{display:flex;align-items:center;gap:7px;margin-left:18px;padding-left:18px;border-left:1px solid var(--nb-border);}
    .nb-breadcrumb a{font-size:13px;color:var(--nb-muted);text-decoration:none;transition:color .2s;}
    .nb-breadcrumb a:hover{color:var(--nb-text);}
    .nb-breadcrumb .sep{color:var(--nb-border);}
    .nb-breadcrumb .current{font-size:13px;color:var(--nb-text);font-weight:500;}
    .nb-center{flex:1;display:flex;justify-content:center;}
    .nb-search{position:relative;width:280px;}
    .nb-search svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);opacity:.4;pointer-events:none;}
    .nb-search input{width:100%;height:38px;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;color:var(--nb-text);font-size:13px;font-family:'DM Sans',sans-serif;padding:0 12px 0 36px;outline:none;transition:border-color .2s,box-shadow .2s;}
    .nb-search input::placeholder{color:var(--nb-muted);}
    .nb-search input:focus{border-color:var(--nb-accent);box-shadow:0 0 0 3px rgba(91,110,245,.12);}
    .nb-right{display:flex;align-items:center;gap:6px;flex:0 0 auto;}
    .nb-icon-btn{width:38px;height:38px;border-radius:9px;background:var(--nb-surface);border:1px solid var(--nb-border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .2s,border-color .2s;position:relative;}
    .nb-icon-btn:hover{background:var(--nb-hover);border-color:#3a3d50;}
    .nb-icon-btn svg{opacity:.7;transition:opacity .2s;}
    .nb-icon-btn:hover svg{opacity:1;}
    .nb-badge{position:absolute;top:6px;right:6px;width:7px;height:7px;border-radius:50%;background:#ef4444;border:1.5px solid var(--nb-bg);}
    .nb-badge.blue{background:var(--nb-accent);}
    .nb-quick-actions{display:flex;align-items:center;gap:3px;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;padding:3px;}
    .nb-qa-btn{padding:5px 11px;border-radius:6px;font-size:12px;font-weight:500;color:var(--nb-muted);cursor:pointer;transition:all .2s;white-space:nowrap;border:none;background:transparent;font-family:'DM Sans',sans-serif;}
    .nb-qa-btn:hover{color:var(--nb-text);background:var(--nb-hover);}
    .nb-qa-btn.active{color:#fff;background:var(--nb-accent);}
    .nb-divider{width:1px;height:22px;background:var(--nb-border);margin:0 4px;}
    .nb-toggle-wrap{display:flex;align-items:center;gap:8px;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;padding:5px 11px;cursor:pointer;transition:border-color .2s;}
    .nb-toggle-wrap:hover{border-color:#3a3d50;}
    .nb-toggle-label{font-size:12px;color:var(--nb-muted);font-weight:500;}
    .nb-toggle{width:30px;height:16px;background:#2a2d3a;border-radius:20px;position:relative;transition:background .3s;}
    .nb-toggle.on{background:var(--nb-accent);}
    .nb-toggle-knob{width:12px;height:12px;background:#fff;border-radius:50%;position:absolute;top:2px;left:2px;transition:transform .3s;}
    .nb-toggle.on .nb-toggle-knob{transform:translateX(14px);}
    .nb-user-pill{display:flex;align-items:center;gap:9px;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;padding:4px 10px 4px 6px;cursor:pointer;transition:border-color .2s,background .2s;position:relative;}
    .nb-user-pill:hover{border-color:#3a3d50;background:var(--nb-hover);}
    .nb-avatar{width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,var(--nb-accent),var(--nb-accent2));display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;flex-shrink:0;}
    .nb-user-info{display:flex;flex-direction:column;line-height:1.2;}
    .nb-user-name{font-size:13px;font-weight:500;color:var(--nb-text);}
    .nb-user-role{font-size:11px;color:var(--nb-muted);}
    .nb-chevron{opacity:.4;transition:opacity .2s,transform .3s;}
    .nb-user-pill:hover .nb-chevron{opacity:.8;}
    .nb-user-pill.open .nb-chevron{transform:rotate(180deg);}
    .nb-dropdown{position:absolute;top:calc(100% + 8px);right:0;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:11px;width:185px;overflow:hidden;opacity:0;transform:translateY(-6px);pointer-events:none;transition:opacity .2s,transform .2s;z-index:999;box-shadow:0 10px 30px rgba(0,0,0,.5);}
    .nb-dropdown.open{opacity:1;transform:translateY(0);pointer-events:all;}
    .nb-dd-item{display:flex;align-items:center;gap:10px;padding:9px 14px;font-size:13px;color:var(--nb-muted);cursor:pointer;transition:background .15s,color .15s;}
    .nb-dd-item:hover{background:var(--nb-hover);color:var(--nb-text);}
    .nb-dd-item.danger:hover{color:#ef4444;}
    .nb-dd-sep{height:1px;background:var(--nb-border);margin:2px 0;}

    /* ═══════════════════════════════
       LAYOUT
    ═══════════════════════════════ */
    .page-wrapper{display:flex;padding-top:0;min-height:100vh;}
    .sidebar-nav-wrapper{position:fixed!important;top:0!important;height:100vh!important;}
    .main-wrapper{margin-left:260px;flex:1;min-height:100vh;background:var(--pg-bg);padding:0;}

    /* ═══════════════════════════════
       DASHBOARD CONTENT
    ═══════════════════════════════ */
    .dash-hero{
      padding:2rem 2rem 1.5rem;
      border-bottom:1px solid var(--pg-border2);
      display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;
    }
    .dash-hero-badge{
      display:inline-flex;align-items:center;gap:7px;
      background:rgba(91,110,245,.1);border:1px solid rgba(91,110,245,.2);
      border-radius:6px;padding:3px 12px;font-size:11px;font-weight:500;
      color:#a5b4fc;letter-spacing:.5px;text-transform:uppercase;margin-bottom:.6rem;
    }
    .dash-hero h1{font-family:'Syne',sans-serif;font-size:1.7rem;font-weight:800;color:var(--pg-text);letter-spacing:-.4px;margin:0 0 .3rem;}
    .dash-hero p{font-size:13px;color:var(--pg-muted2);font-weight:300;margin:0;}
    .dash-hero-right{display:flex;gap:10px;align-items:center;}

    .btn-outline-nb{height:38px;padding:0 16px;background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:9px;color:var(--pg-muted2);font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:7px;}
    .btn-outline-nb:hover{border-color:rgba(255,255,255,.22);color:var(--pg-text);}
    .btn-accent-nb{height:38px;padding:0 16px;background:linear-gradient(135deg,var(--nb-accent),var(--nb-accent2));border:none;border-radius:9px;color:#fff;font-size:13px;font-weight:600;font-family:'Syne',sans-serif;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:7px;box-shadow:0 3px 14px rgba(91,110,245,.3);}
    .btn-accent-nb:hover{opacity:.9;transform:translateY(-1px);}

    .dash-content{padding:2rem;}

    /* KPI cards */
    .kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:2rem;}
    .kpi-card{background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:14px;padding:1.25rem 1.5rem;position:relative;overflow:hidden;transition:transform .2s,border-color .2s;}
    .kpi-card:hover{transform:translateY(-2px);border-color:rgba(255,255,255,.18);}
    .kpi-card-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:1rem;}
    .kpi-card-icon.purple{background:rgba(139,92,246,.15);}
    .kpi-card-icon.green{background:rgba(6,214,160,.15);}
    .kpi-card-icon.blue{background:rgba(91,110,245,.15);}
    .kpi-card-icon.orange{background:rgba(245,158,11,.15);}
    .kpi-label{font-size:12px;color:var(--pg-muted);font-weight:500;letter-spacing:.3px;margin-bottom:6px;}
    .kpi-value{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--pg-text);margin-bottom:6px;}
    .kpi-delta{font-size:12px;display:flex;align-items:center;gap:4px;}
    .kpi-delta.up{color:var(--nb-accent3);}
    .kpi-delta.down{color:#f87171;}
    .kpi-delta span{color:var(--pg-muted);font-weight:300;}

    /* Chart cards */
    .chart-grid{display:grid;grid-template-columns:7fr 5fr;gap:20px;margin-bottom:2rem;}
    .chart-card{background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:14px;padding:1.5rem;overflow:hidden;}
    .chart-card-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:.75rem;}
    .chart-card-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--pg-text);margin:0 0 3px;}
    .chart-card-sub{font-size:13px;color:var(--pg-muted);margin:0;}
    .chart-big-val{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:700;color:var(--pg-text);}

    .nb-select{height:32px;background:var(--pg-bg);border:1px solid var(--pg-border2);border-radius:7px;color:var(--pg-muted2);font-size:12px;font-family:'DM Sans',sans-serif;padding:0 10px;outline:none;cursor:pointer;}

    /* Second row: map + table */
    .dash-row2{display:grid;grid-template-columns:5fr 7fr;gap:20px;margin-bottom:2rem;}

    /* Map placeholder */
    .map-placeholder{background:var(--pg-surface2);border-radius:10px;height:300px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:10px;color:var(--pg-muted);font-size:13px;}
    .map-placeholder svg{opacity:.3;}

    /* Top products table */
    .nb-table{width:100%;border-collapse:collapse;font-size:13px;}
    .nb-table thead tr{border-bottom:1px solid var(--pg-border2);}
    .nb-table thead th{padding:10px 14px;font-size:11px;font-weight:600;color:var(--pg-muted);text-transform:uppercase;letter-spacing:.7px;text-align:left;background:var(--pg-bg);}
    .nb-table tbody tr{border-bottom:1px solid var(--pg-border);transition:background .15s;}
    .nb-table tbody tr:last-child{border-bottom:none;}
    .nb-table tbody tr:hover{background:rgba(255,255,255,.03);}
    .nb-table tbody td{padding:12px 14px;color:var(--pg-muted2);vertical-align:middle;}
    .nb-table tbody td:first-child{color:var(--pg-text);}

    .product-cell{display:flex;align-items:center;gap:10px;}
    .product-thumb{width:34px;height:34px;border-radius:8px;overflow:hidden;flex-shrink:0;background:var(--pg-surface2);}
    .product-thumb img{width:100%;height:100%;object-fit:cover;}

    .nb-badge-sm{display:inline-block;padding:2px 10px;border-radius:100px;font-size:11px;font-weight:600;}
    .nb-badge-sm.up{background:rgba(6,214,160,.12);color:#06d6a0;}
    .nb-badge-sm.down{background:rgba(239,68,68,.12);color:#f87171;}

    /* Progress bar */
    .nb-progress{height:4px;background:var(--pg-border2);border-radius:2px;overflow:hidden;}
    .nb-progress-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--nb-accent),var(--nb-accent2));}

    /* Recent activity */
    .activity-card{background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:14px;overflow:hidden;margin-bottom:2rem;}
    .activity-head{padding:1.25rem 1.5rem;border-bottom:1px solid var(--pg-border2);display:flex;justify-content:space-between;align-items:center;}
    .activity-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--pg-text);margin:0;}
    .activity-body{padding:.5rem 0;}
    .activity-item{display:flex;align-items:center;gap:14px;padding:12px 1.5rem;transition:background .15s;cursor:pointer;}
    .activity-item:hover{background:rgba(255,255,255,.03);}
    .activity-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
    .activity-dot.green{background:var(--nb-accent3);}
    .activity-dot.blue{background:var(--nb-accent);}
    .activity-dot.orange{background:#f59e0b;}
    .activity-dot.red{background:#ef4444;}
    .activity-text{flex:1;font-size:13px;color:var(--pg-muted2);}
    .activity-text strong{color:var(--pg-text);font-weight:500;}
    .activity-time{font-size:11px;color:var(--pg-muted);white-space:nowrap;}

    /* Footer */
    .nb-footer{padding:1.25rem 2rem;border-top:1px solid var(--pg-border2);display:flex;align-items:center;justify-content:space-between;font-size:12px;color:var(--pg-muted);}
    .nb-footer a{color:var(--pg-muted);text-decoration:none;transition:color .2s;margin-left:16px;}
    .nb-footer a:hover{color:var(--pg-text);}

    @media(max-width:1200px){.kpi-grid{grid-template-columns:1fr 1fr;}.chart-grid{grid-template-columns:1fr;}.dash-row2{grid-template-columns:1fr;}}
    @media(max-width:768px){.main-wrapper{margin-left:0;}.kpi-grid{grid-template-columns:1fr 1fr;}}
  </style>
</head>
<body class="dark-mode">

<div id="preloader"><div class="spinner"></div></div>

