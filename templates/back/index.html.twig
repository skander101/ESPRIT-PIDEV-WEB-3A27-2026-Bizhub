              <p class="chart-card-title">Ventes / Revenus</p>
              <p class="chart-card-sub">Évolution mensuelle</p>
            </div>
            <select class="nb-select"><option>Annuel</option><option>Mensuel</option></select>
          </div>
          <canvas id="Chart2" style="width:100%;height:260px;"></canvas>
        </div>
