{% extends 'back/base.html.twig' %}

{% block title %}Tableau de bord Admin{% endblock %}
{% block breadcrumb %}Tableau de bord{% endblock %}

{% block extra_stylesheets %}
  <style>
    .dash-hero{
      padding:2rem 2rem 1.5rem;
      border-bottom:1px solid var(--pg-border2);
      display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;
    }
    .dash-hero-badge{
      display:inline-flex;align-items:center;gap:7px;
      background:rgba(91,110,245,.1);border:1px solid rgba(91,110,245,.2);
      border-radius:6px;padding:3px 12px;font-size:11px;font-weight:500;
      color:#a5b4fc;letter-spacing:.5px;text-transform:uppercase;margin-bottom:.6rem;
    }
    .dash-hero h1{font-family:'Syne',sans-serif;font-size:1.7rem;font-weight:800;color:var(--pg-text);letter-spacing:-.4px;margin:0 0 .3rem;}
    .dash-hero p{font-size:13px;color:var(--pg-muted2);font-weight:300;margin:0;}
    .dash-content{padding:2rem;}

    .kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-bottom:2rem;}
    @media(max-width:1400px){.kpi-grid{grid-template-columns:repeat(3,1fr);}}
    @media(max-width:768px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
    .kpi-card{background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:14px;padding:1.25rem 1.5rem;position:relative;overflow:hidden;transition:transform .2s,border-color .2s;}
    .kpi-card:hover{transform:translateY(-2px);border-color:rgba(255,255,255,.18);}
    .kpi-card-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:1rem;}
    .kpi-card-icon.purple{background:rgba(139,92,246,.15);}
    .kpi-card-icon.green{background:rgba(6,214,160,.15);}
    .kpi-card-icon.blue{background:rgba(91,110,245,.15);}
    .kpi-card-icon.orange{background:rgba(245,158,11,.15);}
    .kpi-card-icon.pink{background:rgba(236,72,153,.15);}
    .kpi-label{font-size:12px;color:var(--pg-muted);font-weight:500;letter-spacing:.3px;margin-bottom:6px;}
    .kpi-value{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--pg-text);margin-bottom:6px;}
    .kpi-delta{font-size:12px;display:flex;align-items:center;gap:4px;}
    .kpi-delta.up{color:#06d6a0;}
    .kpi-delta.down{color:#f87171;}
    .kpi-delta span{color:var(--pg-muted);font-weight:300;}

    .chart-grid{display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:2rem;}
    @media(max-width:992px){.chart-grid{grid-template-columns:1fr;}}
    .chart-card{background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:14px;padding:1.5rem;overflow:hidden;}
    .chart-card-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:.75rem;}
    .chart-card-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--pg-text);margin:0 0 3px;}
    .chart-card-sub{font-size:13px;color:var(--pg-muted);margin:0;}
    .chart-big-val{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:700;color:var(--pg-text);}

    .chart-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:2rem;}
    @media(max-width:992px){.chart-grid-2{grid-template-columns:1fr;}}

    .nb-table{width:100%;border-collapse:collapse;font-size:13px;}
    .nb-table thead tr{border-bottom:1px solid var(--pg-border2);}
    .nb-table thead th{padding:10px 14px;font-size:11px;font-weight:600;color:var(--pg-muted);text-transform:uppercase;letter-spacing:.7px;text-align:left;background:var(--pg-bg);}
    .nb-table tbody tr{border-bottom:1px solid var(--pg-border);transition:background .15s;}
    .nb-table tbody tr:last-child{border-bottom:none;}
    .nb-table tbody tr:hover{background:rgba(255,255,255,.03);}
    .nb-table tbody td{padding:12px 14px;color:var(--pg-muted2);vertical-align:middle;}
    .nb-table tbody td:first-child{color:var(--pg-text);}

    .nb-badge-sm{display:inline-block;padding:2px 10px;border-radius:100px;font-size:11px;font-weight:600;}
    .nb-badge-sm.up{background:rgba(6,214,160,.12);color:#06d6a0;}
    .nb-badge-sm.down{background:rgba(239,68,68,.12);color:#f87171;}
    .nb-badge-sm.pending{background:rgba(251,191,36,.12);color:#fbbf24;}

    .activity-item{display:flex;align-items:center;gap:14px;padding:12px 1.5rem;transition:background .15s;cursor:pointer;border-bottom:1px solid var(--pg-border);}
    .activity-item:hover{background:rgba(255,255,255,.03);}
    .activity-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
    .activity-dot.green{background:#06d6a0;}
    .activity-dot.blue{background:#5b6ef5;}
    .activity-dot.orange{background:#f59e0b;}
    .activity-dot.red{background:#ef4444;}
    .activity-dot.pink{background:#ec4899;}
    .activity-text{flex:1;font-size:13px;color:var(--pg-muted2);}
    .activity-text strong{color:var(--pg-text);font-weight:500;}
    .activity-time{font-size:11px;color:var(--pg-muted);white-space:nowrap;}

    .progress-bar{height:4px;background:var(--pg-border2);border-radius:2px;overflow:hidden;}
    .progress-fill{height:100%;border-radius:2px;}

    .section-title{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:700;color:var(--pg-text);margin:0 0 1rem;}
  </style>
{% endblock %}

{% block content %}
  <div class="dash-hero">
    <div>
      <div class="dash-hero-badge"><svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="#a5b4fc"/></svg>Admin</div>
      <h1>Tableau de bord général</h1>
      <p>Vue d'ensemble de toutes les activités BizHub en temps réel.</p>
    </div>
  </div>

  <div class="dash-content">

    <!-- KPI CARDS -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-card-icon blue"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
        <div class="kpi-label">Utilisateurs totaux</div>
        <div class="kpi-value">{{ total_users|number_format(0, '.', ' ') }}</div>
        <div class="kpi-delta up">↑ {{ active_users }} actifs <span>· {{ inactive_users }} inactifs</span></div>
      </div>
      <div class="kpi-card">
        <div class="kpi-card-icon purple"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.8"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 1 2-1.61L23 6H6"/></svg></div>
        <div class="kpi-label">Formations</div>
        <div class="kpi-value">{{ total_formations }}</div>
        <div class="kpi-delta up">E-learning</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-card-icon green"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#06d6a0" stroke-width="1.8"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
        <div class="kpi-label">Revenu Marketplace</div>
        <div class="kpi-value">{{ marketplace_stats.statsByStatut.total_ttc|number_format(0, '.', ' ') }} <span style="font-size:.7em;color:var(--pg-muted);">TND</span></div>
        <div class="kpi-delta up">{{ marketplace_stats.statsByStatut.total_commandes }} commandes</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-card-icon orange"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.8"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
        <div class="kpi-label">Projets</div>
        <div class="kpi-value">{{ total_projects }}</div>
        <div class="kpi-delta up">{{ total_investments }} investissements</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-card-icon pink"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        <div class="kpi-label">Posts Communauté</div>
        <div class="kpi-value">{{ total_posts }}</div>
        <div class="kpi-delta up">Community</div>
      </div>
    </div>

    <!-- CHART ROW 1: User Registrations + User Roles -->
    <div class="chart-grid-2">
      <div class="chart-card">
        <div class="chart-card-head">
          <div>
            <p class="chart-card-title">Inscriptions utilisateurs</p>
            <p class="chart-card-sub">6 derniers mois</p>
          </div>
        </div>
        <div style="position:relative;height:260px;">
          <canvas id="userRegistrationsChart"></canvas>
        </div>
      </div>
      <div class="chart-card">
        <div class="chart-card-head">
          <div>
            <p class="chart-card-title">Répartition par rôle</p>
            <p class="chart-card-sub">{{ total_users }} utilisateurs au total</p>
          </div>
        </div>
        <div style="position:relative;height:260px;">
          <canvas id="userRolesChart"></canvas>
        </div>
      </div>
    </div>

    <!-- CHART ROW 2: Marketplace Revenue + Investment by Sector -->
    <div class="chart-grid-2">
      <div class="chart-card">
        <div class="chart-card-head">
          <div>
            <p class="chart-card-title">Revenu Marketplace</p>
            <p class="chart-card-sub">6 derniers mois (TND)</p>
          </div>
        </div>
        <div style="position:relative;height:260px;">
          <canvas id="marketplaceRevenueChart"></canvas>
        </div>
      </div>
      <div class="chart-card">
        <div class="chart-card-head">
          <div>
            <p class="chart-card-title">Projets par secteur</p>
            <p class="chart-card-sub">{{ total_projects }} projets · Budget: {{ total_budget_required|number_format(0, '.', ' ') }} TND</p>
          </div>
        </div>
        <div style="position:relative;height:260px;">
          <canvas id="sectorChart"></canvas>
        </div>
      </div>
    </div>

    <!-- CHART ROW 3: Orders by Status + Monthly Orders Evolution -->
    <div class="chart-grid-2">
      <div class="chart-card">
        <div class="chart-card-head">
          <div>
            <p class="chart-card-title">Commandes par statut</p>
            <p class="chart-card-sub">Répartition des {{ marketplace_stats.statsByStatut.total_commandes }} commandes</p>
          </div>
        </div>
        <div style="position:relative;height:260px;">
          <canvas id="orderStatusChart"></canvas>
        </div>
      </div>
      <div class="chart-card">
        <div class="chart-card-head">
          <div>
            <p class="chart-card-title">Évolution commandes</p>
            <p class="chart-card-sub">6 derniers mois</p>
          </div>
        </div>
        <div style="position:relative;height:260px;">
          <canvas id="ordersEvolutionChart"></canvas>
        </div>
      </div>
    </div>

    <!-- BOTTOM ROW: Top Products + Recent Posts -->
    <div class="chart-grid-2">
      <!-- Top Products -->
      <div class="chart-card">
        <div class="chart-card-head">
          <div>
            <p class="chart-card-title">🏆 Top 5 Produits (quantité)</p>
          </div>
          <a href="{{ path('admin_marketplace_produits_index') }}" style="font-size:12px;color:#5b6ef5;text-decoration:none;font-weight:700;">Voir tout →</a>
        </div>
        {% if marketplace_stats.topProductsByFrequency|length > 0 %}
          {% for p in marketplace_stats.topProductsByFrequency %}
            <div style="display:flex;align-items:center;gap:1rem;padding:.75rem 0;{% if not loop.last %}border-bottom:1px solid var(--pg-border);{% endif %}">
              <div style="width:36px;height:36px;border-radius:50%;background:{% if loop.index == 1 %}linear-gradient(135deg,#f59e0b,#d97706){% elseif loop.index == 2 %}linear-gradient(135deg,#9ca3af,#6b7280){% elseif loop.index == 3 %}linear-gradient(135deg,#cd7f32,#a05c1e){% else %}var(--pg-surface2){% endif %};display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.82rem;color:{% if loop.index <= 3 %}white{% else %}var(--pg-muted){% endif %};flex-shrink:0;">
                {{ loop.index }}
              </div>
              <div style="flex:1;min-width:0;">
                <div style="font-weight:700;font-size:0.88rem;color:var(--pg-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ p.nomProduit }}</div>
                <div style="font-size:0.7rem;color:var(--pg-muted);">{{ p.categorie ?: 'Non classé' }}</div>
              </div>
              <div style="text-align:right;flex-shrink:0;">
                <div style="font-weight:800;font-size:0.95rem;color:#06d6a0;">{{ p.totalQuantite }} <span style="font-size:0.65rem;color:var(--pg-muted);">unités</span></div>
                <div style="font-size:0.72rem;color:var(--pg-muted);">{{ p.nbCommandes }} cmd</div>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div style="text-align:center;padding:2rem;color:var(--pg-muted);">Aucune donnée disponible</div>
        {% endif %}
      </div>

      <!-- Recent Community Posts -->
      <div class="chart-card">
        <div class="chart-card-head">
          <div>
            <p class="chart-card-title">💬 Posts Récents</p>
            <p class="chart-card-sub">Dernières publications communauté</p>
          </div>
          <a href="#" style="font-size:12px;color:#ec4899;text-decoration:none;font-weight:700;">Voir tout →</a>
        </div>
        {% if recent_posts|length > 0 %}
          {% for post in recent_posts|slice(0, 5) %}
            <div class="activity-item" style="padding:12px 0;border-bottom:{% if not loop.last %}1px solid var(--pg-border){% else %}none{% endif %};">
              <div class="activity-dot {% if loop.index == 1 %}green{% elseif loop.index == 2 %}blue{% elseif loop.index == 3 %}orange{% else %}pink{% endif %}"></div>
              <div class="activity-text">
                <strong>{{ post.title|length > 40 ? post.title|slice(0, 40) ~ '...' : post.title }}</strong>
                <div style="font-size:11px;margin-top:2px;">Par {{ post.author_name ?? 'Inconnu' }}</div>
              </div>
              <div class="activity-time">{{ post.created_at|date('d/m H:i') }}</div>
            </div>
          {% endfor %}
        {% else %}
          <div style="text-align:center;padding:2rem;color:var(--pg-muted);">Aucun post récent</div>
        {% endif %}
      </div>
    </div>

    <!-- ORDER STATUS BREAKDOWN -->
    <div class="chart-card" style="margin-bottom:2rem;">
      <div class="chart-card-head">
        <p class="chart-card-title">📊 Détail des commandes par statut</p>
      </div>
      {% set statuts = marketplace_stats.statsByStatut.statuts %}
      {% for statut, data in statuts %}
        {% set pct = marketplace_stats.statsByStatut.total_commandes > 0 ? ((data.count / marketplace_stats.statsByStatut.total_commandes) * 100)|round(0) : 0 %}
        {% set color = statut == 'en_attente' ? '#fbbf24'
          : (statut == 'confirmee' ? '#34d399'
          : (statut == 'payee' ? '#06d6a0'
          : (statut == 'annulee' ? '#f87171'
          : (statut == 'livree' ? '#60a5fa'
          : '#a78bfa')))) %}
        <div style="margin-bottom:0.9rem;">
          <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
            <span style="font-size:0.78rem;color:var(--pg-text);font-weight:600;text-transform:capitalize;">{{ statut|replace({'_': ' '}) }}</span>
            <span style="font-size:0.78rem;color:var(--pg-muted);font-weight:700;">{{ data.count }} cmd ({{ pct }}%) · {{ data.total_ttc|number_format(0, '.', ' ') }} TND</span>
          </div>
          <div class="progress-bar">
            <div class="progress-fill" style="background:{{ color }};width:{{ pct }}%;"></div>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const gridColor = 'rgba(255,255,255,.06)';
      const tickColor = '#64748b';

      Chart.defaults.color = tickColor;
      Chart.defaults.borderColor = gridColor;

      // User Registrations Line Chart
      var regCtx = document.getElementById('userRegistrationsChart');
      if (regCtx) {
        new Chart(regCtx, {
          type: 'line',
          data: {
            labels: {{ monthly_labels|json_encode|raw }},
            datasets: [{
              label: 'Nouveaux utilisateurs',
              data: {{ monthly_data|json_encode|raw }},
              borderColor: '#5b6ef5',
              backgroundColor: 'rgba(91,110,245,.1)',
              borderWidth: 2,
              pointBackgroundColor: '#5b6ef5',
              pointRadius: 4,
              pointHoverRadius: 6,
              fill: true,
              tension: .4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: '#1a1d27',
                titleColor: '#9ca3af',
                bodyColor: '#f0f2ff',
                borderColor: '#2a2d3a',
                borderWidth: 1
              }
            },
            scales: {
              y: { grid: { color: gridColor, drawBorder: false }, ticks: { color: tickColor, padding: 12 }, beginAtZero: true },
              x: { grid: { color: gridColor, drawBorder: false }, ticks: { color: tickColor, padding: 8 } }
            }
          }
        });
      }

      // User Roles Doughnut Chart
      var roleCtx = document.getElementById('userRolesChart');
      if (roleCtx) {
        new Chart(roleCtx, {
          type: 'doughnut',
          data: {
            labels: {{ user_role_labels|json_encode|raw }},
            datasets: [{
              data: {{ user_role_data|json_encode|raw }},
              backgroundColor: {{ user_role_colors|json_encode|raw }},
              borderColor: '#0e1220',
              borderWidth: 3,
              hoverOffset: 6
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { position: 'bottom', labels: { color: '#9ca3af', padding: 16, font: { size: 12 } } },
              tooltip: {
                backgroundColor: '#1a1d27',
                titleColor: '#9ca3af',
                bodyColor: '#f0f2ff',
                borderColor: '#2a2d3a',
                borderWidth: 1,
                callbacks: {
                  label: function(ctx) {
                    var total = ctx.dataset.data.reduce(function(a,b){return a+b;},0);
                    var pct = total > 0 ? Math.round(ctx.parsed / total * 100) : 0;
                    return ctx.label + ': ' + ctx.parsed + ' (' + pct + '%)';
                  }
                }
              }
            },
            cutout: '65%'
          }
        });
      }

      // Marketplace Revenue Bar Chart
      var revCtx = document.getElementById('marketplaceRevenueChart');
      if (revCtx) {
        new Chart(revCtx, {
          type: 'bar',
          data: {
            labels: {{ marketplace_revenue_labels|json_encode|raw }},
            datasets: [{
              label: 'CA TTC (TND)',
              data: {{ marketplace_revenue_data|json_encode|raw }},
              backgroundColor: 'rgba(91,110,245,.7)',
              borderColor: '#5b6ef5',
              borderWidth: 2,
              borderRadius: 6,
              barThickness: 20
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: '#1a1d27',
                titleColor: '#9ca3af',
                bodyColor: '#f0f2ff',
                borderColor: '#2a2d3a',
                borderWidth: 1,
                callbacks: {
                  label: function(ctx) { return Number(ctx.parsed.y).toLocaleString('fr-TN') + ' TND'; }
                }
              }
            },
            scales: {
              y: { grid: { color: gridColor, drawBorder: false }, ticks: { color: tickColor, callback: function(v) { return v.toLocaleString() + ' TND'; } }, beginAtZero: true },
              x: { grid: { display: false }, ticks: { color: tickColor } }
            }
          }
        });
      }

      // Projects by Sector Bar Chart
      var sectorCtx = document.getElementById('sectorChart');
      if (sectorCtx) {
        new Chart(sectorCtx, {
          type: 'bar',
          data: {
            labels: {{ sector_labels|json_encode|raw }},
            datasets: [{
              label: 'Nombre de projets',
              data: {{ sector_data|json_encode|raw }},
              backgroundColor: 'rgba(6,214,160,.7)',
              borderColor: '#06d6a0',
              borderWidth: 2,
              borderRadius: 6,
              barThickness: 20
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: '#1a1d27',
                titleColor: '#9ca3af',
                bodyColor: '#f0f2ff',
                borderColor: '#2a2d3a',
                borderWidth: 1
              }
            },
            scales: {
              y: { grid: { color: gridColor, drawBorder: false }, ticks: { color: tickColor, stepSize: 1 }, beginAtZero: true },
              x: { grid: { display: false }, ticks: { color: tickColor } }
            }
          }
        });
      }

      // Order Status Pie Chart
      var statusCtx = document.getElementById('orderStatusChart');
      if (statusCtx) {
        var statusLabels = [];
        var statusData = [];
        var statusColors = [];
        {% for statut, data in marketplace_stats.statsByStatut.statuts %}
          {% set sc = statut %}
          {% set sc_color = sc == 'en_attente' ? '#fbbf24' : (sc == 'confirmee' ? '#34d399' : (sc == 'payee' ? '#06d6a0' : (sc == 'annulee' ? '#f87171' : (sc == 'livree' ? '#60a5fa' : '#a78bfa')))) %}
          statusLabels.push('{{ statut|replace({'_': ' '})|capitalize }}');
          statusData.push({{ data.count }});
          statusColors.push('{{ sc_color }}');
        {% endfor %}

        new Chart(statusCtx, {
          type: 'pie',
          data: {
            labels: statusLabels,
            datasets: [{
              data: statusData,
              backgroundColor: statusColors,
              borderColor: '#0e1220',
              borderWidth: 2,
              hoverOffset: 8
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { position: 'bottom', labels: { color: '#9ca3af', padding: 12, font: { size: 11 } } },
              tooltip: {
                backgroundColor: '#1a1d27',
                titleColor: '#9ca3af',
                bodyColor: '#f0f2ff',
                borderColor: '#2a2d3a',
                borderWidth: 1
              }
            }
          }
        });
      }

      // Orders Evolution Line Chart
      var evoCtx = document.getElementById('ordersEvolutionChart');
      if (evoCtx) {
        new Chart(evoCtx, {
          type: 'line',
          data: {
            labels: {{ orders_evolution_labels|json_encode|raw }},
            datasets: [{
              label: 'Nombre de commandes',
              data: {{ orders_evolution_data|json_encode|raw }},
              borderColor: '#10b981',
              backgroundColor: 'rgba(16,185,129,.1)',
              borderWidth: 3,
              pointRadius: 5,
              pointBackgroundColor: '#10b981',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              pointHoverRadius: 7,
              tension: 0.3,
              fill: true
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: '#1a1d27',
                titleColor: '#9ca3af',
                bodyColor: '#f0f2ff',
                borderColor: '#2a2d3a',
                borderWidth: 1
              }
            },
            scales: {
              y: { grid: { color: gridColor, drawBorder: false }, ticks: { color: tickColor, stepSize: 1 }, beginAtZero: true },
              x: { grid: { color: gridColor, drawBorder: false }, ticks: { color: tickColor } }
            }
          }
        });
      }
    });
  </script>
{% endblock %}
