    },
    options:{plugins:{legend:{display:false},tooltip:{backgroundColor:'#1a1d27',titleColor:'#9ca3af',bodyColor:'#f0f2ff',borderColor:'#2a2d3a',borderWidth:1,padding:{x:14,y:10}}},scales:{y:{grid:{color:gridColor,drawBorder:false},ticks:{color:tickColor,padding:12},border:{display:false}},x:{grid:{color:gridColor,drawBorder:false},ticks:{color:tickColor,padding:8},border:{display:false}}},responsive:true}
  });

