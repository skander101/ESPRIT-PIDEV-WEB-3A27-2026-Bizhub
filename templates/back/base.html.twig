<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}Dashboard{% endblock %}</title>
  <link rel="shortcut icon" href="{{ asset('assets/back/images/logo_dark.png') }}" type="image/png" />

  {% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/back/css/bootstrap.min.css') }}" />
    <link rel="stylesheet" href="{{ asset('assets/back/css/lineicons.css') }}" />
    <link rel="stylesheet" href="{{ asset('assets/back/css/materialdesignicons.min.css') }}" />
    <link rel="stylesheet" href="{{ asset('assets/back/css/main.css') }}" />
    <link rel="stylesheet" href="{{ asset('assets/back/css/dark-mode.css') }}" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  {% endblock %}

  <style>
    :root {
      --nb-bg:#0f1117; --nb-surface:#1a1d27; --nb-border:#2a2d3a;
      --nb-accent:#5b6ef5; --nb-accent2:#8b5cf6; --nb-accent3:#06d6a0;
      --nb-text:#e2e8f0; --nb-muted:#64748b; --nb-hover:#242736;
      --pg-bg:#080b12; --pg-surface:#0e1220; --pg-surface2:#141826;
      --pg-border:rgba(255,255,255,.07); --pg-border2:rgba(255,255,255,.12);
      --pg-text:#f0f2ff; --pg-muted:#6b7280; --pg-muted2:#9ca3af;
    }
    *,*::before,*::after{box-sizing:border-box;}
    html,body{height:100%;margin:0;padding:0;}
    body.dark-mode{background:var(--pg-bg)!important;font-family:'DM Sans',sans-serif;overflow-x:hidden;}

    /* Hide preloader completely */
    #preloader{display:none !important;opacity:0 !important;pointer-events:none !important;}

    /* Page Transition Animation */
    @keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
    .main-wrapper{opacity:0;transition:opacity 0.5s cubic-bezier(0.4,0,0.2,1);}
    .main-wrapper.visible{opacity:1;}

    /* Dropdown Animation */
    @keyframes slideDown{from{opacity:0;transform:translateY(-10px);}to{opacity:1;transform:translateY(0);}}
    .collapse{max-height:0;overflow:hidden;opacity:0;transition:max-height .4s ease,opacity .4s ease;}
    .collapse.show{max-height:none;opacity:1;overflow:visible;animation:slideDown .4s ease-out;transition:none;}
    .dropdown-nav li{transition:background .15s ease;}

    /* Sidebar rail: keep a slim strip visible and expand on hover */
    :root {
      --sidebar-collapsed: 72px;
      --sidebar-expanded: 260px;
    }

    .sidebar-nav-wrapper {
      width: var(--sidebar-expanded) !important;
      transform: translateX(calc(-1 * (var(--sidebar-expanded) - var(--sidebar-collapsed))));
      transition: transform .22s ease;
      z-index: 1200;
    }

    .sidebar-nav-wrapper:hover,
    .sidebar-nav-wrapper.open {
      transform: translateX(0);
    }

    .plain-navbar {
      left: var(--sidebar-collapsed);
      width: calc(100% - var(--sidebar-collapsed));
      transition: left .22s ease, width .22s ease;
    }

    .page-wrapper {
      padding-left: var(--sidebar-collapsed);
      transition: padding-left .22s ease;
    }

    .main-wrapper {
      margin-left: 0 !important;
    }

    .sidebar-nav-wrapper:hover ~ .plain-navbar,
    .sidebar-nav-wrapper.open ~ .plain-navbar {
      left: var(--sidebar-expanded);
      width: calc(100% - var(--sidebar-expanded));
    }

    .sidebar-nav-wrapper:hover ~ .page-wrapper,
    .sidebar-nav-wrapper.open ~ .page-wrapper {
      padding-left: var(--sidebar-expanded);
    }

    @media (max-width: 992px) {
      .sidebar-nav-wrapper {
        transform: translateX(-100%);
      }

      .sidebar-nav-wrapper.open {
        transform: translateX(0);
      }

      .plain-navbar {
        left: 0;
        width: 100%;
      }

      .page-wrapper {
        padding-left: 0;
      }
    }
  </style>

  {% block extra_stylesheets %}{% endblock %}
</head>
<body class="dark-mode">
  <div id="preloader"><div class="spinner" style="width:36px;height:36px;border:2px solid rgba(255,255,255,.08);border-top-color:var(--nb-accent);border-radius:50%;animation:spin .8s linear infinite;"></div></div>

  {% include 'back/partials/sidebar.html.twig' %}

  {% block navbar %}
  <nav class="plain-navbar" id="plainNavbar">
    <div class="nb-left">
      <img src="{{ asset('assets/back/images/logo/logo.png') }}" alt="BizHub" style="height:32px;width:auto;margin-right:12px;">
      <div class="nb-site-title"><span style="color:#ffbe33 !important;">Biz</span><span style="color:#ffffff !important;">Hub</span></div>
      <div class="nb-breadcrumb">
        <a href="{{ path('app_admin_dashboard') }}">Home</a>
        <span class="sep">/</span>
        <span class="current">{% block breadcrumb %}Dashboard{% endblock %}</span>
      </div>
    </div>
    <div class="nb-center">
      <div class="nb-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" placeholder="Search…" />
      </div>
    </div>
    <div class="nb-right">
      <div class="nb-icon-btn" title="Notifications">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.8"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <div class="nb-badge"></div>
      </div>
      <div class="nb-divider"></div>
      <div class="nb-user-pill" id="nbUserPill" onclick="nbToggleDropdown()">
        <div class="nb-avatar">AJ</div>
        <div class="nb-user-info">
          <span class="nb-user-name">Admin</span>
          <span class="nb-user-role">Administrator</span>
        </div>
        <svg class="nb-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        <div class="nb-dropdown" id="nbDropdown">
          <a href="{{ path('app_user_profile') }}" class="nb-dd-item" style="text-decoration:none;color:inherit;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Profile</a>
          <div class="nb-dd-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>Settings</div>
          <div class="nb-dd-sep"></div>
          <a href="{{ path('app_logout') }}" class="nb-dd-item danger" style="text-decoration:none;color:inherit;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Logout</a>
        </div>
      </div>
    </div>
  </nav>
  {% endblock %}

  <div class="page-wrapper">
    <main class="main-wrapper">
      {% block content %}{% endblock %}
    </main>
  </div>

  {% block javascripts %}
    <script src="{{ asset('assets/back/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ asset('assets/back/js/Chart.min.js') }}"></script>
    <script src="{{ asset('assets/back/js/main.js') }}"></script>
    <script>
      // Page transition animation
      const mainWrapper = document.querySelector('.main-wrapper');

      // Fade in on page load
      window.addEventListener('load', () => {
        mainWrapper.classList.add('visible');
      });

      // Fade out on navigation
      document.addEventListener('click', (e) => {
        const link = e.target.closest('a');
        if (link && !link.href.includes('#') && !link.target && link.href.startsWith(window.location.origin)) {
          e.preventDefault();
          mainWrapper.classList.remove('visible');
          setTimeout(() => {
            window.location.href = link.href;
          }, 400);
        }
      }, true);

      let nbDdOpen=false;
      function nbToggleDropdown(){nbDdOpen=!nbDdOpen;document.getElementById('nbDropdown').classList.toggle('open',nbDdOpen);document.getElementById('nbUserPill').classList.toggle('open',nbDdOpen);}
      document.addEventListener('click',function(e){const p=document.getElementById('nbUserPill');if(p&&!p.contains(e.target)){nbDdOpen=false;document.getElementById('nbDropdown').classList.remove('open');p.classList.remove('open');}});
    </script>
  {% endblock %}
</body>
</html>
