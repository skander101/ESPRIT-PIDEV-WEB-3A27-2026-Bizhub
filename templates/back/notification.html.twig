<script>
  window.addEventListener('load',()=>{setTimeout(()=>document.getElementById('preloader').classList.add('hidden'),400);});

  function nbSetActive(el){el.closest('.nb-quick-actions').querySelectorAll('.nb-qa-btn').forEach(b=>b.classList.remove('active'));el.classList.add('active');}
  let nbDark=true;
  function nbToggleDark(){nbDark=!nbDark;document.getElementById('nbToggle').classList.toggle('on',nbDark);document.getElementById('nbToggleLabel').textContent=nbDark?'Sombre':'Clair';}
  let nbDdOpen=false;
  function nbToggleDropdown(){nbDdOpen=!nbDdOpen;document.getElementById('nbDropdown').classList.toggle('open',nbDdOpen);document.getElementById('nbUserPill').classList.toggle('open',nbDdOpen);}
  document.addEventListener('click',function(e){
    const p=document.getElementById('nbUserPill');
    if(p&&!p.contains(e.target)){nbDdOpen=false;document.getElementById('nbDropdown').classList.remove('open');p.classList.remove('open');}
    if(!e.target.closest('.na-more-wrap')) document.querySelectorAll('.na-more-dd').forEach(d=>d.classList.remove('open'));
  });

  function toggleMore(btn){
    const dd=btn.nextElementSibling;
    const isOpen=dd.classList.contains('open');
    document.querySelectorAll('.na-more-dd').forEach(d=>d.classList.remove('open'));
    if(!isOpen) dd.classList.add('open');
  }

  function removeNotif(btn){
    const item=btn.closest('.notif-item');
    item.style.transition='opacity .3s,transform .3s,max-height .4s';
    item.style.opacity='0';
    item.style.transform='translateX(20px)';
    setTimeout(()=>item.remove(),350);
  }

  function markRead(el){
    const item=el.closest('.notif-item');
    item.classList.remove('unread');
    const dot=item.querySelector('.notif-dot');
    if(dot) dot.remove();
  }

  function markAllRead(){
    document.querySelectorAll('.notif-item.unread').forEach(item=>{
      item.classList.remove('unread');
      const dot=item.querySelector('.notif-dot');
      if(dot) dot.remove();
    });
  }

  function clearAll(){
    const items=document.querySelectorAll('.notif-item');
    items.forEach((item,i)=>{
      setTimeout(()=>{item.style.transition='opacity .2s,transform .2s';item.style.opacity='0';item.style.transform='translateX(20px)';setTimeout(()=>item.remove(),200);},i*60);
    });
  }

  function handleCheck(cb){
    const item=cb.closest('.notif-item');
    if(cb.checked) item.style.background='rgba(91,110,245,.07)';
    else item.style.background='';
  }

  function switchTab(btn,type){
    document.querySelectorAll('.ntab').forEach(t=>t.classList.remove('active'));
    btn.classList.add('active');
    const items=document.querySelectorAll('.notif-item');
    items.forEach(item=>{
      if(type==='all') item.style.display='';
      else if(type==='unread') item.style.display=item.classList.contains('unread')?'':'none';
      else item.style.display='';
    });
  }
</script>
</body>
</html>