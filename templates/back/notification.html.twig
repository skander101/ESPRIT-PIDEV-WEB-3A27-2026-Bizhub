  <style>
    :root {
      --nb-bg:#0f1117; --nb-surface:#1a1d27; --nb-border:#2a2d3a;
      --nb-accent:#5b6ef5; --nb-accent2:#8b5cf6; --nb-accent3:#06d6a0;
      --nb-text:#e2e8f0; --nb-muted:#64748b; --nb-hover:#242736;
      --pg-bg:#080b12; --pg-surface:#0e1220; --pg-surface2:#141826;
      --pg-border:rgba(255,255,255,.07); --pg-border2:rgba(255,255,255,.12);
      --pg-text:#f0f2ff; --pg-muted:#6b7280; --pg-muted2:#9ca3af;
    }
    *,*::before,*::after{box-sizing:border-box;}
    body.dark-mode{background:var(--pg-bg)!important;font-family:'DM Sans',sans-serif;}

    #preloader{position:fixed;inset:0;z-index:9999;background:var(--pg-bg);display:flex;align-items:center;justify-content:center;transition:opacity .5s;}
    #preloader.hidden{opacity:0;pointer-events:none;}
    .spinner{width:36px;height:36px;border:2px solid rgba(255,255,255,.08);border-top-color:var(--nb-accent);border-radius:50%;animation:spin .8s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg);}}

    /* ── NAVBAR (same as tables/index) ── */
    .plain-navbar{width:100%;background:var(--nb-bg);border-bottom:1px solid var(--nb-border);display:flex;align-items:center;height:64px;padding:0 1.5rem;position:fixed;top:0;left:0;right:0;z-index:1100;font-family:'DM Sans',sans-serif;}
    .plain-navbar::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--nb-accent),var(--nb-accent2),transparent);opacity:.5;}
    .nb-left{display:flex;align-items:center;gap:14px;flex:0 0 auto;}
    .nb-logo{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--nb-accent),var(--nb-accent2));display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
    .nb-site-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--nb-text);letter-spacing:-.3px;}
    .nb-site-title span{font-weight:400;}
    .nb-breadcrumb{display:flex;align-items:center;gap:7px;margin-left:18px;padding-left:18px;border-left:1px solid var(--nb-border);}
    .nb-breadcrumb a{font-size:13px;color:var(--nb-muted);text-decoration:none;transition:color .2s;}
    .nb-breadcrumb a:hover{color:var(--nb-text);}
    .nb-breadcrumb .sep{color:var(--nb-border);}
    .nb-breadcrumb .current{font-size:13px;color:var(--nb-text);font-weight:500;}
    .nb-center{flex:1;display:flex;justify-content:center;}
    .nb-search{position:relative;width:280px;}
    .nb-search svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);opacity:.4;pointer-events:none;}
    .nb-search input{width:100%;height:38px;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;color:var(--nb-text);font-size:13px;font-family:'DM Sans',sans-serif;padding:0 12px 0 36px;outline:none;transition:border-color .2s,box-shadow .2s;}
    .nb-search input::placeholder{color:var(--nb-muted);}
    .nb-search input:focus{border-color:var(--nb-accent);box-shadow:0 0 0 3px rgba(91,110,245,.12);}
    .nb-right{display:flex;align-items:center;gap:6px;flex:0 0 auto;}
    .nb-icon-btn{width:38px;height:38px;border-radius:9px;background:var(--nb-surface);border:1px solid var(--nb-border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .2s,border-color .2s;position:relative;}
    .nb-icon-btn:hover{background:var(--nb-hover);border-color:#3a3d50;}
    .nb-icon-btn svg{opacity:.7;transition:opacity .2s;}
    .nb-icon-btn:hover svg{opacity:1;}
    .nb-badge{position:absolute;top:6px;right:6px;width:7px;height:7px;border-radius:50%;background:#ef4444;border:1.5px solid var(--nb-bg);}
    .nb-badge.blue{background:var(--nb-accent);}
    .nb-quick-actions{display:flex;align-items:center;gap:3px;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;padding:3px;}
    .nb-qa-btn{padding:5px 11px;border-radius:6px;font-size:12px;font-weight:500;color:var(--nb-muted);cursor:pointer;transition:all .2s;white-space:nowrap;border:none;background:transparent;font-family:'DM Sans',sans-serif;}
    .nb-qa-btn:hover{color:var(--nb-text);background:var(--nb-hover);}
    .nb-qa-btn.active{color:#fff;background:var(--nb-accent);}
    .nb-divider{width:1px;height:22px;background:var(--nb-border);margin:0 4px;}
    .nb-toggle-wrap{display:flex;align-items:center;gap:8px;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;padding:5px 11px;cursor:pointer;transition:border-color .2s;}
    .nb-toggle-wrap:hover{border-color:#3a3d50;}
    .nb-toggle-label{font-size:12px;color:var(--nb-muted);font-weight:500;}
    .nb-toggle{width:30px;height:16px;background:#2a2d3a;border-radius:20px;position:relative;transition:background .3s;}
    .nb-toggle.on{background:var(--nb-accent);}
    .nb-toggle-knob{width:12px;height:12px;background:#fff;border-radius:50%;position:absolute;top:2px;left:2px;transition:transform .3s;}
    .nb-toggle.on .nb-toggle-knob{transform:translateX(14px);}
    .nb-user-pill{display:flex;align-items:center;gap:9px;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;padding:4px 10px 4px 6px;cursor:pointer;transition:border-color .2s,background .2s;position:relative;}
    .nb-user-pill:hover{border-color:#3a3d50;background:var(--nb-hover);}
    .nb-avatar{width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,var(--nb-accent),var(--nb-accent2));display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;flex-shrink:0;}
    .nb-user-info{display:flex;flex-direction:column;line-height:1.2;}
    .nb-user-name{font-size:13px;font-weight:500;color:var(--nb-text);}
    .nb-user-role{font-size:11px;color:var(--nb-muted);}
    .nb-chevron{opacity:.4;transition:opacity .2s,transform .3s;}
    .nb-user-pill:hover .nb-chevron{opacity:.8;}
    .nb-user-pill.open .nb-chevron{transform:rotate(180deg);}
    .nb-dropdown{position:absolute;top:calc(100% + 8px);right:0;background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:11px;width:185px;overflow:hidden;opacity:0;transform:translateY(-6px);pointer-events:none;transition:opacity .2s,transform .2s;z-index:999;box-shadow:0 10px 30px rgba(0,0,0,.5);}
    .nb-dropdown.open{opacity:1;transform:translateY(0);pointer-events:all;}
    .nb-dd-item{display:flex;align-items:center;gap:10px;padding:9px 14px;font-size:13px;color:var(--nb-muted);cursor:pointer;transition:background .15s,color .15s;}
    .nb-dd-item:hover{background:var(--nb-hover);color:var(--nb-text);}
    .nb-dd-item.danger:hover{color:#ef4444;}
    .nb-dd-sep{height:1px;background:var(--nb-border);margin:2px 0;}

    /* ── LAYOUT ── */
    .page-wrapper{display:flex;padding-top:64px;min-height:100vh;}
    .sidebar-nav-wrapper{position:fixed!important;top:64px!important;height:calc(100vh - 64px)!important;}
    .main-wrapper{margin-left:260px;flex:1;min-height:calc(100vh - 64px);background:var(--pg-bg);}

    /* ── NOTIFICATION PAGE ── */
    .notif-hero{
      padding:2rem 2rem 1.5rem;
      border-bottom:1px solid var(--pg-border2);
      display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem;
    }
    .notif-hero-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(6,214,160,.08);border:1px solid rgba(6,214,160,.2);border-radius:6px;padding:3px 12px;font-size:11px;font-weight:500;color:var(--nb-accent3);letter-spacing:.5px;text-transform:uppercase;margin-bottom:.6rem;}
    .notif-hero h1{font-family:'Syne',sans-serif;font-size:1.7rem;font-weight:800;color:var(--pg-text);letter-spacing:-.4px;margin:0 0 .3rem;}
    .notif-hero p{font-size:13px;color:var(--pg-muted2);font-weight:300;margin:0;}
    .notif-hero-right{display:flex;gap:10px;align-items:center;}

    .btn-outline-nb{height:38px;padding:0 16px;background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:9px;color:var(--pg-muted2);font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:7px;}
    .btn-outline-nb:hover{border-color:rgba(255,255,255,.22);color:var(--pg-text);}
    .btn-danger-nb{height:38px;padding:0 16px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:9px;color:#f87171;font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:7px;}
    .btn-danger-nb:hover{background:rgba(239,68,68,.18);}

    .notif-content{padding:2rem;}

    /* Summary cards */
    .notif-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:2rem;}
    .ns-card{background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:12px;padding:1rem 1.25rem;display:flex;align-items:center;gap:14px;}
    .ns-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .ns-icon.purple{background:rgba(139,92,246,.15);}
    .ns-icon.blue{background:rgba(91,110,245,.15);}
    .ns-icon.green{background:rgba(6,214,160,.15);}
    .ns-icon.red{background:rgba(239,68,68,.15);}
    .ns-val{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:700;color:var(--pg-text);}
    .ns-label{font-size:12px;color:var(--pg-muted);}

    /* Tabs */
    .notif-tabs{display:flex;gap:4px;background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:10px;padding:4px;margin-bottom:1.5rem;width:fit-content;}
    .ntab{padding:7px 18px;border-radius:7px;font-size:13px;font-weight:500;color:var(--pg-muted2);cursor:pointer;transition:all .2s;border:none;background:transparent;font-family:'DM Sans',sans-serif;}
    .ntab:hover{color:var(--pg-text);}
    .ntab.active{background:var(--nb-accent);color:#fff;}
    .notif-count{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:#ef4444;color:#fff;font-size:10px;font-weight:700;margin-left:6px;}

    /* Notification list */
    .notif-list{background:var(--pg-surface);border:1px solid var(--pg-border2);border-radius:14px;overflow:hidden;}
    .notif-list-head{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;border-bottom:1px solid var(--pg-border2);}
    .notif-list-title{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--pg-text);}
    .mark-all-btn{font-size:12px;color:var(--nb-accent);background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:color .2s;}
    .mark-all-btn:hover{color:#818cf8;}

    /* Single notification */
    .notif-item{
      display:flex;align-items:flex-start;gap:14px;
      padding:1rem 1.5rem;
      border-bottom:1px solid var(--pg-border);
      transition:background .15s;
      position:relative;
    }
    .notif-item:last-child{border-bottom:none;}
    .notif-item:hover{background:rgba(255,255,255,.03);}
    .notif-item.unread{background:rgba(91,110,245,.04);}
    .notif-item.unread::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--nb-accent);border-radius:0 3px 3px 0;}

    .notif-check{flex-shrink:0;margin-top:3px;}
    .notif-check input{width:15px;height:15px;accent-color:var(--nb-accent);cursor:pointer;}

    .notif-avatar-wrap{flex-shrink:0;position:relative;}
    .notif-avatar{
      width:42px;height:42px;border-radius:11px;
      display:flex;align-items:center;justify-content:center;
      font-size:16px;font-weight:700;color:#fff;
    }
    .notif-avatar.purple{background:linear-gradient(135deg,#8b5cf6,#a78bfa);}
    .notif-avatar.blue{background:linear-gradient(135deg,var(--nb-accent),#818cf8);}
    .notif-avatar.green{background:linear-gradient(135deg,#059669,var(--nb-accent3));}
    .notif-avatar.orange{background:linear-gradient(135deg,#d97706,#f59e0b);}
    .notif-avatar.red{background:linear-gradient(135deg,#dc2626,#ef4444);}
    .notif-avatar.teal{background:linear-gradient(135deg,#0891b2,#06b6d4);}
    .notif-avatar img{width:100%;height:100%;object-fit:cover;border-radius:11px;}

    .notif-dot{position:absolute;top:-2px;right:-2px;width:9px;height:9px;border-radius:50%;background:#ef4444;border:2px solid var(--pg-surface);}

    .notif-body{flex:1;min-width:0;}
    .notif-title{font-size:14px;font-weight:500;color:var(--pg-text);margin:0 0 4px;line-height:1.4;}
    .notif-desc{font-size:13px;color:var(--pg-muted2);font-weight:300;margin:0 0 6px;line-height:1.5;}
    .notif-meta{display:flex;align-items:center;gap:10px;}
    .notif-time{font-size:11px;color:var(--pg-muted);}
    .notif-tag{font-size:10px;font-weight:600;padding:2px 8px;border-radius:100px;letter-spacing:.3px;}
    .notif-tag.product{background:rgba(91,110,245,.12);color:#818cf8;}
    .notif-tag.design{background:rgba(139,92,246,.12);color:#a78bfa;}
    .notif-tag.system{background:rgba(6,214,160,.12);color:#06d6a0;}
    .notif-tag.promo{background:rgba(245,158,11,.12);color:#f59e0b;}
    .notif-tag.alert{background:rgba(239,68,68,.12);color:#f87171;}

    .notif-actions{display:flex;align-items:center;gap:6px;flex-shrink:0;}
    .na-btn{width:32px;height:32px;border-radius:8px;background:transparent;border:1px solid var(--pg-border2);color:var(--pg-muted);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;font-size:14px;}
    .na-btn:hover{border-color:rgba(255,255,255,.2);color:var(--pg-text);background:var(--pg-hover);}
    .na-btn.del:hover{border-color:rgba(239,68,68,.3);color:#f87171;background:rgba(239,68,68,.08);}

    /* Dropdown menu for more actions */
    .na-more-wrap{position:relative;}
    .na-more-dd{position:absolute;right:0;top:calc(100% + 6px);background:var(--nb-surface);border:1px solid var(--nb-border);border-radius:9px;width:160px;overflow:hidden;opacity:0;transform:translateY(-4px);pointer-events:none;transition:opacity .15s,transform .15s;z-index:99;box-shadow:0 6px 20px rgba(0,0,0,.4);}
    .na-more-dd.open{opacity:1;transform:translateY(0);pointer-events:all;}
    .na-more-dd-item{padding:8px 12px;font-size:13px;color:var(--nb-muted);cursor:pointer;transition:background .15s,color .15s;}
    .na-more-dd-item:hover{background:var(--nb-hover);color:var(--nb-text);}

    /* Load more */
    .notif-load-more{display:flex;align-items:center;justify-content:center;padding:1.25rem;border-top:1px solid var(--pg-border);}
    .load-more-btn{height:38px;padding:0 24px;background:transparent;border:1px solid var(--pg-border2);border-radius:9px;color:var(--pg-muted2);font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;}
    .load-more-btn:hover{border-color:var(--nb-accent);color:var(--nb-accent);}

    /* Footer */
    .nb-footer{padding:1.25rem 2rem;border-top:1px solid var(--pg-border2);display:flex;align-items:center;justify-content:space-between;font-size:12px;color:var(--pg-muted);}
    .nb-footer a{color:var(--pg-muted);text-decoration:none;transition:color .2s;margin-left:16px;}
    .nb-footer a:hover{color:var(--pg-text);}

    @media(max-width:1100px){.notif-summary{grid-template-columns:1fr 1fr;}}
    @media(max-width:768px){.main-wrapper{margin-left:0;}.notif-summary{grid-template-columns:1fr 1fr;}}
  </style>
</head>
