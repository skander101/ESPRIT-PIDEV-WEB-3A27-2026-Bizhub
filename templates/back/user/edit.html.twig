{% extends 'back/base.html.twig' %}

{% block title %}Edit User{% endblock %}
{% block breadcrumb %}Edit User{% endblock %}

{% block content %}
<div style="padding:2rem;max-width:1000px;">
    <h2 style="font-size:1.5rem;color:var(--pg-text);margin-bottom:2rem;">Edit User - {{ user.fullName }}</h2>

    <div class="dash-panel">
        <form method="POST" style="display:grid;gap:1.5rem;">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_user') }}">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
                <div>
                    <label style="display:block;color:var(--pg-text);font-weight:700;margin-bottom:0.5rem;font-size:0.85rem;text-transform:uppercase;">Full Name</label>
                    <input type="text" value="{{ user.fullName }}" disabled style="width:100%;background:var(--pg-surface);border:1px solid var(--pg-border);color:var(--pg-text);padding:0.8rem;border-radius:6px;opacity:0.7;cursor:not-allowed;">
                    <p style="font-size:0.75rem;color:var(--pg-muted);margin-top:0.3rem;">This field cannot be changed here. Use profile edit.</p>
                </div>
                <div>
                    <label style="display:block;color:var(--pg-text);font-weight:700;margin-bottom:0.5rem;font-size:0.85rem;text-transform:uppercase;">Email</label>
                    <input type="text" value="{{ user.email }}" disabled style="width:100%;background:var(--pg-surface);border:1px solid var(--pg-border);color:var(--pg-text);padding:0.8rem;border-radius:6px;opacity:0.7;cursor:not-allowed;">
                </div>
                <div>
                    <label style="display:block;color:var(--pg-text);font-weight:700;margin-bottom:0.5rem;font-size:0.85rem;text-transform:uppercase;">User Type</label>
                    <select disabled style="width:100%;background:var(--pg-surface);border:1px solid var(--pg-border);color:var(--pg-text);padding:0.8rem;border-radius:6px;opacity:0.7;cursor:not-allowed;">
                        <option selected>{{ user.userType|capitalize }}</option>
                    </select>
                </div>
                <div>
                    <label style="display:block;color:var(--pg-text);font-weight:700;margin-bottom:0.5rem;font-size:0.85rem;text-transform:uppercase;">Status</label>
                    <select name="is_active" style="width:100%;background:var(--pg-surface);border:1px solid var(--pg-border);color:var(--pg-text);padding:0.8rem;border-radius:6px;">
                        <option value="1" {% if user.isActive %}selected{% endif %}>Active</option>
                        <option value="0" {% if not user.isActive %}selected{% endif %}>Inactive</option>
                    </select>
                </div>
            </div>

            <div style="padding:1rem;background:var(--pg-surface);border-radius:6px;border-left:3px solid #8b5cf6;">
                <p style="color:var(--pg-muted2);font-size:0.85rem;">
                    <strong>Admin Note:</strong> Most user information cannot be changed by admins from this page. Users should update their own profile information. You can only manage user status here.
                </p>
            </div>

            <div style="display:flex;gap:1rem;">
                <button type="submit" style="background:#5b6ef5;color:white;padding:0.9rem 2rem;border-radius:6px;border:none;font-weight:700;cursor:pointer;transition:background 0.2s;">Save Changes</button>
                <a href="{{ path('app_admin_user_show', {'id': user.userId}) }}" style="background:var(--pg-surface);color:var(--pg-text);padding:0.9rem 2rem;border-radius:6px;text-decoration:none;border:1px solid var(--pg-border);font-weight:700;">Cancel</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
