<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            color: #111827;
            margin: 20px;
            font-size: 12px;
        }

        h1, h2, h3 {
            margin: 0;
            padding: 0;
        }

        .header {
            border-bottom: 2px solid #e5e7eb;
            padding-bottom: 10px;
            margin-bottom: 16px;
        }

        .title {
            font-size: 22px;
            color: #0f172a;
            margin-bottom: 6px;
        }

        .muted {
            color: #6b7280;
            font-size: 11px;
        }

        .stats-grid {
            width: 100%;
            border-collapse: separate;
            border-spacing: 10px;
            margin-bottom: 16px;
        }

        .stat-card {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 10px;
            width: 24%;
            vertical-align: top;
        }

        .stat-label {
            font-size: 11px;
            color: #6b7280;
            margin-bottom: 4px;
        }

        .stat-value {
            font-size: 18px;
            color: #0f172a;
            font-weight: 700;
        }

        .section-title {
            font-size: 15px;
            color: #0f172a;
            margin-bottom: 8px;
        }

        .chart-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 18px;
        }

        .chart-cell {
            width: 50%;
            vertical-align: top;
            padding-right: 14px;
        }

        .panel {
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 10px;
            margin-bottom: 10px;
            background: #ffffff;
        }

        .legend-item {
            margin-bottom: 4px;
            font-size: 11px;
        }

        .dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 6px;
        }

        .bar-row {
            margin-bottom: 9px;
        }

        .bar-track {
            height: 12px;
            background: #f1f5f9;
            border-radius: 999px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            margin-top: 4px;
        }

        .bar-fill {
            height: 100%;
            background: #2563eb;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 6px;
        }

        .table th,
        .table td {
            border: 1px solid #e5e7eb;
            padding: 6px;
            text-align: left;
            font-size: 11px;
        }

        .table th {
            background: #f8fafc;
            color: #334155;
            font-weight: 700;
        }

        .table thead {
            display: table-header-group;
        }

        .table tr {
            page-break-inside: avoid;
        }

        .users-table-panel {
            page-break-before: always;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="title">Users Analytics Export</h1>
        <div class="muted">
            Generated at: {{ generated_at|date('Y-m-d H:i') }} |
            Filter: {{ search is not empty ? search : 'None' }} |
            Sort: {{ sort }} {{ direction }}
        </div>
    </div>

    <table class="stats-grid">
        <tr>
            <td class="stat-card">
                <div class="stat-label">Total Users</div>
                <div class="stat-value">{{ stats.total_users }}</div>
            </td>
            <td class="stat-card">
                <div class="stat-label">Active Users</div>
                <div class="stat-value">{{ stats.active_users }}</div>
            </td>
            <td class="stat-card">
                <div class="stat-label">Inactive Users</div>
                <div class="stat-value">{{ stats.inactive_users }}</div>
            </td>
            <td class="stat-card">
                <div class="stat-label">Average Review Rating</div>
                <div class="stat-value">{{ stats.average_rating }}</div>
            </td>
        </tr>
    </table>

    <table class="chart-table">
        <tr>
            <td class="chart-cell">
                <div class="panel">
                    <h2 class="section-title">User Roles Pie Chart</h2>
                    {% if role_pie_chart.slices is not empty %}
                        <img src="{{ role_chart_uri }}" alt="User roles chart" width="260" height="260" style="display:block;" />

                        <div>
                            {% for slice in role_pie_chart.slices %}
                                <div class="legend-item">
                                    <span class="dot" style="background: {{ slice.color }};"></span>
                                    {{ slice.label|capitalize }} - {{ slice.value }} ({{ slice.percent }}%)
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="muted">No role data available.</div>
                    {% endif %}
                </div>
            </td>
            <td class="chart-cell">
                <div class="panel">
                    <h2 class="section-title">Review Ratings Bar Chart</h2>
                    <img src="{{ ratings_chart_uri }}" alt="Ratings bar chart" width="350" height="240" style="display:block;" />
                    <div class="muted">Ratings from 1 to 5 stars.</div>
                </div>
            </td>
        </tr>
    </table>

    <table class="chart-table">
        <tr>
            <td class="chart-cell">
                <div class="panel">
                    <h2 class="section-title">Users Created by Month (Line)</h2>
                    {% if monthly_line_chart.nodes is not empty %}
                        <img src="{{ monthly_chart_uri }}" alt="Monthly users line chart" width="620" height="260" style="display:block;" />
                    {% else %}
                        <div class="muted">No monthly registration data available.</div>
                    {% endif %}
                </div>
            </td>
            <td class="chart-cell">
                <div class="panel">
                    <h2 class="section-title">User Status Pie + Progress Bars</h2>
                    {% if verification_pie_chart.slices is not empty %}
                        <img src="{{ verification_chart_uri }}" alt="User status pie chart" width="220" height="220" style="display:block;" />
                        {% for slice in verification_pie_chart.slices %}
                            <div class="legend-item">
                                <span class="dot" style="background: {{ slice.color }};"></span>
                                {{ slice.label }} - {{ slice.value }} ({{ slice.percent }}%)
                            </div>
                        {% endfor %}
                    {% endif %}

                    {% set activePercent = stats.total_users > 0 ? (stats.active_users / stats.total_users) * 100 : 0 %}

                    <div class="bar-row">
                        <div>Active Users Ratio: {{ activePercent|round(2) }}%</div>
                        <div class="bar-track">
                            <div class="bar-fill" style="width: {{ activePercent }}%; background:#10b981;"></div>
                        </div>
                    </div>

                    {% set reviewersPercent = stats.total_users > 0 ? (stats.reviewers_count / stats.total_users) * 100 : 0 %}
                    <div class="bar-row">
                        <div>Users With At Least One Review: {{ reviewersPercent|round(2) }}%</div>
                        <div class="bar-track">
                            <div class="bar-fill" style="width: {{ reviewersPercent }}%; background:#f97316;"></div>
                        </div>
                    </div>

                    <div class="bar-row">
                        <div>Total Reviews: {{ stats.total_avis }} (Verified: {{ stats.verified_avis }})</div>
                    </div>
                </div>
            </td>
        </tr>
    </table>

    <div class="panel users-table-panel">
        <h3 class="section-title">Exported Users ({{ users|length }})</h3>
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created At</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users|slice(0, 20) %}
                    <tr>
                        <td>{{ user.fullName }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.userType|capitalize }}</td>
                        <td>{{ user.isActive ? 'Active' : 'Inactive' }}</td>
                        <td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : 'N/A' }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">No users found for this export.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>
