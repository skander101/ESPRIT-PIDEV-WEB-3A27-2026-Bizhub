{% extends 'back/base.html.twig' %}

{% block title %}Users Management{% endblock %}
{% block breadcrumb %}Users{% endblock %}

{% block content %}
<div style="padding:2rem;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
        <h2 style="font-size:1.5rem;color:var(--pg-text);">Users Management</h2>
        <div style="display:flex;gap:1rem;">
            <input type="text" id="searchUsers" placeholder="Search users..." style="background:var(--pg-surface);border:1px solid var(--pg-border);color:var(--pg-text);padding:0.7rem 1rem;border-radius:6px;width:250px;"/>
        </div>
    </div>

    {% if users %}
        <div class="dash-panel">
            <div style="overflow-x:auto;">
                <table style="width:100%;color:var(--pg-text);">
                    <thead>
                        <tr style="border-bottom:1px solid var(--pg-border);background:var(--pg-surface2);">
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Name</th>
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Email</th>
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Type</th>
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Status</th>
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Joined</th>
                            <th style="text-align:center;padding:1rem;font-weight:700;color:var(--pg-muted);">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr style="border-bottom:1px solid var(--pg-border);transition:background 0.2s;">
                                <td style="padding:1rem;font-weight:500;">{{ user.fullName }}</td>
                                <td style="padding:1rem;color:var(--pg-muted);">{{ user.email }}</td>
                                <td style="padding:1rem;">
                                    <span style="display:inline-block;background:rgba(91,110,245,0.15);color:#5b6ef5;padding:0.3rem 0.8rem;border-radius:4px;font-size:0.85rem;font-weight:700;text-transform:capitalize;">
                                        {{ user.userType }}
                                    </span>
                                </td>
                                <td style="padding:1rem;">
                                    <span style="display:inline-block;background:{{ user.isActive ? 'rgba(6,214,160,0.15)' : 'rgba(200,0,0,0.15)' }};color:{{ user.isActive ? '#06d6a0' : '#c80000' }};padding:0.3rem 0.8rem;border-radius:4px;font-size:0.85rem;font-weight:700;">
                                        {{ user.isActive ? 'Active' : 'Inactive' }}
                                    </span>
                                </td>
                                <td style="padding:1rem;color:var(--pg-muted);font-size:0.9rem;">{{ user.createdAt|date('M d, Y') }}</td>
                                <td style="padding:1rem;text-align:center;">
                                    <div style="display:flex;gap:0.5rem;justify-content:center;">
                                        <a href="{{ path('app_admin_user_show', {'id': user.userId}) }}" style="background:#5b6ef5;color:white;padding:0.4rem 0.8rem;border-radius:4px;text-decoration:none;font-size:0.85rem;font-weight:700;transition:background 0.2s;">View</a>
                                        <a href="{{ path('app_admin_user_edit', {'id': user.userId}) }}" style="background:#8b5cf6;color:white;padding:0.4rem 0.8rem;border-radius:4px;text-decoration:none;font-size:0.85rem;font-weight:700;transition:background 0.2s;">Edit</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="dash-panel" style="text-align:center;padding:3rem 2rem;">
            <p style="color:var(--pg-muted);margin-bottom:1rem;">No users found</p>
        </div>
    {% endif %}
</div>
{% endblock %}
