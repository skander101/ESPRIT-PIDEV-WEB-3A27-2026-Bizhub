<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Connexion | Backoffice</title>
  <link rel="stylesheet" href="{{ asset('assets/back/css/bootstrap.min.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/lineicons.css') }}" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #080b12;
      --surface:   #0e1220;
      --surface2:  #141826;
      --border:    rgba(255,255,255,0.07);
      --border2:   rgba(255,255,255,0.12);
      --accent:    #5b6ef5;
      --accent2:   #8b5cf6;
      --accent3:   #06d6a0;
      --text:      #f0f2ff;
      --muted:     #6b7280;
      --muted2:    #9ca3af;
      --danger:    #ef4444;
    }

    html, body { height: 100%; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: stretch;
    }

    /* ── Preloader ── */
    #preloader {
      position: fixed; inset: 0; z-index: 9999;
      background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      transition: opacity .5s ease;
    }
    #preloader.hidden { opacity: 0; pointer-events: none; }
    .spinner {
      width: 36px; height: 36px;
      border: 2px solid var(--border2);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin .8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ══════════════════════════════════
       SHELL — two columns
    ══════════════════════════════════ */
    .auth-shell {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
      min-height: 100vh;
    }

    /* ── LEFT PANEL ── */
    .auth-left {
      position: relative;
      background: var(--surface);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 2.5rem 3rem;
      overflow: hidden;
    }

    /* Geometric background shapes */
    .auth-left::before {
      content: '';
      position: absolute;
      width: 500px; height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(91,110,245,.15) 0%, transparent 70%);
      top: -100px; left: -100px;
      pointer-events: none;
    }
    .auth-left::after {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(139,92,246,.12) 0%, transparent 70%);
      bottom: -80px; right: -80px;
      pointer-events: none;
    }

    .auth-left-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: relative; z-index: 1;
    }

    .auth-logo-mark {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none;
    }
    .auth-logo-icon {
      width: 38px; height: 38px; border-radius: 10px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
    }
    .auth-logo-name {
      font-family: 'Syne', sans-serif;
      font-size: 17px; font-weight: 700;
      color: var(--text); letter-spacing: -.3px;
    }
    .auth-logo-name span { color: var(--accent); font-weight: 400; }

    .auth-back {
      display: flex; align-items: center; gap: 6px;
      font-size: 13px; color: var(--muted2);
      text-decoration: none;
      transition: color .2s;
    }
    .auth-back:hover { color: var(--text); }

    /* Left hero */
    .auth-left-body {
      position: relative; z-index: 1;
      max-width: 420px;
    }

    .auth-pill {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(91,110,245,.12);
      border: 1px solid rgba(91,110,245,.25);
      border-radius: 100px;
      padding: 5px 14px 5px 8px;
      font-size: 12px; font-weight: 500;
      color: #a5b4fc;
      margin-bottom: 2rem;
    }
    .auth-pill-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent3);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: .5; transform: scale(.7); }
    }

    .auth-left-body h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2rem, 3vw, 2.8rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -.5px;
      color: var(--text);
      margin-bottom: 1.25rem;
    }
    .auth-left-body h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .auth-left-body p {
      font-size: 15px;
      line-height: 1.7;
      color: var(--muted2);
      margin-bottom: 2.5rem;
      font-weight: 300;
    }

    .auth-features {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .auth-feature {
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }
    .auth-feature-icon {
      width: 36px; height: 36px; flex-shrink: 0;
      border-radius: 10px;
      background: var(--surface2);
      border: 1px solid var(--border2);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
    }
    .auth-feature-text strong {
      display: block;
      font-size: 14px; font-weight: 500;
      color: var(--text);
      margin-bottom: 2px;
    }
    .auth-feature-text span {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }

    /* Left bottom bar */
    .auth-left-bottom {
      position: relative; z-index: 1;
    }
    .auth-stat-row {
      display: flex; gap: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
    .auth-stat strong {
      display: block;
      font-family: 'Syne', sans-serif;
      font-size: 22px; font-weight: 700;
      color: var(--text);
    }
    .auth-stat span {
      font-size: 12px; color: var(--muted);
    }

    /* ── RIGHT PANEL ── */
    .auth-right {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 2rem;
      background: var(--bg);
    }

    .auth-card {
      width: 100%;
      max-width: 420px;
    }

    .auth-card-tag {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(6,214,160,.08);
      border: 1px solid rgba(6,214,160,.2);
      border-radius: 6px;
      padding: 4px 12px;
      font-size: 12px; font-weight: 500;
      color: var(--accent3);
      letter-spacing: .5px;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }

    .auth-card h2 {
      font-family: 'Syne', sans-serif;
      font-size: 2rem; font-weight: 800;
      letter-spacing: -.5px;
      color: var(--text);
      margin-bottom: .5rem;
    }
    .auth-card > p {
      font-size: 14px; color: var(--muted2);
      line-height: 1.6;
      margin-bottom: 2rem;
      font-weight: 300;
    }

    /* Fields */
    .auth-field {
      margin-bottom: 1.25rem;
    }
    .auth-field label {
      display: block;
      font-size: 13px; font-weight: 500;
      color: var(--muted2);
      margin-bottom: 8px;
      letter-spacing: .2px;
    }
    .auth-input-wrap {
      position: relative;
    }
    .auth-input-wrap .fi {
      position: absolute;
      left: 14px; top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 16px;
      pointer-events: none;
    }
    .auth-field input {
      width: 100%;
      height: 48px;
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 10px;
      color: var(--text);
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      padding: 0 14px 0 42px;
      outline: none;
      transition: border-color .2s, box-shadow .2s, background .2s;
    }
    .auth-field input::placeholder { color: var(--muted); }
    .auth-field input:focus {
      border-color: var(--accent);
      background: var(--surface2);
      box-shadow: 0 0 0 3px rgba(91,110,245,.12);
    }

    /* Password toggle */
    .auth-eye {
      position: absolute;
      right: 14px; top: 50%;
      transform: translateY(-50%);
      background: none; border: none;
      color: var(--muted); cursor: pointer;
      font-size: 16px;
      transition: color .2s;
      padding: 0;
    }
    .auth-eye:hover { color: var(--text); }

    /* Row meta */
    .auth-row-meta {
      display: flex; align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
    }
    .auth-remember {
      display: flex; align-items: center; gap: 8px;
      cursor: pointer;
    }
    .auth-remember input[type=checkbox] {
      width: 16px; height: 16px;
      accent-color: var(--accent);
      cursor: pointer;
    }
    .auth-remember span { font-size: 13px; color: var(--muted2); }
    .auth-link {
      font-size: 13px;
      color: var(--accent);
      text-decoration: none;
      transition: color .2s;
    }
    .auth-link:hover { color: #818cf8; }

    /* Submit button */
    .auth-submit {
      width: 100%;
      height: 50px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border: none;
      border-radius: 10px;
      color: #fff;
      font-size: 15px;
      font-weight: 600;
      font-family: 'Syne', sans-serif;
      letter-spacing: .3px;
      cursor: pointer;
      transition: opacity .2s, transform .15s, box-shadow .2s;
      box-shadow: 0 4px 20px rgba(91,110,245,.3);
      margin-bottom: 1.5rem;
    }
    .auth-submit:hover {
      opacity: .92;
      transform: translateY(-1px);
      box-shadow: 0 6px 28px rgba(91,110,245,.4);
    }
    .auth-submit:active { transform: scale(.98); }

    /* Divider */
    .auth-divider {
      display: flex; align-items: center; gap: 12px;
      font-size: 12px; color: var(--muted);
      text-transform: uppercase; letter-spacing: .8px;
      margin-bottom: 1.25rem;
    }
    .auth-divider::before, .auth-divider::after {
      content: ''; flex: 1;
      height: 1px; background: var(--border2);
    }

    /* Social buttons */
    .auth-socials {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 1.75rem;
    }
    .auth-social-btn {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      height: 44px;
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 10px;
      color: var(--muted2);
      font-size: 13px; font-weight: 500;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      transition: border-color .2s, color .2s, background .2s;
    }
    .auth-social-btn:hover {
      border-color: rgba(255,255,255,.2);
      color: var(--text);
      background: var(--surface2);
    }

    /* Bottom text */
    .auth-bottom-text {
      text-align: center;
      font-size: 14px;
      color: var(--muted);
    }
    .auth-bottom-text a {
      color: var(--accent);
      font-weight: 500;
      text-decoration: none;
      transition: color .2s;
    }
    .auth-bottom-text a:hover { color: #818cf8; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .auth-shell { grid-template-columns: 1fr; }
      .auth-left { display: none; }
      .auth-right { padding: 2rem 1.25rem; }
    }
  </style>
</head>
<body>

  <div id="preloader"><div class="spinner"></div></div>

  <div class="auth-shell">

    <!-- ══ LEFT PANEL ══ -->
    <div class="auth-left">
      <div class="auth-left-top">
        <a href="index.html" class="auth-logo-mark">
          <div class="auth-logo-icon">🔷</div>
          <span class="auth-logo-name"><span style="color:#ffbe33 !important;">Biz</span><span style="color:#ffffff !important;">Hub</span></span>
        </a>
        <a href="index.html" class="auth-back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Tableau de bord
        </a>
      </div>

      <div class="auth-left-body">
        <div class="auth-pill">
          <div class="auth-pill-dot"></div>
          Backoffice premium
        </div>

        <h1>Entrez dans un espace d'administration <em>d'exception</em></h1>
        <p>
          Une expérience plus fluide, plus élégante et plus professionnelle
          pour piloter vos données avec confiance.
        </p>

        <div class="auth-features">
          <div class="auth-feature">
            <div class="auth-feature-icon">⚡</div>
            <div class="auth-feature-text">
              <strong>Accès instantané</strong>
              <span>Connexion simple et accès immédiat à votre environnement.</span>
            </div>
          </div>
          <div class="auth-feature">
            <div class="auth-feature-icon">🔒</div>
            <div class="auth-feature-text">
              <strong>Sécurité renforcée</strong>
              <span>Un accès pensé pour un backoffice moderne et fiable.</span>
            </div>
          </div>
          <div class="auth-feature">
            <div class="auth-feature-icon">✦</div>
            <div class="auth-feature-text">
              <strong>Interface premium</strong>
              <span>Une UI claire, agréable et conçue pour la productivité.</span>
            </div>
          </div>
        </div>
      </div>

      <div class="auth-left-bottom">
        <div class="auth-stat-row">
          <div class="auth-stat">
            <strong>12k+</strong>
            <span>Utilisateurs actifs</span>
          </div>
          <div class="auth-stat">
            <strong>99.9%</strong>
            <span>Disponibilité</span>
          </div>
          <div class="auth-stat">
            <strong>4.9★</strong>
            <span>Note moyenne</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ══ RIGHT PANEL ══ -->
    <div class="auth-right">
      <div class="auth-card">

        <div class="auth-card-tag">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="5" fill="#06d6a0"/></svg>
          Connexion sécurisée
        </div>

        <h2>Bon retour 👋</h2>
        <p>Connectez-vous pour accéder à votre espace administrateur.</p>

        <form action="#" novalidate>
          <div class="auth-field">
            <label for="email">Adresse email</label>
            <div class="auth-input-wrap">
              <svg class="fi" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/></svg>
              <input id="email" type="text" placeholder="vous@exemple.com" autocomplete="email" />
            </div>
          </div>

          <div class="auth-field">
            <label for="password">Mot de passe</label>
            <div class="auth-input-wrap">
              <svg class="fi" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input id="password" type="password" placeholder="••••••••" autocomplete="current-password" />
              <button type="button" class="auth-eye" onclick="togglePwd('password',this)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <div class="auth-row-meta">
            <label class="auth-remember">
              <input type="checkbox" />
              <span>Se souvenir de moi</span>
            </label>
            <a href="reset-password.html" class="auth-link">Mot de passe oublié ?</a>
          </div>

          <button type="submit" class="auth-submit">Se connecter →</button>
        </form>

        <div class="auth-divider">ou continuer avec</div>

        <div class="auth-socials">
          <button class="auth-social-btn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Google
          </button>
          <button class="auth-social-btn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M11.5 2.5H2.5v9h9v-9z" fill="#f25022"/><path d="M21.5 2.5h-9v9h9v-9z" fill="#7fba00"/><path d="M11.5 12.5H2.5v9h9v-9z" fill="#00a4ef"/><path d="M21.5 12.5h-9v9h9v-9z" fill="#ffb900"/></svg>
            Microsoft
          </button>
        </div>

        <div class="auth-bottom-text">
          Pas encore de compte ? <a href="signup.html">Créer un compte</a>
        </div>

      </div>
    </div>

  </div>

  <script>
    window.addEventListener('load', () => {
      setTimeout(() => document.getElementById('preloader').classList.add('hidden'), 400);
    });
    function togglePwd(id, btn) {
      const inp = document.getElementById(id);
      inp.type = inp.type === 'password' ? 'text' : 'password';
    }
  </script>
</body>
</html>