<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inscription | Backoffice</title>
  <link rel="stylesheet" href="{{ asset('assets/back/css/bootstrap.min.css') }}" />
  <link rel="stylesheet" href="{{ asset('assets/back/css/lineicons.css') }}" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #080b12;
      --surface:   #0e1220;
      --surface2:  #141826;
      --border:    rgba(255,255,255,0.07);
      --border2:   rgba(255,255,255,0.12);
      --accent:    #5b6ef5;
      --accent2:   #8b5cf6;
      --accent3:   #06d6a0;
      --text:      #f0f2ff;
      --muted:     #6b7280;
      --muted2:    #9ca3af;
    }

    html, body { height: 100%; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: stretch;
    }

    /* Preloader */
    #preloader {
      position: fixed; inset: 0; z-index: 9999;
      background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      transition: opacity .5s ease;
    }
    #preloader.hidden { opacity: 0; pointer-events: none; }
    .spinner {
      width: 36px; height: 36px;
      border: 2px solid var(--border2);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin .8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Shell */
    .auth-shell {
      width: 100%;
      min-height: 100vh;
    }

    /* ── LEFT PANEL ── */
    .auth-left {
      position: relative;
      background: var(--surface);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 2.5rem 3rem;
      overflow: hidden;
    }
    .auth-left::before {
      content: '';
      position: absolute;
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(91,110,245,.15) 0%, transparent 70%);
      top: -100px; right: -100px;
      pointer-events: none;
    }
    .auth-left::after {
      content: '';
      position: absolute;
      width: 350px; height: 350px; border-radius: 50%;
      background: radial-gradient(circle, rgba(6,214,160,.1) 0%, transparent 70%);
      bottom: 0; left: -50px;
      pointer-events: none;
    }

    .auth-left-top {
      display: flex; align-items: center; justify-content: space-between;
      position: relative; z-index: 1;
    }
    .auth-logo-mark {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none;
    }
    .auth-logo-icon {
      width: 38px; height: 38px; border-radius: 10px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
    }
    .auth-logo-name {
      font-family: 'Syne', sans-serif;
      font-size: 17px; font-weight: 700; color: var(--text); letter-spacing: -.3px;
    }
    .auth-logo-name span { color: var(--accent); font-weight: 400; }
    .auth-back {
      display: flex; align-items: center; gap: 6px;
      font-size: 13px; color: var(--muted2); text-decoration: none; transition: color .2s;
    }
    .auth-back:hover { color: var(--text); }

    /* Hero */
    .auth-left-body { position: relative; z-index: 1; max-width: 420px; }

    .auth-pill {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(91,110,245,.12);
      border: 1px solid rgba(91,110,245,.25);
      border-radius: 100px; padding: 5px 14px 5px 8px;
      font-size: 12px; font-weight: 500; color: #a5b4fc;
      margin-bottom: 2rem;
    }
    .auth-pill-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--accent3);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: .5; transform: scale(.7); }
    }

    .auth-left-body h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.9rem, 3vw, 2.6rem);
      font-weight: 800; line-height: 1.15; letter-spacing: -.5px;
      color: var(--text); margin-bottom: 1.25rem;
    }
    .auth-left-body h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent3), #06b6d4);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .auth-left-body p {
      font-size: 15px; line-height: 1.7; color: var(--muted2);
      margin-bottom: 2.5rem; font-weight: 300;
    }

    .auth-features { display: flex; flex-direction: column; gap: 16px; }
    .auth-feature { display: flex; align-items: flex-start; gap: 14px; }
    .auth-feature-icon {
      width: 36px; height: 36px; flex-shrink: 0; border-radius: 10px;
      background: var(--surface2); border: 1px solid var(--border2);
      display: flex; align-items: center; justify-content: center; font-size: 16px;
    }
    .auth-feature-text strong {
      display: block; font-size: 14px; font-weight: 500; color: var(--text); margin-bottom: 2px;
    }
    .auth-feature-text span { font-size: 13px; color: var(--muted); line-height: 1.5; }

    /* Bottom */
    .auth-left-bottom { position: relative; z-index: 1; }
    .auth-stat-row { display: flex; gap: 2rem; padding-top: 2rem; border-top: 1px solid var(--border); }
    .auth-stat strong {
      display: block; font-family: 'Syne', sans-serif;
      font-size: 22px; font-weight: 700; color: var(--text);
    }
    .auth-stat span { font-size: 12px; color: var(--muted); }

    /* ── RIGHT PANEL ── */
    .auth-right {
      display: flex; align-items: center; justify-content: center;
      padding: 2.5rem 2rem; background: var(--bg);
      overflow-y: auto;
    }
    .auth-card { width: 100%; max-width: 420px; }

    .auth-card-tag {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(91,110,245,.08);
      border: 1px solid rgba(91,110,245,.2);
      border-radius: 6px; padding: 4px 12px;
      font-size: 12px; font-weight: 500; color: #a5b4fc;
      letter-spacing: .5px; text-transform: uppercase; margin-bottom: 1.5rem;
    }
    .auth-card h2 {
      font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800;
      letter-spacing: -.5px; color: var(--text); margin-bottom: .5rem;
    }
    .auth-card > p {
      font-size: 14px; color: var(--muted2); line-height: 1.6;
      margin-bottom: 1.75rem; font-weight: 300;
    }

    /* Step indicator */
    .auth-steps {
      display: flex; align-items: center; gap: 0;
      margin-bottom: 1.75rem;
    }
    .auth-step {
      display: flex; align-items: center; gap: 8px;
      font-size: 12px; font-weight: 500;
    }
    .auth-step-num {
      width: 24px; height: 24px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 600;
      background: var(--surface); border: 1px solid var(--border2);
      color: var(--muted);
    }
    .auth-step.active .auth-step-num {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-color: transparent; color: #fff;
    }
    .auth-step.done .auth-step-num {
      background: rgba(6,214,160,.15); border-color: rgba(6,214,160,.3); color: var(--accent3);
    }
    .auth-step-label { color: var(--muted); }
    .auth-step.active .auth-step-label { color: var(--text); }
    .auth-step-line { flex: 1; height: 1px; background: var(--border2); margin: 0 10px; }

    /* Two-col grid for name fields */
    .auth-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    /* Fields */
    .auth-field { margin-bottom: 1.1rem; }
    .auth-field label {
      display: block; font-size: 13px; font-weight: 500;
      color: var(--muted2); margin-bottom: 7px; letter-spacing: .2px;
    }
    .auth-input-wrap { position: relative; }
    .auth-input-wrap .fi {
      position: absolute; left: 14px; top: 50%;
      transform: translateY(-50%); color: var(--muted);
      font-size: 16px; pointer-events: none;
    }
    .auth-field input {
      width: 100%; height: 48px;
      background: var(--surface); border: 1px solid var(--border2);
      border-radius: 10px; color: var(--text);
      font-size: 14px; font-family: 'DM Sans', sans-serif;
      padding: 0 14px 0 42px; outline: none;
      transition: border-color .2s, box-shadow .2s, background .2s;
    }
    .auth-field input::placeholder { color: var(--muted); }
    .auth-field input:focus {
      border-color: var(--accent); background: var(--surface2);
      box-shadow: 0 0 0 3px rgba(91,110,245,.12);
    }
    .auth-eye {
      position: absolute; right: 14px; top: 50%;
      transform: translateY(-50%);
      background: none; border: none; color: var(--muted);
      cursor: pointer; font-size: 16px; transition: color .2s; padding: 0;
    }
    .auth-eye:hover { color: var(--text); }

    /* Password strength */
    .pwd-strength { display: flex; gap: 4px; margin-top: 8px; }
    .pwd-bar {
      flex: 1; height: 3px; border-radius: 2px;
      background: var(--border2); transition: background .3s;
    }
    .pwd-bar.weak { background: #ef4444; }
    .pwd-bar.fair { background: #f59e0b; }
    .pwd-bar.good { background: var(--accent3); }

    /* Terms */
    .auth-terms {
      display: flex; align-items: flex-start; gap: 10px;
      margin-bottom: 1.25rem;
    }
    .auth-terms input[type=checkbox] {
      width: 16px; height: 16px; flex-shrink: 0;
      margin-top: 2px; accent-color: var(--accent); cursor: pointer;
    }
    .auth-terms span {
      font-size: 13px; color: var(--muted); line-height: 1.5;
    }
    .auth-terms a { color: var(--accent); text-decoration: none; }
    .auth-terms a:hover { color: #818cf8; }

    /* Submit */
    .auth-submit {
      width: 100%; height: 50px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border: none; border-radius: 10px; color: #fff;
      font-size: 15px; font-weight: 600; font-family: 'Syne', sans-serif;
      letter-spacing: .3px; cursor: pointer;
      transition: opacity .2s, transform .15s, box-shadow .2s;
      box-shadow: 0 4px 20px rgba(91,110,245,.3);
      margin-bottom: 1.5rem;
    }
    .auth-submit:hover {
      opacity: .92; transform: translateY(-1px);
      box-shadow: 0 6px 28px rgba(91,110,245,.4);
    }
    .auth-submit:active { transform: scale(.98); }

    /* Divider */
    .auth-divider {
      display: flex; align-items: center; gap: 12px;
      font-size: 12px; color: var(--muted);
      text-transform: uppercase; letter-spacing: .8px; margin-bottom: 1.25rem;
    }
    .auth-divider::before, .auth-divider::after {
      content: ''; flex: 1; height: 1px; background: var(--border2);
    }

    /* Socials */
    .auth-socials { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1.75rem; }
    .auth-social-btn {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      height: 44px; background: var(--surface); border: 1px solid var(--border2);
      border-radius: 10px; color: var(--muted2);
      font-size: 13px; font-weight: 500; font-family: 'DM Sans', sans-serif;
      cursor: pointer; transition: border-color .2s, color .2s, background .2s;
    }
    .auth-social-btn:hover {
      border-color: rgba(255,255,255,.2); color: var(--text); background: var(--surface2);
    }

    .auth-bottom-text { text-align: center; font-size: 14px; color: var(--muted); }
    .auth-bottom-text a {
      color: var(--accent); font-weight: 500; text-decoration: none; transition: color .2s;
    }
    .auth-bottom-text a:hover { color: #818cf8; }

    @media (max-width: 900px) {
      .auth-right { padding: 2rem 1.25rem; }
      .auth-field-row { grid-template-columns: 1fr; }
    }

    .signup-wrapper {
      justify-content: center !important;
      align-items: center !important;
    }

    .signup-wrapper .form-wrapper {
      margin: 0 auto;
    }
  </style>
</head>
<body>

  <div id="preloader"><div class="spinner"></div></div>

  <div class="row auth-row">
    <div class="row">

    <!-- ══ RIGHT PANEL ══ -->
    <div class="col-12">
    <div class="auth-right">
      <div class="auth-card">

        <div class="auth-card-tag">
          <svg width="10" height="10" viewBox="0 0 10 10"><circle cx="5" cy="5" r="5" fill="#a5b4fc"/></svg>
          Nouveau compte
        </div>

        <h2>Créer un compte 🚀</h2>
        <p>Rejoignez votre backoffice en quelques secondes, c'est gratuit.</p>

        <form action="#" novalidate>
          <div class="auth-field-row">
            <div class="auth-field">
              <label for="firstname">Prénom</label>
              <div class="auth-input-wrap">
                <svg class="fi" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <input id="firstname" type="text" placeholder="Prénom" autocomplete="given-name" />
              </div>
            </div>
            <div class="auth-field">
              <label for="lastname">Nom</label>
              <div class="auth-input-wrap">
                <svg class="fi" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <input id="lastname" type="text" placeholder="Nom" autocomplete="family-name" />
              </div>
            </div>
          </div>

          <div class="auth-field">
            <label for="email">Adresse email</label>
            <div class="auth-input-wrap">
              <svg class="fi" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/></svg>
                <input id="email" type="text" placeholder="vous@exemple.com" autocomplete="email" />
            </div>
          </div>

          <div class="auth-field">
            <label for="password">Mot de passe</label>
            <div class="auth-input-wrap">
              <svg class="fi" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input id="password" type="password" placeholder="Minimum 8 caractères" autocomplete="new-password" />
              <button type="button" class="auth-eye" onclick="togglePwd('password',this)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <div class="auth-field">
            <label for="password-confirm">Confirmer le mot de passe</label>
            <div class="auth-input-wrap">
              <svg class="fi" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input id="password-confirm" type="password" placeholder="Confirmez votre mot de passe" autocomplete="new-password" />
              <button type="button" class="auth-eye" onclick="togglePwd('password-confirm',this)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <div class="auth-terms">
            <input type="checkbox" id="terms" />
            <span>J'accepte les <a href="#">conditions d'utilisation</a> et la <a href="#">politique de confidentialité</a></span>
          </div>

          <button type="submit" class="auth-submit">Créer mon compte →</button>
        </form>

        <div class="auth-divider">ou s'inscrire avec</div>

        <div class="auth-socials">
          <button class="auth-social-btn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Google
          </button>
          <button class="auth-social-btn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M11.5 2.5H2.5v9h9v-9z" fill="#f25022"/><path d="M21.5 2.5h-9v9h9v-9z" fill="#7fba00"/><path d="M11.5 12.5H2.5v9h9v-9z" fill="#00a4ef"/><path d="M21.5 12.5h-9v9h9v-9z" fill="#ffb900"/></svg>
            Microsoft
          </button>
        </div>

        <div class="auth-bottom-text">
          Déjà un compte ? <a href="signin.html">Se connecter</a>
        </div>

      </div>
    </div>

    </div>

  </div>

  <script>
    window.addEventListener('load', () => {
      setTimeout(() => document.getElementById('preloader').classList.add('hidden'), 400);
    });
    function togglePwd(id, btn) {
      const inp = document.getElementById(id);
      inp.type = inp.type === 'password' ? 'text' : 'password';
    }
  </script>
</body>
</html>