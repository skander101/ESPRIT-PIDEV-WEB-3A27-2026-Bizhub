{% extends 'back/base.html.twig' %}

{% block title %}Produits - Admin{% endblock %}
{% block breadcrumb %}Produits{% endblock %}

{% block content %}
<div style="padding:2rem;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
    <h2 style="font-size:1.5rem;color:var(--pg-text);margin:0;">Gestion des Produits</h2>
    <a href="{{ path('admin_marketplace_produits_new') }}" style="background:#5b6ef5;color:white;padding:0.75rem 1.5rem;border-radius:4px;text-decoration:none;font-weight:700;transition:background 0.2s;">+ Nouveau Produit</a>
  </div>

  {% if categories %}
    <div style="display:flex;gap:0.5rem;margin-bottom:1.5rem;flex-wrap:wrap;">
      <a href="{{ path('admin_marketplace_produits_index') }}" style="padding:0.5rem 1rem;border:1px solid var(--pg-border);background:var(--pg-surface2);border-radius:4px;text-decoration:none;color:var(--pg-text);font-size:0.85rem;{% if not cat_active %}background:#5b6ef5;border-color:#5b6ef5;{% endif %}transition:all 0.2s;">Tous</a>
      {% for cat in categories %}
        <a href="{{ path('admin_marketplace_produits_index', {categorie: cat}) }}" style="padding:0.5rem 1rem;border:1px solid var(--pg-border);background:var(--pg-surface2);border-radius:4px;text-decoration:none;color:var(--pg-text);font-size:0.85rem;{% if cat == cat_active %}background:#5b6ef5;border-color:#5b6ef5;{% endif %}transition:all 0.2s;">{{ cat }}</a>
      {% endfor %}
    </div>
  {% endif %}

  <div class="dash-panel">
    {% if produits|length > 0 %}
      <div style="overflow-x:auto;">
        <table style="width:100%;color:var(--pg-text);">
          <thead>
            <tr style="border-bottom:1px solid var(--pg-border);background:var(--pg-surface2);">
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Nom</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Catégorie</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Prix</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Stock</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Dispo</th>
              <th style="text-align:center;padding:1rem;font-weight:700;color:var(--pg-muted);">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for produit in produits %}
              <tr style="border-bottom:1px solid var(--pg-border);transition:background 0.2s;">
                <td style="padding:1rem;font-weight:600;">{{ produit.nom }}</td>
                <td style="padding:1rem;color:var(--pg-muted);">{{ produit.categorie|default('-') }}</td>
                <td style="padding:1rem;">{{ produit.prix }} TND</td>
                <td style="padding:1rem;">{{ produit.quantite }}</td>
                <td style="padding:1rem;">
                  <span style="display:inline-block;background:{{ produit.disponible ? 'rgba(6,214,160,0.15)' : 'rgba(200,0,0,0.15)' }};color:{{ produit.disponible ? '#06d6a0' : '#c80000' }};padding:0.3rem 0.8rem;border-radius:4px;font-size:0.85rem;font-weight:700;">
                    {{ produit.disponible ? 'Oui' : 'Non' }}
                  </span>
                </td>
                <td style="padding:1rem;text-align:center;">
                  <div style="display:flex;gap:0.5rem;justify-content:center;">
                    <a href="{{ path('admin_marketplace_produits_show', {id: produit.idProduit}) }}" style="background:#17a2b8;color:white;padding:0.4rem 0.8rem;border-radius:4px;text-decoration:none;font-size:0.85rem;font-weight:700;transition:background 0.2s;">Voir</a>
                    <a href="{{ path('admin_marketplace_produits_edit', {id: produit.idProduit}) }}" style="background:#007bff;color:white;padding:0.4rem 0.8rem;border-radius:4px;text-decoration:none;font-size:0.85rem;font-weight:700;transition:background 0.2s;">Éditer</a>
                    <form method="POST" action="{{ path('admin_marketplace_produits_delete', {id: produit.idProduit}) }}" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete_produit_' ~ produit.idProduit) }}">
                      <button type="submit" style="background:#dc3545;color:white;padding:0.4rem 0.8rem;border:none;border-radius:4px;font-size:0.85rem;font-weight:700;cursor:pointer;transition:background 0.2s;">Supp.</button>
                    </form>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <p style="text-align:center;padding:2rem;color:var(--pg-muted);">Aucun produit trouvé.</p>
    {% endif %}
  </div>
</div>
{% endblock %}
