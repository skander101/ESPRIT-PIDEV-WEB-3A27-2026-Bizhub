{% extends 'back/base.html.twig' %}

{% block title %}{{ titre }} - Admin{% endblock %}
{% block breadcrumb %}{{ titre }}{% endblock %}

{% block content %}
<div style="padding:2rem;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
    <div>
      <h2 style="font-size:1.5rem;color:var(--pg-text);margin:0 0 0.5rem 0;">{{ titre }}</h2>
      {% if mode == 'edit' and produit %}
        <p style="color:var(--pg-muted);margin:0;font-size:0.9rem;">Produit: <strong>{{ produit.nom }}</strong></p>
      {% endif %}
    </div>
    <a href="{{ path('admin_marketplace_produits_index') }}" style="background:var(--pg-surface2);color:var(--pg-text);padding:0.5rem 1rem;border-radius:4px;text-decoration:none;font-weight:700;transition:background 0.2s;border:1px solid var(--pg-border);">← Retour</a>
  </div>

  <div class="dash-panel">
    {{ form_start(form) }}

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
      <div>
        {{ form_label(form.nom, 'Nom', {label_attr: {style: 'color:var(--pg-text);display:block;margin-bottom:0.5rem;font-weight:600;'}}) }}
        {{ form_widget(form.nom, {attr: {style: 'width:100%;padding:0.75rem;background:var(--pg-surface2);border:1px solid var(--pg-border);color:var(--pg-text);border-radius:4px;', placeholder: 'Nom du produit'}}) }}
        {{ form_errors(form.nom) }}
      </div>
      <div>
        {{ form_label(form.prix, 'Prix (TND)', {label_attr: {style: 'color:var(--pg-text);display:block;margin-bottom:0.5rem;font-weight:600;'}}) }}
        {{ form_widget(form.prix, {attr: {style: 'width:100%;padding:0.75rem;background:var(--pg-surface2);border:1px solid var(--pg-border);color:var(--pg-text);border-radius:4px;', placeholder: '0.00'}}) }}
        {{ form_errors(form.prix) }}
      </div>
    </div>

    <div style="margin-bottom:1.5rem;">
      {{ form_label(form.description, 'Description', {label_attr: {style: 'color:var(--pg-text);display:block;margin-bottom:0.5rem;font-weight:600;'}}) }}
      {{ form_widget(form.description, {attr: {style: 'width:100%;padding:0.75rem;background:var(--pg-surface2);border:1px solid var(--pg-border);color:var(--pg-text);border-radius:4px;', placeholder: 'Description du produit', rows: 4}}) }}
      {{ form_errors(form.description) }}
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem;">
      <div>
        {{ form_label(form.quantite, 'Quantité', {label_attr: {style: 'color:var(--pg-text);display:block;margin-bottom:0.5rem;font-weight:600;'}}) }}
        {{ form_widget(form.quantite, {attr: {style: 'width:100%;padding:0.75rem;background:var(--pg-surface2);border:1px solid var(--pg-border);color:var(--pg-text);border-radius:4px;', placeholder: '0'}}) }}
        {{ form_errors(form.quantite) }}
      </div>
      <div>
        {{ form_label(form.categorie, 'Catégorie', {label_attr: {style: 'color:var(--pg-text);display:block;margin-bottom:0.5rem;font-weight:600;'}}) }}
        {{ form_widget(form.categorie, {attr: {style: 'width:100%;padding:0.75rem;background:var(--pg-surface2);border:1px solid var(--pg-border);color:var(--pg-text);border-radius:4px;', placeholder: 'Catégorie'}}) }}
        {{ form_errors(form.categorie) }}
      </div>
    </div>

    <div style="display:flex;gap:1rem;padding-top:1rem;border-top:1px solid var(--pg-border);">
      <button type="submit" style="background:#5b6ef5;color:white;padding:0.75rem 1.5rem;border:none;border-radius:4px;font-weight:700;cursor:pointer;transition:background 0.2s;">💾 Enregistrer</button>
      <a href="{{ path('admin_marketplace_produits_index') }}" style="background:var(--pg-surface2);color:var(--pg-text);padding:0.75rem 1.5rem;border-radius:4px;text-decoration:none;font-weight:700;transition:background 0.2s;border:1px solid var(--pg-border);">Annuler</a>
    </div>

    {{ form_end(form) }}
  </div>
</div>
{% endblock %}
