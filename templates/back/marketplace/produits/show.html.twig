{% extends 'back/base.html.twig' %}

{% block title %}{{ produit.nom }} - Admin{% endblock %}
{% block breadcrumb %}Produit: {{ produit.nom }}{% endblock %}

{% block content %}
<div style="padding:2rem;">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;">
    <div>
      <h2 style="font-size:1.5rem;color:var(--pg-text);margin:0 0 0.5rem 0;">{{ produit.nom }}</h2>
      <p style="color:var(--pg-muted);margin:0;font-size:0.9rem;">Détails du produit</p>
    </div>
    <div style="display:flex;gap:0.5rem;align-items:center;">
      <span style="background:#f3f4f6;color:#6b7280;padding:0.5rem 1rem;border-radius:4px;font-size:0.82rem;font-weight:700;">🔒 Lecture seule</span>
      <a href="{{ path('admin_marketplace_produits_index') }}" style="background:var(--pg-surface2);color:var(--pg-text);padding:0.5rem 1rem;border-radius:4px;text-decoration:none;font-weight:700;border:1px solid var(--pg-border);">← Retour</a>
    </div>
  </div>

  <!-- Info Grid -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(250px, 1fr));gap:1.5rem;margin-bottom:2rem;">
    <div class="dash-panel">
      <div style="padding:1rem;border-bottom:1px solid var(--pg-border);">
        <p style="color:var(--pg-muted);margin:0;font-size:0.85rem;font-weight:700;text-transform:uppercase;">Nom</p>
      </div>
      <div style="padding:1rem;">
        <p style="color:var(--pg-text);margin:0;font-size:1rem;font-weight:600;">{{ produit.nom }}</p>
      </div>
    </div>

    <div class="dash-panel">
      <div style="padding:1rem;border-bottom:1px solid var(--pg-border);">
        <p style="color:var(--pg-muted);margin:0;font-size:0.85rem;font-weight:700;text-transform:uppercase;">Catégorie</p>
      </div>
      <div style="padding:1rem;">
        <p style="color:var(--pg-text);margin:0;font-size:1rem;font-weight:600;">{{ produit.categorie|default('-') }}</p>
      </div>
    </div>

    <div class="dash-panel">
      <div style="padding:1rem;border-bottom:1px solid var(--pg-border);">
        <p style="color:var(--pg-muted);margin:0;font-size:0.85rem;font-weight:700;text-transform:uppercase;">Prix</p>
      </div>
      <div style="padding:1rem;">
        <p style="color:#fbbf24;margin:0;font-size:1.5rem;font-weight:700;">{{ produit.prix }} TND</p>
      </div>
    </div>

    <div class="dash-panel">
      <div style="padding:1rem;border-bottom:1px solid var(--pg-border);">
        <p style="color:var(--pg-muted);margin:0;font-size:0.85rem;font-weight:700;text-transform:uppercase;">Stock</p>
      </div>
      <div style="padding:1rem;">
        <p style="color:var(--pg-text);margin:0;font-size:1.5rem;font-weight:700;">{{ produit.quantite }}</p>
      </div>
    </div>

    <div class="dash-panel">
      <div style="padding:1rem;border-bottom:1px solid var(--pg-border);">
        <p style="color:var(--pg-muted);margin:0;font-size:0.85rem;font-weight:700;text-transform:uppercase;">Disponible</p>
      </div>
      <div style="padding:1rem;">
        <span style="display:inline-block;background:{{ produit.disponible ? 'rgba(6,214,160,0.15)' : 'rgba(200,0,0,0.15)' }};color:{{ produit.disponible ? '#06d6a0' : '#c80000' }};padding:0.3rem 0.8rem;border-radius:4px;font-size:0.85rem;font-weight:700;">
          {{ produit.disponible ? 'Oui' : 'Non' }}
        </span>
      </div>
    </div>
  </div>

  <!-- Description -->
  <div class="dash-panel" style="margin-bottom:2rem;">
    <div style="padding:1rem;border-bottom:1px solid var(--pg-border);">
      <p style="color:var(--pg-text);margin:0;font-size:1rem;font-weight:700;">Description</p>
    </div>
    <div style="padding:1rem;">
      <p style="color:var(--pg-text);margin:0;line-height:1.6;">{{ produit.description|default('Aucune description') }}</p>
    </div>
  </div>

  <!-- Actions -->
  <div class="dash-panel">
    <div style="padding:1rem;border-bottom:1px solid var(--pg-border);">
      <p style="color:var(--pg-text);margin:0;font-size:1rem;font-weight:700;">Actions</p>
    </div>
    <div style="padding:1rem;">
      <span style="background:#f0fdf4;color:#15803d;padding:6px 14px;border-radius:20px;font-size:0.8rem;font-weight:700;">
        🔒 Admin — consultation uniquement
      </span>
    </div>
  </div>
</div>
{% endblock %}
