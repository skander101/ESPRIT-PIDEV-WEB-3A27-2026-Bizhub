{% extends 'back/base.html.twig' %}

{% block title %}Clients - Admin Marketplace{% endblock %}
{% block breadcrumb %}Clients{% endblock %}

{% block content %}
<div style="padding:2rem;">

  {# ── HEADER ── #}
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
    <div>
      <h2 style="font-size:1.5rem;color:var(--pg-text);margin:0 0 .25rem;">Gestion des Clients</h2>
      <p style="color:var(--pg-muted);font-size:.85rem;margin:0;">{{ total }} utilisateur{{ total > 1 ? 's' : '' }} enregistré{{ total > 1 ? 's' : '' }}</p>
    </div>
    <a href="{{ path('admin_marketplace_dashboard') }}"
       style="display:inline-flex;align-items:center;gap:6px;background:var(--pg-surface2);color:var(--pg-text);padding:.6rem 1.2rem;border-radius:6px;text-decoration:none;font-size:.82rem;font-weight:700;border:1px solid var(--pg-border);transition:background .2s;"
       onmouseover="this.style.background='var(--pg-border)'" onmouseout="this.style.background='var(--pg-surface2)'">
      ← Dashboard
    </a>
  </div>

  {# ── KPI DISTRIBUTION ── #}
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:2rem;">
    {% set type_colors = {startup: '#5b6ef5', fournisseur: '#06d6a0', formateur: '#fbbf24', investisseur: '#f472b6'} %}
    {% set type_icons  = {startup: '🚀', fournisseur: '📦', formateur: '🎓', investisseur: '💼'} %}
    {% for d in distribution %}
      {% set col = type_colors[d.role] ?? '#8b5cf6' %}
      {% set ico = type_icons[d.role]  ?? '👤' %}
      <div style="background:var(--pg-surface2);padding:1.2rem 1.4rem;border-radius:10px;border-left:4px solid {{ col }};position:relative;overflow:hidden;">
        <div style="font-size:1.6rem;font-weight:800;color:{{ col }};line-height:1;">{{ d.total }}</div>
        <div style="font-size:.7rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-top:.3rem;letter-spacing:.06em;">{{ d.role }}</div>
        <div style="position:absolute;right:.8rem;top:50%;transform:translateY(-50%);font-size:1.8rem;opacity:.12;">{{ ico }}</div>
      </div>
    {% endfor %}
  </div>

  {# ── FILTRES + RECHERCHE ── #}
  <div style="background:var(--pg-surface2);border-radius:10px;padding:1.2rem 1.5rem;margin-bottom:1.5rem;border:1px solid var(--pg-border);">
    <form method="GET" style="display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;">

      {# Recherche #}
      <div style="flex:1;min-width:200px;display:flex;align-items:center;gap:.5rem;background:var(--pg-bg);border:1px solid var(--pg-border);border-radius:6px;padding:.5rem .9rem;">
        <span style="color:var(--pg-muted);font-size:.85rem;">🔍</span>
        <input type="text" name="q" value="{{ search }}" placeholder="Nom, email…"
               style="background:transparent;border:none;outline:none;color:var(--pg-text);font-size:.85rem;flex:1;min-width:0;">
      </div>

      {# Filtre type #}
      <select name="type" onchange="this.form.submit()"
              style="background:var(--pg-bg);border:1px solid var(--pg-border);border-radius:6px;padding:.5rem .9rem;color:var(--pg-text);font-size:.85rem;cursor:pointer;outline:none;">
        <option value="">Tous les types</option>
        {% for t in types %}
          <option value="{{ t }}" {{ type_filter == t ? 'selected' : '' }}>{{ t|capitalize }}</option>
        {% endfor %}
      </select>

      <button type="submit"
              style="background:#5b6ef5;color:white;padding:.5rem 1.2rem;border:none;border-radius:6px;font-size:.82rem;font-weight:700;cursor:pointer;transition:background .2s;"
              onmouseover="this.style.background='#4a5de4'" onmouseout="this.style.background='#5b6ef5'">
        Filtrer
      </button>

      {% if search or type_filter %}
        <a href="{{ path('admin_marketplace_clients_index') }}"
           style="color:var(--pg-muted);font-size:.82rem;text-decoration:none;padding:.5rem .9rem;border:1px solid var(--pg-border);border-radius:6px;transition:color .2s;"
           onmouseover="this.style.color='var(--pg-text)'" onmouseout="this.style.color='var(--pg-muted)'">
          ✕ Réinitialiser
        </a>
      {% endif %}

    </form>
  </div>

  {# ── TABLEAU CLIENTS ── #}
  <div class="dash-panel">
    {% if users|length > 0 %}
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;color:var(--pg-text);">
          <thead>
            <tr style="background:var(--pg-surface2);">
              <th style="padding:.9rem 1rem;text-align:left;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;border-bottom:1px solid var(--pg-border);">ID</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;border-bottom:1px solid var(--pg-border);">Client</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;border-bottom:1px solid var(--pg-border);">Email</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;border-bottom:1px solid var(--pg-border);">Type</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;border-bottom:1px solid var(--pg-border);">Téléphone</th>
              <th style="padding:.9rem 1rem;text-align:center;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;border-bottom:1px solid var(--pg-border);">Commandes</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;border-bottom:1px solid var(--pg-border);">Statut</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;border-bottom:1px solid var(--pg-border);">Inscription</th>
            </tr>
          </thead>
          <tbody>
            {% for user in users %}
              {% set uid = user.userId %}
              {% set nbCmd = commandes_par_client[uid] ?? 0 %}
              {% set typeColor = type_colors[user.userType] ?? '#8b5cf6' %}
              <tr style="border-top:1px solid var(--pg-border);transition:background .15s;"
                  onmouseover="this.style.background='var(--pg-surface2)'" onmouseout="this.style.background='transparent'">

                {# ID #}
                <td style="padding:.9rem 1rem;font-weight:700;font-size:.82rem;color:var(--pg-muted);">#{{ uid }}</td>

                {# Avatar + nom #}
                <td style="padding:.9rem 1rem;">
                  <div style="display:flex;align-items:center;gap:.75rem;">
                    <div style="width:36px;height:36px;border-radius:50%;flex-shrink:0;overflow:hidden;background:linear-gradient(135deg,{{ typeColor }},{{ typeColor }}88);display:flex;align-items:center;justify-content:center;font-size:.9rem;font-weight:700;color:white;text-transform:uppercase;">
                      {% if user.avatarUrl %}
                        <img src="{{ user.avatarUrl }}" alt="{{ user.fullName }}" style="width:100%;height:100%;object-fit:cover;">
                      {% else %}
                        {{ user.fullName|slice(0,1) }}
                      {% endif %}
                    </div>
                    <div>
                      <div style="font-weight:700;font-size:.88rem;color:var(--pg-text);">{{ user.fullName }}</div>
                      {% if user.companyName %}
                        <div style="font-size:.72rem;color:var(--pg-muted);">{{ user.companyName }}</div>
                      {% endif %}
                    </div>
                  </div>
                </td>

                {# Email #}
                <td style="padding:.9rem 1rem;font-size:.85rem;color:var(--pg-muted);">{{ user.email }}</td>

                {# Type badge #}
                <td style="padding:.9rem 1rem;">
                  <span style="display:inline-block;background:{{ typeColor }}22;color:{{ typeColor }};padding:3px 10px;border-radius:6px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;">
                    {{ user.userType }}
                  </span>
                </td>

                {# Téléphone #}
                <td style="padding:.9rem 1rem;font-size:.85rem;color:var(--pg-muted);">{{ user.phone ?? '—' }}</td>

                {# Commandes #}
                <td style="padding:.9rem 1rem;text-align:center;">
                  {% if nbCmd > 0 %}
                    <a href="{{ path('admin_marketplace_commandes_index') }}"
                       style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;background:rgba(91,110,245,.15);color:#5b6ef5;font-weight:800;font-size:.85rem;text-decoration:none;transition:background .2s;"
                       title="{{ nbCmd }} commande{{ nbCmd > 1 ? 's' : '' }}"
                       onmouseover="this.style.background='rgba(91,110,245,.3)'" onmouseout="this.style.background='rgba(91,110,245,.15)'">
                      {{ nbCmd }}
                    </a>
                  {% else %}
                    <span style="color:var(--pg-muted);font-size:.8rem;">—</span>
                  {% endif %}
                </td>

                {# Statut actif #}
                <td style="padding:.9rem 1rem;">
                  {% set actif = user.isActive ?? false %}
                  <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:6px;font-size:.68rem;font-weight:700;background:{{ actif ? 'rgba(6,214,160,.12)' : 'rgba(200,50,50,.1)' }};color:{{ actif ? '#06d6a0' : '#f87171' }};">
                    <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;"></span>
                    {{ actif ? 'Actif' : 'Inactif' }}
                  </span>
                </td>

                {# Date inscription #}
                <td style="padding:.9rem 1rem;font-size:.8rem;color:var(--pg-muted);">
                  {% if user.createdAt %}
                    {{ user.createdAt|date('d/m/Y') }}
                  {% else %}
                    —
                  {% endif %}
                </td>

              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {# Footer count #}
      <div style="padding:.8rem 1rem;border-top:1px solid var(--pg-border);font-size:.78rem;color:var(--pg-muted);">
        {{ users|length }} client{{ users|length > 1 ? 's' : '' }} affiché{{ users|length > 1 ? 's' : '' }}
        {% if search or type_filter %} — filtrés{% endif %}
      </div>

    {% else %}
      <div style="text-align:center;padding:3rem;color:var(--pg-muted);">
        <div style="font-size:2.5rem;margin-bottom:.8rem;opacity:.3;">👥</div>
        <div style="font-size:.9rem;">Aucun client trouvé{% if search %} pour "{{ search }}"{% endif %}.</div>
        {% if search or type_filter %}
          <a href="{{ path('admin_marketplace_clients_index') }}"
             style="display:inline-block;margin-top:.8rem;color:#5b6ef5;font-size:.82rem;text-decoration:none;">
            Réinitialiser les filtres
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>

</div>
{% endblock %}
