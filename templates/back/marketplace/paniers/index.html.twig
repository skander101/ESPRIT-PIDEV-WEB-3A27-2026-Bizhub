{% extends 'back/base.html.twig' %}

{% block title %}Paniers - Admin{% endblock %}
{% block breadcrumb %}Paniers Actifs (lecture seule){% endblock %}

{% block content %}
<div style="padding:2rem;">

  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:.8rem;">
    <div>
      <h2 style="font-size:1.4rem;color:var(--pg-text);margin:0 0 .25rem 0;">Paniers Actifs</h2>
      <p style="color:var(--pg-muted);margin:0;font-size:0.83rem;">Lecture seule — {{ paniers|length }} article(s) en cours</p>
    </div>
    <a href="{{ path('admin_marketplace_dashboard') }}" style="background:var(--pg-surface2);color:var(--pg-text);padding:8px 16px;border-radius:6px;text-decoration:none;font-size:0.82rem;font-weight:700;border:1px solid var(--pg-border);">
      ← Retour Dashboard
    </a>
  </div>

  <div class="dash-panel">
    {% if paniers|length > 0 %}
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;color:var(--pg-text);">
          <thead>
            <tr style="border-bottom:2px solid var(--pg-border);background:var(--pg-surface2);">
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);font-size:.78rem;text-transform:uppercase;">ID</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);font-size:.78rem;text-transform:uppercase;">Client</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);font-size:.78rem;text-transform:uppercase;">Produit</th>
              <th style="text-align:center;padding:1rem;font-weight:700;color:var(--pg-muted);font-size:.78rem;text-transform:uppercase;">Qté</th>
              <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);font-size:.78rem;text-transform:uppercase;">Ajouté le</th>
            </tr>
          </thead>
          <tbody>
            {% for panier in paniers %}
              <tr style="border-bottom:1px solid var(--pg-border);transition:background .15s;">
                <td style="padding:.9rem 1rem;">
                  <span style="background:var(--pg-surface2);color:var(--pg-muted);padding:3px 8px;border-radius:4px;font-size:.78rem;font-weight:700;">#{{ panier.idPanier }}</span>
                </td>
                <td style="padding:.9rem 1rem;font-weight:600;">
                  <span style="background:#eff6ff;color:#1d4ed8;padding:4px 10px;border-radius:20px;font-size:.8rem;font-weight:700;">
                    Client #{{ panier.idClient }}
                  </span>
                </td>
                <td style="padding:.9rem 1rem;">
                  <span style="font-size:.85rem;color:var(--pg-text);">Produit #{{ panier.idProduit }}</span>
                </td>
                <td style="padding:.9rem 1rem;text-align:center;">
                  <span style="background:#f0fdf4;color:#15803d;padding:4px 12px;border-radius:20px;font-size:.82rem;font-weight:700;">
                    {{ panier.quantite }}
                  </span>
                </td>
                <td style="padding:.9rem 1rem;color:var(--pg-muted);font-size:.82rem;">
                  {{ panier.dateAjout ? panier.dateAjout|date('d/m/Y H:i') : '-' }}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <div style="text-align:center;padding:3rem;color:var(--pg-muted);">
        <div style="font-size:2rem;margin-bottom:.5rem;">🛒</div>
        <p>Aucun article dans les paniers actifs.</p>
      </div>
    {% endif %}
  </div>
</div>
{% endblock %}
