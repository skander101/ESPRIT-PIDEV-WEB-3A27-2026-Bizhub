{% extends 'back/base.html.twig' %}

{% block title %}Tableau de bord Marché - Admin{% endblock %}
{% block breadcrumb %}Tableau de bord Marché{% endblock %}

{% block content %}
<div style="padding:2rem;">

  {# ── TEST BANNER — StatisticsService connecté ── #}
  <div style="background:#dcfce7; border:2px solid #16a34a; border-radius:8px; padding:10px 16px; margin-bottom:1.5rem; display:flex; align-items:center; gap:10px;">
    <span style="font-size:1.2rem;">✅</span>
    <span style="font-family:monospace; font-size:0.8rem; font-weight:700; color:#166534;">
      STATS WORKING — StatisticsService connecté :
      {{ stats.total_commandes }} commandes · {{ stats.total_produits }} produits · {{ top_commandes|length }} top commandes · {{ top_produits|length }} top produits
    </span>
  </div>

  {# ── HEADER ── #}
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
    <div>
      <h2 style="font-size:1.5rem;color:var(--pg-text);margin:0 0 0.25rem 0;">Tableau de bord Marché</h2>
      <p style="color:var(--pg-muted);margin:0;font-size:0.85rem;">Statistiques & gestion du marché en temps réel</p>
    </div>
    <div style="display:flex;gap:.6rem;">
      <a href="{{ path('admin_marketplace_clients_index') }}" style="background:#5b6ef5;color:#fff;padding:8px 16px;border-radius:6px;text-decoration:none;font-size:0.8rem;font-weight:700;">👤 Clients</a>
      <a href="{{ path('admin_marketplace_produits_index') }}" style="background:#06d6a0;color:#fff;padding:8px 16px;border-radius:6px;text-decoration:none;font-size:0.8rem;font-weight:700;">📦 Produits</a>
      <a href="{{ path('admin_marketplace_commandes_index') }}" style="background:#8b5cf6;color:#fff;padding:8px 16px;border-radius:6px;text-decoration:none;font-size:0.8rem;font-weight:700;">🛍️ Commandes</a>
    </div>
  </div>

  {# ── KPI CARDS ── #}
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1.2rem;margin-bottom:2rem;">
    {% set kpis = [
      {v: stats.total_produits,  l: 'Total Produits',  c: '#5b6ef5', i: '📦'},
      {v: stats.produits_dispo,  l: 'Disponibles',     c: '#06d6a0', i: '✅'},
      {v: stats.total_commandes, l: 'Total Commandes', c: '#8b5cf6', i: '🛍️'},
      {v: stats.en_attente,      l: 'En Attente',      c: '#fbbf24', i: '⏳'},
      {v: stats.confirmees,      l: 'Confirmées',      c: '#34d399', i: '✔️'},
      {v: stats.paniers_actifs,  l: 'Paniers Actifs',  c: '#f472b6', i: '🛒'},
    ] %}
    {% for kpi in kpis %}
      <div style="background:var(--pg-surface2);padding:1.4rem;border-radius:10px;border-left:4px solid {{ kpi.c }};position:relative;overflow:hidden;">
        <div style="font-size:1.8rem;font-weight:800;color:{{ kpi.c }};line-height:1;">{{ kpi.v }}</div>
        <div style="font-size:0.72rem;color:var(--pg-muted);text-transform:uppercase;font-weight:700;margin-top:0.4rem;letter-spacing:.06em;">{{ kpi.l }}</div>
        <div style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);font-size:2rem;opacity:.13;">{{ kpi.i }}</div>
      </div>
    {% endfor %}
  </div>

  {# ── REVENUE CHART + STATUTS ── #}
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;margin-bottom:2rem;">

    {# Revenue bar chart #}
    <div class="dash-panel" style="padding:1.5rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;">
        <h3 style="margin:0;font-size:1rem;color:var(--pg-text);">💰 Revenu mensuel</h3>
        <span style="font-size:0.72rem;color:var(--pg-muted);">6 derniers mois — commandes payées</span>
      </div>
        <div style="position:relative; height:220px; width:100%;">
          <canvas id="revenueChart" width="400" height="220"></canvas>
        </div>
        {% if revenue_labels|length == 0 %}
          <div style="text-align:center;padding:1rem;color:var(--pg-muted);font-size:0.85rem;">Aucune donnée de revenu disponible</div>
        {% endif %}
      </div>

    {# Statuts breakdown #}
    <div class="dash-panel" style="padding:1.5rem;">
      <h3 style="margin:0 0 1rem;font-size:1rem;color:var(--pg-text);">📊 Répartition par état</h3>
      {% for statut, count in statuts %}
        {% set pct = stats.total_commandes > 0 ? ((count / stats.total_commandes) * 100)|round(0) : 0 %}
        {% set color = statut == 'en_attente' ? '#fbbf24'
          : (statut == 'confirmee'      ? '#34d399'
          : (statut == 'payee'          ? '#06d6a0'
          : (statut == 'annulee'        ? '#f87171'
          : (statut == 'livree'         ? '#60a5fa'
          : '#a78bfa')))) %}
        <div style="margin-bottom:0.9rem;">
          <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
            <span style="font-size:0.78rem;color:var(--pg-text);font-weight:600;text-transform:capitalize;">{{ statut|replace({'_': ' '}) }}</span>
            <span style="font-size:0.78rem;color:var(--pg-muted);font-weight:700;">{{ count }} ({{ pct }}%)</span>
          </div>
          <div style="background:var(--pg-border);border-radius:4px;height:6px;">
            <div style="background:{{ color }};width:{{ pct }}%;height:6px;border-radius:4px;transition:width .6s ease;"></div>
          </div>
        </div>
      {% endfor %}
    </div>

   </div>

   {# ── NEW CHARTS ROW: Pie chart + Evolution line chart ── #}
   <div style="display:grid;grid-template-columns:1fr 2fr;gap:1.5rem;margin-bottom:2rem;">

     {# Product categories pie chart #}
     <div class="dash-panel" style="padding:1.5rem;">
       <h3 style="margin:0 0 1rem;font-size:1rem;color:var(--pg-text);">🥧 Répartition par catégorie</h3>
          <div style="position:relative; height:220px; width:100%;">
            <canvas id="catPieChart" width="400" height="220"></canvas>
          </div>
          {% if cat_labels|length == 0 %}
            <div style="text-align:center;padding:1rem;color:var(--pg-muted);font-size:0.85rem;">Aucune donnée de catégorie disponible</div>
          {% else %}
            <div style="margin-top:1rem; display:flex; flex-direction:column; gap:.5rem;">
              {% set cat_colors = ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF', '#FF9F40', '#C9CBCF', '#7BC67B', '#FF6B6B', '#4ECDC4'] %}
              {% for i in range(0, cat_labels|length - 1) %}
                <div style="display:flex; align-items:center; gap:.6rem; font-size:.8rem;">
                  <div style="width:10px; height:10px; border-radius:3px; background:{{ cat_colors[i % cat_colors|length] }}; flex-shrink:0;"></div>
                  <span style="flex:1; color:var(--pg-text);">{{ cat_labels[i] ?: 'Non classé' }}</span>
                  <span style="font-family:'Josefin Sans',sans-serif; font-weight:700; color:var(--pg-text);">{{ cat_data[i] }}</span>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>

     {# Orders evolution line chart #}
     <div class="dash-panel" style="padding:1.5rem;">
       <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;">
         <h3 style="margin:0;font-size:1rem;color:var(--pg-text);">📈 Évolution des commandes</h3>
         <span style="font-size:0.72rem;color:var(--pg-muted);">6 derniers mois</span>
       </div>
          <div style="position:relative; height:220px; width:100%;">
            <canvas id="evoLineChart" width="400" height="220"></canvas>
          </div>
          {% if evo_labels|length == 0 %}
            <div style="text-align:center;padding:1rem;color:var(--pg-muted);font-size:0.85rem;">Aucune donnée d'évolution disponible</div>
          {% endif %}
        </div>

   </div>

  {# ── TOP 5 COMMANDES (by amount) ── #}
  <div class="dash-panel" style="margin-bottom:2rem;">
    <div style="padding:1rem 1.5rem;border-bottom:1px solid var(--pg-border);display:flex;align-items:center;justify-content:space-between;">
      <h3 style="margin:0;font-size:1rem;color:var(--pg-text);">🏆 Top 5 — Commandes par montant</h3>
      <a href="{{ path('admin_marketplace_commandes_index') }}"
         style="font-size:0.75rem;color:#5b6ef5;text-decoration:none;font-weight:700;">Voir toutes →</a>
    </div>
    {% if top_commandes|length > 0 %}
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;color:var(--pg-text);">
          <thead>
            <tr style="background:var(--pg-surface2);">
              <th style="padding:.9rem 1rem;text-align:left;font-size:0.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;">#</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:0.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;">Commande</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:0.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;">Client</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:0.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;">Date</th>
              <th style="padding:.9rem 1rem;text-align:left;font-size:0.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;">Statut</th>
              <th style="padding:.9rem 1rem;text-align:right;font-size:0.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--pg-muted);font-weight:700;">Total TTC</th>
            </tr>
          </thead>
          <tbody>
            {% for cmd in top_commandes %}
              {% set medal = loop.index == 1 ? '🥇' : (loop.index == 2 ? '🥈' : (loop.index == 3 ? '🥉' : '')) %}
              <tr style="border-top:1px solid var(--pg-border);transition:background .15s;" onmouseover="this.style.background='var(--pg-surface2)'" onmouseout="this.style.background='transparent'">
                <td style="padding:.9rem 1rem;font-weight:700;font-size:0.9rem;">{{ medal }} {{ loop.index }}</td>
                <td style="padding:.9rem 1rem;">
                  <a href="{{ path('admin_marketplace_commandes_show', {id: cmd.idCommande}) }}"
                     style="color:#5b6ef5;text-decoration:none;font-weight:700;">#{{ cmd.idCommande }}</a>
                </td>
                <td style="padding:.9rem 1rem;color:var(--pg-muted);">Client #{{ cmd.idClient }}</td>
                <td style="padding:.9rem 1rem;font-size:0.82rem;">{{ cmd.dateCommande }}</td>
                <td style="padding:.9rem 1rem;">
                  {% set sc = cmd.statut %}
                  {% set sc_color = sc == 'payee' ? '#06d6a0' : (sc == 'confirmee' ? '#34d399' : (sc == 'livree' ? '#60a5fa' : (sc == 'annulee' ? '#f87171' : '#fbbf24'))) %}
                  <span style="display:inline-block;background:rgba(91,110,245,.12);color:{{ sc_color }};padding:3px 10px;border-radius:6px;font-size:0.72rem;font-weight:700;text-transform:capitalize;">
                    {{ sc|replace({'_': ' '}) }}
                  </span>
                </td>
                <td style="padding:.9rem 1rem;text-align:right;font-family:monospace;font-weight:800;color:#fbbf24;font-size:1rem;">
                  {{ cmd.totalTtc|number_format(3, '.', ' ') }} <span style="font-size:0.7rem;color:var(--pg-muted);">TND</span>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <div style="text-align:center;padding:2.5rem;color:var(--pg-muted);">Aucune commande avec un montant enregistré.</div>
    {% endif %}
  </div>

  {# ── BOTTOM GRID: Top produits + Actions rapides ── #}
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;">

    {# Top 5 produits #}
    <div class="dash-panel">
      <div style="padding:1rem 1.5rem;border-bottom:1px solid var(--pg-border);display:flex;align-items:center;justify-content:space-between;">
        <h3 style="margin:0;font-size:1rem;color:var(--pg-text);">🔥 Top 5 — Produits les plus commandés</h3>
      </div>
      {% if top_produits|length > 0 %}
        <div style="padding:1rem 1.5rem;">
          {% for p in top_produits %}
            <div style="display:flex;align-items:center;gap:1rem;padding:.75rem 0;{% if not loop.last %}border-bottom:1px solid var(--pg-border);{% endif %}">
              {# Rank badge #}
              <div style="width:36px;height:36px;border-radius:50%;background:{% if loop.index == 1 %}linear-gradient(135deg,#f59e0b,#d97706){% elseif loop.index == 2 %}linear-gradient(135deg,#9ca3af,#6b7280){% elseif loop.index == 3 %}linear-gradient(135deg,#cd7f32,#a05c1e){% else %}var(--pg-surface2){% endif %};display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.82rem;color:{% if loop.index <= 3 %}white{% else %}var(--pg-muted){% endif %};flex-shrink:0;">
                {{ loop.index }}
              </div>
              {# Info #}
              <div style="flex:1;min-width:0;">
                <div style="font-weight:700;font-size:0.88rem;color:var(--pg-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ p.nomProduit }}</div>
                {% if p.categorie %}
                  <div style="font-size:0.7rem;color:var(--pg-muted);margin-top:2px;">{{ p.categorie }}</div>
                {% endif %}
              </div>
              {# Metrics #}
              <div style="text-align:right;flex-shrink:0;">
                <div style="font-weight:800;font-size:0.95rem;color:#06d6a0;">{{ p.totalQuantite }} <span style="font-size:0.65rem;color:var(--pg-muted);">unités</span></div>
                <div style="font-size:0.72rem;color:var(--pg-muted);">{{ p.nbCommandes }} cmd{{ p.nbCommandes > 1 ? 's' : '' }}</div>
              </div>
              {# Revenue bar #}
              {% set maxRevenue = top_produits[0].totalRevenue ?? 0 %}
              {% set barPct = maxRevenue > 0 ? ((p.totalRevenue / maxRevenue) * 100)|round(0) : 0 %}
              <div style="width:60px;flex-shrink:0;">
                <div style="background:var(--pg-border);border-radius:4px;height:6px;">
                  <div style="background:#5b6ef5;width:{{ barPct }}%;height:6px;border-radius:4px;"></div>
                </div>
                <div style="font-size:0.65rem;color:var(--pg-muted);margin-top:3px;text-align:right;">{{ p.totalRevenue|number_format(0, '.', ' ') }} TND</div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div style="padding:2rem;text-align:center;color:var(--pg-muted);">Aucune ligne de commande enregistrée.</div>
      {% endif %}
    </div>

    {# Navigation principale #}
    <div class="dash-panel" style="padding:1.5rem;">
      <h3 style="margin:0 0 1.2rem;font-size:1rem;color:var(--pg-text);">🗂️ Gestion Marché</h3>
      <div style="display:flex;flex-direction:column;gap:1rem;">

        {# Clients #}
        <a href="{{ path('admin_marketplace_clients_index') }}"
           style="display:flex;align-items:center;gap:1rem;background:var(--pg-surface2);border:1px solid var(--pg-border);border-radius:10px;padding:1rem 1.2rem;text-decoration:none;transition:border-color .2s,background .2s;"
           onmouseover="this.style.borderColor='#5b6ef5';this.style.background='rgba(91,110,245,.08)'"
           onmouseout="this.style.borderColor='var(--pg-border)';this.style.background='var(--pg-surface2)'">
          <div style="width:42px;height:42px;border-radius:10px;background:rgba(91,110,245,.15);display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0;">👥</div>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:.9rem;color:var(--pg-text);">Clients</div>
            <div style="font-size:.72rem;color:var(--pg-muted);margin-top:2px;">Liste & profils des utilisateurs</div>
          </div>
          <div style="color:#5b6ef5;font-size:1rem;flex-shrink:0;">→</div>
        </a>

        {# Produits #}
        <a href="{{ path('admin_marketplace_produits_index') }}"
           style="display:flex;align-items:center;gap:1rem;background:var(--pg-surface2);border:1px solid var(--pg-border);border-radius:10px;padding:1rem 1.2rem;text-decoration:none;transition:border-color .2s,background .2s;"
           onmouseover="this.style.borderColor='#06d6a0';this.style.background='rgba(6,214,160,.08)'"
           onmouseout="this.style.borderColor='var(--pg-border)';this.style.background='var(--pg-surface2)'">
          <div style="width:42px;height:42px;border-radius:10px;background:rgba(6,214,160,.15);display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0;">📦</div>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:.9rem;color:var(--pg-text);">Produits</div>
            <div style="font-size:.72rem;color:var(--pg-muted);margin-top:2px;">Catalogue & disponibilités</div>
          </div>
          <div style="color:#06d6a0;font-size:1rem;flex-shrink:0;">→</div>
        </a>

        {# Commandes #}
        <a href="{{ path('admin_marketplace_commandes_index') }}"
           style="display:flex;align-items:center;gap:1rem;background:var(--pg-surface2);border:1px solid var(--pg-border);border-radius:10px;padding:1rem 1.2rem;text-decoration:none;transition:border-color .2s,background .2s;"
           onmouseover="this.style.borderColor='#fbbf24';this.style.background='rgba(251,191,36,.08)'"
           onmouseout="this.style.borderColor='var(--pg-border)';this.style.background='var(--pg-surface2)'">
          <div style="width:42px;height:42px;border-radius:10px;background:rgba(251,191,36,.15);display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0;">🛍️</div>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:.9rem;color:var(--pg-text);">Commandes</div>
            <div style="font-size:.72rem;color:var(--pg-muted);margin-top:2px;">Suivi & gestion des commandes</div>
          </div>
          <div style="color:#fbbf24;font-size:1rem;flex-shrink:0;">→</div>
        </a>

      </div>
    </div>

  </div>

</div>

{# Chart.js — Tous les graphiques #}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  
  // ── Revenue bar chart ────────────────────────────────
  var revenueCanvas = document.getElementById('revenueChart');
  if (revenueCanvas) {
    var revenueLabels = {{ revenue_labels|json_encode|raw }};
    var revenueData = {{ revenue_data|json_encode|raw }};
    if (revenueLabels.length > 0) {
      new Chart(revenueCanvas, {
        type: 'bar',
        data: { 
          labels: revenueLabels, 
          datasets: [{
            label: 'CA TTC (TND)',
            data: revenueData,
            backgroundColor: 'rgba(91,110,245,0.7)',
            borderColor: '#5b6ef5',
            borderWidth: 2,
            borderRadius: 6
          }] 
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(ctx) {
                  return Number(ctx.parsed.y).toLocaleString('fr-TN', {minimumFractionDigits: 3}) + ' TND';
                }
              }
            }
          },
          scales: {
            x: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: { color: '#6b7280', font: { size: 11 } }
            },
            y: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                color: '#6b7280',
                font: { size: 11 },
                callback: function(v) { return v.toLocaleString() + ' TND'; }
              },
              beginAtZero: true
            }
          }
        }
      });
    }
  }

  // ── Product categories pie chart ──────────────────────────────────
  var catCanvas = document.getElementById('catPieChart');
  if (catCanvas) {
    var catLabels = {{ cat_labels|json_encode|raw }};
    var catData = {{ cat_data|json_encode|raw }};
    if (catLabels.length > 0) {
      new Chart(catCanvas, {
        type: 'pie',
        data: {
          labels: catLabels,
          datasets: [{
            data: catData,
            backgroundColor: ['#FF6384','#36A2EB','#FFCE56','#4BC0C0','#9966FF','#FF9F40','#C9CBCF','#7BC67B','#FF6B6B','#4ECDC4'],
            borderColor: '#fff',
            borderWidth: 2,
            hoverOffset: 10
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'right',
              labels: {
                color: '#6b7280',
                font: { size: 11 },
                padding: 12,
                usePointStyle: true,
                pointStyle: 'circle'
              }
            },
            tooltip: {
              callbacks: {
                label: function(ctx) {
                  var total = ctx.dataset.data.reduce(function(a,b){return a+b;},0);
                  var pct = total > 0 ? Math.round(ctx.parsed / total * 100) : 0;
                  return ctx.label + ': ' + ctx.parsed + ' produit(s) (' + pct + '%)';
                }
              }
            }
          }
        }
      });
    }
  }

  // ── Orders evolution line chart ──────────────────────────────────
  var evoCanvas = document.getElementById('evoLineChart');
  if (evoCanvas) {
    var evoLabels = {{ evo_labels|json_encode|raw }};
    var evoData = {{ evo_data|json_encode|raw }};
    if (evoLabels.length > 0) {
      new Chart(evoCanvas, {
        type: 'line',
        data: {
          labels: evoLabels,
          datasets: [{
            label: 'Nombre de commandes',
            data: evoData,
            borderColor: '#10b981',
            backgroundColor: 'rgba(16,185,129,0.1)',
            borderWidth: 3,
            pointRadius: 5,
            pointBackgroundColor: '#10b981',
            pointBorderColor: '#fff',
            pointBorderWidth: 2,
            pointHoverRadius: 7,
            tension: 0.3,
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'top',
              labels: {
                color: '#6b7280',
                font: { size: 11 },
                usePointStyle: true,
                pointStyle: 'line'
              }
            },
            tooltip: {
              callbacks: {
                label: function(ctx) {
                  return ctx.dataset.label + ': ' + ctx.parsed.y + ' commande(s)';
                }
              }
            }
          },
          scales: {
            x: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: { color: '#6b7280', font: { size: 11 } }
            },
            y: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: {
                color: '#6b7280',
                font: { size: 11 },
                callback: function(v) { return v + ' cmd'; },
                stepSize: 1
              },
              beginAtZero: true
            }
          }
        }
      });
    }
  }

});
</script>
{% endblock %}
