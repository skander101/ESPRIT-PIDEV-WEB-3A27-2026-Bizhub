{% extends 'back/base.html.twig' %}

{% block title %}Modifier Commande #{{ commande.idCommande }} - Admin{% endblock %}
{% block breadcrumb %}Modifier Commande #{{ commande.idCommande }}{% endblock %}

{% block content %}
<div style="padding:2rem;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
    <div>
      <h2 style="font-size:1.5rem;color:var(--pg-text);margin:0 0 0.5rem 0;">Modifier la Commande</h2>
      <p style="color:var(--pg-muted);margin:0;font-size:0.9rem;">Commande #{{ commande.idCommande }}</p>
    </div>
    <a href="{{ path('admin_marketplace_commandes_show', {id: commande.idCommande}) }}" style="background:var(--pg-surface2);color:var(--pg-text);padding:0.5rem 1rem;border-radius:4px;text-decoration:none;font-weight:700;transition:background 0.2s;border:1px solid var(--pg-border);">← Retour</a>
  </div>

  <div class="dash-panel">
    {{ form_start(form) }}

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
      <div>
        {{ form_label(form.statut, 'Statut', {label_attr: {style: 'color:var(--pg-text);display:block;margin-bottom:0.5rem;font-weight:600;'}}) }}
        {{ form_widget(form.statut, {attr: {style: 'width:100%;padding:0.75rem;background:var(--pg-surface2);border:1px solid var(--pg-border);color:var(--pg-text);border-radius:4px;'}}) }}
        {{ form_errors(form.statut) }}
        <small style="color:var(--pg-muted);display:block;margin-top:0.25rem;">Statut actuel: <strong>{{ commande.statut }}</strong></small>
      </div>

      <div>
        {{ form_label(form.estPayee, 'Paiement', {label_attr: {style: 'color:var(--pg-text);display:block;margin-bottom:0.5rem;font-weight:600;'}}) }}
        <div style="padding:0.75rem;background:var(--pg-surface2);border:1px solid var(--pg-border);border-radius:4px;display:flex;align-items:center;gap:0.5rem;">
          {{ form_widget(form.estPayee, {attr: {style: 'cursor:pointer;width:18px;height:18px;'}}) }}
          <label style="color:var(--pg-text);cursor:pointer;flex:1;margin:0;">Commande payée</label>
        </div>
        {{ form_errors(form.estPayee) }}
      </div>
    </div>

    <div style="display:flex;gap:1rem;padding-top:1rem;border-top:1px solid var(--pg-border);">
      <button type="submit" style="background:#5b6ef5;color:white;padding:0.75rem 1.5rem;border:none;border-radius:4px;font-weight:700;cursor:pointer;transition:background 0.2s;">💾 Enregistrer</button>
      <a href="{{ path('admin_marketplace_commandes_show', {id: commande.idCommande}) }}" style="background:var(--pg-surface2);color:var(--pg-text);padding:0.75rem 1.5rem;border-radius:4px;text-decoration:none;font-weight:700;transition:background 0.2s;border:1px solid var(--pg-border);">Annuler</a>
    </div>

    {{ form_end(form) }}
  </div>
</div>
{% endblock %}
