{% extends 'back/base.html.twig' %}

{% block title %}Edit Review{% endblock %}
{% block breadcrumb %}Edit Review{% endblock %}

{% block content %}
<div style="padding:2rem;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
        <h2 style="font-size:1.5rem;color:var(--pg-text);">Edit Review</h2>
        <a href="{{ path('app_admin_avis_show', {'id': avi.avisId}) }}" style="background:var(--pg-surface);color:var(--pg-text);padding:0.7rem 1.5rem;border-radius:6px;text-decoration:none;font-weight:700;border:1px solid var(--pg-border);">Cancel</a>
    </div>

    <form method="POST" style="max-width:600px;">
        <div class="dash-panel">
            <div style="margin-bottom:1.5rem;">
                <div style="font-size:0.75rem;color:var(--pg-muted);margin-bottom:0.5rem;text-transform:uppercase;font-weight:700;">Review Status</div>
                <label style="display:flex;align-items:center;gap:0.8rem;color:var(--pg-text);cursor:pointer;">
                    <input type="checkbox" name="is_verified" value="1" {% if avi.isVerified %}checked{% endif %} style="width:18px;height:18px;cursor:pointer;"/>
                    <span>Mark as Verified</span>
                </label>
                <div style="font-size:0.8rem;color:var(--pg-muted);margin-top:0.5rem;">
                    {% if avi.isVerified %}
                        This review is currently <strong>verified</strong> and visible to all users.
                    {% else %}
                        This review is currently <strong>pending</strong> verification.
                    {% endif %}
                </div>
            </div>

            <div style="border-top:1px solid var(--pg-border);padding-top:1.5rem;margin-top:1.5rem;">
                <h5 style="margin-bottom:1rem;">Review Details</h5>
                <div style="display:grid;gap:1rem;">
                    <div>
                        <div style="font-size:0.75rem;color:var(--pg-muted);margin-bottom:0.5rem;text-transform:uppercase;font-weight:700;">Author</div>
                        <div style="color:var(--pg-text);font-weight:500;">{{ avi.user.fullName }} ({{ avi.user.email }})</div>
                    </div>
                    <div>
                        <div style="font-size:0.75rem;color:var(--pg-muted);margin-bottom:0.5rem;text-transform:uppercase;font-weight:700;">Rating</div>
                        <div style="color:#ffbe33;font-size:1.1rem;">
                            {% for i in 1..avi.rating %}<i class="fas fa-star"></i>{% endfor %}
                        </div>
                    </div>
                    <div>
                        <div style="font-size:0.75rem;color:var(--pg-muted);margin-bottom:0.5rem;text-transform:uppercase;font-weight:700;">Comment</div>
                        <div style="color:var(--pg-text);padding:1rem;background:var(--pg-surface);border-radius:6px;line-height:1.6;max-height:200px;overflow-y:auto;">
                            {{ avi.comment|nl2br }}
                        </div>
                    </div>
                </div>
            </div>

            <div style="display:flex;gap:1rem;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--pg-border);">
                <input type="hidden" name="_token" value="{{ csrf_token('edit_avis') }}">
                <button type="submit" style="background:#5b6ef5;color:white;padding:0.7rem 1.5rem;border-radius:6px;border:none;font-weight:700;cursor:pointer;transition:background 0.2s;">
                    Save Changes
                </button>
                <a href="{{ path('app_admin_avis_show', {'id': avi.avisId}) }}" style="background:var(--pg-surface);color:var(--pg-text);padding:0.7rem 1.5rem;border-radius:6px;border:1px solid var(--pg-border);text-decoration:none;font-weight:700;">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>
{% endblock %}
