{% extends 'back/base.html.twig' %}

{% block title %}Reviews Management{% endblock %}
{% block breadcrumb %}Reviews{% endblock %}

{% block content %}
<div style="padding:2rem;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
        <h2 style="font-size:1.5rem;color:var(--pg-text);">Reviews Management</h2>
        <div style="display:flex;gap:1rem;">
            <input type="text" id="searchReviews" placeholder="Search reviews..." style="background:var(--pg-surface);border:1px solid var(--pg-border);color:var(--pg-text);padding:0.7rem 1rem;border-radius:6px;width:250px;"/>
        </div>
    </div>

    {% if avis %}
        <div class="dash-panel">
            <div style="overflow-x:auto;">
                <table style="width:100%;color:var(--pg-text);">
                    <thead>
                        <tr style="border-bottom:1px solid var(--pg-border);background:var(--pg-surface2);">
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Author</th>
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Rating</th>
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Comment</th>
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Status</th>
                            <th style="text-align:left;padding:1rem;font-weight:700;color:var(--pg-muted);">Created</th>
                            <th style="text-align:center;padding:1rem;font-weight:700;color:var(--pg-muted);">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for avi in avis %}
                            <tr style="border-bottom:1px solid var(--pg-border);transition:background 0.2s;">
                                <td style="padding:1rem;font-weight:500;">{{ avi.user.fullName }}</td>
                                <td style="padding:1rem;">
                                    <span style="color:#ffbe33;">
                                        {% for i in 1..avi.rating %}<i class="fas fa-star"></i>{% endfor %}
                                    </span>
                                </td>
                                <td style="padding:1rem;max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:{{ avi.isRemoved ? '#9ca3af' : 'var(--pg-muted)' }};font-style:{{ avi.isRemoved ? 'italic' : 'normal' }};">{{ avi.displayComment|raw }}</td>
                                <td style="padding:1rem;">
                                    {% if avi.isRemoved %}
                                        <span style="display:inline-block;background:rgba(200,0,0,0.15);color:#c80000;padding:0.3rem 0.8rem;border-radius:4px;font-size:0.85rem;font-weight:700;">Removed</span>
                                    {% else %}
                                        <span style="display:inline-block;background:{{ avi.isVerified ? 'rgba(6,214,160,0.15)' : 'rgba(200,0,0,0.15)' }};color:{{ avi.isVerified ? '#06d6a0' : '#c80000' }};padding:0.3rem 0.8rem;border-radius:4px;font-size:0.85rem;font-weight:700;">
                                            {{ avi.isVerified ? 'Verified' : 'Pending' }}
                                        </span>
                                    {% endif %}
                                </td>
                                <td style="padding:1rem;color:var(--pg-muted);font-size:0.9rem;">{{ avi.createdAt|date('M d, Y') }}</td>
                                <td style="padding:1rem;text-align:center;">
                                    <div style="display:flex;gap:0.5rem;justify-content:center;">
                                        <a href="{{ path('app_admin_avis_show', {'id': avi.avisId}) }}" style="background:#5b6ef5;color:white;padding:0.4rem 0.8rem;border-radius:4px;text-decoration:none;font-size:0.85rem;font-weight:700;transition:background 0.2s;">View</a>
                                        <a href="{{ path('app_admin_avis_edit', {'id': avi.avisId}) }}" style="background:#8b5cf6;color:white;padding:0.4rem 0.8rem;border-radius:4px;text-decoration:none;font-size:0.85rem;font-weight:700;transition:background 0.2s;">Edit</a>
                                        {% if not avi.isRemoved %}
                                            <form method="POST" action="{{ path('app_admin_avis_remove', {'id': avi.avisId}) }}" style="display:inline;margin:0;" onsubmit="return confirm('Are you sure you want to remove this comment?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('remove_avis') }}">
                                                <button type="submit" style="background:#da3c3c;color:white;padding:0.4rem 0.8rem;border-radius:4px;border:none;font-size:0.85rem;font-weight:700;cursor:pointer;">Soft Ban</button>
                                            </form>
                                        {% else %}
                                            <form method="POST" action="{{ path('app_admin_avis_restore', {'id': avi.avisId}) }}" style="display:inline;margin:0;" onsubmit="return confirm('Restore this comment?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('restore_avis') }}">
                                                <button type="submit" style="background:#06d6a0;color:white;padding:0.4rem 0.8rem;border-radius:4px;border:none;font-size:0.85rem;font-weight:700;cursor:pointer;">Restore</button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="dash-panel" style="text-align:center;padding:3rem 2rem;">
            <p style="color:var(--pg-muted);margin-bottom:1rem;">No reviews found</p>
        </div>
    {% endif %}
</div>
{% endblock %}
