<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inscription faciale - BizHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600;700&family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --primary:      #ffbe33;
            --primary-dark: #e0a820;
            --dark:         #222831;
            --dark2:        #1a1f27;
            --white:        #ffffff;
            --text-muted:   #666666;
            --border:       #ebebeb;
        }
        body {
            font-family: 'Lora', serif;
            background: var(--dark2);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        body::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 20%, rgba(255,190,51,0.08) 0%, transparent 50%),
                        radial-gradient(circle at 70% 80%, rgba(255,190,51,0.05) 0%, transparent 40%);
            pointer-events: none;
        }
        .auth-wrapper {
            width: 100%;
            max-width: 520px;
            position: relative;
            z-index: 1;
        }
        .auth-brand { text-align: center; margin-bottom: 1.5rem; }
        .auth-brand a {
            font-size: 2rem;
            font-weight: 700;
            color: var(--white);
            letter-spacing: 0.1em;
            font-family: 'Josefin Sans', sans-serif;
            text-transform: uppercase;
            text-decoration: none;
        }
        .auth-brand a span { color: var(--primary); }
        .auth-container {
            background: var(--white);
            border-radius: 16px;
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.4);
            padding: 40px;
            border: 1px solid var(--border);
        }
        .step-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            padding: 8px 16px;
            border-radius: 20px;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 1.5rem;
        }
        h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 0.5rem;
            font-family: 'Lora', serif;
        }
        .subtitle {
            color: var(--text-muted);
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            line-height: 1.5;
        }
        .camera-box {
            background: #f8fafc;
            border: 2px dashed #cbd5e1;
            border-radius: 12px;
            padding: 1rem;
            text-align: center;
            margin-bottom: 1.5rem;
            overflow: hidden;
        }
        #video {
            width: 100%;
            border-radius: 8px;
            max-height: 300px;
            object-fit: cover;
        }
        #preview {
            width: 100%;
            border-radius: 8px;
            max-height: 300px;
            object-fit: cover;
            display: none;
        }
        .btn-primary {
            display: block;
            width: 100%;
            background: var(--primary);
            color: var(--dark);
            border: none;
            padding: 14px;
            border-radius: 8px;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
            margin-bottom: 0.75rem;
        }
        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }
        .btn-primary:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
        }
        .btn-secondary {
            display: block;
            width: 100%;
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
            padding: 12px;
            border-radius: 8px;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.85rem;
            text-decoration: none;
            text-align: center;
            cursor: pointer;
        }
        .btn-secondary:hover { border-color: var(--text-muted); }
        .success-box {
            background: #ecfdf5;
            border: 1px solid #a7f3d0;
            border-radius: 8px;
            padding: 1rem;
            color: #065f46;
            margin-bottom: 1rem;
        }
        .success-box i { margin-right: 8px; }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-brand">
            <a href="{{ path('app_index') }}">Biz<span>Hub</span></a>
        </div>

        <div class="auth-container">
            <div class="step-badge">
                <i class="fa-solid fa-face-smile"></i>
                Etape 4: Reconnaissance faciale
            </div>

            <h1>Enroll your face</h1>
            <p class="subtitle">Take a clear photo of your face to enable biometric login. Make sure you're in a well-lit area.</p>

            {% if enrolled %}
                <div class="success-box">
                    <i class="fa-solid fa-check-circle"></i>
                    You are already enrolled. You can re-enroll to update your face data.
                </div>
            {% endif %}

            <div class="camera-box">
                <video id="video" autoplay playsinline></video>
                <img id="preview" alt="Preview">
            </div>

            <button id="captureBtn" class="btn-primary" disabled>
                <i class="fa-solid fa-camera"></i> Capture Photo
            </button>

            <form id="enrollmentForm" method="post" action="{{ path('app_face_enroll_submit') }}" style="display: none;">
                <input type="hidden" name="image" id="capturedImage">
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-check"></i> Confirm & Enroll
                </button>
            </form>

            <a class="btn-secondary" href="{{ path('app_user_dashboard') }}">
                Plus tard
            </a>
        </div>
    </div>

    <script>
        const video = document.getElementById('video');
        const preview = document.getElementById('preview');
        const captureBtn = document.getElementById('captureBtn');
        const capturedImage = document.getElementById('capturedImage');
        const enrollmentForm = document.getElementById('enrollmentForm');

        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } })
            .then(stream => {
                video.srcObject = stream;
                captureBtn.disabled = false;
            })
            .catch(err => {
                alert('Could not access camera: ' + err.message);
            });

        captureBtn.addEventListener('click', () => {
            const canvas = document.createElement('canvas');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            
            const dataUrl = canvas.toDataURL('image/jpeg', 0.9);
            preview.src = dataUrl;
            preview.style.display = 'block';
            video.style.display = 'none';
            capturedImage.value = dataUrl;
            enrollmentForm.style.display = 'block';
            captureBtn.style.display = 'none';
        });
    </script>
</body>
</html>