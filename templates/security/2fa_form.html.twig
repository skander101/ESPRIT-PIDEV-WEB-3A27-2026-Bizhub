<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Two-Factor Authentication - BizHub</title>
    <style>
        body { font-family: Arial, sans-serif; background: #0f1524; color: #fff; margin: 0; padding: 2rem; }
        .card { max-width: 560px; margin: 0 auto; background: #141d2f; border: 1px solid #2a3957; border-radius: 12px; padding: 1.5rem; }
        h1 { margin-top: 0; }
        p { color: #c9d5ea; }
        .row { margin-bottom: 0.9rem; }
        label { display: block; font-weight: 700; margin-bottom: 0.35rem; }
        input { width: 100%; border: 1px solid #324663; border-radius: 8px; background: #091224; color: #fff; padding: 0.75rem; box-sizing: border-box; }
        .btn, button {
            border: 0;
            border-radius: 8px;
            padding: 0.8rem 1rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }
        .btn-primary { background: #ffbe33; color: #111; width: 100%; }
        .btn-secondary { background: #2a3957; color: #fff; }
        .actions { margin-top: 1rem; }
        .flash { margin-bottom: 0.8rem; padding: 0.7rem; border-radius: 8px; }
        .flash-error { background: #3a1521; color: #ffd5df; }
        .flash-success { background: #123525; color: #c5f5d9; }
    </style>
</head>
<body>
<div class="card">
    <h1>Two-Factor Authentication</h1>
    <p>Enter the 6-digit code from your authenticator app.</p>

    {% if authenticationError %}
        <div class="flash flash-error">{{ authenticationError|trans(authenticationErrorData, 'scheb_two_factor') }}</div>
    {% endif %}

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}

    <form method="post" action="{{ check_path_url }}">
        <div class="row">
            <label for="auth_code">Authenticator Code</label>
            <input
                type="text"
                id="auth_code"
                name="_auth_code"
                maxlength="6"
                pattern="[0-9]*"
                inputmode="numeric"
                autocomplete="one-time-code"
                required
                autofocus
            />
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('2fa_verify') }}" />

        <button type="submit" class="btn-primary">Verify</button>
    </form>
</div>
</body>
</html>