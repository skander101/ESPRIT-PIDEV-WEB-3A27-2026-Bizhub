<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Face Login - BizHub</title>
    <style>
        body { font-family: Arial, sans-serif; background: #0f1524; color: #fff; margin: 0; padding: 2rem; }
        .card { max-width: 680px; margin: 0 auto; background: #141d2f; border: 1px solid #2a3957; border-radius: 12px; padding: 1.5rem; }
        h1 { margin-top: 0; }
        p { color: #c9d5ea; }
        .row { display: grid; grid-template-columns: 1fr; gap: 1rem; }
        video, img { width: 100%; max-width: 420px; border-radius: 10px; border: 1px solid #2f4367; }
        .actions { margin-top: 1rem; display: flex; gap: 0.75rem; flex-wrap: wrap; }
        button, .btn {
            border: 0;
            border-radius: 8px;
            padding: 0.8rem 1rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }
        .btn-primary { background: #ffbe33; color: #111; }
        .btn-secondary { background: #2a3957; color: #fff; }
        .flash { margin-bottom: 0.8rem; padding: 0.7rem; border-radius: 8px; }
        .flash-error { background: #3a1521; color: #ffd5df; }
        .flash-success { background: #123525; color: #c5f5d9; }
    </style>
</head>
<body>
<div class="card">
    <h1>Sign in with Face Scan</h1>
    <p>Capture your face and confirm. If matching succeeds, you will be logged in.</p>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    <div class="row">
        <video id="video" autoplay playsinline></video>
        <canvas id="canvas" style="display: none;"></canvas>
        <img id="preview" alt="Preview" style="display: none;" />
    </div>

    <div class="actions">
        <button id="captureBtn" class="btn-primary" disabled>Capture</button>
    </div>

    <form id="faceLoginForm" method="post" action="{{ path('app_login_face') }}" style="display: none; margin-top: 1rem;">
        <input type="hidden" name="image" id="capturedImage" />
        <div class="actions">
            <button type="submit" class="btn-primary">Login with this image</button>
            <a href="{{ path('app_login') }}" class="btn-secondary">Back to email login</a>
        </div>
    </form>

    <div class="actions" style="margin-top: 1rem;">
        <a href="{{ path('app_login') }}" class="btn-secondary">Back to email login</a>
    </div>
</div>

<script>
const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const preview = document.getElementById('preview');
const captureBtn = document.getElementById('captureBtn');
const capturedImage = document.getElementById('capturedImage');
const faceLoginForm = document.getElementById('faceLoginForm');

navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } })
    .then(stream => {
        video.srcObject = stream;
        captureBtn.disabled = false;
    })
    .catch(err => {
        alert('Could not access camera: ' + err.message);
    });

captureBtn.addEventListener('click', () => {
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0);

    const dataUrl = canvas.toDataURL('image/jpeg', 0.9);
    preview.src = dataUrl;
    preview.style.display = 'block';
    capturedImage.value = dataUrl;
    faceLoginForm.style.display = 'block';
});
</script>
</body>
</html>
