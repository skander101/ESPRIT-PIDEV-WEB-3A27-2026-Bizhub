<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - BizHub</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f4f6f8; margin: 0; padding: 2rem; }
        .card { max-width: 520px; margin: 0 auto; background: #fff; padding: 2rem; border-radius: 12px; box-shadow: 0 6px 18px rgba(0,0,0,0.08); }
        h1 { margin-top: 0; color: #1b1f23; }
        .help { color: #555; margin-bottom: 1.2rem; }
        .row { margin-bottom: 1rem; }
        label { display: block; margin-bottom: 0.4rem; font-weight: 600; }
        input { width: 100%; padding: 0.75rem; border: 1px solid #d1d9e0; border-radius: 8px; }
        button { background: #1166ff; color: #fff; border: 0; padding: 0.8rem 1rem; border-radius: 8px; width: 100%; font-weight: 700; cursor: pointer; }
    </style>
</head>
<body>
<div class="card">
    <h1>Set a new password</h1>
    <p class="help">Choose a strong password. It must include uppercase, lowercase, and numbers.</p>

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="row">
            {{ form_label(form.password.first) }}
            {{ form_widget(form.password.first) }}
            {{ form_errors(form.password.first) }}
        </div>
        <div class="row">
            {{ form_label(form.password.second) }}
            {{ form_widget(form.password.second) }}
            {{ form_errors(form.password.second) }}
        </div>
        <button type="submit">Update password</button>
    {{ form_end(form) }}
</div>
</body>
</html>
