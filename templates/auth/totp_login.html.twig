<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TOTP Login - BizHub</title>
    <style>
        body { font-family: Arial, sans-serif; background: #0f1524; color: #fff; margin: 0; padding: 2rem; }
        .card { max-width: 560px; margin: 0 auto; background: #141d2f; border: 1px solid #2a3957; border-radius: 12px; padding: 1.5rem; }
        h1 { margin-top: 0; }
        p { color: #c9d5ea; }
        .row { margin-bottom: 0.9rem; }
        label { display: block; font-weight: 700; margin-bottom: 0.35rem; }
        input { width: 100%; border: 1px solid #324663; border-radius: 8px; background: #091224; color: #fff; padding: 0.75rem; }
        .btn, button {
            border: 0;
            border-radius: 8px;
            padding: 0.8rem 1rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }
        .btn-primary { background: #ffbe33; color: #111; }
        .btn-secondary { background: #2a3957; color: #fff; }
        .actions { margin-top: 1rem; display: flex; gap: 0.75rem; flex-wrap: wrap; }
        .flash { margin-bottom: 0.8rem; padding: 0.7rem; border-radius: 8px; }
        .flash-error { background: #3a1521; color: #ffd5df; }
        .flash-success { background: #123525; color: #c5f5d9; }
        ul { margin: 0.35rem 0 0 1rem; color: #ffd5df; }
    </style>
</head>
<body>
<div class="card">
    <h1>Login with TOTP</h1>
    <p>Use your account email and 6-digit authenticator code.</p>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="row">
            {{ form_label(form.email) }}
            {{ form_widget(form.email, {'attr': {'placeholder': 'you@example.com', 'autocomplete': 'email'}}) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="row">
            {{ form_label(form.otp) }}
            {{ form_widget(form.otp, {'attr': {'placeholder': '123456', 'autocomplete': 'one-time-code', 'inputmode': 'numeric'}}) }}
            {{ form_errors(form.otp) }}
        </div>

        <button type="submit" class="btn-primary">Login with TOTP</button>
    {{ form_end(form) }}

    <div class="actions">
        <a href="{{ path('app_login') }}" class="btn-secondary">Back to login options</a>
    </div>
</div>
</body>
</html>
