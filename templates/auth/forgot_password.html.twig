<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - BizHub</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f4f6f8; margin: 0; padding: 2rem; }
        .card { max-width: 520px; margin: 0 auto; background: #fff; padding: 2rem; border-radius: 12px; box-shadow: 0 6px 18px rgba(0,0,0,0.08); }
        h1 { margin-top: 0; color: #1b1f23; }
        .help { color: #555; margin-bottom: 1.2rem; }
        .row { margin-bottom: 1rem; }
        label { display: block; margin-bottom: 0.4rem; font-weight: 600; }
        input { width: 100%; padding: 0.75rem; border: 1px solid #d1d9e0; border-radius: 8px; }
        button { background: #1166ff; color: #fff; border: 0; padding: 0.8rem 1rem; border-radius: 8px; width: 100%; font-weight: 700; cursor: pointer; }
        .flash { margin-bottom: 1rem; padding: 0.75rem; border-radius: 8px; }
        .flash-success { background: #ecfdf3; color: #0c6b3d; }
        .flash-error { background: #fff1f2; color: #9f1239; }
        .links { margin-top: 1rem; text-align: center; }
    </style>
</head>
<body>
<div class="card">
    <h1>Forgot your password?</h1>
    <p class="help">Enter your email and we will send a secure reset link valid for 15 minutes.</p>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="row">
            {{ form_label(form.email) }}
            {{ form_widget(form.email, {'attr': {'placeholder': 'you@example.com'}}) }}
            {{ form_errors(form.email) }}
        </div>
        <button type="submit">Send reset link</button>
    {{ form_end(form) }}

    <div class="links">
        <a href="{{ path('app_login') }}">Back to login</a>
    </div>
</div>
</body>
</html>
