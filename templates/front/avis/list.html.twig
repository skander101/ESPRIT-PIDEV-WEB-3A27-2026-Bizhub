{% extends 'front/base.html.twig' %}

{% block title %}My Reviews - BizHub{% endblock %}

{% block content %}
<div style="max-width:1000px;margin:0 auto;padding:40px 5%;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
        <div>
            <h2 style="font-size:1.8rem;color:var(--dark);margin-bottom:0.5rem;font-family:'Lora',serif;">My Reviews</h2>
            <p style="color:var(--text-muted);">{% if avis|length %}You have {{ avis|length }} review(s){% else %}You haven't written any reviews yet{% endif %}</p>
        </div>
        <a href="{{ path('app_avis_new') }}" class="btn-yellow">Write Review</a>
    </div>

    {% if avis|length > 0 %}
        <div style="display:grid;gap:1rem;">
            {% for aviItem in avis %}
                <a href="{{ path('app_avis_show', {'id': aviItem.avisId}) }}" class="dash-panel" style="text-decoration:none;color:var(--dark);display:grid;grid-template-columns:auto 1fr auto;gap:1.5rem;align-items:center;transition:border-color 0.2s;cursor:pointer;">
                    <div>
                        <div style="font-size:1.5rem;">
                            {% for i in 1..aviItem.rating %}<i class="fa fa-star" style="color:var(--primary);"></i>{% endfor %}
                        </div>
                    </div>
                    <div>
                        <div style="font-weight:700;color:var(--dark);margin-bottom:0.5rem;font-size:0.95rem;">
                            {{ aviItem.comment|slice(0, 80) }}{% if aviItem.comment|length > 80 %}...{% endif %}
                        </div>
                        <div style="font-size:0.85rem;color:var(--text-muted);">
                            Published {{ aviItem.createdAt|date('M d, Y') }}
                            {% if aviItem.isVerified %}
                                <span style="background:rgba(6,214,160,0.2);color:var(--primary);padding:2px 8px;border-radius:3px;font-size:0.75rem;margin-left:0.5rem;">Verified</span>
                            {% endif %}
                        </div>
                    </div>
                    <div style="text-align:right;">
                        <a href="{{ path('app_avis_edit', {'id': aviItem.avisId}) }}" style="color:var(--primary);text-decoration:none;font-weight:700;display:block;margin-bottom:0.5rem;">Edit</a>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="dash-panel" style="text-align:center;padding:3rem 2rem;">
            <i class="fa fa-star" style="font-size:2.5rem;color:var(--text-muted);margin-bottom:1rem;display:block;opacity:0.5;"></i>
            <p style="color:var(--text-muted);margin-bottom:1.5rem;font-size:0.95rem;">
                You haven't written any reviews yet. Share your experience and help others!
            </p>
            <a href="{{ path('app_avis_new') }}" class="btn-yellow">Write Your First Review</a>
        </div>
    {% endif %}
</div>
{% endblock %}
