{% extends 'front/base.html.twig' %}

{% block title %}Review - BizHub{% endblock %}

{% block content %}
<div style="max-width:900px;margin:0 auto;padding:40px 5%;">
    <a href="{{ path('app_avis_list') }}" style="color:var(--primary);text-decoration:none;font-weight:700;margin-bottom:1.5rem;display:inline-flex;align-items:center;gap:0.5rem;">
        <i class="fa fa-arrow-left"></i> Back to Reviews
    </a>

    <div class="dash-panel">
        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:1.5rem;">
            <div>
                <h2 style="font-size:1.6rem;color:var(--dark);margin-bottom:0.5rem;">
                    {% for i in 1..avis.rating %}<i class="fa fa-star" style="color:var(--primary);"></i>{% endfor %}
                </h2>
                <div style="font-size:0.9rem;color:var(--text-muted);">
                    By <strong>{{ avis.user.fullName }}</strong> on {{ avis.createdAt|date('F d, Y') }}
                </div>
            </div>
            {% if app.user == avis.user or is_granted('ROLE_ADMIN') %}
                <div style="display:flex;gap:0.5rem;">
                    <a href="{{ path('app_avis_edit', {'id': avis.avisId}) }}" class="btn-yellow" style="padding:8px 16px;font-size:0.8rem;">Edit</a>
                    <form method="POST" action="{{ path('app_avis_delete', {'id': avis.avisId}) }}" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this review?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ avis.avisId) }}">
                        <button type="submit" style="background:#da3c3c;color:white;border:none;padding:8px 16px;border-radius:6px;font-size:0.8rem;cursor:pointer;font-weight:700;transition:background 0.2s;">Delete</button>
                    </form>
                </div>
            {% endif %}
        </div>

        {% if avis.isVerified %}
            <div style="background:rgba(6,214,160,0.1);border-left:3px solid var(--primary);padding:0.8rem 1rem;border-radius:4px;margin-bottom:1.5rem;font-size:0.85rem;color:var(--dark);">
                <i class="fa fa-check-circle" style="color:var(--primary);margin-right:0.5rem;"></i> Verified Review
            </div>
        {% endif %}

        <div style="padding:1.5rem;background:var(--light-bg);border-radius:8px;line-height:1.8;">
            {{ avis.comment|nl2br }}
        </div>

        {% if is_granted('ROLE_ADMIN') and not avis.isVerified %}
            <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border);">
                <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:0.8rem;">Admin Action</p>
                <form method="GET" style="display:inline;">
                    <a href="{{ path('app_avis_edit', {'id': avis.avisId}) }}" class="btn-yellow" style="padding:8px 16px;font-size:0.8rem;">Verify Review</a>
                </form>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
