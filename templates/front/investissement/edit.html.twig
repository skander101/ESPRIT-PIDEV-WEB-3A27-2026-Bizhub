{% extends 'front/base.html.twig' %}

{% block title %}Modifier investissement — BizHub{% endblock %}

{% block extra_styles %}
.page-header { background: linear-gradient(135deg, var(--dark) 0%, var(--dark2) 100%); padding: 60px 5% 40px; }
.page-header h1 { font-size: 2rem; color: var(--white); font-family: 'Josefin Sans', sans-serif; font-weight: 700; }
.page-header p { color: rgba(255,255,255,0.55); margin-top: 0.4rem; }
.back-link { display: inline-flex; align-items: center; gap: 6px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.8rem; margin-bottom: 1rem; transition: color 0.2s; font-family: 'Josefin Sans', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }
.back-link:hover { color: var(--primary); }
.page-body { max-width: 1000px; margin: 0 auto; padding: 40px 5%; }
.form-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--border); box-shadow: 0 4px 18px rgba(0,0,0,0.06); padding: 30px; margin-bottom: 2rem; }
.form-group { margin-bottom: 1.5rem; }
.form-group label { display: block; font-weight: 700; font-size: 0.85rem; color: var(--dark); margin-bottom: 0.5rem; font-family: 'Josefin Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.06em; }
.form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px 12px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 0.95rem; color: var(--dark); background: var(--white); transition: border-color 0.2s; font-family: 'Lora', serif; }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(255,190,51,0.1); }
.form-group textarea { resize: vertical; min-height: 80px; }
.form-errors { color: #ef4444; font-size: 0.8rem; margin-top: 0.3rem; display: block; }
.form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.form-actions { display: flex; gap: 1rem; justify-content: flex-start; margin-top: 2rem; }
.btn-primary { background: var(--primary); color: var(--dark); padding: 12px 28px; border-radius: 8px; font-size: 0.85rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.06em; border: none; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; }
.btn-primary:hover { background: var(--primary-dark); }
.btn-secondary { background: var(--light-bg); color: var(--dark); padding: 12px 28px; border-radius: 8px; font-size: 0.85rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.06em; border: 1.5px solid var(--border); cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; }
.btn-secondary:hover { border-color: var(--primary); background: rgba(255,190,51,0.08); }
.flash-msg { padding: 14px 20px; border-radius: 10px; margin-bottom: 1.5rem; font-size: 0.9rem; font-weight: 600; }
.flash-success { background: rgba(6,214,160,0.1); color: #06d6a0; border: 1px solid rgba(6,214,160,0.3); }
.flash-error { background: rgba(239,68,68,0.08); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
@media (max-width: 768px) { .form-row-2 { grid-template-columns: 1fr; } }
{% endblock %}

{% block content %}
<div class="page-header">
    <div style="max-width:1000px;margin:0 auto;">
        <a href="{{ path('app_front_investissement_index') }}" class="back-link">
            <i class="fa fa-arrow-left"></i> Retour à mes investissements
        </a>
        <h1><i class="fa fa-pen" style="color:var(--primary);margin-right:0.5rem;"></i>Modifier mon investissement</h1>
        {% if investment.project %}
            <p>{{ investment.project.title }}</p>
        {% endif %}
    </div>
</div>

<div class="page-body">
    <div class="form-card">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="form-row-2">
                <div class="form-group">
                    {{ form_label(form.amount) }}
                    {{ form_widget(form.amount) }}
                    {% if form.amount.vars.errors %}
                        {% for error in form.amount.vars.errors %}
                            <span class="form-errors">{{ error.message }}</span>
                        {% endfor %}
                    {% endif %}
                </div>

                <div class="form-group">
                    {{ form_label(form.investment_date) }}
                    {{ form_widget(form.investment_date) }}
                    {% if form.investment_date.vars.errors %}
                        {% for error in form.investment_date.vars.errors %}
                            <span class="form-errors">{{ error.message }}</span>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

            <div class="form-row-2">
                <div class="form-group">
                    {{ form_label(form.payment_mode) }}
                    {{ form_widget(form.payment_mode) }}
                    {% if form.payment_mode.vars.errors %}
                        {% for error in form.payment_mode.vars.errors %}
                            <span class="form-errors">{{ error.message }}</span>
                        {% endfor %}
                    {% endif %}
                </div>

                <div class="form-group">
                    {{ form_label(form.statut) }}
                    {{ form_widget(form.statut) }}
                    {% if form.statut.vars.errors %}
                        {% for error in form.statut.vars.errors %}
                            <span class="form-errors">{{ error.message }}</span>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.contract_url) }}
                {{ form_widget(form.contract_url) }}
                {% if form.contract_url.vars.errors %}
                    {% for error in form.contract_url.vars.errors %}
                        <span class="form-errors">{{ error.message }}</span>
                    {% endfor %}
                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.commentaire) }}
                {{ form_widget(form.commentaire) }}
                {% if form.commentaire.vars.errors %}
                    {% for error in form.commentaire.vars.errors %}
                        <span class="form-errors">{{ error.message }}</span>
                    {% endfor %}
                {% endif %}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    <i class="fa fa-save"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('app_front_investissement_index') }}" class="btn-secondary">
                    <i class="fa fa-arrow-left"></i> Annuler
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
