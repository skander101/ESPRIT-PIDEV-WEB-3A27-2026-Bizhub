{% extends 'front/base.html.twig' %}

{% block title %}Investir dans {{ projet.title }} — BizHub{% endblock %}

{% block extra_styles %}
/* ── Page layout ─────────────────────────────────────── */
.invest-header {
    background: linear-gradient(135deg, var(--dark) 0%, #1a1f2e 100%);
    padding: 56px 5% 38px;
}
.invest-header h1 {
    font-size: 1.75rem; color: var(--white);
    font-family: 'Josefin Sans', sans-serif; font-weight: 700;
    margin: 0 0 0.3rem;
}
.invest-header p { color: rgba(255,255,255,0.5); font-size: 0.88rem; margin: 0; }
.back-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.78rem;
    margin-bottom: 1.4rem; transition: color 0.2s;
    font-family: 'Josefin Sans', sans-serif; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
}
.back-link:hover { color: var(--primary); }

.invest-body {
    max-width: 980px; margin: 0 auto;
    padding: 36px 5%;
    display: grid; grid-template-columns: 1fr 290px;
    gap: 2rem; align-items: start;
}

/* ── Form card ────────────────────────────────────────── */
.invest-form-card {
    background: var(--white);
    border-radius: 16px;
    border: 1.5px solid var(--border);
    padding: 32px 28px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}

/* ── Section labels ───────────────────────────────────── */
.form-section-label {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-muted);
    font-family: 'Josefin Sans', sans-serif;
    border-bottom: 1.5px solid var(--border);
    padding-bottom: 8px; margin: 24px 0 16px;
}
.form-section-label:first-child { margin-top: 0; }

/* ── Grid helpers ─────────────────────────────────────── */
.form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

/* ── Field groups ─────────────────────────────────────── */
.form-group { margin-bottom: 0; }
.form-group label {
    display: block; font-size: 0.82rem; font-weight: 600;
    color: var(--dark); margin-bottom: 6px;
}
.form-group input,
.form-group select,
.form-group textarea {
    width: 100%; box-sizing: border-box;
    padding: 10px 14px;
    border: 1.5px solid var(--border); border-radius: 9px;
    font-size: 0.88rem; color: var(--dark);
    background: #fafafa;
    transition: border-color 0.18s, box-shadow 0.18s;
    outline: none;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(255,190,51,0.15);
    background: var(--white);
}
.form-group select { appearance: auto; cursor: pointer; }
.form-group textarea { resize: vertical; min-height: 80px; }
.form-hint {
    font-size: 0.74rem; color: var(--text-muted);
    margin-top: 5px; display: flex; align-items: center; gap: 5px;
}
.form-errors { color: #dc2626; font-size: 0.78rem; margin-top: 4px; }

/* ── Confirmation checkbox ────────────────────────────── */
.confirm-block {
    background: rgba(255,190,51,0.06);
    border: 1.5px solid rgba(255,190,51,0.25);
    border-radius: 12px;
    padding: 16px 18px;
    margin-top: 24px;
    display: flex; gap: 12px; align-items: flex-start;
}
.confirm-block input[type="checkbox"] {
    width: 18px; height: 18px; flex-shrink: 0;
    margin-top: 2px; accent-color: var(--primary);
    cursor: pointer;
}
.confirm-block label {
    font-size: 0.83rem; font-weight: 500; color: var(--dark);
    line-height: 1.5; margin: 0; cursor: pointer;
}
.confirm-block .form-errors { margin-top: 4px; }

/* ── Submit button ────────────────────────────────────── */
.invest-submit {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; margin-top: 20px;
    padding: 14px 24px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: var(--dark); font-weight: 700; font-size: 0.95rem;
    font-family: 'Josefin Sans', sans-serif; letter-spacing: 0.04em;
    border: none; border-radius: 10px; cursor: pointer;
    box-shadow: 0 4px 14px rgba(255,190,51,0.35);
    transition: transform 0.15s, box-shadow 0.15s;
}
.invest-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(255,190,51,0.45);
}
.invest-submit:active { transform: translateY(0); }

/* ── Project summary sidebar ──────────────────────────── */
.project-summary {
    background: var(--white); border-radius: 14px;
    border: 1.5px solid var(--border); padding: 22px 20px;
    box-shadow: 0 4px 18px rgba(0,0,0,0.06); position: sticky; top: 90px;
}
.summary-head {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; font-family: 'Josefin Sans', sans-serif;
    color: var(--text-muted); margin-bottom: 14px; padding-bottom: 10px;
    border-bottom: 1.5px solid var(--border);
    display: flex; align-items: center; gap: 7px;
}
.info-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 0.82rem;
}
.info-row:last-of-type { border-bottom: none; }
.info-label { color: var(--text-muted); }
.info-value { font-weight: 700; color: var(--dark); font-family: 'Josefin Sans', sans-serif; }
.progress-bar-wrap { height: 7px; background: var(--border); border-radius: 4px; overflow: hidden; margin: 8px 0 4px; }
.progress-bar-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--primary-dark)); border-radius: 4px; }

@media (max-width: 768px) {
    .invest-body { grid-template-columns: 1fr; }
    .form-row-2  { grid-template-columns: 1fr; }
    .invest-form-card { padding: 22px 16px; }
}
{% endblock %}

{% block content %}
<div class="invest-header">
    <div style="max-width:980px;margin:0 auto;">
        <a href="{{ path('app_front_projet_show', {'id': projet.project_id}) }}" class="back-link">
            <i class="fa fa-arrow-left"></i> Retour au projet
        </a>
        <h1><i class="fa fa-hand-holding-usd" style="color:var(--primary);margin-right:0.5rem;"></i>Soumettre un investissement</h1>
        <p>{{ projet.title }}</p>
    </div>
</div>

<div class="invest-body">

    {# ── Formulaire ────────────────────────────────────── #}
    <div class="invest-form-card">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'invest-form'}}) }}

        {# Section 1 : Détails financiers #}
        <div class="form-section-label"><i class="fa fa-coins" style="color:var(--primary);"></i> Détails financiers</div>

        <div class="form-row-2">
            <div class="form-group">
                {{ form_label(form.amount) }}
                {{ form_widget(form.amount) }}
                {{ form_errors(form.amount) }}
                <div class="form-hint"><i class="fa fa-info-circle"></i> Minimum 100 TND</div>
            </div>

            <div class="form-group">
                {{ form_label(form.payment_mode) }}
                {{ form_widget(form.payment_mode) }}
                {{ form_errors(form.payment_mode) }}
            </div>
        </div>

        {# Section 2 : Nature de l'investissement #}
        <div class="form-section-label"><i class="fa fa-layer-group" style="color:var(--primary);"></i> Nature de l'investissement</div>

        <div class="form-row-2">
            <div class="form-group">
                {{ form_label(form.typeInvestissement) }}
                {{ form_widget(form.typeInvestissement) }}
                {{ form_errors(form.typeInvestissement) }}
            </div>

            <div class="form-group">
                {{ form_label(form.dureeSouhaitee) }}
                {{ form_widget(form.dureeSouhaitee) }}
                {{ form_errors(form.dureeSouhaitee) }}
            </div>
        </div>

        {# Section 3 : Informations complémentaires #}
        <div class="form-section-label"><i class="fa fa-comment-dots" style="color:var(--primary);"></i> Informations complémentaires</div>

        <div class="form-group" style="margin-bottom:14px;">
            {{ form_label(form.conditionsParticulieres) }}
            {{ form_widget(form.conditionsParticulieres) }}
            {{ form_errors(form.conditionsParticulieres) }}
            <div class="form-hint"><i class="fa fa-file-contract"></i> Clauses, exigences, droits attendus — optionnel</div>
        </div>

        <div class="form-group">
            {{ form_label(form.commentaire) }}
            {{ form_widget(form.commentaire) }}
            {{ form_errors(form.commentaire) }}
            <div class="form-hint"><i class="fa fa-paper-plane"></i> Message visible par la startup — optionnel</div>
        </div>

        {# Case de confirmation #}
        <div class="confirm-block">
            {{ form_widget(form.confirmation) }}
            <div>
                {{ form_label(form.confirmation) }}
                {{ form_errors(form.confirmation) }}
            </div>
        </div>

        <button type="submit" class="invest-submit">
            <i class="fa fa-check-circle"></i> Confirmer ma demande d'investissement
        </button>

        {{ form_end(form) }}
    </div>

    {# ── Résumé du projet ──────────────────────────────── #}
    <div class="project-summary">
        <div class="summary-head">
            <i class="fa fa-folder-open" style="color:var(--primary);"></i> Résumé du projet
        </div>

        <div style="font-weight:700;font-size:0.93rem;margin-bottom:0.4rem;color:var(--dark);">{{ projet.title }}</div>

        <div style="margin-bottom:0.9rem;">
            <span class="badge badge-{{ projet.status }}">
                {% if projet.status == 'publie' %}Publié
                {% elseif projet.status == 'en_cours' %}En cours
                {% else %}{{ projet.status }}{% endif %}
            </span>
        </div>

        {% if projet.description %}
            <p style="font-size:0.81rem;color:var(--text-muted);line-height:1.6;margin-bottom:1rem;">
                {{ projet.description|slice(0,120) }}{% if projet.description|length > 120 %}…{% endif %}
            </p>
        {% endif %}

        <div class="progress-bar-wrap">
            <div class="progress-bar-fill" style="width:{{ pourcentage }}%;"></div>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:0.73rem;color:var(--text-muted);margin-bottom:0.9rem;">
            <span>{{ total_investi|number_format(0,',',' ') }} TND</span>
            <span>{{ pourcentage }}%</span>
        </div>

        <div class="info-row">
            <span class="info-label">Objectif</span>
            <span class="info-value">{{ projet.requiredBudget|number_format(0,',',' ') }} TND</span>
        </div>
        <div class="info-row">
            <span class="info-label">Investisseurs</span>
            <span class="info-value">{{ projet.investments|length }}</span>
        </div>
        {% if projet.secteur %}
        <div class="info-row">
            <span class="info-label">Secteur</span>
            <span class="info-value">{{ projet.secteur|capitalize }}</span>
        </div>
        {% endif %}
        {% if projet.user %}
        <div class="info-row">
            <span class="info-label">Startup</span>
            <span class="info-value">{{ projet.user.fullName }}</span>
        </div>
        {% endif %}
        <div class="info-row">
            <span class="info-label">Créé le</span>
            <span class="info-value">{{ projet.createdAt ? projet.createdAt|date('d/m/Y') : '—' }}</span>
        </div>

        <a href="{{ path('app_front_projet_show', {'id': projet.project_id}) }}"
           class="btn-ghost" style="width:100%;justify-content:center;margin-top:1.2rem;display:flex;align-items:center;gap:6px;font-size:0.83rem;">
            <i class="fa fa-eye"></i> Voir le projet complet
        </a>
    </div>

</div>
{% endblock %}
