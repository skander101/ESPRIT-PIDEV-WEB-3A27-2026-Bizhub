{% extends 'front/base.html.twig' %}
{% block title %}Marketplace — BizHub{% endblock %}

{% block extra_styles %}
/* ── HERO ── */
.mkt-hero {
  position: relative; overflow: hidden;
  background: linear-gradient(135deg, #0d1117 0%, #151b26 50%, #1a2235 100%);
  padding: 72px 5% 56px;
}
.mkt-hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 70% 50%, rgba(255,190,51,.08) 0%, transparent 70%);
  pointer-events: none;
}
.mkt-hero-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
.mkt-hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: 'Josefin Sans', sans-serif; font-size: .7rem; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase; color: var(--primary);
  margin-bottom: 1rem;
}
.mkt-hero-eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--primary); }
.mkt-hero h1 {
  font-family: 'Josefin Sans', sans-serif; font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700; color: #fff; margin: 0 0 .8rem; line-height: 1.15;
}
.mkt-hero h1 em { color: var(--primary); font-style: normal; }
.mkt-hero-sub { color: rgba(255,255,255,.5); font-size: .92rem; margin: 0 0 2rem; max-width: 520px; line-height: 1.7; }
.mkt-hero-stats { display: flex; gap: 2.5rem; flex-wrap: wrap; }
.mkt-hero-stat-v { font-family: 'Josefin Sans', sans-serif; font-size: 1.6rem; font-weight: 700; color: #fff; line-height: 1; }
.mkt-hero-stat-l { font-size: .72rem; color: rgba(255,255,255,.35); letter-spacing: .08em; text-transform: uppercase; margin-top: 4px; }
.mkt-hero-actions { display: flex; gap: .8rem; flex-wrap: wrap; }

/* ── CATEGORIES PILLS ── */
.mkt-cats { background: #fff; border-bottom: 1.5px solid var(--border); padding: 16px 5%; position: sticky; top: 70px; z-index: 90; }
.mkt-cats-inner { max-width: 1200px; margin: 0 auto; display: flex; gap: .5rem; flex-wrap: wrap; align-items: center; }
.cat-pill {
  font-family: 'Josefin Sans', sans-serif; font-size: .72rem; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase; padding: 7px 18px;
  border-radius: 100px; border: 1.5px solid var(--border);
  background: #fff; color: var(--text-muted); text-decoration: none;
  transition: all .18s; white-space: nowrap; display: inline-block;
}
.cat-pill:hover, .cat-pill.active { background: var(--primary); color: var(--dark); border-color: var(--primary); }

/* ── BODY ── */
.mkt-body { max-width: 1200px; margin: 0 auto; padding: 36px 5%; }

/* ── SEARCH BAR ── */
.mkt-search-bar {
  display: flex; gap: .8rem; align-items: center; margin-bottom: 2.4rem;
  background: #fff; border: 1.5px solid var(--border); border-radius: 12px;
  padding: 10px 16px; box-shadow: 0 2px 10px rgba(0,0,0,.04);
}
.mkt-search-bar input {
  flex: 1; border: none; outline: none; font-size: .9rem; color: var(--dark);
  background: transparent;
}
.mkt-search-bar input::placeholder { color: var(--text-muted); }
.mkt-search-btn {
  padding: 9px 22px; background: var(--primary); border: none; border-radius: 8px;
  font-weight: 700; font-size: .82rem; cursor: pointer; font-family: 'Josefin Sans', sans-serif;
  transition: background .15s; white-space: nowrap;
}
.mkt-search-btn:hover { background: var(--primary-dark); }

/* ── RESULTS HEADER ── */
.mkt-results-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.4rem; flex-wrap: wrap; gap: .8rem; }
.mkt-results-count { font-size: .82rem; color: var(--text-muted); }
.mkt-results-count strong { color: var(--dark); }

/* ── PRODUCT GRID ── */
.prod-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px,1fr)); gap: 1.5rem; }

.prod-card {
  background: #fff; border-radius: 16px; border: 1.5px solid var(--border);
  overflow: hidden; transition: transform .2s, box-shadow .2s, border-color .2s;
  box-shadow: 0 2px 12px rgba(0,0,0,.05); display: flex; flex-direction: column;
}
.prod-card:hover { transform: translateY(-5px); box-shadow: 0 14px 40px rgba(0,0,0,.1); border-color: rgba(255,190,51,.35); }

.prod-img-wrap { position: relative; overflow: hidden; }
.prod-img {
  width: 100%; height: 200px; object-fit: cover; background: #f3f4f6;
  display: flex; align-items: center; justify-content: center;
  font-size: 3.5rem; color: #d1d5db; transition: transform .4s;
}
.prod-card:hover .prod-img { transform: scale(1.04); }
.prod-img img { width: 100%; height: 200px; object-fit: cover; transition: transform .4s; display: block; }
.prod-card:hover .prod-img img { transform: scale(1.04); }
.prod-badge-stock {
  position: absolute; top: 10px; right: 10px;
  background: rgba(239,68,68,.92); color: #fff;
  font-family: 'Josefin Sans', sans-serif; font-size: .62rem; font-weight: 700;
  letter-spacing: .08em; text-transform: uppercase; padding: 3px 9px; border-radius: 100px;
}

.prod-body { padding: 18px; flex: 1; display: flex; flex-direction: column; }
.prod-cat {
  font-size: .64rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em;
  color: var(--primary); margin-bottom: .5rem; font-family: 'Josefin Sans', sans-serif;
  display: inline-flex; align-items: center; gap: 5px;
}
.prod-name {
  font-size: .95rem; font-weight: 700; color: var(--dark); margin-bottom: .5rem;
  line-height: 1.35; flex: 1;
}
.prod-name a { text-decoration: none; color: inherit; }
.prod-name a:hover { color: var(--primary); }
.prod-desc { font-size: .78rem; color: var(--text-muted); line-height: 1.55; margin-bottom: .8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.prod-price { font-family: 'Josefin Sans', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--dark); }
.prod-price span { font-size: .75rem; color: var(--text-muted); font-weight: 400; }

.prod-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 18px; border-top: 1px solid var(--border); background: #fafafa;
}
.prod-stock { font-size: .72rem; color: var(--text-muted); display: flex; align-items: center; gap: 4px; }
.prod-stock.low { color: #ef4444; font-weight: 600; }
.prod-stock.ok  { color: #059669; }
.btn-add {
  padding: 8px 18px; background: var(--primary); border: none; border-radius: 8px;
  font-weight: 700; font-size: .78rem; cursor: pointer; font-family: 'Josefin Sans', sans-serif;
  transition: background .15s, transform .1s; display: flex; align-items: center; gap: 6px;
  text-decoration: none; color: var(--dark);
}
.btn-add:hover { background: var(--primary-dark); transform: scale(1.03); }
.btn-view {
  padding: 8px 14px; background: transparent; border: 1.5px solid var(--border);
  border-radius: 8px; font-size: .78rem; font-weight: 700; cursor: pointer;
  font-family: 'Josefin Sans', sans-serif; color: var(--dark); text-decoration: none;
  transition: border-color .15s, color .15s;
}
.btn-view:hover { border-color: var(--primary); color: var(--primary); }

/* ── EMPTY STATE ── */
.mkt-empty { text-align: center; padding: 80px 20px; color: var(--text-muted); background: #fff; border-radius: 16px; border: 1.5px solid var(--border); }
.mkt-empty i { font-size: 3.5rem; margin-bottom: 1.2rem; display: block; opacity: .4; }
.mkt-empty h3 { font-family: 'Josefin Sans', sans-serif; font-size: 1.1rem; color: var(--dark); margin-bottom: .5rem; }

/* ── SELLER CTA ── */
.seller-cta {
  background: linear-gradient(135deg, var(--dark) 0%, #242e42 100%);
  border-radius: 16px; padding: 40px; margin-top: 3rem;
  display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;
}
.seller-cta h3 { font-family: 'Josefin Sans', sans-serif; font-size: 1.3rem; font-weight: 700; color: #fff; margin: 0 0 .5rem; }
.seller-cta p { color: rgba(255,255,255,.5); font-size: .88rem; margin: 0; }

@media(max-width: 768px) {
  .mkt-hero-stats { gap: 1.5rem; }
  .prod-grid { grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); }
  .seller-cta { flex-direction: column; text-align: center; }
}
@media(max-width: 480px) { .prod-grid { grid-template-columns: 1fr 1fr; } }
@media(max-width: 360px) { .prod-grid { grid-template-columns: 1fr; } }
{% endblock %}

{% block content %}

{# ── HERO ── #}
<div class="mkt-hero">
  <div class="mkt-hero-inner">
    <div class="mkt-hero-eyebrow"><i class="fa fa-store"></i> Produits & Services</div>
    <h1>Marketplace <em>BizHub</em></h1>
    <p class="mkt-hero-sub">Découvrez des produits et services professionnels proposés par les fournisseurs de la communauté BizHub.</p>

    <div class="mkt-hero-stats" style="margin-bottom:2rem;">
      <div>
        <div class="mkt-hero-stat-v">{{ produits|length }}+</div>
        <div class="mkt-hero-stat-l">Produits disponibles</div>
      </div>
      <div>
        <div class="mkt-hero-stat-v">{{ categories|length }}</div>
        <div class="mkt-hero-stat-l">Catégories</div>
      </div>
      <div>
        <div class="mkt-hero-stat-v">24h</div>
        <div class="mkt-hero-stat-l">Délai de réponse</div>
      </div>
    </div>

    <div class="mkt-hero-actions">
      {% if is_granted('IS_AUTHENTICATED_FULLY') %}
        <a href="{{ path('app_marketplace_panier') }}" class="btn-yellow" style="display:inline-flex;align-items:center;gap:8px;"><i class="fa fa-shopping-cart"></i> Mon panier</a>
        <a href="{{ path('app_marketplace_mes_commandes') }}" class="btn-ghost" style="display:inline-flex;align-items:center;gap:8px;border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.7);"><i class="fa fa-receipt"></i> Mes commandes</a>
      {% else %}
        <a href="{{ path('app_login') }}" class="btn-yellow" style="display:inline-flex;align-items:center;gap:8px;"><i class="fa fa-sign-in-alt"></i> Se connecter pour acheter</a>
      {% endif %}
      {% if is_granted('IS_AUTHENTICATED_FULLY') and app.user.userType == 'fournisseur' %}
        <a href="{{ path('app_marketplace_mes_produits') }}" class="btn-ghost" style="display:inline-flex;align-items:center;gap:8px;border-color:rgba(255,190,51,.4);color:var(--primary);"><i class="fa fa-box"></i> Mes produits</a>
      {% endif %}
    </div>
  </div>
</div>

{# ── CATEGORY PILLS ── #}
<div class="mkt-cats">
  <div class="mkt-cats-inner">
    <a href="{{ path('app_marketplace_index') }}" class="cat-pill {{ not category ? 'active' : '' }}">
      <i class="fa fa-th"></i> Tout
    </a>
    {% for label, value in categories %}
      <a href="{{ path('app_marketplace_index', {category: value}) }}" class="cat-pill {{ category == value ? 'active' : '' }}">
        {{ label }}
      </a>
    {% endfor %}
  </div>
</div>

{# ── MAIN BODY ── #}
<div class="mkt-body">

  {# ── SEARCH BAR ── #}
  <form method="get" action="{{ path('app_marketplace_index') }}">
    {% if category %}<input type="hidden" name="category" value="{{ category }}">{% endif %}
    <div class="mkt-search-bar">
      <i class="fa fa-search" style="color:var(--text-muted);"></i>
      <input type="text" name="search" value="{{ search|default('') }}" placeholder="Rechercher un produit, service, marque…">
      {% if search or category %}
        <a href="{{ path('app_marketplace_index') }}" style="color:var(--text-muted);font-size:.82rem;text-decoration:none;white-space:nowrap;">
          <i class="fa fa-times"></i> Réinitialiser
        </a>
      {% endif %}
      <button type="submit" class="mkt-search-btn"><i class="fa fa-search"></i> Rechercher</button>
    </div>
  </form>

  {# ── RESULTS ── #}
  {% if produits is empty %}
    <div class="mkt-empty">
      <i class="fa fa-box-open"></i>
      <h3>Aucun produit trouvé</h3>
      <p>{% if search %}Aucun résultat pour "{{ search }}"{% elseif category %}Aucun produit dans cette catégorie{% else %}Le catalogue est vide pour le moment{% endif %}</p>
      {% if search or category %}
        <a href="{{ path('app_marketplace_index') }}" class="btn-yellow" style="display:inline-block;margin-top:1.2rem;">Voir tous les produits</a>
      {% endif %}
      {% if is_granted('IS_AUTHENTICATED_FULLY') and app.user.userType == 'fournisseur' %}
        <a href="{{ path('app_marketplace_produit_new') }}" class="btn-yellow" style="display:inline-block;margin-top:1rem;"><i class="fa fa-plus"></i> Ajouter le premier produit</a>
      {% endif %}
    </div>
  {% else %}

    <div class="mkt-results-header">
      <p class="mkt-results-count">
        <strong>{{ produits|length }}</strong> produit{{ produits|length > 1 ? 's' : '' }} trouvé{{ produits|length > 1 ? 's' : '' }}
        {% if category %} dans <strong>{{ category }}</strong>{% endif %}
        {% if search %} pour <strong>"{{ search }}"</strong>{% endif %}
      </p>
      {% if is_granted('IS_AUTHENTICATED_FULLY') and app.user.userType == 'fournisseur' %}
        <a href="{{ path('app_marketplace_produit_new') }}" class="btn-yellow" style="font-size:.8rem;padding:8px 16px;display:inline-flex;align-items:center;gap:6px;">
          <i class="fa fa-plus"></i> Nouveau produit
        </a>
      {% endif %}
    </div>

    <div class="prod-grid">
      {% for p in produits %}
        <div class="prod-card">
          <div class="prod-img-wrap">
            <a href="{{ path('app_marketplace_show', {id: p.productId}) }}">
              <div class="prod-img">
                {% if p.imageUrl %}
                  <img src="{{ p.imageUrl }}" alt="{{ p.name }}" loading="lazy">
                {% else %}
                  <i class="fa fa-box"></i>
                {% endif %}
              </div>
            </a>
            {% if p.stock <= 3 %}
              <span class="prod-badge-stock">Plus que {{ p.stock }}</span>
            {% endif %}
          </div>

          <div class="prod-body">
            {% if p.category %}
              <div class="prod-cat"><i class="fa fa-tag"></i> {{ p.category }}</div>
            {% endif %}
            <div class="prod-name">
              <a href="{{ path('app_marketplace_show', {id: p.productId}) }}">{{ p.name }}</a>
            </div>
            {% if p.description %}
              <p class="prod-desc">{{ p.description }}</p>
            {% endif %}
            <div class="prod-price">
              {{ p.price|number_format(2,',',' ') }} <span>TND</span>
            </div>
          </div>

          <div class="prod-footer">
            <span class="prod-stock {{ p.stock <= 5 ? 'low' : 'ok' }}">
              <i class="fa fa-warehouse"></i> {{ p.stock }} en stock
            </span>
            <div style="display:flex;gap:.4rem;">
              <a href="{{ path('app_marketplace_show', {id: p.productId}) }}" class="btn-view" title="Voir le détail">
                <i class="fa fa-eye"></i>
              </a>
              {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                <form method="post" action="{{ path('app_marketplace_panier_add', {id: p.productId}) }}" style="margin:0;">
                  <input type="hidden" name="_token" value="{{ csrf_token('add_panier_' ~ p.productId) }}">
                  <input type="hidden" name="quantite" value="1">
                  <button type="submit" class="btn-add" title="Ajouter au panier">
                    <i class="fa fa-cart-plus"></i>
                  </button>
                </form>
              {% else %}
                <a href="{{ path('app_login') }}" class="btn-add" title="Se connecter">
                  <i class="fa fa-lock"></i>
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  {% endif %}

  {# ── SELLER CTA ── #}
  {% if is_granted('IS_AUTHENTICATED_FULLY') and app.user.userType != 'fournisseur' %}
  <div class="seller-cta">
    <div>
      <h3><i class="fa fa-store" style="color:var(--primary);margin-right:.5rem;"></i>Vous êtes fournisseur ?</h3>
      <p>Publiez vos produits et services sur BizHub et accédez à une communauté de startups et investisseurs.</p>
    </div>
    <a href="{{ path('app_register') }}" class="btn-yellow" style="white-space:nowrap;display:inline-flex;align-items:center;gap:8px;">
      <i class="fa fa-rocket"></i> Créer un compte fournisseur
    </a>
  </div>
  {% elseif not is_granted('IS_AUTHENTICATED_FULLY') %}
  <div class="seller-cta">
    <div>
      <h3><i class="fa fa-store" style="color:var(--primary);margin-right:.5rem;"></i>Rejoignez la Marketplace BizHub</h3>
      <p>Achetez des services professionnels ou vendez vos produits à la communauté BizHub.</p>
    </div>
    <div style="display:flex;gap:.8rem;flex-wrap:wrap;">
      <a href="{{ path('app_login') }}" class="btn-yellow" style="display:inline-flex;align-items:center;gap:8px;">
        <i class="fa fa-sign-in-alt"></i> Se connecter
      </a>
      <a href="{{ path('app_register') }}" class="btn-ghost" style="display:inline-flex;align-items:center;gap:8px;border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.7);">
        <i class="fa fa-user-plus"></i> Créer un compte
      </a>
    </div>
  </div>
  {% endif %}

</div>
{% endblock %}
