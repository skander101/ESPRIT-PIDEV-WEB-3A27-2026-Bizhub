{% extends 'front/Marketplace/base_marketplace.html.twig' %}

{% block title %}{{ produit.nom }}{% endblock %}
{% block hero_eyebrow %}Produit{% endblock %}
{% block hero_title %}<span>{{ produit.nom }}</span>{% endblock %}
{% block breadcrumb_extra %}
  <i class="fa fa-chevron-right" style="font-size:.55rem"></i>
  <a href="{{ path('produit_index') }}">Catalogue</a>
  <i class="fa fa-chevron-right" style="font-size:.55rem"></i>
  {{ produit.nom|slice(0,30) }}{% if produit.nom|length > 30 %}…{% endif %}
{% endblock %}

{% block body %}
<div style="max-width:1100px; margin:0 auto; padding:60px 5%;">
  <div style="display:grid; grid-template-columns:1fr 340px; gap:3rem; align-items:start;">

    {# ── Infos produit ── #}
    <div>
      <a href="{{ path('produit_index') }}" class="btn-ghost btn-sm" style="margin-bottom:2rem">
        <i class="fa fa-arrow-left"></i> Retour au catalogue
      </a>

      <div style="background:var(--light-bg); border-radius:16px; height:280px; display:flex; align-items:center; justify-content:center; margin-bottom:2rem; border:1.5px solid var(--border); overflow:hidden;">
        {% if produit.imagePath %}
          <img src="{{ asset('assets/images/productimages/' ~ produit.imagePath) }}" alt="{{ produit.nom }}" style="width:100%; height:100%; object-fit:cover; border-radius:16px;">
        {% else %}
          <i class="fa fa-cube" style="font-size:5rem; color:rgba(255,190,51,0.35);"></i>
        {% endif %}
      </div>

      <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:1rem; align-items:center;">
        {% if produit.categorie %}<span class="tag">{{ produit.categorie }}</span>{% endif %}
        <span style="display:inline-flex; align-items:center; gap:4px; padding:6px 12px; border-radius:6px; background:{{ produit.disponible ? 'rgba(34,197,94,0.12)' : 'rgba(220,53,69,0.12)' }}; color:{{ produit.disponible ? '#15803d' : '#b91c1c' }}; font-size:0.85rem; font-weight:700;">
          <i class="fa fa-{{ produit.disponible ? 'check-circle' : 'times-circle' }}"></i>
          {{ produit.disponible ? 'Disponible' : 'Indisponible' }}
        </span>
      </div>

      <h1 style="font-family:'Lora',serif; font-size:clamp(1.5rem,3vw,2.2rem); font-weight:700; color:var(--dark); margin-bottom:1rem;">
        {{ produit.nom }}
      </h1>

      {% if produit.description %}
      <p style="font-size:0.92rem; color:var(--muted); line-height:1.8; margin-bottom:1.5rem;">
        {{ produit.description }}
      </p>
      {% endif %}

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">
        <div class="biz-card">
          <div class="biz-card-body" style="text-align:center; padding:18px;">
            <div style="font-family:'Josefin Sans',sans-serif; font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); margin-bottom:4px;">Prix HT</div>
            <div style="font-family:'Josefin Sans',sans-serif; font-size:1.8rem; font-weight:800; color:var(--dark);">
              {{ produit.prix }} <span style="font-size:0.9rem; font-weight:500; color:var(--muted);">TND</span>
            </div>
          </div>
        </div>
        <div class="biz-card">
          <div class="biz-card-body" style="text-align:center; padding:18px;">
            <div style="font-family:'Josefin Sans',sans-serif; font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); margin-bottom:4px;">Stock</div>
            <div style="font-family:'Josefin Sans',sans-serif; font-size:1.8rem; font-weight:800; color:var(--dark);">
              {{ produit.quantite }} <span style="font-size:0.9rem; font-weight:500; color:var(--muted);">unités</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    {# ── Panneau achat ── #}
    <div style="position:sticky; top:90px;">
      <div class="biz-card">
        <div class="biz-card-body">
          <h3 style="font-family:'Lora',serif; font-size:1.1rem; font-weight:700; margin-bottom:1.2rem; padding-bottom:0.8rem; border-bottom:1px solid var(--border);">
            Commander
          </h3>

          {% if produit.disponible %}
          {# Ajouter au panier #}
          <form method="post" action="{{ path('panier_add', {id: produit.idProduit}) }}" style="margin-bottom:0.75rem;">
            <input type="hidden" name="_token" value="{{ csrf_token('add_panier_' ~ produit.idProduit) }}">
            <div class="biz-form-group">
              <label class="biz-label">Quantité</label>
              <input type="number" name="quantite" value="1" min="1" max="{{ produit.quantite }}" class="biz-input">
            </div>
            <input type="hidden" name="redirect" value="panier">
            <button type="submit" class="btn-yellow" style="width:100%; justify-content:center;">
              <i class="fa fa-cart-plus"></i> Ajouter au panier
            </button>
          </form>

          {# Commander direct #}
          <form method="post" action="{{ path('commande_directe', {produitId: produit.idProduit}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('directe_' ~ produit.idProduit) }}">
            <input type="hidden" name="quantite" value="1">
            <button type="submit" class="btn-success" style="width:100%; justify-content:center;">
              <i class="fa fa-bolt"></i> Commander directement
            </button>
          </form>

          {% else %}
          <div class="flash flash-warning">
            <i class="fa fa-exclamation-triangle"></i> Ce produit n'est plus disponible.
          </div>
          {% endif %}

          <hr style="border:none; border-top:1px solid var(--border); margin:1.2rem 0;">

          <div style="font-size:0.78rem; color:var(--muted); display:flex; flex-direction:column; gap:6px;">
            <div><i class="fa fa-shield-alt" style="color:var(--primary); width:16px;"></i> Transaction sécurisée</div>
            <div><i class="fa fa-check-circle" style="color:var(--success); width:16px;"></i> Confirmation rapide</div>
            <div><i class="fa fa-undo" style="color:var(--info); width:16px;"></i> Annulation possible avant confirmation</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

{# ── PRODUITS SIMILAIRES (RecommendationService) ── #}
<div style="max-width:1100px; margin:0 auto; padding:0 5% 70px;">

  {# TEST BANNER — prouve que RecommendationService est connecté #}
  <div style="background:#dcfce7; border:2px solid #16a34a; border-radius:8px; padding:10px 16px; margin-bottom:1.5rem; display:flex; align-items:center; gap:10px;">
    <span style="font-size:1.1rem;">✅</span>
    <span style="font-family:monospace; font-size:0.78rem; font-weight:700; color:#166534;">
      RECOMMENDATION WORKING — {{ similaires|length }} produit(s) similaire(s) trouvé(s) via RecommendationService
    </span>
  </div>

{% if similaires is defined and similaires|length > 0 %}

  <div style="display:flex; align-items:center; gap:12px; margin-bottom:1.8rem;">
    <div style="width:4px; height:28px; background:var(--primary); border-radius:2px;"></div>
    <div>
      <div style="font-family:'Josefin Sans',sans-serif; font-size:0.62rem; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:var(--primary-dark);">Recommandations</div>
      <div style="font-family:'Lora',serif; font-size:1.15rem; font-weight:700; color:var(--dark);">Produits similaires</div>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(230px,1fr)); gap:1.2rem;">
    {% for p in similaires %}
      <div class="biz-card" style="display:flex; flex-direction:column;">

        {# Image #}
        <a href="{{ path('produit_show', {id: p.idProduit}) }}" style="display:block; height:160px; overflow:hidden; border-bottom:1.5px solid var(--border); background:var(--light-bg); display:flex; align-items:center; justify-content:center; position:relative;">
          {% if p.imagePath %}
            <img src="{{ asset('assets/images/productimages/' ~ p.imagePath) }}" alt="{{ p.nom }}"
                 style="width:100%; height:160px; object-fit:cover; transition:transform .35s;"
                 onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'">
          {% else %}
            <i class="fa fa-cube" style="font-size:3rem; color:rgba(255,190,51,0.25);"></i>
          {% endif %}
          {% if p.categorie %}
            <span style="position:absolute; top:10px; left:10px; background:rgba(255,190,51,.9); color:var(--dark); font-family:'Josefin Sans',sans-serif; font-size:.58rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; padding:3px 9px; border-radius:100px;">
              {{ p.categorie }}
            </span>
          {% endif %}
        </a>

        {# Body #}
        <div class="biz-card-body" style="flex:1; display:flex; flex-direction:column; gap:.4rem; padding:16px;">
          <a href="{{ path('produit_show', {id: p.idProduit}) }}"
             style="font-family:'Lora',serif; font-size:.92rem; font-weight:700; color:var(--dark); text-decoration:none; line-height:1.3; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;"
             onmouseover="this.style.color='var(--primary-dark)'" onmouseout="this.style.color='var(--dark)'">
            {{ p.nom }}
          </a>
          {% if p.description %}
            <p style="font-size:.76rem; color:var(--muted); line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; margin:0;">
              {{ p.description }}
            </p>
          {% endif %}
          <div style="margin-top:auto; padding-top:.6rem; display:flex; align-items:center; justify-content:space-between;">
            <span style="font-family:'Josefin Sans',sans-serif; font-size:1.05rem; font-weight:800; color:var(--dark);">
              {{ p.prix }} <span style="font-size:.65rem; color:var(--muted); font-weight:400;">TND</span>
            </span>
            <span style="font-size:.7rem; color:{{ p.disponible ? '#15803d' : '#b91c1c' }}; font-weight:700;">
              <i class="fa fa-{{ p.disponible ? 'check-circle' : 'times-circle' }}"></i>
              {{ p.disponible ? 'Dispo' : 'Indispo' }}
            </span>
          </div>
        </div>

        {# Footer actions #}
        <div style="padding:10px 16px; border-top:1px solid var(--border); display:flex; gap:.5rem;">
          <a href="{{ path('produit_show', {id: p.idProduit}) }}" class="btn-ghost btn-sm" style="flex:1; justify-content:center;">
            <i class="fa fa-eye"></i> Voir
          </a>
          {% if p.disponible %}
            <form method="post" action="{{ path('panier_add', {id: p.idProduit}) }}" style="flex:1;">
              <input type="hidden" name="_token" value="{{ csrf_token('add_panier_' ~ p.idProduit) }}">
              <input type="hidden" name="quantite" value="1">
              <input type="hidden" name="redirect" value="catalogue">
              <button type="submit" class="btn-yellow btn-sm" style="width:100%; justify-content:center;">
                <i class="fa fa-cart-plus"></i> Panier
              </button>
            </form>
          {% endif %}
        </div>

      </div>
    {% endfor %}
  </div>

{% else %}
  <div style="padding:2rem; text-align:center; color:var(--text-muted); background:var(--light-bg); border-radius:10px; border:1.5px dashed var(--border);">
    <i class="fa fa-box-open" style="font-size:1.8rem; color:var(--primary); display:block; margin-bottom:.5rem;"></i>
    Aucun produit similaire disponible actuellement.
  </div>
{% endif %}

</div>

{% endblock %}
