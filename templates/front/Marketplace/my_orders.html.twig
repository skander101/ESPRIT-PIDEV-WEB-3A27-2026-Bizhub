{% extends 'front/base.html.twig' %}
{% block title %}Mes commandes — BizHub{% endblock %}

{% block extra_styles %}
.ord-body { max-width:900px; margin:36px auto; padding:0 5%; }
.ord-card { background:#fff; border-radius:14px; border:1.5px solid var(--border); margin-bottom:1rem; overflow:hidden; box-shadow:0 2px 10px rgba(0,0,0,.04); transition:transform .15s; }
.ord-card:hover { transform:translateY(-2px); }
.ord-head { display:flex; align-items:center; gap:1rem; padding:16px 20px; border-bottom:1px solid var(--border); flex-wrap:wrap; }
.ord-img { width:54px; height:54px; border-radius:10px; background:#f3f4f6; overflow:hidden; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:1.4rem; color:#d1d5db; }
.ord-img img { width:100%; height:100%; object-fit:cover; }
.ord-name { font-weight:700; font-size:.92rem; color:var(--dark); }
.ord-meta { font-size:.76rem; color:var(--text-muted); margin-top:2px; }
.ord-price { font-family:'Josefin Sans',sans-serif; font-weight:700; font-size:1rem; color:var(--dark); margin-left:auto; white-space:nowrap; }
.status-badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:100px; font-size:.68rem; font-weight:700; font-family:'Josefin Sans',sans-serif; text-transform:uppercase; letter-spacing:.06em; }
.s-en_attente  { background:rgba(234,179,8,.12);  color:#b45309; }
.s-en_cours    { background:rgba(59,130,246,.12); color:#1d4ed8; }
.s-livre       { background:rgba(16,185,129,.12); color:#059669; }
.s-annule      { background:rgba(239,68,68,.12);  color:#dc2626; }
.ord-footer { padding:10px 20px; display:flex; align-items:center; justify-content:space-between; background:#fafafa; }
.kpi-row { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:2rem; }
.kpi-mini { background:#fff; border:1.5px solid var(--border); border-radius:12px; padding:18px; text-align:center; box-shadow:0 1px 6px rgba(0,0,0,.04); }
.kpi-mini-v { font-family:'Josefin Sans',sans-serif; font-size:1.5rem; font-weight:700; color:var(--dark); }
.kpi-mini-l { font-size:.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.08em; margin-top:3px; }
{% endblock %}

{% block content %}
<div class="ord-body">

  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.8rem;">
    <h1 style="font-family:'Josefin Sans',sans-serif;font-size:1.7rem;font-weight:700;color:var(--dark);margin:0;">Mes commandes</h1>
    <a href="{{ path('app_marketplace_index') }}" class="btn-yellow">
      <i class="fa fa-store"></i> Marketplace
    </a>
  </div>

  <div class="kpi-row">
    <div class="kpi-mini">
      <div class="kpi-mini-v">{{ commandes|length }}</div>
      <div class="kpi-mini-l">Commandes</div>
    </div>
    <div class="kpi-mini">
      <div class="kpi-mini-v">{{ total|number_format(0,',',' ') }}</div>
      <div class="kpi-mini-l">TND dépensés</div>
    </div>
    <div class="kpi-mini">
      <div class="kpi-mini-v">{{ commandes|filter(c => c.status == 'en_attente')|length }}</div>
      <div class="kpi-mini-l">En attente</div>
    </div>
  </div>

  {% if commandes is empty %}
    <div style="text-align:center;padding:60px;color:var(--text-muted);">
      <i class="fa fa-receipt" style="font-size:3rem;display:block;margin-bottom:1rem;"></i>
      <p>Vous n'avez pas encore passé de commande.</p>
      <a href="{{ path('app_marketplace_index') }}" class="btn-yellow" style="display:inline-block;margin-top:1rem;">Découvrir la marketplace</a>
    </div>
  {% else %}
    {% for c in commandes %}
      {% set product = c.productService %}
      <div class="ord-card">
        <div class="ord-head">
          <div class="ord-img">
            {% if product and product.imageUrl %}<img src="{{ product.imageUrl }}" alt="{{ product.name }}">
            {% else %}<i class="fa fa-box"></i>{% endif %}
          </div>
          <div>
            <div class="ord-name">{{ product ? product.name : 'Produit supprimé' }}</div>
            <div class="ord-meta">
              Commande #{{ c.orderId }} &nbsp;·&nbsp; {{ c.orderDate ? c.orderDate|date('d/m/Y') : '—' }}
              &nbsp;·&nbsp; Qté : {{ c.quantity }}
            </div>
          </div>
          <div class="ord-price">{{ c.totalPrice|number_format(2,',',' ') }} TND</div>
          <span class="status-badge s-{{ c.status }}">
            {% if c.status == 'en_attente' %}⏳ En attente
            {% elseif c.status == 'en_cours' %}🔄 En cours
            {% elseif c.status == 'livre' %}✓ Livré
            {% elseif c.status == 'annule' %}✕ Annulé
            {% else %}{{ c.status }}{% endif %}
          </span>
        </div>
        <div class="ord-footer">
          <span style="font-size:.76rem;color:var(--text-muted);">
            {% if c.deliveryAddress %}<i class="fa fa-map-marker-alt"></i> {{ c.deliveryAddress|slice(0,50) }}{% endif %}
          </span>
          {% if c.status == 'en_attente' %}
            <form method="post" action="{{ path('app_marketplace_commande_cancel', {id: c.orderId}) }}" style="margin:0;" data-confirm data-confirm-title="Annuler cette commande ?">
              <input type="hidden" name="_token" value="{{ csrf_token('cancel_order_' ~ c.orderId) }}">
              <button type="submit" style="background:none;border:1px solid #ef4444;color:#ef4444;padding:5px 14px;border-radius:7px;font-size:.78rem;font-weight:600;cursor:pointer;">
                Annuler
              </button>
            </form>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  {% endif %}

</div>
{% endblock %}
