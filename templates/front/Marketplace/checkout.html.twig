{% extends 'front/base.html.twig' %}
{% block title %}Finaliser la commande — BizHub{% endblock %}

{% block extra_styles %}
.chk-body { max-width:800px; margin:36px auto; padding:0 5%; display:grid; grid-template-columns:1fr 260px; gap:2rem; align-items:start; }
.chk-card { background:#fff; border-radius:16px; border:1.5px solid var(--border); padding:28px; box-shadow:0 2px 12px rgba(0,0,0,.05); }
.chk-title { font-family:'Josefin Sans',sans-serif; font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--text-muted); border-bottom:1.5px solid var(--border); padding-bottom:10px; margin-bottom:18px; }
.chk-row { display:flex; justify-content:space-between; padding:7px 0; font-size:.84rem; border-bottom:1px solid var(--border); }
.chk-row:last-of-type { border-bottom:none; }
.chk-total { font-family:'Josefin Sans',sans-serif; font-size:1.3rem; font-weight:700; display:flex; justify-content:space-between; border-top:2px solid var(--border); padding-top:12px; margin-top:8px; }
.confirm-btn { display:flex; align-items:center; justify-content:center; gap:8px; width:100%; padding:14px; background:linear-gradient(135deg,var(--primary),var(--primary-dark)); border:none; border-radius:10px; font-weight:700; font-size:.98rem; font-family:'Josefin Sans',sans-serif; cursor:pointer; box-shadow:0 4px 14px rgba(255,190,51,.3); margin-top:1.4rem; transition:transform .15s; }
.confirm-btn:hover { transform:translateY(-1px); }
.notice { background:rgba(255,190,51,.07); border:1px solid rgba(255,190,51,.25); border-radius:10px; padding:14px 16px; font-size:.82rem; color:#92650a; margin-top:1.2rem; display:flex; gap:10px; }
@media(max-width:680px) { .chk-body { grid-template-columns:1fr; } }
{% endblock %}

{% block content %}
<div style="max-width:800px;margin:0 auto;padding:24px 5% 0;">
  <a href="{{ path('app_marketplace_panier') }}" style="font-size:.78rem;color:var(--text-muted);text-decoration:none;display:inline-flex;align-items:center;gap:5px;">
    <i class="fa fa-arrow-left"></i> Retour au panier
  </a>
  <h1 style="font-family:'Josefin Sans',sans-serif;font-size:1.6rem;font-weight:700;color:var(--dark);margin:16px 0 0;">Finaliser la commande</h1>
</div>

<div class="chk-body">

  <form method="post" action="{{ path('app_marketplace_checkout') }}">
    <input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">

    <div class="chk-card">
      <div class="chk-title"><i class="fa fa-map-marker-alt" style="color:var(--primary);margin-right:5px;"></i>Adresse de livraison</div>

      <div class="form-group">
        <label style="font-size:.82rem;font-weight:600;color:var(--dark);display:block;margin-bottom:6px;">Adresse complète</label>
        <textarea name="delivery_address" rows="3" placeholder="Rue, ville, code postal…"
          style="width:100%;box-sizing:border-box;padding:10px 14px;border:1.5px solid var(--border);border-radius:9px;font-size:.88rem;resize:none;">{{ user.address }}</textarea>
      </div>

      <div class="notice">
        <i class="fa fa-shield-alt" style="color:var(--primary);flex-shrink:0;margin-top:2px;"></i>
        <span>Votre commande sera traitée et vous serez contacté par le vendeur sous 24h. Le stock sera réservé à la confirmation.</span>
      </div>

      <button type="submit" class="confirm-btn">
        <i class="fa fa-check-circle"></i> Confirmer la commande ({{ total|number_format(2,',',' ') }} TND)
      </button>
    </div>
  </form>

  {# Order summary #}
  <div class="chk-card">
    <div class="chk-title">Votre commande</div>
    {% for item in items %}
      <div class="chk-row">
        <span style="color:var(--text-muted);">{{ item.product.name|slice(0,24) }}{% if item.product.name|length > 24 %}…{% endif %} ×{{ item.quantite }}</span>
        <span style="font-weight:600;">{{ item.subtotal|number_format(2,',',' ') }}</span>
      </div>
    {% endfor %}
    <div class="chk-total">
      <span>Total</span>
      <span>{{ total|number_format(2,',',' ') }} TND</span>
    </div>
  </div>

</div>
{% endblock %}
