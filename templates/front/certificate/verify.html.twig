{% extends 'front/base.html.twig' %}

{% block title %}Vérification certificat — BizHub{% endblock %}

{% block head_extra %}
  <meta name="robots" content="noindex" />
{% endblock %}

{% block extra_styles %}
  .cert-verify { max-width: 560px; margin: 100px auto 60px; padding: 0 5%; }
  .cert-verify-card {
    background: #fff; border-radius: 16px; padding: 2rem;
    box-shadow: 0 16px 48px rgba(0,0,0,0.08); border: 1px solid #e5e7eb; text-align: center;
  }
  .cert-verify h1 { font-size: 1.35rem; color: #0f172a; margin: 0 0 0.75rem; font-family: 'Josefin Sans', sans-serif; }
  .cert-verify p { color: #64748b; line-height: 1.55; margin: 0; }
  .cert-ok { color: #059669; font-weight: 800; font-size: 2rem; margin-bottom: 0.5rem; }
  .cert-bad { color: #dc2626; font-weight: 800; font-size: 2rem; margin-bottom: 0.5rem; }
{% endblock %}

{% block content %}
<div class="cert-verify">
  <div class="cert-verify-card">
    {% if valid %}
      <div class="cert-ok"><i class="fa-solid fa-circle-check"></i></div>
      <h1>Certificat authentique</h1>
      <p>Ce document BizHub correspond à une participation enregistrée et payée.</p>
      <p style="margin-top:1rem;font-size:0.9rem;color:#0f172a;">
        <strong>{{ user.fullName|default(user.email)|e }}</strong><br/>
        {{ formation.title|e }}<br/>
        <span style="color:#64748b;">Réf. #{{ participation.id_candidature }}</span>
      </p>
    {% else %}
      <div class="cert-bad"><i class="fa-solid fa-triangle-exclamation"></i></div>
      <h1>Vérification impossible</h1>
      <p>Lien invalide ou certificat introuvable.</p>
    {% endif %}
    <p style="margin-top:1.5rem;">
      <a href="{{ path('app_front_formations_index') }}" style="color:#0369a1;font-weight:700;">Retour aux formations</a>
    </p>
  </div>
</div>
{% endblock %}
