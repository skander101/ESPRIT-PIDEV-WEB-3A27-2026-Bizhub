{# Expects: reco, track_url, track_csrf — reco_compact: n'affiche que la ligne « Recommandé » + lien catalogue #}
{% if reco is defined %}
{% macro reco_row(title, icon, formations, section) %}
  {% if formations|length > 0 %}
    <section class="reco-section" data-reco-section="{{ section|e('html_attr') }}">
      <div class="reco-section-head">
        <h2 class="reco-title"><span class="reco-title-icon">{{ icon|raw }}</span>{{ title }}</h2>
        <div class="reco-nav">
          <button type="button" class="reco-nav-btn reco-prev" aria-label="Précédent"><i class="fa-solid fa-chevron-left"></i></button>
          <button type="button" class="reco-nav-btn reco-next" aria-label="Suivant"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
      </div>
      <div class="reco-rail" tabindex="0">
        {% for f in formations %}
          <article class="reco-card" data-formation-id="{{ f.formation_id }}">
            {% if section == 'personalized' %}
              <span class="reco-badge">IA</span>
            {% endif %}
            <div class="reco-card-accent {{ f.enLigne ? 'reco-card-accent--online' : 'reco-card-accent--present' }}"></div>
            <div class="reco-card-body">
              <div class="reco-card-tag {{ f.enLigne ? 'online' : '' }}">{{ f.enLigne ? 'En ligne' : 'Présentielle' }}</div>
              <h3 class="reco-card-title"><a href="{{ path('app_front_formation_show', { formation_id: f.formation_id, reco_section: section }) }}">{{ f.title }}</a></h3>
              {% if f.description %}
                <p class="reco-card-desc">{{ f.description }}</p>
              {% endif %}
            </div>
            <div class="reco-card-meta">
              <span><i class="fa-regular fa-calendar"></i> {{ f.start_date|date('d/m/Y') }}</span>
              {% if f.cost is not null %}
                <span class="reco-price">{{ f.cost|number_format(2, ',', ' ') }} TND</span>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}
{% endmacro %}
<div class="reco-wrap" id="formation-reco-root"
     data-track-url="{{ track_url|default('')|e('html_attr') }}"
     data-track-csrf="{{ track_csrf|default('')|e('html_attr') }}">

  {% if show_ai_best_pick|default(false) and ai_best_pick_url|default('')|trim != '' %}
  <div class="reco-ai-toolbar">
    <button type="button" class="reco-ai-pick-btn" onclick="openAIModal()" aria-haspopup="dialog">
      <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
      Meilleure formation pour moi (IA)
    </button>
    <p class="reco-ai-toolbar-hint">Suggestion basée sur vos anciennes inscriptions et le catalogue ouvert.</p>
  </div>

  <div id="formation-ai-best-pick-modal" data-ai-url="{{ ai_best_pick_url|e('html_attr') }}" data-ai-csrf="{{ ai_best_pick_csrf|default('')|e('html_attr') }}" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(15,23,42,0.55);z-index:9999;">
    <div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#fff;border-radius:18px;padding:0;max-width:520px;width:90%;box-shadow:0 24px 64px rgba(0,0,0,0.22);" onclick="event.stopPropagation();">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid #f0f2f5;">
        <h2 style="font-size:1rem;font-weight:700;color:#1e2533;margin:0;">Conseiller IA</h2>
        <button type="button" onclick="closeAIModal()" style="width:32px;height:32px;border-radius:8px;border:none;background:#f4f6fa;color:#6b7280;cursor:pointer;display:flex;align-items:center;justify-content:center;"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div style="padding:1.5rem;">
        <label style="display:block;font-size:0.75rem;font-weight:700;color:#4b5563;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.5rem;">Objectifs ou préférences (optionnel)</label>
        <textarea id="formation-ai-best-pick-notes" rows="3" maxlength="500" placeholder="Ex. : approfondir le marketing digital, préférence pour le distanciel…" style="width:100%;border:1.5px solid #e5e7eb;border-radius:10px;padding:0.75rem;font-size:0.85rem;resize:vertical;min-height:80px;"></textarea>
        <div style="margin-top:1rem;display:flex;justify-content:flex-end;">
          <a href="javascript:void(0);" onclick="runAIRecommendation(); return false;" style="display:inline-block;height:40px;line-height:40px;padding:0 1.25rem;border-radius:10px;background:#8b5cf6;color:#fff;font-size:0.78rem;font-weight:700;font-family:'Josefin Sans',sans-serif;text-transform:uppercase;letter-spacing:0.05em;cursor:pointer;text-decoration:none;">Obtenir une suggestion</a>
        </div>
        <p id="formation-ai-best-pick-status" style="display:none;margin-top:0.75rem;font-size:0.82rem;color:#6b7280;text-align:center;"></p>
        <div id="formation-ai-best-pick-result" style="display:none;margin-top:1rem;"></div>
      </div>
    </div>
  </div>
  {% endif %}

  {{ _self.reco_row('Recommandé pour vous', '&#128293;', reco.personalized|default([]), 'personalized') }}
  {% if not reco_compact|default(false) %}
    {{ _self.reco_row('Formations tendance', '&#128200;', reco.trending|default([]), 'trending') }}
    {{ _self.reco_row('Les plus populaires', '&#11088;', reco.popular|default([]), 'popular') }}
    {{ _self.reco_row('Nouvelles formations', '&#127381;', reco.newFormations|default([]), 'new') }}
  {% else %}
    <div class="reco-home-cta">
      <a href="{{ path('app_front_formations_index') }}" class="reco-home-cta-btn">Voir toutes les formations <i class="fa-solid fa-arrow-right"></i></a>
    </div>
  {% endif %}
</div>
{% endif %}
