{% extends 'front/base.html.twig' %}

{% block title %}AI Assistant - BizHub{% endblock %}

{% block content %}
<div style="max-width:900px;margin:0 auto;padding:32px 5%;">
    <div class="dash-panel" style="padding:1.4rem;display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1rem;">
        <div>
            <h2 style="margin:0;font-size:1.3rem;color:var(--dark);">AI Assistant</h2>
            <p style="margin:0.35rem 0 0;color:var(--text-muted);font-size:0.9rem;">Navigation + database answers for BizHub.</p>
        </div>
        <div style="display:flex;gap:0.6rem;align-items:center;">
            <button id="clear-chat-btn" type="button" class="btn-ghost">Clear Chat</button>
            <a href="{{ path('app_user_profile') }}" class="btn-outline-dark">Back to Profile</a>
        </div>
    </div>

    {% if not cloudflareConfigured %}
        <div style="background:#fff3cd;border:1px solid #ffeeba;color:#856404;padding:0.9rem 1rem;border-radius:10px;margin-bottom:1rem;">
            Cloudflare credentials are not fully configured. Navigation intents still work, but AI database responses may be limited.
        </div>
    {% endif %}

    <div class="dash-panel" style="padding:0;overflow:hidden;">
        <div id="chat-messages" style="max-height:560px;overflow-y:auto;padding:1.25rem;display:flex;flex-direction:column;gap:0.85rem;background:linear-gradient(180deg,#f9fafb 0%, #f4f6fa 100%);"></div>

        <form id="chat-form" style="display:flex;gap:0.75rem;padding:1rem;border-top:1px solid var(--border);background:#fff;" novalidate>
            <textarea
                id="chat-input"
                name="message"
                rows="2"
                maxlength="1200"
                placeholder="Ask for navigation or data insights..."
                style="flex:1;border:1px solid var(--border);border-radius:10px;padding:0.8rem 0.9rem;resize:vertical;font-family:inherit;font-size:0.95rem;"
                required
            ></textarea>
            <button id="send-chat-btn" type="submit" class="btn-yellow" style="height:fit-content;align-self:flex-end;">Send</button>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            const welcomeMessage = {{ welcomeMessage|json_encode|raw }};
            const messageEndpoint = {{ path('app_ai_chat_message')|json_encode|raw }};
            const clearEndpoint = {{ path('app_ai_chat_clear')|json_encode|raw }};
            const csrfMessageToken = {{ csrfMessageToken|json_encode|raw }};
            const csrfClearToken = {{ csrfClearToken|json_encode|raw }};

            const chatMessages = document.getElementById('chat-messages');
            const chatForm = document.getElementById('chat-form');
            const chatInput = document.getElementById('chat-input');
            const clearBtn = document.getElementById('clear-chat-btn');
            const sendBtn = document.getElementById('send-chat-btn');

            if (!chatMessages || !chatForm || !chatInput || !clearBtn || !sendBtn) {
                return;
            }

            const storageKey = 'bizhub_ai_chat_messages_v1';
            const createMessage = (role, text, isLoading = false, navigateUrl = null) => ({ role, text, isLoading, navigateUrl });

            const renderMessage = (message) => {
                const row = document.createElement('div');
                row.style.display = 'flex';
                row.style.justifyContent = message.role === 'user' ? 'flex-end' : 'flex-start';

                const bubble = document.createElement('div');
                bubble.style.maxWidth = '80%';
                bubble.style.padding = '0.75rem 0.9rem';
                bubble.style.borderRadius = '10px';
                bubble.style.whiteSpace = 'pre-wrap';
                bubble.style.wordBreak = 'break-word';
                bubble.style.fontSize = '0.92rem';
                bubble.style.lineHeight = '1.45';

                if (message.role === 'user') {
                    bubble.style.background = 'var(--primary)';
                    bubble.style.color = 'var(--dark)';
                } else if (message.isLoading) {
                    bubble.style.background = '#e5e7eb';
                    bubble.style.color = '#374151';
                    bubble.textContent = 'Bzz... thinking...';
                } else {
                    bubble.style.background = '#ffffff';
                    bubble.style.border = '1px solid var(--border)';
                    bubble.style.color = 'var(--dark)';
                }

                if (!message.isLoading) {
                    bubble.textContent = message.text;

                    if (message.navigateUrl) {
                        const linkWrap = document.createElement('div');
                        linkWrap.style.marginTop = '0.55rem';

                        const link = document.createElement('a');
                        link.href = message.navigateUrl;
                        link.textContent = 'Open page';
                        link.className = 'btn-ghost';
                        link.style.padding = '6px 12px';
                        link.style.fontSize = '0.72rem';

                        linkWrap.appendChild(link);
                        bubble.appendChild(linkWrap);
                    }
                }

                row.appendChild(bubble);
                chatMessages.appendChild(row);
            };

            const trimToMaxVisible = (messages) => {
                if (messages.length <= 50) {
                    return messages;
                }

                const first = messages[0];
                return [first, ...messages.slice(-(50 - 1))];
            };

            const saveMessages = (messages) => {
                sessionStorage.setItem(storageKey, JSON.stringify(trimToMaxVisible(messages)));
            };

            const loadMessages = () => {
                try {
                    const raw = sessionStorage.getItem(storageKey);
                    if (!raw) {
                        return [createMessage('assistant', welcomeMessage)];
                    }

                    const parsed = JSON.parse(raw);
                    if (!Array.isArray(parsed) || parsed.length === 0) {
                        return [createMessage('assistant', welcomeMessage)];
                    }

                    parsed[0] = createMessage('assistant', welcomeMessage);
                    return trimToMaxVisible(parsed);
                } catch (e) {
                    return [createMessage('assistant', welcomeMessage)];
                }
            };

            let visibleMessages = loadMessages();

            const refresh = () => {
                chatMessages.innerHTML = '';
                visibleMessages.forEach(renderMessage);
                chatMessages.scrollTop = chatMessages.scrollHeight;
                saveMessages(visibleMessages);
            };

            const pushMessage = (message) => {
                visibleMessages = trimToMaxVisible([...visibleMessages, message]);
                refresh();
            };

            const removeLastLoading = () => {
                const idx = [...visibleMessages].reverse().findIndex((item) => item.isLoading);
                if (idx === -1) {
                    return;
                }

                const absolute = visibleMessages.length - idx - 1;
                visibleMessages.splice(absolute, 1);
            };

            chatInput.addEventListener('keydown', function (event) {
                if (event.key === 'Enter' && !event.shiftKey) {
                    event.preventDefault();
                    chatForm.requestSubmit();
                }
            });

            chatForm.addEventListener('submit', async function (event) {
                event.preventDefault();

                const text = chatInput.value.trim();
                if (text === '') {
                    return;
                }

                pushMessage(createMessage('user', text));
                pushMessage(createMessage('assistant', '', true));
                chatInput.value = '';
                sendBtn.disabled = true;

                const payload = new URLSearchParams();
                payload.set('message', text);
                payload.set('_token', csrfMessageToken);

                try {
                    const response = await fetch(messageEndpoint, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: payload.toString()
                    });

                    const data = await response.json();
                    removeLastLoading();

                    if (!response.ok || !data.success) {
                        pushMessage(createMessage('assistant', data.message || 'Something went wrong while processing your message.'));
                    } else {
                        pushMessage(createMessage('assistant', data.reply || '', false, data.navigateUrl || null));
                    }
                } catch (error) {
                    removeLastLoading();
                    pushMessage(createMessage('assistant', 'Network error. Please try again.'));
                } finally {
                    sendBtn.disabled = false;
                    refresh();
                }
            });

            clearBtn.addEventListener('click', async function () {
                const payload = new URLSearchParams();
                payload.set('_token', csrfClearToken);

                try {
                    await fetch(clearEndpoint, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: payload.toString()
                    });
                } catch (error) {
                    // Ignore clear endpoint failures and still reset local state.
                }

                visibleMessages = [createMessage('assistant', welcomeMessage)];
                refresh();
            });

            refresh();
        })();
    </script>
{% endblock %}
