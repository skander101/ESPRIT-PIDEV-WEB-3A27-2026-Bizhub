{% extends 'front/base.html.twig' %}

{% block title %}Deal #{{ deal.deal_id }} — BizHub{% endblock %}

{% block extra_styles %}
.deal-header { background: linear-gradient(135deg, var(--dark) 0%, #1a1f2e 100%); padding: 48px 5% 32px; }
.deal-header h1 { font-size: 1.6rem; color: var(--white); font-family: 'Josefin Sans', sans-serif; font-weight: 700; margin: 0 0 0.25rem; }
.deal-header p { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin: 0; }
.back-link { display: inline-flex; align-items: center; gap: 6px; color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.78rem; margin-bottom: 1.2rem; transition: color 0.2s; font-family: 'Josefin Sans', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }
.back-link:hover { color: var(--primary); }

.deal-body { max-width: 920px; margin: 0 auto; padding: 36px 5%; }

/* Stepper */
.stepper { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 3rem; position: relative; }
.stepper::before { content: ''; position: absolute; top: 22px; left: 0; right: 0; height: 2px; background: var(--border); z-index: 0; }
.step { display: flex; flex-direction: column; align-items: center; position: relative; z-index: 1; flex: 1; }
.step-circle { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; font-weight: 700; border: 2px solid var(--border); background: var(--white); transition: all 0.3s; }
.step.done   .step-circle { background: #10b981; border-color: #10b981; color: #fff; }
.step.active .step-circle { background: var(--primary); border-color: var(--primary); color: var(--dark); box-shadow: 0 0 0 4px rgba(255,190,51,0.25); }
.step.locked .step-circle { background: #f3f4f6; border-color: #d1d5db; color: #9ca3af; }
.step-label { margin-top: 8px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; font-family: 'Josefin Sans', sans-serif; text-align: center; max-width: 90px; }
.step.done   .step-label { color: #10b981; }
.step.active .step-label { color: var(--primary); }
.step.locked .step-label { color: #9ca3af; }

/* Action cards */
.action-card { background: var(--white); border-radius: 16px; border: 1.5px solid var(--border); padding: 32px 28px; margin-bottom: 1.5rem; box-shadow: 0 4px 18px rgba(0,0,0,0.05); }
.action-card.active-step { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(255,190,51,0.15); }
.action-card.done-step   { border-color: #10b981; background: rgba(16,185,129,0.02); }
.action-card.locked-step { opacity: 0.55; }
.card-title { font-size: 1.05rem; font-weight: 700; color: var(--dark); font-family: 'Josefin Sans', sans-serif; display: flex; align-items: center; gap: 10px; margin-bottom: 0.5rem; }
.card-desc  { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.2rem; }
.lock-msg   { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; color: #9ca3af; background: #f3f4f6; padding: 8px 14px; border-radius: 8px; }

/* Buttons */
.btn-action { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 28px; border-radius: 10px; font-weight: 700; font-size: 0.9rem; font-family: 'Josefin Sans', sans-serif; border: none; cursor: pointer; text-decoration: none; transition: all 0.2s; }
.btn-stripe  { background: #635bff; color: #fff; }
.btn-stripe:hover { background: #4f46e5; }
.btn-sign    { background: #10b981; color: #fff; }
.btn-sign:hover { background: #059669; }
.btn-dl      { background: var(--primary); color: var(--dark); }
.btn-dl:hover { background: var(--primary-dark); }
.btn-neg     { background: transparent; color: var(--dark); border: 1.5px solid var(--border); }
.btn-neg:hover { border-color: var(--primary); color: var(--primary); }

/* Done badge */
.done-badge { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: rgba(16,185,129,0.12); color: #065f46; border-radius: 8px; font-weight: 700; font-size: 0.88rem; }

/* Email signature status */
.email-status-box { background: rgba(99,102,241,0.06); border: 1px solid rgba(99,102,241,0.2); border-radius: 10px; padding: 16px 20px; margin-bottom: 14px; font-size: 0.86rem; }
.email-status-box .es-title { font-weight: 700; color: #4338ca; margin-bottom: 4px; }
.email-status-box .es-detail { color: #6b7280; font-size: 0.82rem; line-height: 1.6; }
.email-status-box .es-expiry { margin-top: 6px; font-size: 0.8rem; }
.email-status-box .es-expiry.expired { color: #ef4444; font-weight: 600; }
.email-status-box .es-expiry.valid   { color: #059669; }
.btn-resend { display: inline-flex; align-items: center; gap: 6px; padding: 9px 20px; background: #6366f1; color: #fff; border: none; border-radius: 8px; font-size: 0.83rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; cursor: pointer; text-decoration: none; transition: background 0.2s; }
.btn-resend:hover { background: #4f46e5; }

/* Deal info sidebar */
.deal-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem; }
.deal-meta-card { background: var(--white); border-radius: 12px; border: 1.5px solid var(--border); padding: 20px; }
.deal-meta-card h4 { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); font-family: 'Josefin Sans', sans-serif; margin: 0 0 12px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
.meta-row { display: flex; justify-content: space-between; padding: 7px 0; font-size: 0.84rem; border-bottom: 1px solid #f3f4f6; }
.meta-row:last-child { border-bottom: none; }
.meta-label { color: var(--text-muted); }
.meta-value { font-weight: 600; color: var(--dark); }

@media (max-width: 768px) {
  .stepper { flex-direction: column; gap: 1rem; }
  .stepper::before { display: none; }
  .deal-grid { grid-template-columns: 1fr; }
}
{% endblock %}

{% block content %}

{# ── Determine current step ── #}
{% set step = 1 %}
{% if deal.status == 'pending_payment'   %}{% set step = 2 %}{% endif %}
{% if deal.status == 'paid'              %}{% set step = 3 %}{% endif %}
{% if deal.status == 'pending_signature' %}{% set step = 3 %}{% endif %}
{% if deal.status == 'signed'            %}{% set step = 4 %}{% endif %}
{% if deal.status == 'completed'         %}{% set step = 5 %}{% endif %}

<div class="deal-header">
  <div style="max-width:920px;margin:0 auto;">
    {% if negotiation %}
      <a href="{{ path('app_negociation_show', {id: negotiation.negotiation_id}) }}" class="back-link">
        <i class="fa fa-arrow-left"></i> Négociation
      </a>
    {% endif %}
    <h1><i class="fa fa-handshake" style="color:var(--primary);margin-right:0.5rem;"></i>Deal #{{ deal.deal_id }}</h1>
    <p>Workflow d'investissement — Suivi des étapes</p>
  </div>
</div>

<div class="deal-body">

  {# ── Flash messages ── #}
  {% for type, msgs in app.flashes %}
    {% for msg in msgs %}
      <div style="padding:12px 18px;border-radius:10px;margin-bottom:1.2rem;background:{{ type == 'success' ? 'rgba(16,185,129,0.1)' : (type == 'warning' ? 'rgba(245,158,11,0.1)' : (type == 'info' ? 'rgba(59,130,246,0.1)' : 'rgba(239,68,68,0.1)')) }};color:{{ type == 'success' ? '#065f46' : (type == 'warning' ? '#92400e' : (type == 'info' ? '#1e40af' : '#991b1b')) }};border:1px solid currentColor;font-weight:600;font-size:0.88rem;">
        {{ msg }}
      </div>
    {% endfor %}
  {% endfor %}

  {# ── Bannière de rôle ── #}
  {% if is_buyer %}
    <div style="display:flex;align-items:center;gap:10px;padding:12px 18px;border-radius:10px;margin-bottom:1.5rem;background:rgba(255,190,51,0.08);border:1px solid rgba(255,190,51,0.25);font-size:0.85rem;font-weight:600;color:#b8860b;">
      <i class="fa fa-user-tie" style="font-size:1.1rem;"></i>
      <span>Vous êtes l'<strong>investisseur</strong> — Suivez les étapes pour finaliser votre investissement.</span>
    </div>
  {% else %}
    <div style="display:flex;align-items:center;gap:10px;padding:12px 18px;border-radius:10px;margin-bottom:1.5rem;background:rgba(91,110,245,0.07);border:1px solid rgba(91,110,245,0.2);font-size:0.85rem;font-weight:600;color:#4a5de0;">
      <i class="fa fa-building" style="font-size:1.1rem;"></i>
      <span>Vous êtes la <strong>startup</strong> — Suivez l'avancement du deal initié par l'investisseur.</span>
    </div>
  {% endif %}

  {# ── Stepper ── #}
  <div class="stepper">
    <div class="step {{ step > 1 ? 'done' : 'active' }}">
      <div class="step-circle">{% if step > 1 %}<i class="fa fa-check"></i>{% else %}1{% endif %}</div>
      <div class="step-label">Négociation</div>
    </div>
    <div class="step {{ step > 2 ? 'done' : (step == 2 ? 'active' : 'locked') }}">
      <div class="step-circle">{% if step > 2 %}<i class="fa fa-check"></i>{% else %}2{% endif %}</div>
      <div class="step-label">Accord validé</div>
    </div>
    <div class="step {{ step > 3 ? 'done' : (step == 3 ? 'active' : 'locked') }}">
      <div class="step-circle">{% if step > 3 %}<i class="fa fa-check"></i>{% else %}3{% endif %}</div>
      <div class="step-label">Paiement</div>
    </div>
    <div class="step {{ step > 4 ? 'done' : (step == 4 ? 'active' : 'locked') }}">
      <div class="step-circle">{% if step > 4 %}<i class="fa fa-check"></i>{% else %}4{% endif %}</div>
      <div class="step-label">Signature</div>
    </div>
    <div class="step {{ step == 5 ? 'done' : 'locked' }}">
      <div class="step-circle">{% if step == 5 %}<i class="fa fa-check"></i>{% else %}5{% endif %}</div>
      <div class="step-label">Contrat</div>
    </div>
  </div>

  {# ── Étape 1 : Négociation (toujours validée ici) ── #}
  <div class="action-card done-step">
    <div class="card-title"><i class="fa fa-comments" style="color:#10b981;"></i> Étape 1 — Négociation</div>
    <div class="card-desc">La négociation a abouti à un accord entre les deux parties.</div>
    <span class="done-badge"><i class="fa fa-check-circle"></i> Accord validé</span>
    {% if negotiation %}
      <a href="{{ path('app_negociation_show', {id: negotiation.negotiation_id}) }}" class="btn-action btn-neg" style="margin-left:10px;">
        <i class="fa fa-eye"></i> Voir la négociation
      </a>
    {% endif %}
  </div>

  {# ── Étape 2 : Paiement Stripe ── #}
  <div class="action-card {{ step == 2 ? 'active-step' : (step > 2 ? 'done-step' : 'locked-step') }}">
    <div class="card-title">
      <i class="fa fa-credit-card" style="color:{{ step == 2 ? 'var(--primary)' : (step > 2 ? '#10b981' : '#9ca3af') }};"></i>
      Étape 2 — Paiement sécurisé
    </div>
    <div class="card-desc">
      Montant à régler : <strong>{{ deal.amount|number_format(0, ',', ' ') }} TND</strong>
      via Stripe (paiement par carte bancaire sécurisé).
    </div>

    {% if step > 2 %}
      <span class="done-badge"><i class="fa fa-check-circle"></i> Paiement confirmé</span>
      {% if deal.stripe_payment_intent_id %}
        <div style="margin-top:8px;font-size:0.78rem;color:var(--text-muted);">Réf. Stripe : {{ deal.stripe_payment_intent_id }}</div>
      {% endif %}
    {% elseif step == 2 and is_buyer %}
      <a href="{{ path('app_deal_payer', {id: deal.deal_id}) }}" class="btn-action btn-stripe">
        <i class="fa fa-lock"></i> Payer {{ deal.amount|number_format(0, ',', ' ') }} TND
      </a>
    {% elseif step == 2 and not is_buyer %}
      <div class="lock-msg"><i class="fa fa-clock"></i> En attente du paiement de l'investisseur</div>
    {% else %}
      <div class="lock-msg"><i class="fa fa-lock"></i> Disponible après validation de l'accord</div>
    {% endif %}
  </div>

  {# ── Étape 3 : Signature par email ── #}
  <div class="action-card {{ (step == 3 or step == 4) ? (step == 3 ? 'active-step' : 'done-step') : 'locked-step' }}">
    <div class="card-title">
      <i class="fa fa-pen-fancy" style="color:{{ step == 3 ? 'var(--primary)' : (step > 3 ? '#10b981' : '#9ca3af') }};"></i>
      Étape 3 — Signature du contrat
    </div>
    <div class="card-desc">Le contrat est signé via un lien sécurisé envoyé par email à l'investisseur.</div>

    {# Signé #}
    {% if step > 3 %}
      <span class="done-badge"><i class="fa fa-check-circle"></i> Contrat signé électroniquement</span>
      {% if deal.completed_at %}
        <div style="margin-top:8px;font-size:0.8rem;color:var(--text-muted);">Signé le {{ deal.completed_at|date('d/m/Y à H:i') }}</div>
      {% endif %}
      {% if deal.yousign_signature_request_id %}
        <div style="margin-top:6px;font-size:0.76rem;color:var(--text-muted);"><i class="fa fa-shield-alt"></i> Signature via Yousign — ID : {{ deal.yousign_signature_request_id|slice(0,16) }}…</div>
      {% endif %}

    {# En attente de signature #}
    {% elseif step == 3 and can_sign %}

      {% if is_buyer %}
        {# ── CAS 1 : Yousign déjà envoyé ─────────────────────────────────── #}
        {% if deal.yousign_signature_request_id %}
          {% set ys = deal.yousign_status ?? 'ongoing' %}
          <div class="email-status-box" style="border-color:{% if ys == 'done' %}rgba(16,185,129,0.4){% elseif ys == 'declined' or ys == 'expired' or ys == 'canceled' %}rgba(239,68,68,0.4){% else %}rgba(99,102,241,0.4){% endif %};background:{% if ys == 'done' %}rgba(16,185,129,0.06){% elseif ys == 'declined' or ys == 'expired' or ys == 'canceled' %}rgba(239,68,68,0.06){% else %}rgba(99,102,241,0.06){% endif %};">
            <div class="es-title" style="color:{% if ys == 'done' %}#059669{% elseif ys == 'declined' or ys == 'expired' or ys == 'canceled' %}#dc2626{% else %}#6366f1{% endif %};">
              <i class="fa fa-shield-alt"></i>
              {% if ys == 'done' %}Signature électronique Yousign terminée
              {% elseif ys == 'declined' %}Signature refusée par le signataire
              {% elseif ys == 'expired' %}Lien de signature expiré
              {% elseif ys == 'canceled' %}Demande de signature annulée
              {% else %}Signature électronique Yousign envoyée — en attente{% endif %}
            </div>
            <div class="es-detail">
              {% if ys == 'done' %}
                ✅ Tous les signataires ont signé. Cliquez sur <strong>« Vérifier la signature »</strong> pour confirmer et débloquer le téléchargement.
              {% elseif ys == 'ongoing' or ys == 'approval' %}
                Un email de signature électronique légale a été envoyé via <strong>Yousign</strong>. En attente de la signature de l'investisseur.
              {% else %}
                Statut Yousign : <strong>{{ ys }}</strong>. Renvoyez une nouvelle demande si nécessaire.
              {% endif %}
            </div>
          </div>

          {# Bouton de synchronisation Yousign #}
          <form method="post" action="{{ path('app_deal_yousign_sync', {id: deal.deal_id}) }}" style="display:inline;margin-right:8px;">
            <input type="hidden" name="_token" value="{{ csrf_token('yousign_sync_' ~ deal.deal_id) }}">
            <button type="submit" class="btn-resend" style="background:{% if ys == 'done' %}#059669{% else %}#6366f1{% endif %};">
              <i class="fa fa-sync-alt"></i> {% if ys == 'done' %}Confirmer la signature &amp; débloquer{% else %}Vérifier la signature{% endif %}
            </button>
          </form>
          {# Renvoyer via Yousign #}
          <form method="post" action="{{ path('app_deal_yousign_send', {id: deal.deal_id}) }}" style="display:inline;margin-right:8px;">
            <input type="hidden" name="_token" value="{{ csrf_token('yousign_' ~ deal.deal_id) }}">
            <button type="submit" class="btn-resend" style="background:#6b7280;font-size:0.8rem;">
              <i class="fa fa-redo"></i> Renvoyer via Yousign
            </button>
          </form>
          {# Fallback classique — si Yousign inaccessible depuis ce réseau #}
          {% if ys != 'done' %}
          <div style="margin-top:10px;padding:10px 14px;border-radius:8px;background:rgba(107,114,128,0.07);border:1px solid #e5e7eb;font-size:0.8rem;color:#6b7280;">
            <i class="fa fa-wifi" style="color:#9ca3af;margin-right:5px;"></i>
            Yousign inaccessible depuis ce réseau ?
            <form method="post" action="{{ path('app_deal_resend_signature', {id: deal.deal_id}) }}" style="display:inline;margin-left:8px;">
              <input type="hidden" name="_token" value="{{ csrf_token('resend_' ~ deal.deal_id) }}">
              <button type="submit" style="background:none;border:none;color:#4f46e5;font-weight:700;cursor:pointer;font-size:0.8rem;padding:0;text-decoration:underline;">
                Utiliser un lien de signature classique (email / lien direct)
              </button>
            </form>
          </div>
          {% endif %}

        {# ── CAS 2 : Pas encore envoyé ou fallback token email ─────────── #}
        {% else %}
          <div class="email-status-box">
            <div class="es-title"><i class="fa fa-file-signature"></i> Prêt pour la signature électronique</div>
            <div class="es-detail">
              Le contrat PDF est généré. Envoyez la demande de signature électronique <strong>Yousign</strong>
              à votre adresse email. Vous recevrez un lien sécurisé pour signer en ligne.
            </div>
          </div>
          <form method="post" action="{{ path('app_deal_yousign_send', {id: deal.deal_id}) }}" style="display:inline;margin-right:8px;">
            <input type="hidden" name="_token" value="{{ csrf_token('yousign_' ~ deal.deal_id) }}">
            <button type="submit" class="btn-resend" style="background:#6366f1;">
              <i class="fa fa-paper-plane"></i> Envoyer la signature via Yousign
            </button>
          </form>
          {# Fallback : email token classique #}
          <form method="post" action="{{ path('app_deal_resend_signature', {id: deal.deal_id}) }}" style="display:inline;">
            <input type="hidden" name="_token" value="{{ csrf_token('resend_' ~ deal.deal_id) }}">
            <button type="submit" class="btn-resend" style="background:#6b7280;font-size:0.77rem;">
              <i class="fa fa-envelope"></i> Email classique (fallback)
            </button>
          </form>
        {% endif %}

      {% else %}
        {# Startup : peut synchroniser, ne peut pas envoyer #}
        {% if deal.yousign_signature_request_id %}
          {% set ys = deal.yousign_status ?? 'ongoing' %}
          <div class="lock-msg" style="{% if ys == 'done' %}color:#065f46;border-left:3px solid #10b981;padding-left:10px;{% elseif ys == 'declined' or ys == 'expired' %}color:#991b1b;{% else %}{% endif %}">
            <i class="fa fa-shield-alt" style="color:{% if ys == 'done' %}#10b981{% elseif ys == 'declined' or ys == 'expired' %}#ef4444{% else %}#6366f1{% endif %};"></i>
            Signature Yousign —
            {% if ys == 'done' %}✅ terminée
            {% elseif ys == 'declined' %}❌ refusée par l'investisseur
            {% elseif ys == 'expired' %}⚠️ lien expiré
            {% else %}en attente (statut : <strong>{{ ys }}</strong>){% endif %}
          </div>
          {# Startup peut aussi déclencher la sync #}
          <form method="post" action="{{ path('app_deal_yousign_sync', {id: deal.deal_id}) }}" style="margin-top:8px;">
            <input type="hidden" name="_token" value="{{ csrf_token('yousign_sync_' ~ deal.deal_id) }}">
            <button type="submit" class="btn-resend" style="background:{% if ys == 'done' %}#059669{% else %}#6366f1{% endif %};font-size:0.78rem;">
              <i class="fa fa-sync-alt"></i> {% if ys == 'done' %}Confirmer &amp; débloquer le téléchargement{% else %}Vérifier le statut{% endif %}
            </button>
          </form>
        {% elseif deal.signature_sent_at %}
          <div class="lock-msg"><i class="fa fa-envelope"></i> Email de signature envoyé le {{ deal.signature_sent_at|date('d/m/Y') }} — en attente</div>
        {% else %}
          <div class="lock-msg"><i class="fa fa-clock"></i> En attente de la signature de l'investisseur</div>
        {% endif %}
      {% endif %}

    {# Étape verrouillée #}
    {% elseif step == 3 %}
      <div class="lock-msg"><i class="fa fa-clock"></i> En attente de validation du paiement</div>
    {% else %}
      <div class="lock-msg"><i class="fa fa-lock"></i> Disponible après paiement</div>
    {% endif %}
  </div>

  {# ── Étape 4 : Téléchargement ── #}
  <div class="action-card {{ step >= 4 ? (step == 4 ? 'active-step' : 'done-step') : 'locked-step' }}">
    <div class="card-title">
      <i class="fa fa-file-pdf" style="color:{{ step >= 4 ? (step == 4 ? 'var(--primary)' : '#10b981') : '#9ca3af' }};"></i>
      Étape 4 — Téléchargement du contrat
    </div>
    <div class="card-desc">Téléchargez le contrat signé en PDF. Ce document a valeur contractuelle entre les deux parties.</div>

    {% if step == 5 %}
      <span class="done-badge" style="margin-bottom:12px;display:inline-flex;"><i class="fa fa-check-circle"></i> Téléchargé</span>
      <br>
    {% endif %}

    {% if can_download %}
      <a href="{{ path('app_deal_telecharger', {id: deal.deal_id}) }}" class="btn-action btn-dl">
        <i class="fa fa-download"></i> Télécharger le contrat PDF
      </a>
      <a href="{{ path('app_deal_dompdf', {id: deal.deal_id}) }}" class="btn-action" style="background:#6366f1;color:#fff;margin-left:10px;"
         title="Générer une copie fraîche du contrat via Dompdf (sans passer par Yousign)">
        <i class="fa fa-file-pdf"></i> Copie PDF locale
      </a>
      <a href="{{ path('app_deal_certificat', {id: deal.deal_id}) }}" class="btn-action" style="background:#1a1f2e;color:#ffbe33;margin-left:10px;">
        <i class="fa fa-certificate"></i> Certificat de signature
      </a>
    {% elseif step >= 4 %}
      {# Deal signé mais contract_pdf_path manquant — cas exceptionnel #}
      <div style="padding:12px 16px;border-radius:9px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.3);color:#92400e;font-size:0.84rem;font-weight:600;margin-bottom:12px;">
        <i class="fa fa-exclamation-triangle" style="color:#f59e0b;margin-right:6px;"></i>
        Le deal est bien signé mais le fichier PDF n'est pas encore référencé. Cliquez sur « Vérifier la signature » à l'étape 3 pour récupérer le PDF final depuis Yousign.
      </div>
      {% if deal.yousign_signature_request_id %}
        <form method="post" action="{{ path('app_deal_yousign_sync', {id: deal.deal_id}) }}" style="display:inline;">
          <input type="hidden" name="_token" value="{{ csrf_token('yousign_sync_' ~ deal.deal_id) }}">
          <button type="submit" class="btn-action btn-sign" style="font-size:0.85rem;">
            <i class="fa fa-sync-alt"></i> Récupérer le PDF signé depuis Yousign
          </button>
        </form>
      {% endif %}
      <a href="{{ path('app_deal_certificat', {id: deal.deal_id}) }}" class="btn-action" style="background:#1a1f2e;color:#ffbe33;margin-left:10px;font-size:0.85rem;">
        <i class="fa fa-certificate"></i> Certificat de signature
      </a>
    {% else %}
      {% if deal.yousign_signature_request_id and deal.yousign_status == 'done' %}
        <div style="padding:12px 16px;border-radius:9px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.3);color:#065f46;font-size:0.84rem;font-weight:600;margin-bottom:12px;">
          <i class="fa fa-check-circle" style="color:#10b981;margin-right:6px;"></i>
          La signature Yousign est terminée ! Cliquez sur <strong>« Vérifier la signature »</strong> à l'étape 3 pour débloquer le téléchargement.
        </div>
      {% elseif deal.yousign_signature_request_id %}
        <div class="lock-msg"><i class="fa fa-shield-alt" style="color:#6366f1;"></i> En attente de la signature électronique Yousign (statut : <strong>{{ deal.yousign_status ?? 'ongoing' }}</strong>)</div>
      {% else %}
        <div class="lock-msg"><i class="fa fa-lock"></i> Disponible après signature du contrat</div>
      {% endif %}
    {% endif %}
  </div>

  {# ── Résumé du deal ── #}
  <div class="deal-grid" style="margin-top:2rem;">
    <div class="deal-meta-card">
      <h4><i class="fa fa-info-circle"></i> Détails du deal</h4>
      <div class="meta-row"><span class="meta-label">Référence</span><span class="meta-value">DEAL-{{ deal.deal_id }}</span></div>
      <div class="meta-row"><span class="meta-label">Montant</span><span class="meta-value" style="color:var(--primary);">{{ deal.amount|number_format(0, ',', ' ') }} TND</span></div>
      <div class="meta-row"><span class="meta-label">Investisseur</span><span class="meta-value">{{ buyer ? buyer.fullName : '—' }}</span></div>
      <div class="meta-row"><span class="meta-label">Startup</span><span class="meta-value">{{ seller ? seller.fullName : '—' }}</span></div>
      <div class="meta-row"><span class="meta-label">Créé le</span><span class="meta-value">{{ deal.created_at ? deal.created_at|date('d/m/Y H:i') : '—' }}</span></div>
      {% if deal.completed_at %}
        <div class="meta-row"><span class="meta-label">Complété le</span><span class="meta-value">{{ deal.completed_at|date('d/m/Y H:i') }}</span></div>
      {% endif %}
      <div class="meta-row">
        <span class="meta-label">Statut</span>
        <span class="meta-value">
          {% set statusLabels = {'pending_payment': 'Paiement en attente', 'paid': 'Payé', 'pending_signature': 'En attente de signature', 'signed': 'Signé', 'completed': 'Complété', 'cancelled': 'Annulé'} %}
          {{ statusLabels[deal.status] ?? deal.status }}
        </span>
      </div>
    </div>

    <div class="deal-meta-card">
      <h4><i class="fa fa-shield-alt"></i> Sécurité</h4>
      <div style="font-size:0.82rem;color:var(--text-muted);line-height:1.7;">
        <p><i class="fa fa-check" style="color:#10b981;margin-right:5px;"></i>Paiement sécurisé Stripe</p>
        <p><i class="fa fa-check" style="color:#10b981;margin-right:5px;"></i>Contrat généré automatiquement</p>
        <p><i class="fa fa-check" style="color:#10b981;margin-right:5px;"></i>Workflow séquentiel bloquant</p>
        <p><i class="fa fa-check" style="color:#10b981;margin-right:5px;"></i>Accès restreint aux parties</p>
      </div>
    </div>
  </div>

</div>
{% endblock %}
