{% extends 'front/base.html.twig' %}

{% block title %}Deal #{{ deal.deal_id }} — BizHub{% endblock %}

{% block extra_styles %}
.deal-hero { background: linear-gradient(135deg, var(--dark) 0%, var(--dark2) 100%); padding: 50px 5% 35px; }
.deal-hero h1 { font-size: 1.7rem; color: var(--white); font-family: 'Josefin Sans', sans-serif; font-weight: 700; }
.deal-hero p  { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-top: 0.3rem; }
.deal-layout  { max-width: 1000px; margin: 0 auto; padding: 30px 5%; display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; }
@media (max-width: 820px) { .deal-layout { grid-template-columns: 1fr; } }

/* ── Stepper ─────────────────────────────────── */
.stepper { display: flex; align-items: flex-start; gap: 0; margin-bottom: 2rem; overflow-x: auto; padding-bottom: 8px; }
.step { display: flex; flex-direction: column; align-items: center; flex: 1; min-width: 80px; position: relative; }
.step:not(:last-child)::after {
    content: ''; position: absolute; top: 18px; left: 60%; width: 80%; height: 2px;
    background: var(--border); z-index: 0;
}
.step.done:not(:last-child)::after  { background: var(--primary); }
.step-circle {
    width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; font-weight: 700; z-index: 1; position: relative;
    border: 2.5px solid var(--border); background: var(--white); color: var(--text-muted); transition: all 0.3s;
}
.step.done   .step-circle { background: var(--primary); border-color: var(--primary); color: var(--dark); }
.step.active .step-circle { background: #6366f1; border-color: #6366f1; color: var(--white); box-shadow: 0 0 0 4px rgba(99,102,241,0.2); }
.step.error  .step-circle { background: rgba(239,68,68,0.1); border-color: #ef4444; color: #ef4444; }
.step-label { font-size: 0.7rem; font-weight: 700; text-align: center; margin-top: 6px; font-family: 'Josefin Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); }
.step.done   .step-label { color: #d97706; }
.step.active .step-label { color: #6366f1; }

/* ── Cards ───────────────────────────────────── */
.deal-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--border); padding: 24px; margin-bottom: 1.2rem; }
.deal-card-title { font-family: 'Josefin Sans', sans-serif; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1rem; display: flex; align-items: center; gap: 8px; }
.info-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 0.85rem; }
.info-row:last-child { border-bottom: none; }
.info-label { color: var(--text-muted); }
.info-value { font-weight: 700; color: var(--dark); font-family: 'Josefin Sans', sans-serif; }
.info-value.primary { color: var(--primary); }
.info-value.green   { color: #06d6a0; }

/* ── Action buttons ──────────────────────────── */
.deal-btn { width: 100%; padding: 14px; border-radius: 9px; font-family: 'Josefin Sans', sans-serif; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none; border: none; margin-bottom: 0.6rem; }
.btn-pay     { background: var(--primary); color: var(--dark); }
.btn-pay:hover     { opacity: 0.88; }
.btn-sign    { background: #6366f1; color: var(--white); }
.btn-sign:hover    { background: #4f51d8; }
.btn-dl      { background: rgba(6,214,160,0.1); color: #06d6a0; border: 1.5px solid rgba(6,214,160,0.3) !important; }
.btn-dl:hover      { background: rgba(6,214,160,0.2); }
.btn-resend  { background: var(--light-bg); color: var(--dark); border: 1.5px solid var(--border); font-size: 0.78rem; padding: 10px; }
.btn-secondary { background: var(--light-bg); color: var(--text-muted); border: 1.5px solid var(--border); }

/* ── Status badge ────────────────────────────── */
.deal-status { display: inline-flex; align-items: center; gap: 6px; font-size: 0.75rem; font-weight: 700; padding: 5px 14px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.08em; font-family: 'Josefin Sans', sans-serif; }
.status-pending_payment   { background: rgba(255,190,51,0.12); color: #d97706; border: 1px solid rgba(255,190,51,0.3); }
.status-paid              { background: rgba(99,102,241,0.1);  color: #6366f1; border: 1px solid rgba(99,102,241,0.25); }
.status-pending_signature { background: rgba(59,130,246,0.1);  color: #3b82f6; border: 1px solid rgba(59,130,246,0.25); }
.status-signed            { background: rgba(6,214,160,0.1);   color: #06d6a0; border: 1px solid rgba(6,214,160,0.25); }
.status-completed         { background: rgba(6,214,160,0.15);  color: #059669; border: 1px solid rgba(6,214,160,0.3); }
.status-cancelled         { background: rgba(239,68,68,0.08);  color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }

/* ── Flash ───────────────────────────────────── */
.flash-msg { padding: 13px 18px; border-radius: 9px; margin-bottom: 1rem; font-size: 0.88rem; font-weight: 600; }
.flash-success { background: rgba(6,214,160,0.1);   color: #06d6a0; border: 1px solid rgba(6,214,160,0.3); }
.flash-warning { background: rgba(255,190,51,0.1);  color: #d97706; border: 1px solid rgba(255,190,51,0.3); }
.flash-error   { background: rgba(239,68,68,0.08);  color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
.flash-info    { background: rgba(99,102,241,0.08); color: #6366f1; border: 1px solid rgba(99,102,241,0.2); }
{% endblock %}

{% block content %}

{# ── Hero ── #}
<div class="deal-hero">
    <div style="max-width:1000px;margin:0 auto;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;">
        <div>
            <h1><i class="fa fa-file-contract" style="color:var(--primary);margin-right:0.5rem;"></i>Deal #{{ deal.deal_id }}</h1>
            <p>
                <span class="deal-status status-{{ deal.status }}">
                    {% if deal.status == 'pending_payment' %}En attente de paiement
                    {% elseif deal.status == 'paid' %}Payé
                    {% elseif deal.status == 'pending_signature' %}En attente de signature
                    {% elseif deal.status == 'signed' %}Signé
                    {% elseif deal.status == 'completed' %}Terminé
                    {% elseif deal.status == 'cancelled' %}Annulé
                    {% endif %}
                </span>
                &nbsp;· Montant : <strong style="color:var(--primary);">{{ deal.amount|number_format(0, ',', ' ') }} TND</strong>
            </p>
        </div>
        {% if negotiation %}
        <a href="{{ path('app_negociation_show', {'id': negotiation.negotiation_id}) }}"
           style="color:rgba(255,255,255,0.5);font-size:0.83rem;text-decoration:none;">
            <i class="fa fa-arrow-left"></i> Négociation #{{ negotiation.negotiation_id }}
        </a>
        {% endif %}
    </div>
</div>

<div class="deal-layout">
<div>

    {# ── Flash messages ── #}
    {% for type, msgs in app.flashes %}
        {% for msg in msgs %}
            <div class="flash-msg flash-{{ type }}">{{ msg }}</div>
        {% endfor %}
    {% endfor %}

    {# ── Stepper ── #}
    <div class="deal-card">
        <div class="deal-card-title"><i class="fa fa-route" style="color:var(--primary);"></i> Progression du deal</div>
        <div class="stepper">
            {# Étape 1 : Accord #}
            <div class="step done">
                <div class="step-circle"><i class="fa fa-handshake"></i></div>
                <div class="step-label">Accord</div>
            </div>
            {# Étape 2 : Paiement #}
            <div class="step {% if deal.status == 'pending_payment' %}active{% elseif deal.status != 'cancelled' %}done{% endif %}">
                <div class="step-circle">
                    {% if deal.status == 'pending_payment' %}<i class="fa fa-credit-card"></i>
                    {% else %}<i class="fa fa-check"></i>{% endif %}
                </div>
                <div class="step-label">Paiement</div>
            </div>
            {# Étape 3 : Contrat #}
            <div class="step {% if deal.status == 'paid' %}active{% elseif deal.status in ['pending_signature','signed','completed'] %}done{% endif %}">
                <div class="step-circle">
                    {% if deal.status == 'paid' %}<i class="fa fa-file-pdf"></i>
                    {% else %}<i class="fa fa-check"></i>{% endif %}
                </div>
                <div class="step-label">Contrat</div>
            </div>
            {# Étape 4 : Signature #}
            <div class="step {% if deal.status == 'pending_signature' %}active{% elseif deal.status in ['signed','completed'] %}done{% endif %}">
                <div class="step-circle">
                    {% if deal.status == 'pending_signature' %}<i class="fa fa-pen"></i>
                    {% else %}<i class="fa fa-check"></i>{% endif %}
                </div>
                <div class="step-label">Signature</div>
            </div>
            {# Étape 5 : Finalisé #}
            <div class="step {% if deal.status == 'completed' %}done{% elseif deal.status == 'signed' %}active{% elseif deal.status == 'cancelled' %}error{% endif %}">
                <div class="step-circle">
                    {% if deal.status == 'completed' %}<i class="fa fa-trophy"></i>
                    {% elseif deal.status == 'cancelled' %}<i class="fa fa-times"></i>
                    {% else %}<i class="fa fa-flag-checkered"></i>{% endif %}
                </div>
                <div class="step-label">{{ deal.status == 'cancelled' ? 'Annulé' : 'Finalisé' }}</div>
            </div>
        </div>

        {# Message contextuel selon statut #}
        <div style="padding:12px 16px;border-radius:8px;font-size:0.86rem;
            {% if deal.status == 'pending_payment' %}background:rgba(255,190,51,0.07);border:1px solid rgba(255,190,51,0.2);color:#d97706;
            {% elseif deal.status == 'paid' %}background:rgba(99,102,241,0.07);border:1px solid rgba(99,102,241,0.2);color:#6366f1;
            {% elseif deal.status == 'pending_signature' %}background:rgba(59,130,246,0.07);border:1px solid rgba(59,130,246,0.2);color:#3b82f6;
            {% elseif deal.status in ['signed','completed'] %}background:rgba(6,214,160,0.07);border:1px solid rgba(6,214,160,0.2);color:#059669;
            {% else %}background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.15);color:#ef4444;
            {% endif %}">
            {% if deal.status == 'pending_payment' %}
                <i class="fa fa-info-circle" style="margin-right:6px;"></i>
                <strong>Action requise :</strong> L'investisseur doit effectuer le paiement via Stripe pour passer à l'étape suivante.
            {% elseif deal.status == 'paid' %}
                <i class="fa fa-hourglass-half" style="margin-right:6px;"></i>
                Paiement reçu. Le contrat PDF est en cours de génération et sera envoyé pour signature.
            {% elseif deal.status == 'pending_signature' %}
                <i class="fa fa-envelope" style="margin-right:6px;"></i>
                <strong>Action requise :</strong> Un email de signature a été envoyé à l'investisseur. En attente de signature électronique.
            {% elseif deal.status == 'signed' %}
                <i class="fa fa-check-circle" style="margin-right:6px;"></i>
                Contrat signé ! L'investisseur peut maintenant télécharger le contrat final pour finaliser le deal.
            {% elseif deal.status == 'completed' %}
                <i class="fa fa-trophy" style="margin-right:6px;"></i>
                <strong>Deal finalisé !</strong> L'investissement est confirmé et le contrat signé est disponible.
            {% elseif deal.status == 'cancelled' %}
                <i class="fa fa-ban" style="margin-right:6px;"></i>
                Ce deal a été annulé.
            {% endif %}
        </div>
    </div>

    {# ── Détails du deal ── #}
    <div class="deal-card">
        <div class="deal-card-title"><i class="fa fa-info-circle" style="color:var(--primary);"></i> Détails de la transaction</div>
        <div class="info-row">
            <span class="info-label">Investisseur (acheteur)</span>
            <span class="info-value">{{ buyer ? buyer.fullName : '—' }}</span>
        </div>
        <div class="info-row">
            <span class="info-label">Startup (vendeur)</span>
            <span class="info-value">{{ seller ? seller.fullName : '—' }}</span>
        </div>
        <div class="info-row">
            <span class="info-label">Montant (TND)</span>
            <span class="info-value primary">{{ deal.amount|number_format(0, ',', ' ') }} TND</span>
        </div>
        <div class="info-row">
            <span class="info-label">Équivalent EUR (estimé)</span>
            <span class="info-value" style="color:var(--text-muted);">~{{ (deal.amount * 0.30)|number_format(2, ',', ' ') }} EUR</span>
        </div>
        {% if deal.stripe_payment_status %}
        <div class="info-row">
            <span class="info-label">Statut Stripe</span>
            <span class="info-value green">{{ deal.stripe_payment_status }}</span>
        </div>
        {% endif %}
        {% if deal.created_at %}
        <div class="info-row">
            <span class="info-label">Créé le</span>
            <span class="info-value">{{ deal.created_at|date('d/m/Y H:i') }}</span>
        </div>
        {% endif %}
        {% if negotiation %}
        <div class="info-row">
            <span class="info-label">Négociation d'origine</span>
            <span class="info-value">
                <a href="{{ path('app_negociation_show', {'id': negotiation.negotiation_id}) }}" style="color:var(--primary);">
                    #{{ negotiation.negotiation_id }}
                </a>
            </span>
        </div>
        {% endif %}
    </div>

    {# ── Contrat / Signature ── #}
    {% if deal.status in ['pending_signature','signed','completed'] %}
    <div class="deal-card">
        <div class="deal-card-title"><i class="fa fa-file-pdf" style="color:#ef4444;"></i> Contrat PDF</div>
        {% if deal.contract_pdf_path %}
            <div style="display:flex;align-items:center;gap:10px;padding:10px;background:var(--light-bg);border-radius:8px;margin-bottom:0.8rem;">
                <i class="fa fa-file-pdf" style="font-size:1.4rem;color:#ef4444;"></i>
                <div style="flex:1;">
                    <div style="font-weight:700;font-size:0.88rem;color:var(--dark);">contrat-deal-{{ deal.deal_id }}.pdf</div>
                    <div style="font-size:0.75rem;color:var(--text-muted);">Contrat d'investissement généré</div>
                </div>
                {% if can_download %}
                <a href="{{ path('app_deal_telecharger', {'id': deal.deal_id}) }}" class="deal-btn btn-dl" style="width:auto;padding:8px 16px;margin:0;font-size:0.75rem;">
                    <i class="fa fa-download"></i> Télécharger
                </a>
                {% endif %}
            </div>
        {% else %}
            <p style="color:var(--text-muted);font-size:0.87rem;font-style:italic;">Le contrat sera généré automatiquement après confirmation du paiement.</p>
        {% endif %}
        {% if deal.yousign_status %}
        <div class="info-row">
            <span class="info-label">Statut Yousign</span>
            <span class="info-value">{{ deal.yousign_status }}</span>
        </div>
        {% endif %}
    </div>
    {% endif %}

</div>

{# ── Sidebar actions ── #}
<div>
    <div class="deal-card" style="position:sticky;top:90px;">
        <div class="deal-card-title"><i class="fa fa-bolt" style="color:var(--primary);"></i> Actions</div>

        {% if deal.status == 'cancelled' %}
            <div style="text-align:center;padding:20px 0;color:var(--text-muted);font-size:0.87rem;">
                <i class="fa fa-ban" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:8px;"></i>
                Ce deal a été annulé.
            </div>

        {% elseif deal.status == 'completed' %}
            <div style="text-align:center;padding:16px 0;color:#059669;font-size:0.87rem;margin-bottom:1rem;">
                <i class="fa fa-trophy" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
                <strong>Deal finalisé !</strong><br>L'investissement est confirmé.
            </div>
            {% if can_download %}
            <a href="{{ path('app_deal_telecharger', {'id': deal.deal_id}) }}" class="deal-btn btn-dl">
                <i class="fa fa-download"></i> Télécharger le contrat
            </a>
            {% endif %}

        {% elseif is_buyer and can_pay %}
            {# ── ÉTAPE PAIEMENT (investisseur seulement) ── #}
            <div style="text-align:center;margin-bottom:1.2rem;">
                <div style="font-size:1.6rem;font-weight:700;color:var(--primary);font-family:'Josefin Sans',sans-serif;">
                    {{ deal.amount|number_format(0, ',', ' ') }} TND
                </div>
                <div style="font-size:0.78rem;color:var(--text-muted);">
                    ≈ {{ (deal.amount * 0.30)|number_format(2, ',', ' ') }} EUR à débiter
                </div>
            </div>
            <a href="{{ path('app_deal_payer', {'id': deal.deal_id}) }}" class="deal-btn btn-pay">
                <i class="fa fa-credit-card"></i> Payer via Stripe
            </a>
            <div style="text-align:center;font-size:0.75rem;color:var(--text-muted);margin-top:0.5rem;">
                <i class="fa fa-shield-alt" style="margin-right:4px;color:#06d6a0;"></i>
                Paiement sécurisé Stripe (3D Secure)
            </div>

        {% elseif deal.status == 'pending_payment' and not is_buyer %}
            <div style="padding:14px;background:rgba(255,190,51,0.07);border:1px solid rgba(255,190,51,0.2);border-radius:8px;text-align:center;font-size:0.86rem;color:#d97706;">
                <i class="fa fa-hourglass-half" style="display:block;font-size:1.5rem;margin-bottom:6px;"></i>
                En attente du paiement de l'investisseur.
            </div>

        {% elseif deal.status == 'pending_signature' %}
            {% if is_buyer %}
                <div style="padding:12px 14px;background:rgba(59,130,246,0.07);border:1px solid rgba(59,130,246,0.2);border-radius:8px;font-size:0.85rem;color:#3b82f6;margin-bottom:1rem;">
                    <i class="fa fa-envelope" style="margin-right:6px;"></i>
                    Un email de signature a été envoyé à votre adresse. Consultez votre boîte mail.
                </div>
                <form method="post" action="{{ path('app_deal_resend_signature', {'id': deal.deal_id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('resend_' ~ deal.deal_id) }}">
                    <button type="submit" class="deal-btn btn-resend">
                        <i class="fa fa-redo"></i> Renvoyer l'email de signature
                    </button>
                </form>
                {% if deal.contract_pdf_path %}
                <form method="post" action="{{ path('app_deal_yousign_send', {'id': deal.deal_id}) }}" style="margin-top:0.5rem;">
                    <input type="hidden" name="_token" value="{{ csrf_token('yousign_' ~ deal.deal_id) }}">
                    <button type="submit" class="deal-btn btn-sign">
                        <i class="fa fa-pen-nib"></i> Envoyer via Yousign
                    </button>
                </form>
                {% if deal.yousign_signature_request_id %}
                <form method="post" action="{{ path('app_deal_yousign_sync', {'id': deal.deal_id}) }}" style="margin-top:0.5rem;">
                    <input type="hidden" name="_token" value="{{ csrf_token('yousign_sync_' ~ deal.deal_id) }}">
                    <button type="submit" class="deal-btn btn-secondary" style="font-size:0.75rem;padding:10px;">
                        <i class="fa fa-sync"></i> Vérifier statut Yousign
                    </button>
                </form>
                {% endif %}
                {% endif %}
            {% else %}
                <div style="padding:14px;background:rgba(59,130,246,0.07);border:1px solid rgba(59,130,246,0.2);border-radius:8px;text-align:center;font-size:0.86rem;color:#3b82f6;">
                    <i class="fa fa-hourglass-half" style="display:block;font-size:1.5rem;margin-bottom:6px;"></i>
                    En attente de la signature de l'investisseur.
                </div>
            {% endif %}

        {% elseif deal.status == 'signed' %}
            {% if can_download %}
            <a href="{{ path('app_deal_telecharger', {'id': deal.deal_id}) }}" class="deal-btn btn-dl">
                <i class="fa fa-download"></i> Télécharger le contrat signé
            </a>
            <div style="text-align:center;font-size:0.75rem;color:var(--text-muted);margin-top:0.4rem;">
                Le téléchargement finalisera le deal
            </div>
            {% else %}
                <div style="padding:12px 14px;background:rgba(6,214,160,0.07);border-radius:8px;text-align:center;font-size:0.85rem;color:#059669;">
                    <i class="fa fa-check-circle"></i> Contrat signé. En attente de finalisation.
                </div>
            {% endif %}
        {% endif %}

        {# ── Lien workflow ── #}
        <div style="margin-top:1.2rem;padding-top:1rem;border-top:1px solid var(--border);">
            <a href="{{ path('app_front_projet_index') }}"
               style="display:block;text-align:center;font-size:0.8rem;color:var(--text-muted);text-decoration:none;padding:8px;">
                <i class="fa fa-arrow-left" style="margin-right:5px;"></i>Retour à mes projets
            </a>
        </div>
    </div>
</div>
</div>
{% endblock %}
