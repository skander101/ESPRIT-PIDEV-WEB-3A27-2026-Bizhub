{% extends 'front/base.html.twig' %}

{% block title %}Signature du contrat — Deal #{{ deal.deal_id }}{% endblock %}

{% block extra_styles %}
.confirm-wrap { max-width: 560px; margin: 60px auto; padding: 0 5%; }
.confirm-card { background: var(--white); border-radius: 18px; border: 1.5px solid var(--border); padding: 40px 36px; box-shadow: 0 8px 32px rgba(0,0,0,0.07); text-align: center; }
.confirm-icon { font-size: 3rem; margin-bottom: 1rem; }
.confirm-title { font-family: 'Josefin Sans', sans-serif; font-size: 1.5rem; font-weight: 800; color: var(--dark); margin-bottom: 0.5rem; }
.confirm-sub { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 2rem; }
.deal-summary { background: #f9fafb; border-radius: 10px; border: 1px solid var(--border); padding: 18px 20px; margin-bottom: 2rem; text-align: left; }
.deal-summary table { width: 100%; border-collapse: collapse; }
.deal-summary td { padding: 8px 0; font-size: 0.88rem; border-bottom: 1px solid #f3f4f6; }
.deal-summary td:last-child { border-bottom: none; }
.deal-summary .lbl { color: var(--text-muted); }
.deal-summary .val { font-weight: 700; color: var(--dark); text-align: right; }
.deal-summary .val.amount { color: var(--primary); }
.btn-confirm { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 36px; background: #10b981; color: #fff; border: none; border-radius: 10px; font-size: 1rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; cursor: pointer; text-decoration: none; transition: background 0.2s; width: 100%; }
.btn-confirm:hover { background: #059669; }
.btn-cancel { display: inline-block; margin-top: 14px; font-size: 0.85rem; color: var(--text-muted); text-decoration: underline; }
.warning-box { background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.3); border-radius: 10px; padding: 14px 18px; margin-bottom: 1.5rem; font-size: 0.85rem; color: #92400e; text-align: left; }
.error-card { border-color: rgba(239,68,68,0.3); }
.error-icon { color: #ef4444; }
.error-title { color: #991b1b; }
.success-card { border-color: rgba(16,185,129,0.3); }
.success-icon { color: #10b981; }
{% endblock %}

{% block content %}

<div class="confirm-wrap">

  {# ── Token invalide ou expiré ── #}
  {% if not token_valid %}
    <div class="confirm-card error-card">
      <div class="confirm-icon error-icon">⛔</div>
      <h1 class="confirm-title error-title">Lien invalide ou expiré</h1>
      <p class="confirm-sub">{{ error_message }}</p>

      <div class="warning-box">
        <strong>Que faire ?</strong><br>
        Si votre lien a expiré, retournez sur la page du deal et cliquez sur
        <strong>« Renvoyer l'email »</strong> pour recevoir un nouveau lien.
      </div>

      <a href="{{ path('app_deal_show', {id: deal.deal_id}) }}" class="btn-confirm" style="background:#6366f1;">
        <i class="fa fa-arrow-left"></i> Retourner au deal
      </a>
    </div>

  {# ── Confirmation de signature ── #}
  {% elseif signed %}
    <div class="confirm-card success-card">
      <div class="confirm-icon success-icon">✅</div>
      <h1 class="confirm-title" style="color:#065f46;">Contrat signé !</h1>
      <p class="confirm-sub">Votre signature a bien été enregistrée. Vous pouvez maintenant télécharger le contrat final.</p>
      <a href="{{ path('app_deal_show', {id: deal.deal_id}) }}" class="btn-confirm">
        <i class="fa fa-file-pdf"></i> Accéder au contrat
      </a>
    </div>

  {# ── Formulaire de confirmation ── #}
  {% else %}
    <div class="confirm-card">
      <div class="confirm-icon">✍️</div>
      <h1 class="confirm-title">Confirmer la signature</h1>
      <p class="confirm-sub">Vous êtes sur le point de signer le contrat d'investissement suivant. Cette action est définitive.</p>

      <div class="deal-summary">
        <table>
          <tr>
            <td class="lbl">Référence</td>
            <td class="val">DEAL-{{ deal.deal_id }}</td>
          </tr>
          <tr>
            <td class="lbl">Montant</td>
            <td class="val amount">{{ deal.amount|number_format(0, ',', ' ') }} TND</td>
          </tr>
          {% if buyer %}
          <tr>
            <td class="lbl">Investisseur</td>
            <td class="val">{{ buyer.fullName }}</td>
          </tr>
          {% endif %}
          {% if seller %}
          <tr>
            <td class="lbl">Startup</td>
            <td class="val">{{ seller.fullName }}</td>
          </tr>
          {% endif %}
          <tr>
            <td class="lbl">Lien expire le</td>
            <td class="val" style="color:#ef4444;">{{ deal.signature_token_expires_at|date('d/m/Y à H:i') }}</td>
          </tr>
        </table>
      </div>

      <div class="warning-box">
        <i class="fa fa-info-circle"></i>
        <strong>En signant, vous acceptez les termes du contrat d'investissement.</strong><br>
        Cette action est irréversible et a valeur contractuelle entre les deux parties.
      </div>

      <form method="post" action="{{ path('app_deal_sign_token', {id: deal.deal_id, token: token}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('sign_token_' ~ deal.deal_id) }}">
        <button type="submit" class="btn-confirm">
          <i class="fa fa-pen-fancy"></i> Je signe ce contrat
        </button>
      </form>

      <a href="{{ path('app_deal_show', {id: deal.deal_id}) }}" class="btn-cancel">Annuler et revenir au deal</a>
    </div>
  {% endif %}

</div>
{% endblock %}
