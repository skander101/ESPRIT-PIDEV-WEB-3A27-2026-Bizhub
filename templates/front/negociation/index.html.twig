{% extends 'front/base.html.twig' %}

{% block title %}Mes Négociations — BizHub{% endblock %}

{% block extra_styles %}
.page-header { background: linear-gradient(135deg, var(--dark) 0%, var(--dark2) 100%); padding: 60px 5% 40px; }
.page-header h1 { font-size: 2rem; color: var(--white); font-family: 'Josefin Sans', sans-serif; font-weight: 700; }
.page-header p { color: rgba(255,255,255,0.55); margin-top: 0.4rem; }
.page-body { max-width: 1000px; margin: 0 auto; padding: 40px 5%; }
.neg-card {
    background: var(--white);
    border-radius: 14px;
    border: 1.5px solid var(--border);
    box-shadow: 0 4px 18px rgba(0,0,0,0.06);
    margin-bottom: 1rem;
    padding: 22px;
    transition: border-color 0.2s;
    text-decoration: none;
    display: block;
    color: inherit;
}
.neg-card:hover { border-color: var(--primary); box-shadow: 0 6px 24px rgba(255,190,51,0.12); }
.neg-card-body { display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: center; }
.neg-projet-title { font-size: 1rem; font-weight: 700; color: var(--dark); margin-bottom: 0.3rem; font-family: 'Josefin Sans', sans-serif; }
.neg-meta { font-size: 0.82rem; color: var(--text-muted); display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.5rem; }
.neg-meta span { display: flex; align-items: center; gap: 4px; }
.neg-amount { font-size: 1.3rem; font-weight: 700; color: var(--primary); font-family: 'Josefin Sans', sans-serif; text-align: right; }
.neg-amount-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; font-family: 'Josefin Sans', sans-serif; }
.badge-neg { font-size: 0.7rem; font-weight: 700; padding: 3px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.08em; font-family: 'Josefin Sans', sans-serif; display: inline-block; }
.badge-open     { background: rgba(255,190,51,0.12); color: #d97706; border: 1px solid rgba(255,190,51,0.3); }
.badge-accepted { background: rgba(6,214,160,0.12);  color: #06d6a0; border: 1px solid rgba(6,214,160,0.3); }
.badge-rejected { background: rgba(239,68,68,0.08);  color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
.badge-expired  { background: rgba(107,114,128,0.1); color: #9ca3af; border: 1px solid rgba(107,114,128,0.2); }
@media (max-width: 600px) { .neg-card-body { grid-template-columns: 1fr; } .neg-amount { text-align: left; } }
{% endblock %}

{% block content %}
<div class="page-header">
    <div style="max-width:1000px;margin:0 auto;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;">
        <div>
            <h1><i class="fa fa-handshake" style="color:var(--primary);margin-right:0.5rem;"></i>Mes Négociations</h1>
            <p>{{ negociations|length }} négociation(s) au total</p>
        </div>
        {% if user_type == 'investisseur' %}
        <a href="{{ path('app_front_projet_index') }}" class="btn-yellow" style="display:flex;align-items:center;gap:8px;">
            <i class="fa fa-search"></i> Explorer les projets
        </a>
        {% endif %}
    </div>
</div>

<div class="page-body">

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-msg flash-{{ type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if negociations|length > 0 %}

        {% for neg in negociations %}
            <a href="{{ path('app_negociation_show', {'id': neg.negotiation_id}) }}" class="neg-card">
                <div class="neg-card-body">
                    <div>
                        <div class="neg-projet-title">
                            {% if neg.project %}
                                {{ neg.project.title }}
                            {% else %}
                                <span style="color:var(--text-muted);">Projet supprimé</span>
                            {% endif %}
                        </div>

                        <div style="margin-top:0.4rem;">
                            {% if neg.status == 'open' %}
                                <span class="badge-neg badge-open"><i class="fa fa-circle" style="font-size:0.5rem;"></i> Ouverte</span>
                            {% elseif neg.status == 'accepted' %}
                                <span class="badge-neg badge-accepted"><i class="fa fa-check"></i> Acceptée</span>
                            {% elseif neg.status == 'rejected' %}
                                <span class="badge-neg badge-rejected"><i class="fa fa-times"></i> Rejetée</span>
                            {% elseif neg.status == 'expired' %}
                                <span class="badge-neg badge-expired"><i class="fa fa-clock"></i> Expirée</span>
                            {% endif %}
                        </div>

                        <div class="neg-meta">
                            {% if user_type == 'investisseur' and neg.startup %}
                                <span><i class="fa fa-building" style="color:var(--primary);"></i> {{ neg.startup.fullName }}</span>
                            {% elseif user_type == 'startup' and neg.investor %}
                                <span><i class="fa fa-user-tie" style="color:var(--primary);"></i> {{ neg.investor.fullName }}</span>
                            {% endif %}
                            <span><i class="fa fa-calendar" style="color:var(--primary);"></i>
                                {{ neg.created_at ? neg.created_at|date('d/m/Y') : '—' }}
                            </span>
                            {% if neg.updated_at and neg.updated_at != neg.created_at %}
                                <span><i class="fa fa-clock" style="color:var(--text-muted);"></i>
                                    Mis à jour {{ neg.updated_at|date('d/m/Y H:i') }}
                                </span>
                            {% endif %}
                        </div>
                    </div>

                    <div>
                        <div class="neg-amount-label">Montant proposé</div>
                        <div class="neg-amount">
                            {{ neg.proposed_amount ? neg.proposed_amount|number_format(0, ',', ' ') : '—' }}
                        </div>
                        {% if neg.proposed_amount %}
                            <div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px;text-align:right;">TND</div>
                        {% endif %}
                        {% if neg.status == 'accepted' and neg.final_amount %}
                            <div style="margin-top:0.5rem;text-align:right;">
                                <span style="font-size:0.75rem;color:#06d6a0;font-weight:700;">
                                    Final : {{ neg.final_amount|number_format(0, ',', ' ') }} TND
                                </span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </a>
        {% endfor %}

    {% else %}
        <div style="background:var(--white);border:1.5px solid var(--border);border-radius:14px;padding:60px 20px;text-align:center;">
            <div style="font-size:3rem;color:var(--text-muted);opacity:0.3;margin-bottom:1.2rem;"><i class="fa fa-handshake"></i></div>
            <h3 style="font-family:'Josefin Sans',sans-serif;font-size:1.1rem;margin-bottom:0.7rem;">Aucune négociation pour l'instant</h3>
            {% if user_type == 'investisseur' %}
                <p style="color:var(--text-muted);margin-bottom:1.8rem;font-size:0.9rem;">Explorez les projets et initiez votre première négociation.</p>
                <a href="{{ path('app_front_projet_index') }}" class="btn-yellow">
                    <i class="fa fa-search" style="margin-right:6px;"></i>Explorer les projets
                </a>
            {% else %}
                <p style="color:var(--text-muted);font-size:0.9rem;">Aucun investisseur n'a encore initié de négociation sur vos projets.</p>
            {% endif %}
        </div>
    {% endif %}

</div>
{% endblock %}
