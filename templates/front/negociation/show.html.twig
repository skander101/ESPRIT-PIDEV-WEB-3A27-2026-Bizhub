{% extends 'front/base.html.twig' %}

{% block title %}Négociation — {{ negociation.project.title }}{% endblock %}

{% block extra_styles %}
.neg-header { background: linear-gradient(135deg, var(--dark) 0%, #1a1f2e 100%); padding: 48px 5% 32px; }
.neg-header h1 { font-size: 1.6rem; color: var(--white); font-family: 'Josefin Sans', sans-serif; font-weight: 700; margin: 0 0 0.25rem; }
.neg-header p { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin: 0; }
.back-link { display: inline-flex; align-items: center; gap: 6px; color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.78rem; margin-bottom: 1.2rem; transition: color 0.2s; font-family: 'Josefin Sans', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }
.back-link:hover { color: var(--primary); }

.neg-body { max-width: 900px; margin: 0 auto; padding: 32px 5%; display: grid; grid-template-columns: 1fr 280px; gap: 1.5rem; align-items: start; }

/* Status badge */
.neg-status { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 20px; font-size: 0.78rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; }
.neg-status.open     { background: rgba(59,130,246,0.15); color: #3b82f6; }
.neg-status.accepted { background: rgba(16,185,129,0.15); color: #10b981; }
.neg-status.rejected { background: rgba(239,68,68,0.15);  color: #ef4444; }
.neg-status.expired  { background: rgba(107,114,128,0.15);color: #6b7280; }

/* Chat */
.chat-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--border); box-shadow: 0 4px 18px rgba(0,0,0,0.05); overflow: hidden; }
.chat-header { padding: 18px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.chat-header h3 { font-size: 0.95rem; font-weight: 700; color: var(--dark); margin: 0; }
.chat-messages { padding: 20px; max-height: 440px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; }
.msg-row { display: flex; gap: 10px; }
.msg-row.mine { flex-direction: row-reverse; }
.msg-avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; color: var(--dark); flex-shrink: 0; }
.msg-bubble { max-width: 72%; padding: 10px 14px; border-radius: 12px; font-size: 0.85rem; line-height: 1.5; }
.msg-row.mine  .msg-bubble { background: var(--primary); color: var(--dark); border-bottom-right-radius: 4px; }
.msg-row.other .msg-bubble { background: #f3f4f6; color: var(--dark); border-bottom-left-radius: 4px; }
.msg-row.system .msg-bubble { background: rgba(16,185,129,0.1); color: #065f46; border: 1px solid rgba(16,185,129,0.2); width: 100%; max-width: 100%; text-align: center; }
.msg-meta { font-size: 0.7rem; color: var(--text-muted); margin-top: 4px; }
.msg-offer { margin-top: 6px; background: rgba(255,190,51,0.12); border: 1px solid rgba(255,190,51,0.3); padding: 6px 10px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; color: var(--dark); }

/* Compose */
.chat-compose { padding: 16px 20px; border-top: 1px solid var(--border); background: #fafafa; }
.compose-row { display: flex; gap: 8px; margin-bottom: 8px; }
.compose-input { flex: 1; border: 1.5px solid var(--border); border-radius: 9px; padding: 10px 14px; font-size: 0.87rem; color: var(--dark); background: var(--white); outline: none; resize: none; }
.compose-input:focus { border-color: var(--primary); }
.compose-amount { width: 130px; border: 1.5px solid var(--border); border-radius: 9px; padding: 10px 12px; font-size: 0.87rem; color: var(--dark); background: var(--white); outline: none; }
.compose-send { background: var(--primary); border: none; border-radius: 9px; padding: 10px 18px; font-weight: 700; font-size: 0.87rem; color: var(--dark); cursor: pointer; transition: background 0.2s; }
.compose-send:hover { background: var(--primary-dark); }

/* Sidebar */
.neg-sidebar { display: flex; flex-direction: column; gap: 1rem; }
.info-card { background: var(--white); border-radius: 12px; border: 1.5px solid var(--border); padding: 18px; box-shadow: 0 2px 12px rgba(0,0,0,0.05); }
.info-card h4 { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); font-family: 'Josefin Sans', sans-serif; margin: 0 0 12px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
.info-row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 0.84rem; border-bottom: 1px solid #f3f4f6; }
.info-row:last-child { border-bottom: none; }
.info-label { color: var(--text-muted); }
.info-value { font-weight: 600; color: var(--dark); }

.action-btn { display: block; width: 100%; padding: 12px; border-radius: 9px; border: none; font-weight: 700; font-size: 0.88rem; font-family: 'Josefin Sans', sans-serif; cursor: pointer; text-align: center; text-decoration: none; transition: all 0.2s; margin-bottom: 8px; }
.action-btn.accept { background: #10b981; color: #fff; }
.action-btn.accept:hover { background: #059669; }
.action-btn.reject { background: transparent; color: #ef4444; border: 1.5px solid #ef4444; }
.action-btn.reject:hover { background: rgba(239,68,68,0.08); }
.action-btn.deal   { background: var(--primary); color: var(--dark); }
.action-btn.deal:hover { background: var(--primary-dark); }
.action-btn.disabled { background: #f3f4f6; color: #9ca3af; cursor: not-allowed; }

.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; }
.modal-overlay.active { display: flex; }
.modal-box { background: var(--white); border-radius: 14px; padding: 28px; max-width: 420px; width: 90%; }
.modal-box h3 { margin: 0 0 16px; font-size: 1.1rem; }
.modal-box input { width: 100%; box-sizing: border-box; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 0.9rem; margin-bottom: 12px; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; }

/* ── AI Trigger (sidebar) ─────────────────────────────── */
.ai-trigger { background: linear-gradient(145deg, #0f172a, #1e1b4b); border-radius: 14px; border: 1.5px solid rgba(139,92,246,0.35); padding: 18px; box-shadow: 0 6px 28px rgba(99,60,220,0.18); }
.ai-trigger h4 { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(167,139,250,0.85); font-family: 'Josefin Sans', sans-serif; margin: 0 0 10px; padding-bottom: 8px; border-bottom: 1px solid rgba(139,92,246,0.18); display: flex; align-items: center; gap: 6px; }
.ai-trigger-desc { font-size: 0.76rem; color: rgba(255,255,255,0.38); margin: 0 0 14px; line-height: 1.55; }
.ai-btn { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 12px; border-radius: 10px; border: none; background: linear-gradient(135deg, #7c3aed, #4f46e5); color: #fff; font-weight: 700; font-size: 0.87rem; font-family: 'Josefin Sans', sans-serif; cursor: pointer; transition: all 0.25s; box-shadow: 0 4px 14px rgba(124,58,237,0.4); }
.ai-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(124,58,237,0.55); }
.ai-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
.ai-last-time { margin-top: 8px; font-size: 0.7rem; color: rgba(255,255,255,0.3); text-align: center; }

/* ── AI Results Panel (full-width) ───────────────────── */
.ai-panel-wrap { max-width: 900px; margin: 0 auto; padding: 0 5% 40px; }
.ai-panel { background: linear-gradient(160deg, #0b0f1e 0%, #111827 50%, #0f0a24 100%); border-radius: 20px; border: 1.5px solid rgba(139,92,246,0.3); box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(139,92,246,0.1); overflow: hidden; animation: aiPanelIn 0.4s ease; }
@keyframes aiPanelIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
.ai-panel-header { padding: 22px 28px; border-bottom: 1px solid rgba(139,92,246,0.15); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
.ai-panel-title { font-size: 1rem; font-weight: 800; color: #e2e8f0; font-family: 'Josefin Sans', sans-serif; display: flex; align-items: center; gap: 10px; }
.ai-panel-meta { display: flex; align-items: center; gap: 10px; }
.ai-src-badge { padding: 4px 12px; border-radius: 20px; font-size: 0.72rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; }
.ai-src-badge.openai { background: rgba(16,185,129,0.15); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.25); }
.ai-src-badge.local  { background: rgba(245,158,11,0.12); color: #fcd34d; border: 1px solid rgba(245,158,11,0.22); }
.ai-close-btn { width: 28px; height: 28px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.12); background: transparent; color: rgba(255,255,255,0.4); cursor: pointer; font-size: 0.85rem; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
.ai-close-btn:hover { background: rgba(255,255,255,0.08); color: #fff; }

/* Score section */
.ai-score-section { padding: 24px 28px; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
.ai-score-ring-wrap { flex-shrink: 0; position: relative; width: 96px; height: 96px; }
.ai-score-ring-wrap svg { transform: rotate(-90deg); }
.ai-score-ring-bg  { fill: none; stroke: rgba(255,255,255,0.07); stroke-width: 8; }
.ai-score-ring-val { fill: none; stroke-width: 8; stroke-linecap: round; transition: stroke-dashoffset 1.2s cubic-bezier(0.22,1,0.36,1); }
.ai-score-ring-text { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.ai-score-num  { font-size: 1.55rem; font-weight: 900; color: #e2e8f0; font-family: 'Josefin Sans', sans-serif; line-height: 1; }
.ai-score-lbl  { font-size: 0.6rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.1em; }
.ai-score-info { flex: 1; min-width: 200px; }
.ai-rec-badge  { display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 24px; font-size: 0.82rem; font-weight: 800; font-family: 'Josefin Sans', sans-serif; margin-bottom: 10px; }
.ai-rec-badge.invest  { background: rgba(16,185,129,0.18); color: #6ee7b7; border: 1.5px solid rgba(16,185,129,0.3); }
.ai-rec-badge.negocie { background: rgba(245,158,11,0.16); color: #fcd34d; border: 1.5px solid rgba(245,158,11,0.3); }
.ai-rec-badge.decline { background: rgba(239,68,68,0.15);  color: #fca5a5; border: 1.5px solid rgba(239,68,68,0.3); }
.ai-smart-badges { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.ai-smart-badge { padding: 3px 10px; border-radius: 14px; font-size: 0.7rem; font-weight: 700; background: rgba(139,92,246,0.15); color: #c4b5fd; border: 1px solid rgba(139,92,246,0.25); }

/* Sub-scores + chart grid */
.ai-analysis-grid { padding: 24px 28px; border-bottom: 1px solid rgba(255,255,255,0.05); display: grid; grid-template-columns: 1fr 220px; gap: 28px; align-items: start; }
@media (max-width: 640px) { .ai-analysis-grid { grid-template-columns: 1fr; } }
.ai-sub-label { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(167,139,250,0.75); font-family: 'Josefin Sans', sans-serif; margin: 0 0 16px; }
.ai-criterion { margin-bottom: 14px; }
.ai-criterion:last-child { margin-bottom: 0; }
.ai-crit-header { display: flex; justify-content: space-between; margin-bottom: 5px; }
.ai-crit-name  { font-size: 0.8rem; color: rgba(255,255,255,0.65); }
.ai-crit-score { font-size: 0.8rem; font-weight: 700; color: #a78bfa; }
.ai-crit-bar   { height: 6px; border-radius: 99px; background: rgba(255,255,255,0.08); overflow: hidden; }
.ai-crit-fill  { height: 100%; border-radius: 99px; transition: width 1s cubic-bezier(0.22,1,0.36,1); width: 0%; }
.fill-high   { background: linear-gradient(90deg, #10b981, #34d399); }
.fill-mid    { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
.fill-low    { background: linear-gradient(90deg, #ef4444, #f87171); }
.ai-chart-wrap { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.ai-chart-lbl  { font-size: 0.65rem; color: rgba(255,255,255,0.3); text-align: center; }

/* Résumé */
.ai-resume-section { padding: 22px 28px; border-bottom: 1px solid rgba(255,255,255,0.05); }
.ai-section-title { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(167,139,250,0.75); font-family: 'Josefin Sans', sans-serif; margin: 0 0 12px; display: flex; align-items: center; gap: 7px; }
.ai-resume-text { font-size: 0.85rem; color: rgba(255,255,255,0.68); line-height: 1.7; border-left: 3px solid rgba(139,92,246,0.5); padding-left: 14px; }

/* Action plan + brouillon grid */
.ai-bottom-grid { padding: 24px 28px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
@media (max-width: 640px) { .ai-bottom-grid { grid-template-columns: 1fr; } }
.ai-plan-list { list-style: none; margin: 0; padding: 0; }
.ai-plan-list li { display: flex; gap: 10px; padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.82rem; color: rgba(255,255,255,0.65); line-height: 1.45; }
.ai-plan-list li:last-child { border-bottom: none; }
.ai-plan-num { flex-shrink: 0; width: 22px; height: 22px; border-radius: 50%; background: rgba(139,92,246,0.2); color: #a78bfa; font-size: 0.7rem; font-weight: 700; display: flex; align-items: center; justify-content: center; margin-top: 1px; }

/* ── Brouillon IA ──────────────────────────────────────── */
.ai-draft-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(139,92,246,0.2); border-radius: 14px; padding: 18px 20px; display: flex; flex-direction: column; gap: 12px; }
.ai-draft-styles { display: flex; gap: 6px; flex-wrap: wrap; }
.ai-style-btn { padding: 6px 13px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,0.1); background: transparent; color: rgba(255,255,255,0.45); font-size: 0.73rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; cursor: pointer; transition: all 0.18s; display: flex; align-items: center; gap: 5px; white-space: nowrap; }
.ai-style-btn:hover { border-color: rgba(139,92,246,0.4); color: #c4b5fd; background: rgba(139,92,246,0.1); }
.ai-style-btn.active { border-color: rgba(139,92,246,0.6); color: #c4b5fd; background: rgba(139,92,246,0.18); box-shadow: 0 0 0 1px rgba(139,92,246,0.2); }
.ai-style-btn.loading { opacity: 0.5; cursor: not-allowed; pointer-events: none; }
.ai-draft-area-wrap { position: relative; }
.ai-draft-area { width: 100%; box-sizing: border-box; background: rgba(255,255,255,0.035); border: 1.5px solid rgba(139,92,246,0.22); border-radius: 10px; color: rgba(255,255,255,0.82); font-size: 0.83rem; padding: 13px 15px; resize: vertical; min-height: 110px; line-height: 1.65; font-family: inherit; transition: border-color 0.2s, background 0.2s; }
.ai-draft-area:focus { outline: none; border-color: rgba(139,92,246,0.5); background: rgba(255,255,255,0.055); }
.ai-draft-area::placeholder { color: rgba(255,255,255,0.2); font-style: italic; }
.ai-draft-area.refreshing { opacity: 0.4; transition: opacity 0.15s; }
.ai-draft-spinner { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); color: #a78bfa; font-size: 1.1rem; display: none; pointer-events: none; }
.ai-draft-area-wrap.busy .ai-draft-spinner { display: block; }
.ai-draft-actions { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
.ai-draft-hint { font-size: 0.68rem; color: rgba(255,255,255,0.25); font-style: italic; margin-left: auto; }
.ai-act-btn { padding: 8px 14px; border-radius: 8px; font-size: 0.76rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; cursor: pointer; transition: all 0.18s; display: flex; align-items: center; gap: 6px; white-space: nowrap; }
.ai-act-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.ai-act-btn.primary  { background: linear-gradient(135deg, #7c3aed, #4f46e5); color: #fff; border: none; }
.ai-act-btn.primary:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(124,58,237,0.45); }
.ai-act-btn.outline  { background: transparent; color: rgba(255,255,255,0.55); border: 1.5px solid rgba(255,255,255,0.14); }
.ai-act-btn.outline:hover:not(:disabled) { background: rgba(255,255,255,0.06); color: #fff; border-color: rgba(255,255,255,0.3); }
.ai-act-btn.success  { background: transparent; color: #6ee7b7; border: 1.5px solid rgba(16,185,129,0.28); }
.ai-act-btn.success:hover:not(:disabled) { background: rgba(16,185,129,0.1); }
.ai-act-btn.copied, .ai-act-btn.inserted { background: rgba(16,185,129,0.18); color: #6ee7b7; border: 1.5px solid rgba(16,185,129,0.38); }
.ai-draft-error { padding: 8px 12px; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.22); border-radius: 8px; color: #fca5a5; font-size: 0.77rem; display: none; }
/* Compatibilité ancien système de tabs */
.ai-draft-tabs { display: none; }
.ai-draft-tone-label { display: none; }

/* Points forts / Points faibles */
.ai-reasons-section { padding: 0 28px 22px; border-bottom: 1px solid rgba(255,255,255,0.05); }
.ai-pf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
@media (max-width: 620px) { .ai-pf-grid { grid-template-columns: 1fr; } }
.ai-pf-title { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 10px; display: flex; align-items: center; gap: 6px; font-family: 'Josefin Sans', sans-serif; }
.ai-pf-title.strengths { color: rgba(110,231,183,0.85); }
.ai-pf-title.weaknesses { color: rgba(252,196,77,0.85); }
.ai-pf-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
.ai-pf-item { padding: 8px 11px; border-radius: 8px; font-size: 0.79rem; line-height: 1.5; display: flex; gap: 9px; align-items: flex-start; }
.ai-pf-item.strength  { background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.18); color: rgba(255,255,255,0.65); }
.ai-pf-item.weakness  { background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.18); color: rgba(255,255,255,0.65); }
.ai-pf-icon { flex-shrink: 0; margin-top: 1px; font-size: 0.7rem; }
.ai-pf-item.strength .ai-pf-icon { color: #6ee7b7; }
.ai-pf-item.weakness .ai-pf-icon { color: #fcd34d; }
.ai-pf-empty { font-size: 0.78rem; color: rgba(255,255,255,0.28); font-style: italic; padding: 6px 0; }

/* Fallback notice */
.ai-fallback-notice { margin: 12px 28px 0; padding: 8px 14px; background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2); border-radius: 8px; font-size: 0.74rem; color: rgba(253,211,77,0.7); display: flex; align-items: center; gap: 7px; }

/* ── Startup Coach Panel ──────────────────────────────────── */
.coach-panel { background: linear-gradient(160deg, #0a1628 0%, #0e1f38 50%, #081020 100%); border-radius: 20px; border: 1.5px solid rgba(56,189,248,0.3); box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(56,189,248,0.1); overflow: hidden; animation: aiPanelIn 0.4s ease; }
.coach-panel-header { padding: 22px 28px; border-bottom: 1px solid rgba(56,189,248,0.15); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
.coach-panel-title { font-size: 1rem; font-weight: 800; color: #e0f2fe; font-family: 'Josefin Sans', sans-serif; display: flex; align-items: center; gap: 10px; }
.coach-summary-section { padding: 22px 28px; border-bottom: 1px solid rgba(255,255,255,0.05); }
.coach-summary-text { font-size: 0.87rem; color: rgba(224,242,254,0.82); line-height: 1.7; border-left: 3px solid rgba(56,189,248,0.5); padding-left: 14px; }
.coach-grid { padding: 24px 28px; border-bottom: 1px solid rgba(255,255,255,0.05); display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
@media (max-width: 640px) { .coach-grid { grid-template-columns: 1fr; } }
.coach-block-title { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; font-family: 'Josefin Sans', sans-serif; margin: 0 0 12px; display: flex; align-items: center; gap: 7px; }
.coach-block-title.hesitations { color: rgba(252,165,165,0.85); }
.coach-block-title.weaknesses  { color: rgba(253,211,77,0.85); }
.coach-block-title.suggestions { color: rgba(110,231,183,0.85); }
.coach-block-title.tips        { color: rgba(167,139,250,0.85); }
.coach-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 7px; }
.coach-list li { padding: 9px 12px; border-radius: 8px; font-size: 0.8rem; line-height: 1.5; display: flex; gap: 9px; align-items: flex-start; color: rgba(255,255,255,0.7); }
.coach-list li.hesitation { background: rgba(239,68,68,0.06);  border: 1px solid rgba(239,68,68,0.18); }
.coach-list li.weakness   { background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.18); }
.coach-list li.suggestion { background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.18); }
.coach-list li.tip        { background: rgba(139,92,246,0.06); border: 1px solid rgba(139,92,246,0.18); }
.coach-list-icon { flex-shrink: 0; margin-top: 1px; font-size: 0.7rem; }
.coach-list li.hesitation .coach-list-icon { color: #fca5a5; }
.coach-list li.weakness   .coach-list-icon { color: #fcd34d; }
.coach-list li.suggestion .coach-list-icon { color: #6ee7b7; }
.coach-list li.tip        .coach-list-icon { color: #c4b5fd; }
.coach-msg-section { padding: 22px 28px; border-bottom: 1px solid rgba(255,255,255,0.05); }
.coach-msg-area { width: 100%; box-sizing: border-box; background: rgba(56,189,248,0.04); border: 1.5px solid rgba(56,189,248,0.22); border-radius: 10px; color: rgba(224,242,254,0.88); font-size: 0.83rem; padding: 14px 16px; resize: vertical; min-height: 130px; line-height: 1.65; font-family: inherit; transition: border-color 0.2s; }
.coach-msg-area:focus { outline: none; border-color: rgba(56,189,248,0.5); }
.coach-actions-section { padding: 22px 28px; }
.coach-steps-list { list-style: none; margin: 0; padding: 0; }
.coach-steps-list li { display: flex; gap: 10px; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.82rem; color: rgba(255,255,255,0.65); line-height: 1.45; }
.coach-steps-list li:last-child { border-bottom: none; }
.coach-step-num { flex-shrink: 0; width: 24px; height: 24px; border-radius: 50%; background: rgba(56,189,248,0.18); color: #7dd3fc; font-size: 0.72rem; font-weight: 700; display: flex; align-items: center; justify-content: center; margin-top: 1px; }

@media (max-width: 768px) { .neg-body { grid-template-columns: 1fr; } }
{% endblock %}

{% block content %}
<div class="neg-header">
  <div style="max-width:900px;margin:0 auto;">
    {% if is_investor %}
      <a href="{{ path('app_front_investissement_index') }}" class="back-link">
        <i class="fa fa-arrow-left"></i> Mes investissements
      </a>
    {% else %}
      <a href="{{ path('app_front_projet_show', {id: negociation.project.project_id}) }}" class="back-link">
        <i class="fa fa-arrow-left"></i> Mon projet
      </a>
    {% endif %}
    <h1><i class="fa fa-comments" style="color:var(--primary);margin-right:0.5rem;"></i>Négociation</h1>
    <p>{{ negociation.project.title }}</p>
  </div>
</div>

<div class="neg-body">

  {# ── Chat principal ────────────────────────────────── #}
  <div>
    {% for type, msgs in app.flashes %}
      {% for msg in msgs %}
        <div style="padding:10px 16px;border-radius:8px;margin-bottom:1rem;background:{{ type == 'success' ? 'rgba(16,185,129,0.1)' : (type == 'warning' ? 'rgba(245,158,11,0.1)' : 'rgba(239,68,68,0.1)') }};color:{{ type == 'success' ? '#065f46' : (type == 'warning' ? '#92400e' : '#991b1b') }};border:1px solid currentColor;">{{ msg }}</div>
      {% endfor %}
    {% endfor %}

    <div class="chat-card">
      <div class="chat-header">
        <h3><i class="fa fa-comments" style="color:var(--primary);margin-right:6px;"></i>Échanges</h3>
        <span class="neg-status {{ negociation.status }}">
          {% if negociation.status == 'open' %}<i class="fa fa-circle"></i> En cours
          {% elseif negociation.status == 'accepted' %}<i class="fa fa-check-circle"></i> Acceptée
          {% elseif negociation.status == 'rejected' %}<i class="fa fa-times-circle"></i> Refusée
          {% else %}{{ negociation.status }}{% endif %}
        </span>
      </div>

      <div class="chat-messages" id="chatMessages">
        {% for msg in messages %}
          {# my_id est l'entier pur passé par le contrôleur — évite les proxies Doctrine #}
          {% set senderId = msg.user ? msg.user.userId : null %}
          {% set isMine   = senderId is not null and senderId == my_id %}
          {% set isSystem = msg.message_type in ['system', 'ai_suggestion'] %}
          <div class="msg-row {{ isSystem ? 'system' : (isMine ? 'mine' : 'other') }}">
            {% if not isSystem %}
              <div class="msg-avatar">
                {% if isMine %}
                  <i class="fa fa-user" style="font-size:0.8rem;"></i>
                {% else %}
                  {{ msg.user ? msg.user.fullName|slice(0,1)|upper : '?' }}
                {% endif %}
              </div>
            {% endif %}
            <div>
              <div class="msg-bubble">
                {{ msg.message }}
                {% if msg.proposed_amount and msg.message_type == 'offer' %}
                  <div class="msg-offer"><i class="fa fa-coins"></i> Proposition : {{ msg.proposed_amount|number_format(0, ',', ' ') }} TND</div>
                {% endif %}
              </div>
              {% if not isSystem %}
                <div class="msg-meta" style="{{ isMine ? 'text-align:right' : 'text-align:left' }}">
                  {% if isMine %}
                    Vous
                  {% else %}
                    {{ msg.user ? msg.user.fullName : (is_investor ? negociation.startup.fullName : negociation.investor.fullName) }}
                  {% endif %}
                  · {{ msg.created_at ? msg.created_at|date('d/m H:i') : '' }}
                </div>
              {% endif %}
            </div>
          </div>
        {% else %}
          <div style="text-align:center;color:var(--text-muted);padding:2rem;font-size:0.88rem;">
            <i class="fa fa-comments" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:0.5rem;"></i>
            Aucun message pour l'instant. Commencez la discussion !
          </div>
        {% endfor %}
      </div>

      {# Formulaire de message #}
      {% if negociation.status == 'open' %}
        <div class="chat-compose">
          <form method="post" action="{{ path('app_negociation_message', {id: negociation.negotiation_id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('msg_' ~ negociation.negotiation_id) }}">
            <div class="compose-row">
              <textarea name="message" class="compose-input" rows="2" placeholder="Votre message…" required></textarea>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
              <input type="number" name="proposed_amount" class="compose-amount" placeholder="Montant (TND)" min="1" step="0.01">
              <button type="submit" class="compose-send"><i class="fa fa-paper-plane"></i> Envoyer</button>
            </div>
          </form>
        </div>
      {% else %}
        <div style="padding:16px 20px;background:#fafafa;border-top:1px solid var(--border);text-align:center;color:var(--text-muted);font-size:0.85rem;">
          <i class="fa fa-lock"></i> Négociation clôturée
        </div>
      {% endif %}
    </div>
  </div>

  {# ── Sidebar ───────────────────────────────────────── #}
  <div class="neg-sidebar">

    {# Infos du projet #}
    <div class="info-card">
      <h4><i class="fa fa-folder-open"></i> Projet</h4>
      <div style="font-weight:700;color:var(--dark);margin-bottom:10px;">{{ negociation.project.title }}</div>
      <div class="info-row"><span class="info-label">Secteur</span><span class="info-value">{{ negociation.project.secteur ? negociation.project.secteur|capitalize : '—' }}</span></div>
      <div class="info-row"><span class="info-label">Budget</span><span class="info-value">{{ negociation.project.requiredBudget|number_format(0,',',' ') }} TND</span></div>
      <div class="info-row"><span class="info-label">Montant proposé</span><span class="info-value" style="color:var(--primary);">{{ negociation.proposed_amount|number_format(0,',',' ') }} TND</span></div>
      {% if negociation.final_amount %}
        <div class="info-row"><span class="info-label">Montant final</span><span class="info-value" style="color:#10b981;">{{ negociation.final_amount|number_format(0,',',' ') }} TND</span></div>
      {% endif %}
      <div class="info-row"><span class="info-label">Startup</span><span class="info-value">{{ negociation.startup.fullName }}</span></div>
      <div class="info-row"><span class="info-label">Investisseur</span><span class="info-value">{{ negociation.investor.fullName }}</span></div>
    </div>

    {# Actions #}
    <div class="info-card">
      <h4><i class="fa fa-bolt"></i> Actions</h4>

      {% if deal %}
        {# Un deal existe déjà #}
        <a href="{{ path('app_deal_show', {id: deal.deal_id}) }}" class="action-btn deal">
          <i class="fa fa-arrow-right"></i> Voir le Deal
        </a>
      {% elseif negociation.status == 'accepted' %}
        <div style="padding:10px;background:rgba(16,185,129,0.1);border-radius:8px;text-align:center;color:#065f46;font-size:0.84rem;font-weight:600;">
          <i class="fa fa-check-circle"></i> Accord validé — Deal en cours de création
        </div>
      {% elseif negociation.status == 'rejected' %}
        <div style="padding:10px;background:rgba(239,68,68,0.1);border-radius:8px;text-align:center;color:#991b1b;font-size:0.84rem;font-weight:600;">
          <i class="fa fa-times-circle"></i> Négociation refusée
        </div>
      {% elseif negociation.status == 'open' and is_startup %}
        {# Bouton Accepter #}
        <button type="button" class="action-btn accept" onclick="document.getElementById('modalAccept').classList.add('active')">
          <i class="fa fa-check"></i> Valider l'accord
        </button>
        {# Bouton Rejeter #}
        <form method="post" action="{{ path('app_negociation_rejeter', {id: negociation.negotiation_id}) }}" onsubmit="return confirm('Rejeter cette négociation ?');">
          <input type="hidden" name="_token" value="{{ csrf_token('reject_' ~ negociation.negotiation_id) }}">
          <button type="submit" class="action-btn reject">
            <i class="fa fa-times"></i> Rejeter
          </button>
        </form>
      {% elseif negociation.status == 'open' and is_investor %}
        <div style="font-size:0.82rem;color:var(--text-muted);text-align:center;">
          <i class="fa fa-clock"></i> En attente de réponse de la startup
        </div>
      {% endif %}
    </div>

    {# ── Analyse IA ──────────────────────────────────────── #}
    <div class="ai-trigger" id="aiTrigger">
      <h4>✦ {% if is_investor %}Analyse IA{% else %}Coach IA{% endif %}</h4>
      {% if is_investor %}
        <p class="ai-trigger-desc">Score, recommandation, plan d'action et brouillon — analyse décisionnelle en un clic.</p>
      {% else %}
        <p class="ai-trigger-desc">Pourquoi l'investisseur hésite, comment améliorer votre offre, message recommandé — votre coach en un clic.</p>
      {% endif %}
      <button class="ai-btn" id="aiAnalyseBtn" type="button">
        <span id="aiBtnText"><i class="fa fa-magic"></i> {% if is_investor %}Analyser avec l'IA{% else %}Obtenir des conseils IA{% endif %}</span>
        <span id="aiBtnLoader" style="display:none;"><i class="fa fa-spinner fa-spin"></i> {% if is_investor %}Analyse…{% else %}Coaching…{% endif %}</span>
      </button>
      <div id="aiLastTime" class="ai-last-time"></div>
      <div id="aiError" style="display:none;margin-top:10px;padding:10px 12px;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);border-radius:8px;color:#fca5a5;font-size:0.8rem;line-height:1.5;"></div>
      <form id="aiForm" style="display:none;" method="post"
            action="{{ path('app_negociation_analyser', {id: negociation.negotiation_id}) }}">
        <input type="hidden" name="_token" id="aiToken"
               value="{{ csrf_token('ai_analyse_' ~ negociation.negotiation_id) }}">
      </form>
    </div>

  </div>
</div>

{# ── AI Results Panel (full-width) ────────────────────── #}
<div class="ai-panel-wrap" id="aiPanelWrap" style="display:none;">
  <div class="ai-panel" id="aiPanel">

    <div class="ai-panel-header">
      <div class="ai-panel-title">
        <i class="fa fa-robot" style="color:#a78bfa;"></i>
        Analyse IA — Négociation
      </div>
      <div class="ai-panel-meta">
        <span class="ai-src-badge" id="aiSrcBadge">—</span>
        <span style="font-size:0.72rem;color:rgba(255,255,255,0.25);" id="aiPanelTime"></span>
        <button class="ai-close-btn" id="aiCloseBtn" title="Fermer">✕</button>
      </div>
    </div>

    {# Score + recommandation #}
    <div class="ai-score-section">
      <div class="ai-score-ring-wrap">
        <svg width="96" height="96" viewBox="0 0 96 96">
          <circle class="ai-score-ring-bg" cx="48" cy="48" r="40"/>
          <circle class="ai-score-ring-val" id="aiRingVal" cx="48" cy="48" r="40"
                  stroke="#7c3aed"
                  stroke-dasharray="251.33"
                  stroke-dashoffset="251.33"/>
        </svg>
        <div class="ai-score-ring-text">
          <span class="ai-score-num" id="aiScoreNum">—</span>
          <span class="ai-score-lbl">/ 100</span>
        </div>
      </div>
      <div class="ai-score-info">
        <div id="aiRecBadge" class="ai-rec-badge invest">—</div>
        <div style="font-size:0.8rem;color:rgba(255,255,255,0.45);margin-bottom:8px;" id="aiRiskText">—</div>
        <div class="ai-smart-badges" id="aiSmartBadges"></div>
      </div>
    </div>

    {# Sous-scores + Radar #}
    <div class="ai-analysis-grid">
      <div>
        <div class="ai-sub-label">Critères détaillés</div>
        <div class="ai-criterion">
          <div class="ai-crit-header">
            <span class="ai-crit-name">Rentabilité</span>
            <span class="ai-crit-score" id="sc-rentabilite">—</span>
          </div>
          <div class="ai-crit-bar"><div class="ai-crit-fill" id="sf-rentabilite"></div></div>
        </div>
        <div class="ai-criterion">
          <div class="ai-crit-header">
            <span class="ai-crit-name">Risque maîtrisé</span>
            <span class="ai-crit-score" id="sc-risque">—</span>
          </div>
          <div class="ai-crit-bar"><div class="ai-crit-fill" id="sf-risque"></div></div>
        </div>
        <div class="ai-criterion">
          <div class="ai-crit-header">
            <span class="ai-crit-name">Qualité négociation</span>
            <span class="ai-crit-score" id="sc-negociation">—</span>
          </div>
          <div class="ai-crit-bar"><div class="ai-crit-fill" id="sf-negociation"></div></div>
        </div>
        <div class="ai-criterion">
          <div class="ai-crit-header">
            <span class="ai-crit-name">Potentiel projet</span>
            <span class="ai-crit-score" id="sc-potentiel">—</span>
          </div>
          <div class="ai-crit-bar"><div class="ai-crit-fill" id="sf-potentiel"></div></div>
        </div>
        <div class="ai-criterion">
          <div class="ai-crit-header">
            <span class="ai-crit-name">Cohérence budget</span>
            <span class="ai-crit-score" id="sc-coherence">—</span>
          </div>
          <div class="ai-crit-bar"><div class="ai-crit-fill" id="sf-coherence"></div></div>
        </div>
      </div>
      <div class="ai-chart-wrap">
        <canvas id="aiRadarChart" width="200" height="200"></canvas>
        <div class="ai-chart-lbl">Radar des performances</div>
      </div>
    </div>

    {# Résumé intelligent #}
    <div class="ai-resume-section">
      <div class="ai-section-title"><i class="fa fa-align-left"></i> Résumé intelligent</div>
      <p class="ai-resume-text" id="aiResumeText">—</p>
    </div>

    {# Points forts / Points faibles #}
    <div class="ai-reasons-section">
      <div class="ai-pf-grid">
        <div>
          <div class="ai-pf-title strengths">
            <i class="fa fa-check-circle"></i> Points forts
          </div>
          <ul class="ai-pf-list" id="aiStrengthsList">
            <li class="ai-pf-empty">—</li>
          </ul>
        </div>
        <div>
          <div class="ai-pf-title weaknesses">
            <i class="fa fa-exclamation-triangle"></i> Points à surveiller
          </div>
          <ul class="ai-pf-list" id="aiWeaknessesList">
            <li class="ai-pf-empty">—</li>
          </ul>
        </div>
      </div>
    </div>

    {# Plan d'action + Brouillon #}
    <div class="ai-bottom-grid">
      <div>
        <div class="ai-section-title"><i class="fa fa-tasks"></i> Plan d'action recommandé</div>
        <ol class="ai-plan-list" id="aiPlanList"></ol>
      </div>
      <div>
        <div class="ai-section-title"><i class="fa fa-edit"></i> Brouillon de réponse</div>

        {# Carte brouillon interactive #}
        <div class="ai-draft-card" id="aiDraftCard">

          {# Sélecteur de style #}
          <div class="ai-draft-styles" id="aiDraftStyles">
            <button class="ai-style-btn active" data-style="professionnel" title="Formel, style investisseur institutionnel">
              <i class="fa fa-briefcase"></i> Professionnel
            </button>
            <button class="ai-style-btn" data-style="diplomatique" title="Ouvert, bienveillant, style partenariat">
              <i class="fa fa-handshake"></i> Diplomatique
            </button>
            <button class="ai-style-btn" data-style="direct" title="Court et factuel, sans fioritures">
              <i class="fa fa-bolt"></i> Direct
            </button>
            <button class="ai-style-btn" data-style="persuasif" title="Enthousiaste et convaincant">
              <i class="fa fa-star"></i> Persuasif
            </button>
          </div>

          {# Zone de texte avec spinner de chargement #}
          <div class="ai-draft-area-wrap" id="aiDraftAreaWrap">
            <textarea class="ai-draft-area" id="aiDraftArea" rows="5"
                      placeholder="Le brouillon apparaîtra ici après l'analyse ou en cliquant Régénérer…"></textarea>
            <span class="ai-draft-spinner"><i class="fa fa-spinner fa-spin"></i></span>
          </div>

          {# Message d'erreur #}
          <div class="ai-draft-error" id="aiDraftError"></div>

          {# Actions #}
          <div class="ai-draft-actions">
            <button class="ai-act-btn primary" id="aiRegenBtn" title="Générer un nouveau brouillon avec le style sélectionné">
              <i class="fa fa-sync"></i> Régénérer
            </button>
            <button class="ai-act-btn outline" id="aiCopyBtn" title="Copier le texte dans le presse-papiers">
              <i class="fa fa-copy"></i> Copier
            </button>
            <button class="ai-act-btn success" id="aiInsertBtn" title="Insérer ce texte dans le champ de message">
              <i class="fa fa-arrow-down"></i> Insérer dans le chat
            </button>
            <span class="ai-draft-hint"><i class="fa fa-pencil-alt"></i> Modifiable</span>
          </div>

        </div>

        {# Token CSRF dédié au draft #}
        <input type="hidden" id="aiDraftToken"
               value="{{ csrf_token('neg_draft_' ~ negociation.negotiation_id) }}">
      </div>
    </div>

    {# Notice fallback #}
    <div class="ai-fallback-notice" id="aiFallbackNotice" style="display:none;">
      <i class="fa fa-info-circle"></i>
      <span id="aiFallbackText">Analyse locale — résultat basé sur les données de la négociation sans API externe.</span>
    </div>
    <div style="height:8px;"></div>

  </div>
</div>

{# ── Coach IA Panel (startup) ─────────────────────────── #}
<div class="ai-panel-wrap" id="coachPanelWrap" style="display:none;">
  <div class="coach-panel" id="coachPanel">

    <div class="coach-panel-header">
      <div class="coach-panel-title">
        <i class="fa fa-graduation-cap" style="color:#7dd3fc;"></i>
        Coach IA — Améliorer votre position
      </div>
      <div class="ai-panel-meta">
        <span class="ai-src-badge" id="coachSrcBadge">—</span>
        <span style="font-size:0.72rem;color:rgba(255,255,255,0.25);" id="coachPanelTime"></span>
        <button class="ai-close-btn" id="coachCloseBtn" title="Fermer">✕</button>
      </div>
    </div>

    {# Résumé du coach #}
    <div class="coach-summary-section">
      <div class="ai-section-title" style="color:rgba(125,211,252,0.75);"><i class="fa fa-comment-dots"></i> Message du coach</div>
      <p class="coach-summary-text" id="coachSummaryText">—</p>
    </div>

    {# Grille : Hésitations + Points faibles #}
    <div class="coach-grid">
      <div>
        <div class="coach-block-title hesitations">
          <i class="fa fa-question-circle"></i> Pourquoi l'investisseur hésite
        </div>
        <ul class="coach-list" id="coachHesitationsList"></ul>
      </div>
      <div>
        <div class="coach-block-title weaknesses">
          <i class="fa fa-exclamation-triangle"></i> Points faibles identifiés
        </div>
        <ul class="coach-list" id="coachWeakPointsList"></ul>
      </div>
    </div>

    {# Grille : Suggestions + Conseils d'amélioration #}
    <div class="coach-grid" style="border-top:1px solid rgba(255,255,255,0.05);">
      <div>
        <div class="coach-block-title suggestions">
          <i class="fa fa-lightbulb"></i> Suggestions concrètes
        </div>
        <ul class="coach-list" id="coachSuggestionsList"></ul>
      </div>
      <div>
        <div class="coach-block-title tips">
          <i class="fa fa-rocket"></i> Améliorer votre offre
        </div>
        <ul class="coach-list" id="coachTipsList"></ul>
      </div>
    </div>

    {# Message recommandé #}
    <div class="coach-msg-section">
      <div class="ai-section-title" style="color:rgba(125,211,252,0.75);margin-bottom:10px;"><i class="fa fa-envelope"></i> Message recommandé à envoyer</div>
      <textarea class="coach-msg-area" id="coachMsgArea" rows="6"></textarea>
      <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;">
        <button class="ai-act-btn primary" id="coachCopyMsgBtn">
          <i class="fa fa-copy"></i> Copier
        </button>
        <button class="ai-act-btn success" id="coachInsertMsgBtn">
          <i class="fa fa-arrow-down"></i> Insérer dans le chat
        </button>
        <span class="ai-draft-hint"><i class="fa fa-pencil-alt"></i> Modifiable avant envoi</span>
      </div>
    </div>

    {# Prochaines actions #}
    <div class="coach-actions-section">
      <div class="ai-section-title" style="color:rgba(125,211,252,0.75);"><i class="fa fa-tasks"></i> Prochaines actions prioritaires</div>
      <ol class="coach-steps-list" id="coachStepsList"></ol>
    </div>

    {# Fallback notice #}
    <div class="ai-fallback-notice" id="coachFallbackNotice" style="display:none;">
      <i class="fa fa-info-circle"></i>
      <span id="coachFallbackText">Coaching local — résultat basé sur les données de la négociation sans API externe.</span>
    </div>
    <div style="height:8px;"></div>

  </div>
</div>

{# ── Modal : Validation de l'accord ───────────────────── #}
{% if is_startup and negociation.status == 'open' %}
<div class="modal-overlay" id="modalAccept">
  <div class="modal-box">
    <h3><i class="fa fa-check-circle" style="color:#10b981;margin-right:6px;"></i>Valider l'accord</h3>
    <p style="font-size:0.87rem;color:var(--text-muted);margin-bottom:16px;">
      Confirmez le montant final convenu. Cela créera automatiquement un <strong>Deal</strong> et débloquera l'étape de paiement.
    </p>
    <form method="post" action="{{ path('app_negociation_accepter', {id: negociation.negotiation_id}) }}">
      <input type="hidden" name="_token" value="{{ csrf_token('accept_' ~ negociation.negotiation_id) }}">
      <label style="font-size:0.82rem;font-weight:600;color:var(--dark);display:block;margin-bottom:6px;">Montant final (TND)</label>
      <input type="number" name="final_amount" value="{{ negociation.proposed_amount }}" min="1" step="0.01" required>
      <div class="modal-actions">
        <button type="button" onclick="document.getElementById('modalAccept').classList.remove('active')" style="padding:9px 18px;border-radius:8px;border:1px solid var(--border);background:transparent;cursor:pointer;">Annuler</button>
        <button type="submit" style="padding:9px 18px;border-radius:8px;border:none;background:#10b981;color:#fff;font-weight:700;cursor:pointer;"><i class="fa fa-check"></i> Confirmer</button>
      </div>
    </form>
  </div>
</div>
{% endif %}

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
(function () {
  'use strict';

  // ── Auto-scroll chat ────────────────────────────────────────────────────
  var chat = document.getElementById('chatMessages');
  if (chat) { chat.scrollTop = chat.scrollHeight; }

  // Close modal on overlay click
  document.querySelectorAll('.modal-overlay').forEach(function (el) {
    el.addEventListener('click', function (e) {
      if (e.target === el) { el.classList.remove('active'); }
    });
  });

  // ── AI Panel ─────────────────────────────────────────────────────────────
  var NEG_ID       = {{ negociation.negotiation_id }};
  var STORAGE_KEY  = 'bizhub_ai_' + NEG_ID;
  var CIRCUMFERENCE = 251.33; // 2π × r40

  var btn         = document.getElementById('aiAnalyseBtn');
  var btnText     = document.getElementById('aiBtnText');
  var btnLoader   = document.getElementById('aiBtnLoader');
  var errBox      = document.getElementById('aiError');
  var form        = document.getElementById('aiForm');
  var token       = document.getElementById('aiToken');
  var panelWrap   = document.getElementById('aiPanelWrap');
  var closeBtn    = document.getElementById('aiCloseBtn');
  var regenBtn    = document.getElementById('aiRegenBtn');
  var copyBtn     = document.getElementById('aiCopyBtn');
  var insertBtn   = document.getElementById('aiInsertBtn');
  var lastTimeEl  = document.getElementById('aiLastTime');

  var currentDrafts  = { professionnel: '', diplomatique: '', direct: '', persuasif: '' };
  var currentStyle   = 'professionnel';
  var radarChart     = null;
  var draftToken     = document.getElementById('aiDraftToken');
  var draftAreaWrap  = document.getElementById('aiDraftAreaWrap');
  var draftError     = document.getElementById('aiDraftError');
  var DRAFT_URL      = '{{ path('app_negociation_draft', {id: negociation.negotiation_id}) }}';

  if (!btn || !form) return;

  // ── Helpers ──────────────────────────────────────────────────────────────
  function setLoading(on) {
    btn.disabled              = on;
    btnText.style.display     = on ? 'none'   : 'inline';
    btnLoader.style.display   = on ? 'inline' : 'none';
    if (regenBtn) regenBtn.disabled = on;
  }

  function showError(msg) {
    errBox.innerHTML     = '<i class="fa fa-exclamation-triangle"></i> ' + msg;
    errBox.style.display = 'block';
  }

  function hideError() {
    errBox.style.display = 'none';
  }

  function fillScore(score) {
    document.getElementById('aiScoreNum').textContent = score;
    var ring   = document.getElementById('aiRingVal');
    var offset = CIRCUMFERENCE * (1 - score / 100);
    var color  = score >= 70 ? '#10b981' : (score >= 45 ? '#f59e0b' : '#ef4444');
    ring.style.stroke = color;
    setTimeout(function () { ring.style.strokeDashoffset = offset; }, 80);
  }

  function fillSubScore(key, val) {
    var scoreEl = document.getElementById('sc-' + key);
    var fillEl  = document.getElementById('sf-' + key);
    if (!scoreEl || !fillEl) return;
    scoreEl.textContent = val;
    var cls = val >= 70 ? 'fill-high' : (val >= 45 ? 'fill-mid' : 'fill-low');
    fillEl.className = 'ai-crit-fill ' + cls;
    setTimeout(function () { fillEl.style.width = val + '%'; }, 100);
  }

  function buildRadar(ss) {
    var ctx = document.getElementById('aiRadarChart');
    if (!ctx) return;
    if (radarChart) { radarChart.destroy(); }
    radarChart = new Chart(ctx.getContext('2d'), {
      type: 'radar',
      data: {
        labels: ['Rentabilité', 'Risque', 'Négociation', 'Potentiel', 'Budget'],
        datasets: [{
          data: [
            ss.rentabilite         || 0,
            ss.risque_maitrise     || 0,
            ss.qualite_negociation || 0,
            ss.potentiel_projet    || 0,
            ss.coherence_budget    || 0
          ],
          backgroundColor: 'rgba(124,58,237,0.18)',
          borderColor:     'rgba(167,139,250,0.8)',
          borderWidth:     2,
          pointBackgroundColor: '#a78bfa',
          pointRadius:     3
        }]
      },
      options: {
        responsive: false,
        scales: {
          r: {
            min: 0, max: 100,
            ticks:       { display: false, stepSize: 25 },
            grid:        { color: 'rgba(255,255,255,0.06)' },
            pointLabels: { color: 'rgba(255,255,255,0.45)', font: { size: 9 } },
            angleLines:  { color: 'rgba(255,255,255,0.06)' }
          }
        },
        plugins: { legend: { display: false } }
      }
    });
  }

  function setActiveDraft(style) {
    currentStyle = style;
    // Mettre à jour les boutons de style
    document.querySelectorAll('.ai-style-btn').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.style === style);
    });
    var area = document.getElementById('aiDraftArea');
    if (area) { area.value = currentDrafts[style] || ''; }
    // Masquer l'erreur draft si elle était visible
    if (draftError) { draftError.style.display = 'none'; }
  }

  function setDraftLoading(on) {
    if (draftAreaWrap) { draftAreaWrap.classList.toggle('busy', on); }
    var area = document.getElementById('aiDraftArea');
    if (area) { area.classList.toggle('refreshing', on); area.disabled = on; }
    document.querySelectorAll('.ai-style-btn').forEach(function (b) { b.classList.toggle('loading', on); });
    if (regenBtn) { regenBtn.disabled = on; }
  }

  function showDraftError(msg) {
    if (!draftError) return;
    draftError.innerHTML = '<i class="fa fa-exclamation-triangle"></i> ' + msg;
    draftError.style.display = 'block';
  }

  function fetchDraft(style) {
    if (!draftToken) { return; }
    setDraftLoading(true);
    if (draftError) { draftError.style.display = 'none'; }

    var body = new FormData();
    body.append('_token', draftToken.value);
    body.append('style', style);

    fetch(DRAFT_URL, { method: 'POST', body: body })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        setDraftLoading(false);
        if (data.error) { showDraftError(data.error); return; }
        if (data.draft) {
          currentDrafts[style] = data.draft;
          // Animation de remplacement
          var area = document.getElementById('aiDraftArea');
          if (area) {
            area.style.transition = 'opacity 0.15s';
            area.style.opacity    = '0.2';
            setTimeout(function () {
              area.value       = data.draft;
              area.style.opacity = '1';
            }, 150);
          }
        }
      })
      .catch(function () {
        setDraftLoading(false);
        showDraftError('Erreur réseau. Vérifiez votre connexion et réessayez.');
      });
  }

  function saveHistory(d) {
    try {
      var history = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      history.unshift({ ts: Date.now(), data: d });
      if (history.length > 3) { history.length = 3; }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(history));
    } catch (e) {}
  }

  function loadLastTimestamp() {
    try {
      var history = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      if (history.length > 0 && lastTimeEl) {
        var ts      = new Date(history[0].ts);
        var timeStr = ts.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
        lastTimeEl.textContent = 'Dernière analyse : ' + timeStr;
      }
    } catch (e) {}
  }

  function renderPanel(d) {
    // Source badge
    var srcBadge = document.getElementById('aiSrcBadge');
    if (d.source === 'openai') {
      srcBadge.className   = 'ai-src-badge openai';
      srcBadge.textContent = '✨ GPT-4o-mini';
    } else {
      srcBadge.className   = 'ai-src-badge local';
      srcBadge.textContent = '⚙️ Analyse locale';
    }

    // Timestamp
    var now     = new Date();
    var timeStr = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    document.getElementById('aiPanelTime').textContent = timeStr;
    if (lastTimeEl) { lastTimeEl.textContent = 'Dernière analyse : ' + timeStr; }

    // Score ring
    fillScore(d.score || 0);

    // Recommendation badge
    var recBadge = document.getElementById('aiRecBadge');
    var rec      = (d.recommendation || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    var recIcon  = rec === 'investir' ? '✅' : (rec === 'negocier' ? '⚖️' : '❌');
    var recClass = rec === 'investir' ? 'invest' : (rec === 'negocier' ? 'negocie' : 'decline');
    recBadge.className = 'ai-rec-badge ' + recClass;
    recBadge.innerHTML = recIcon + ' ' + (d.recommendation || '—');

    // Risk
    var risk     = (d.risk_level || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    var riskIcon = risk === 'faible' ? '🟢' : (risk === 'eleve' ? '🔴' : '🟡');
    document.getElementById('aiRiskText').textContent = riskIcon + ' Risque : ' + (d.risk_level || '—');

    // Smart badges
    var badgesEl = document.getElementById('aiSmartBadges');
    badgesEl.innerHTML = '';
    (d.badges || []).slice(0, 3).forEach(function (b) {
      var span = document.createElement('span');
      span.className   = 'ai-smart-badge';
      span.textContent = b;
      badgesEl.appendChild(span);
    });

    // Sub-scores (staggered)
    var ss = d.sub_scores || {};
    [
      ['rentabilite', ss.rentabilite         || 0],
      ['risque',      ss.risque_maitrise     || 0],
      ['negociation', ss.qualite_negociation || 0],
      ['potentiel',   ss.potentiel_projet    || 0],
      ['coherence',   ss.coherence_budget    || 0]
    ].forEach(function (pair, i) {
      setTimeout(function () { fillSubScore(pair[0], pair[1]); }, 120 + i * 80);
    });

    // Radar chart
    buildRadar(ss);

    // Résumé
    document.getElementById('aiResumeText').textContent = d.resume || '—';

    // Points forts
    var strengthsList = document.getElementById('aiStrengthsList');
    strengthsList.innerHTML = '';
    var sts = d.strengths || [];
    if (sts.length === 0) {
      strengthsList.innerHTML = '<li class="ai-pf-empty">Aucun point fort identifié.</li>';
    } else {
      sts.forEach(function (s) {
        var li = document.createElement('li');
        li.className = 'ai-pf-item strength';
        li.innerHTML = '<span class="ai-pf-icon"><i class="fa fa-check"></i></span><span>' + s + '</span>';
        strengthsList.appendChild(li);
      });
    }

    // Points à surveiller
    var weaknessesList = document.getElementById('aiWeaknessesList');
    weaknessesList.innerHTML = '';
    var wks = d.weaknesses || [];
    if (wks.length === 0) {
      weaknessesList.innerHTML = '<li class="ai-pf-empty">Aucun point à surveiller identifié.</li>';
    } else {
      wks.forEach(function (w) {
        var li = document.createElement('li');
        li.className = 'ai-pf-item weakness';
        li.innerHTML = '<span class="ai-pf-icon"><i class="fa fa-exclamation-triangle"></i></span><span>' + w + '</span>';
        weaknessesList.appendChild(li);
      });
    }

    // Action plan
    var planList = document.getElementById('aiPlanList');
    planList.innerHTML = '';
    (d.action_plan || []).forEach(function (step, i) {
      var li = document.createElement('li');
      li.innerHTML = '<span class="ai-plan-num">' + (i + 1) + '</span>' + step;
      planList.appendChild(li);
    });

    // Drafts — charger les 4 variantes pré-générées par l'analyse
    currentDrafts = {
      professionnel: d.draft_pro        || '',
      diplomatique:  d.draft_diplomatic || '',
      direct:        d.draft_direct     || '',
      persuasif:     d.draft_persuasif  || ''
    };
    setActiveDraft('professionnel');

    // Fallback notice
    var fallback = document.getElementById('aiFallbackNotice');
    if (d.source !== 'openai' && d.fallback_reason) {
      document.getElementById('aiFallbackText').textContent = d.fallback_reason;
      fallback.style.display = 'flex';
    } else {
      fallback.style.display = 'none';
    }

    // Show panel & scroll
    panelWrap.style.display = 'block';
    panelWrap.scrollIntoView({ behavior: 'smooth', block: 'start' });

    saveHistory(d);
  }

  // ── Coach panel (startup) ────────────────────────────────────────────────

  var coachPanelWrap  = document.getElementById('coachPanelWrap');
  var coachCloseBtn   = document.getElementById('coachCloseBtn');
  var coachCopyBtn    = document.getElementById('coachCopyMsgBtn');
  var coachInsertBtn  = document.getElementById('coachInsertMsgBtn');

  function renderCoachPanel(d) {
    // Source badge
    var srcBadge = document.getElementById('coachSrcBadge');
    if (srcBadge) {
      srcBadge.className   = d.source === 'openai' ? 'ai-src-badge openai' : 'ai-src-badge local';
      srcBadge.textContent = d.source === 'openai' ? '✨ GPT-4o-mini' : '⚙️ Coaching local';
    }

    // Timestamp
    var now     = new Date();
    var timeStr = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    var timeEl  = document.getElementById('coachPanelTime');
    if (timeEl) { timeEl.textContent = timeStr; }
    if (lastTimeEl) { lastTimeEl.textContent = 'Dernière analyse : ' + timeStr; }

    // Coach summary
    var summaryEl = document.getElementById('coachSummaryText');
    if (summaryEl) { summaryEl.textContent = d.coach_summary || '—'; }

    // Helper: build list
    function fillList(id, items, cssClass, iconClass) {
      var ul = document.getElementById(id);
      if (!ul) return;
      ul.innerHTML = '';
      if (!items || items.length === 0) {
        ul.innerHTML = '<li class="' + cssClass + '"><span class="coach-list-icon"><i class="fa ' + iconClass + '"></i></span><span>—</span></li>';
        return;
      }
      items.forEach(function (item) {
        var li = document.createElement('li');
        li.className = cssClass;
        li.innerHTML = '<span class="coach-list-icon"><i class="fa ' + iconClass + '"></i></span><span>' + item + '</span>';
        ul.appendChild(li);
      });
    }

    fillList('coachHesitationsList', d.hesitation_reasons, 'hesitation', 'fa-question-circle');
    fillList('coachWeakPointsList',  d.weak_points,        'weakness',   'fa-exclamation-triangle');
    fillList('coachSuggestionsList', d.suggestions,        'suggestion', 'fa-lightbulb');
    fillList('coachTipsList',        d.improvement_tips,   'tip',        'fa-rocket');

    // Recommended message
    var msgArea = document.getElementById('coachMsgArea');
    if (msgArea) { msgArea.value = d.recommended_message || ''; }

    // Action steps
    var stepsList = document.getElementById('coachStepsList');
    if (stepsList) {
      stepsList.innerHTML = '';
      (d.action_steps || []).forEach(function (step, i) {
        var li = document.createElement('li');
        li.innerHTML = '<span class="coach-step-num">' + (i + 1) + '</span>' + step;
        stepsList.appendChild(li);
      });
    }

    // Fallback notice
    var fallback = document.getElementById('coachFallbackNotice');
    if (fallback) {
      if (d.source !== 'openai' && d.fallback_reason) {
        document.getElementById('coachFallbackText').textContent = d.fallback_reason;
        fallback.style.display = 'flex';
      } else {
        fallback.style.display = 'none';
      }
    }

    // Show panel
    if (coachPanelWrap) {
      coachPanelWrap.style.display = 'block';
      coachPanelWrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    saveHistory(d);
  }

  // Coach panel close
  if (coachCloseBtn) {
    coachCloseBtn.addEventListener('click', function () {
      if (coachPanelWrap) { coachPanelWrap.style.display = 'none'; }
    });
  }

  // Coach copy message button
  if (coachCopyBtn) {
    coachCopyBtn.addEventListener('click', function () {
      var area = document.getElementById('coachMsgArea');
      if (!area || !area.value.trim()) { return; }
      var doCopy = function () {
        coachCopyBtn.className = 'ai-act-btn copied';
        coachCopyBtn.innerHTML = '<i class="fa fa-check"></i> Copié !';
        setTimeout(function () {
          coachCopyBtn.className = 'ai-act-btn primary';
          coachCopyBtn.innerHTML = '<i class="fa fa-copy"></i> Copier';
        }, 2000);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(area.value).then(doCopy).catch(function () { area.select(); document.execCommand('copy'); doCopy(); });
      } else {
        area.select(); document.execCommand('copy'); doCopy();
      }
    });
  }

  // Coach insert into chat
  if (coachInsertBtn) {
    coachInsertBtn.addEventListener('click', function () {
      var area       = document.getElementById('coachMsgArea');
      var chatInput  = document.querySelector('.compose-input');
      if (!area || !chatInput) { return; }
      chatInput.value = area.value;
      chatInput.focus();
      coachInsertBtn.className = 'ai-act-btn inserted';
      coachInsertBtn.innerHTML = '<i class="fa fa-check"></i> Inséré !';
      setTimeout(function () {
        coachInsertBtn.className = 'ai-act-btn success';
        coachInsertBtn.innerHTML = '<i class="fa fa-arrow-down"></i> Insérer dans le chat';
      }, 2000);
    });
  }

  function doAnalyse() {
    hideError();
    setLoading(true);

    var data = new FormData();
    data.append('_token', token.value);

    fetch(form.action, { method: 'POST', body: data })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        setLoading(false);
        if (d.error) { showError(d.error); return; }
        // Route to the right panel based on user_type
        if (d.user_type === 'startup') {
          if (panelWrap) { panelWrap.style.display = 'none'; }
          renderCoachPanel(d);
        } else {
          if (coachPanelWrap) { coachPanelWrap.style.display = 'none'; }
          renderPanel(d);
        }
      })
      .catch(function () {
        setLoading(false);
        showError('Erreur réseau inattendue. Veuillez réessayer.');
      });
  }

  // ── Listeners ────────────────────────────────────────────────────────────

  // Analyse complète
  btn.addEventListener('click', doAnalyse);

  // Fermer le panel
  if (closeBtn) {
    closeBtn.addEventListener('click', function () {
      panelWrap.style.display = 'none';
    });
  }

  // Boutons de style : changer de tonalité sans appel réseau
  document.querySelectorAll('.ai-style-btn').forEach(function (styleBtn) {
    styleBtn.addEventListener('click', function () {
      var style = styleBtn.dataset.style;
      setActiveDraft(style);
      // Si le texte pour ce style n'est pas encore chargé, le générer
      if (!currentDrafts[style]) {
        fetchDraft(style);
      }
    });
  });

  // Régénérer : appel dédié avec le style actif
  if (regenBtn) {
    regenBtn.addEventListener('click', function () {
      fetchDraft(currentStyle);
    });
  }

  // Copier
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var area = document.getElementById('aiDraftArea');
      if (!area || !area.value.trim()) {
        copyBtn.innerHTML = '<i class="fa fa-times"></i> Vide';
        setTimeout(function () { copyBtn.innerHTML = '<i class="fa fa-copy"></i> Copier'; }, 1200);
        return;
      }
      var doCopy = function () {
        copyBtn.className = 'ai-act-btn copied';
        copyBtn.innerHTML = '<i class="fa fa-check"></i> Copié !';
        setTimeout(function () {
          copyBtn.className = 'ai-act-btn outline';
          copyBtn.innerHTML = '<i class="fa fa-copy"></i> Copier';
        }, 2000);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(area.value).then(doCopy).catch(function () {
          area.select(); document.execCommand('copy'); doCopy();
        });
      } else {
        area.select(); document.execCommand('copy'); doCopy();
      }
    });
  }

  // Insérer dans le chat
  if (insertBtn) {
    insertBtn.addEventListener('click', function () {
      var area    = document.getElementById('aiDraftArea');
      var compose = document.querySelector('.compose-input');
      if (!area || !area.value.trim()) return;
      if (compose) {
        compose.value = area.value;
        compose.focus();
        insertBtn.className = 'ai-act-btn inserted';
        insertBtn.innerHTML = '<i class="fa fa-check"></i> Inséré !';
        setTimeout(function () {
          insertBtn.className = 'ai-act-btn success';
          insertBtn.innerHTML = '<i class="fa fa-arrow-down"></i> Insérer dans le chat';
        }, 2000);
        compose.scrollIntoView({ behavior: 'smooth', block: 'center' });
        compose.style.transition = 'box-shadow 0.3s';
        compose.style.boxShadow  = '0 0 0 3px rgba(124,58,237,0.5)';
        setTimeout(function () { compose.style.boxShadow = ''; }, 1200);
      }
    });
  }

  // Compatibilité anciens onglets (éventuels restes)
  document.querySelectorAll('.ai-tab').forEach(function (tab) {
    tab.addEventListener('click', function () { setActiveDraft(tab.dataset.draft || tab.dataset.style); });
  });

  // Charger le timestamp de la dernière analyse
  loadLastTimestamp();
})();
</script>
{% endblock %}
