{% extends 'front/base.html.twig' %}

{% block title %}Edit Profile - BizHub{% endblock %}

{% block content %}
<div style="max-width:800px;margin:0 auto;padding:40px 5%;">
    <h2 style="font-size:1.8rem;color:var(--dark);margin-bottom:0.5rem;font-family:'Lora',serif;">Edit Your Profile</h2>
    <p style="color:var(--text-muted);margin-bottom:2rem;">Update your profile information</p>

    {% for message in app.flashes('error') %}
        <div style="background:#fee;border:1px solid #fcc;color:#c33;padding:1rem;border-radius:8px;margin-bottom:1.5rem;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="biz-form">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.full_name) }}
                {{ form_widget(form.full_name) }}
                {% if form.full_name.vars.errors|length %}
                    <div style="color:#c33;font-size:0.85rem;margin-top:0.4rem;">
                        {% for error in form.full_name.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                {% if form.email.vars.errors|length %}
                    <div style="color:#c33;font-size:0.85rem;margin-top:0.4rem;">
                        {% for error in form.email.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.phone) }}
                {{ form_widget(form.phone) }}
            </div>
            <div class="form-group">
                {{ form_label(form.bio) }}
                {{ form_widget(form.bio) }}
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.avatar) }}
                {{ form_widget(form.avatar) }}
                {% if form.avatar.vars.errors|length %}
                    <div style="color:#c33;font-size:0.85rem;margin-top:0.4rem;">
                        {% for error in form.avatar.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.address) }}
            {{ form_widget(form.address) }}
            {% if form.address.vars.errors|length %}
                <div style="color:#c33;font-size:0.85rem;margin-top:0.4rem;">
                    {% for error in form.address.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div style="display:flex;gap:1rem;margin-top:2rem;flex-wrap:wrap;">
            <button type="submit" class="form-submit" style="flex:1;min-width:150px;">Save Changes</button>
            <a href="{{ path('app_user_edit_specific') }}" style="flex:1;min-width:150px;text-align:center;padding:15px 0;background:var(--primary);color:var(--dark);border:none;border-radius:8px;font-weight:600;text-decoration:none;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.background='var(--primary-dark)'" onmouseout="this.style.background='var(--primary)';">Role Fields</a>
            <a href="{{ path('app_user_profile') }}" class="btn-outline-dark" style="flex:1;min-width:150px;text-align:center;padding:15px 0;">Cancel</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
