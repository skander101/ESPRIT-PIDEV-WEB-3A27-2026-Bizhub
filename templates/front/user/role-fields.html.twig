<script>
    // Handle dynamic role-specific fields in profile edit
    const userTypeSelect = document.querySelector('[name="user_form[user_type]"]');
    const roleSection = document.getElementById('roleSection');
    const roleFields = document.querySelectorAll('.role-field');

    function updateRoleFields() {
        const selectedRole = userTypeSelect?.value;
        if (!selectedRole) {
            roleSection.style.display = 'none';
            return;
        }

        roleSection.style.display = 'block';

        roleFields.forEach(field => {
            const roles = field.dataset.role.split(',');
            if (roles.includes(selectedRole)) {
                field.style.display = 'block';
            } else {
                field.style.display = 'none';
            }
        });
    }

    if (userTypeSelect) {
        userTypeSelect.addEventListener('change', updateRoleFields);
        updateRoleFields(); // Initial state
    }
</script>
