{% extends 'front/base.html.twig' %}

{% block title %}Profile - {{ app.user.fullName }} - BizHub{% endblock %}

{% block content %}
{% set moderatedComment = '<-this review has been removed by a moderator->' %}
<div style="max-width:1100px;margin:0 auto;padding:40px 5%;">
    {% for message in app.flashes('success') %}
        <div style="background:#d4edda;border:1px solid #c3e6cb;color:#155724;padding:1rem;border-radius:8px;margin-bottom:1.5rem;">
            {{ message }}
        </div>
    {% endfor %}

    <div style="display:grid;grid-template-columns:1fr 2fr;gap:2rem;margin-bottom:3rem;">
        <div style="text-align:center;">
            {% if app.user.avatarUrl %}
                <img src="{{ app.user.avatarUrl }}" alt="{{ app.user.fullName }}" style="width:140px;height:140px;border-radius:50%;object-fit:cover;border:3px solid var(--primary);margin:0 auto 1.5rem;display:block;">
            {% else %}
                <div style="width:140px;height:140px;border-radius:50%;background:var(--light-bg);border:3px solid var(--primary);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:3rem;color:var(--primary);">
                    {{ app.user.fullName|first|upper }}
                </div>
            {% endif %}
            <h2 style="font-size:1.5rem;color:var(--dark);margin-bottom:0.5rem;">{{ app.user.fullName }}</h2>
            <div style="display:inline-block;background:rgba(255,190,51,0.13);color:var(--primary-dark);padding:4px 12px;border-radius:100px;font-size:0.75rem;font-weight:700;text-transform:capitalize;margin-bottom:1.5rem;">
                {{ app.user.userType }}
            </div>
            <div style="display:flex;flex-direction:column;gap:0.8rem;">
                <a href="{{ path('app_user_edit') }}" class="btn-yellow" style="display:block;">Edit Profile</a>
                <a href="{{ path('app_user_edit_specific') }}" style="display:block;background:var(--primary);color:var(--dark);padding:15px;border-radius:8px;text-align:center;font-weight:600;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background='var(--primary-dark)'" onmouseout="this.style.background='var(--primary)';">Edit Role-Specific Info</a>
                <a href="{{ path('app_front_index') }}" class="btn-outline-dark" style="display:block;">Back to Home</a>
            </div>
        </div>
        <div class="dash-panel">
            <h5>Profile Information</h5>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
                <div style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
                    <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.4rem;text-transform:uppercase;font-weight:700;">Email</div>
                    <div style="font-size:0.9rem;color:var(--dark);font-weight:500;">{{ app.user.email }}</div>
                </div>
                <div style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
                    <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.4rem;text-transform:uppercase;font-weight:700;">Phone</div>
                    <div style="font-size:0.9rem;color:var(--dark);font-weight:500;">{{ app.user.phone ?? 'Not provided' }}</div>
                </div>
                <div style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
                    <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.4rem;text-transform:uppercase;font-weight:700;">Company</div>
                    <div style="font-size:0.9rem;color:var(--dark);font-weight:500;">{{ app.user.companyName ?? 'Not provided' }}</div>
                </div>
                <div style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
                    <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.4rem;text-transform:uppercase;font-weight:700;">Member Since</div>
                    <div style="font-size:0.9rem;color:var(--dark);font-weight:500;">{{ app.user.createdAt|date('F d, Y') }}</div>
                </div>
                <div style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
                    <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.4rem;text-transform:uppercase;font-weight:700;">Status</div>
                    <div style="font-size:0.9rem;color:{{ app.user.isActive ? 'var(--primary)' : '#999' }};font-weight:500;">
                        {{ app.user.isActive ? 'Active' : 'Inactive' }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="dash-panel" style="margin-bottom:2rem;">
        <h5><i class="fa-solid fa-shield-halved" style="margin-right:8px;"></i>Security Settings</h5>
        <p style="color:var(--text-muted);margin-bottom:1.5rem;font-size:0.9rem;">Enable optional two-factor authentication and face login to secure your account.</p>
        
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div style="background:var(--light-bg);padding:1.25rem;border-radius:10px;border:1px solid var(--border);">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
                    <div style="display:flex;align-items:center;gap:0.75rem;">
                        <div style="width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#1166ff,#0d5ae4);display:flex;align-items:center;justify-content:center;color:white;font-size:1.1rem;">
                            <i class="fa-solid fa-mobile-screen"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;color:var(--dark);">TOTP Authenticator</div>
                            <div style="font-size:0.8rem;color:var(--text-muted);">Use authenticator app</div>
                        </div>
                    </div>
                    {% if app.user.totpSecret|default(false) %}
                        <span style="background:#d1fae5;color:#065f46;padding:4px 10px;border-radius:100px;font-size:0.75rem;font-weight:600;">Enabled</span>
                    {% endif %}
                </div>
                {% if app.user.totpSecret|default(false) %}
                    <a href="{{ path('app_2fa_setup') }}" style="display:inline-block;padding:8px 16px;background:var(--primary);color:var(--dark);text-decoration:none;border-radius:6px;font-size:0.85rem;font-weight:600;">Manage</a>
                {% else %}
                    <a href="{{ path('app_2fa_setup') }}" style="display:inline-block;padding:8px 16px;background:var(--dark);color:white;text-decoration:none;border-radius:6px;font-size:0.85rem;font-weight:600;">Enable</a>
                {% endif %}
            </div>

            <div style="background:var(--light-bg);padding:1.25rem;border-radius:10px;border:1px solid var(--border);">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
                    <div style="display:flex;align-items:center;gap:0.75rem;">
                        <div style="width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;color:white;font-size:1.1rem;">
                            <i class="fa-solid fa-face-smile"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;color:var(--dark);">Face Recognition</div>
                            <div style="font-size:0.8rem;color:var(--text-muted);">Login with your face</div>
                        </div>
                    </div>
                    {% if app.user.faceToken|default(false) %}
                        <span style="background:#d1fae5;color:#065f46;padding:4px 10px;border-radius:100px;font-size:0.75rem;font-weight:600;">Enabled</span>
                    {% endif %}
                </div>
                {% if app.user.faceToken|default(false) %}
                    <a href="{{ path('app_face_enroll') }}" style="display:inline-block;padding:8px 16px;background:var(--primary);color:var(--dark);text-decoration:none;border-radius:6px;font-size:0.85rem;font-weight:600;">Manage</a>
                {% else %}
                    <a href="{{ path('app_face_enroll') }}" style="display:inline-block;padding:8px 16px;background:var(--dark);color:white;text-decoration:none;border-radius:6px;font-size:0.85rem;font-weight:600;">Enable</a>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="dash-panel">
        <h5>Your Reviews</h5>
        {% if app.user.avis is not empty %}
            <div style="display:grid;gap:1rem;">
                {% for avi in app.user.avis %}
                    <a href="{{ path('app_avis_show', {'id': avi.avisId}) }}" style="display:grid;grid-template-columns:auto 1fr;gap:1rem;padding:1rem;background:var(--light-bg);border-radius:8px;text-decoration:none;color:var(--dark);transition:background 0.2s;">
                        <div style="color:var(--primary);font-size:1.2rem;display:flex;align-items:flex-start;margin-top:0.2rem;">
                            {% for i in 1..avi.rating %}<i class="fa fa-star"></i>{% endfor %}
                        </div>
                        <div>
                            <div style="font-weight:700;margin-bottom:0.3rem;color:{{ avi.comment == moderatedComment ? '#9ca3af' : 'inherit' }};font-style:{{ avi.comment == moderatedComment ? 'italic' : 'normal' }};">
                                {% if avi.comment == moderatedComment %}
                                    {{ avi.comment }}
                                {% else %}
                                    {{ avi.comment|slice(0, 50) }}{% if avi.comment|length > 50 %}...{% endif %}
                                {% endif %}
                            </div>
                            <div style="font-size:0.8rem;color:var(--text-muted);">{{ avi.createdAt|date('M d, Y') }}</div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <p style="color:var(--text-muted);font-size:0.9rem;padding:1.5rem;text-align:center;">
                You haven't written any reviews yet. <a href="{{ path('app_avis_new') }}" style="color:var(--primary);font-weight:700;">Write one now</a>
            </p>
        {% endif %}
    </div>
</div>
{% endblock %}
