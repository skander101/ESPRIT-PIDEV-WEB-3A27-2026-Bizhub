{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'biz-form'}}) }}

    {# ── Titre ── #}
    <div class="form-group">
        {{ form_label(form.title) }}
        {{ form_widget(form.title, {'attr': {'placeholder': 'Ex : Application FinTech mobile'}}) }}
        {{ form_errors(form.title) }}
        <div class="form-hint"><i class="fa fa-info-circle"></i> Entre 3 et 255 caractères</div>
    </div>

    {# ── Description ── #}
    <div class="form-group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {'attr': {
            'placeholder': 'Décrivez votre projet, votre vision, votre marché cible…',
            'rows': 5,
            'id': 'projet_description',
            'maxlength': 5000
        }}) }}
        {{ form_errors(form.description) }}
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:4px;">
            <div class="form-hint"><i class="fa fa-info-circle"></i> Minimum 20 caractères, maximum 5 000</div>
            <div id="desc-counter" style="font-size:0.75rem;color:var(--text-muted);font-family:'Josefin Sans',sans-serif;">
                <span id="desc-count">0</span> / 5 000
            </div>
        </div>
    </div>

    {# ── Secteur + Budget ── #}
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.secteur) }}
            {{ form_widget(form.secteur) }}
            {{ form_errors(form.secteur) }}
            <div class="form-hint"><i class="fa fa-tag"></i> Sélection obligatoire</div>
        </div>
        <div class="form-group">
            {{ form_label(form.required_budget) }}
            {{ form_widget(form.required_budget, {'attr': {'placeholder': '50 000'}}) }}
            {{ form_errors(form.required_budget) }}
            <div class="form-hint"><i class="fa fa-info-circle"></i> Montant en TND — doit être positif</div>
        </div>
    </div>

    {# ── Statut ── #}
    <div class="form-group">
        {{ form_label(form.status) }}
        {{ form_widget(form.status) }}
        {{ form_errors(form.status) }}
        <div class="form-hint"><i class="fa fa-lightbulb"></i> Seuls les projets <strong>Publié</strong> ou <strong>En cours</strong> reçoivent des investissements</div>
    </div>

    {# ── Actions ── #}
    <div style="display:flex;gap:1rem;margin-top:1.5rem;">
        <button type="submit" class="form-submit" style="flex:1;">
            <i class="fa fa-{{ submitIcon|default('save') }}"></i>
            {{ submitLabel|default('Enregistrer') }}
        </button>
        <a href="{{ path('app_front_projet_index') }}" class="btn-ghost" style="padding:14px 24px;">
            Annuler
        </a>
    </div>

{{ form_end(form) }}

<script>
(function () {
    var textarea = document.getElementById('projet_description');
    var counter  = document.getElementById('desc-count');
    var wrap     = document.getElementById('desc-counter');

    if (!textarea || !counter) return;

    function update() {
        var len = textarea.value.length;
        counter.textContent = len;

        if (len < 20) {
            wrap.style.color = '#ef4444';
        } else if (len > 4800) {
            wrap.style.color = '#f59e0b';
        } else {
            wrap.style.color = 'var(--text-muted)';
        }
    }

    textarea.addEventListener('input', update);
    update();
})();
</script>
