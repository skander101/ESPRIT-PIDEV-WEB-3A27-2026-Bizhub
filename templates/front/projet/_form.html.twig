{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'biz-form'}}) }}

    <div class="form-group">
        {{ form_label(form.title) }}
        {{ form_widget(form.title, {'attr': {'placeholder': 'Ex : Application FinTech mobile'}}) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="form-group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {'attr': {'placeholder': 'Décrivez votre projet, votre vision, votre marché cible…', 'rows': 5}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.secteur) }}
            {{ form_widget(form.secteur) }}
            {{ form_errors(form.secteur) }}
        </div>
        <div class="form-group">
            {{ form_label(form.required_budget) }}
            {{ form_widget(form.required_budget, {'attr': {'placeholder': '50 000'}}) }}
            {{ form_errors(form.required_budget) }}
            <div class="form-hint"><i class="fa fa-info-circle"></i> Montant en TND</div>
        </div>
    </div>

    <div class="form-group">
        {{ form_label(form.status) }}
        {{ form_widget(form.status) }}
        {{ form_errors(form.status) }}
        <div class="form-hint"><i class="fa fa-lightbulb"></i> Seuls les projets <strong>En cours</strong> reçoivent des investissements</div>
    </div>

    <div style="display:flex;gap:1rem;margin-top:1.5rem;">
        <button type="submit" class="form-submit" style="flex:1;">
            <i class="fa fa-{{ submitIcon|default('save') }}"></i>
            {{ submitLabel|default('Enregistrer') }}
        </button>
        <a href="{{ path('app_front_projet_index') }}" class="btn-ghost" style="padding:14px 24px;">
            Annuler
        </a>
    </div>

{{ form_end(form) }}
