{% extends 'front/base.html.twig' %}

{% block title %}Coach IA — {{ projet.title }} — BizHub{% endblock %}

{% block extra_styles %}
/* ── Variables ── */
:root {
    --coach-purple: #7c3aed;
    --coach-purple-soft: rgba(124,58,237,0.1);
    --coach-purple-border: rgba(124,58,237,0.25);
    --coach-green: #059669;
    --coach-green-soft: rgba(5,150,105,0.08);
    --coach-green-border: rgba(5,150,105,0.2);
    --coach-red: #dc2626;
    --coach-red-soft: rgba(220,38,38,0.07);
    --coach-red-border: rgba(220,38,38,0.2);
    --coach-gold: #d97706;
    --coach-gold-soft: rgba(217,119,6,0.1);
    --coach-gold-border: rgba(217,119,6,0.25);
}

/* ── Hero ── */
.coach-hero {
    background: linear-gradient(135deg, #1a0533 0%, #0f172a 100%);
    padding: 50px 5% 40px;
    border-bottom: 1px solid rgba(124,58,237,0.2);
}
.coach-hero-inner { max-width: 960px; margin: 0 auto; }
.back-link { display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,0.4);text-decoration:none;font-size:0.78rem;margin-bottom:1.2rem;transition:color 0.2s;font-family:'Josefin Sans',sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:0.08em; }
.back-link:hover { color: var(--coach-purple); }
.coach-hero-badge { display:inline-flex;align-items:center;gap:6px;background:var(--coach-purple-soft);color:var(--coach-purple);border:1px solid var(--coach-purple-border);border-radius:100px;padding:4px 14px;font-size:0.7rem;font-weight:700;font-family:'Josefin Sans',sans-serif;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.8rem; }
.coach-hero-title { font-size:1.7rem;color:#fff;font-family:'Josefin Sans',sans-serif;font-weight:700;margin-bottom:0.3rem; }
.coach-hero-sub { font-size:0.88rem;color:rgba(255,255,255,0.45); }

/* ── Body layout ── */
.coach-body { max-width:960px;margin:0 auto;padding:36px 5%; }

/* ── Trigger (empty state) ── */
.coach-trigger {
    background: linear-gradient(135deg, var(--coach-purple-soft), rgba(99,102,241,0.06));
    border: 1.5px dashed var(--coach-purple-border);
    border-radius: 18px;
    padding: 60px 40px;
    text-align: center;
}
.coach-trigger-icon { font-size:3rem;color:var(--coach-purple);opacity:0.7;margin-bottom:1.2rem; }
.coach-trigger h2 { font-family:'Josefin Sans',sans-serif;font-size:1.5rem;font-weight:700;color:var(--dark);margin-bottom:0.6rem; }
.coach-trigger p { color:var(--text-muted);font-size:0.92rem;max-width:480px;margin:0 auto 2rem; }
.btn-coach-launch {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: linear-gradient(135deg, var(--coach-purple), #6366f1);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 20px rgba(124,58,237,0.3);
}
.btn-coach-launch:hover { transform:translateY(-2px);box-shadow:0 6px 28px rgba(124,58,237,0.45); }

/* ── Panel ── */
.coach-panel {
    background: #fff;
    border-radius: 16px;
    border: 1.5px solid var(--border);
    padding: 28px;
    margin-bottom: 1.4rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.coach-panel-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.2rem;
    padding-bottom: 0.9rem;
    border-bottom: 1.5px solid var(--border);
}
.coach-panel-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.95rem;
    flex-shrink: 0;
}
.icon-purple { background: var(--coach-purple-soft); color: var(--coach-purple); }
.icon-green  { background: var(--coach-green-soft);  color: var(--coach-green); }
.icon-red    { background: var(--coach-red-soft);    color: var(--coach-red); }
.icon-gold   { background: var(--coach-gold-soft);   color: var(--coach-gold); }
.coach-panel-title { font-family:'Josefin Sans',sans-serif;font-size:0.85rem;font-weight:700;color:var(--dark);text-transform:uppercase;letter-spacing:0.08em; }

/* ── Analyse globale ── */
.coach-analyse-text { line-height:1.8;color:var(--text-muted);font-size:0.93rem; }

/* ── Source badge ── */
.source-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 100px;
    font-size: 0.68rem; font-weight: 700; font-family:'Josefin Sans',sans-serif;
}
.source-openai { background: rgba(16,185,129,0.1); color:#059669; border:1px solid rgba(16,185,129,0.25); }
.source-local  { background: rgba(107,114,128,0.1); color:#6b7280; border:1px solid rgba(107,114,128,0.2); }

/* ── Scores ── */
.scores-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem; }
.score-card { text-align:center;padding:20px 10px;border-radius:14px;border:1.5px solid var(--border); }
.score-ring-wrap { position:relative;width:88px;height:88px;margin:0 auto 0.8rem; }
.score-ring-wrap svg { transform:rotate(-90deg); }
.score-ring-track { fill:none;stroke:var(--border);stroke-width:8; }
.score-ring-fill  { fill:none;stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset 1s ease; }
.score-center { position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column; }
.score-val { font-size:1.3rem;font-weight:700;font-family:'Josefin Sans',sans-serif;color:var(--dark); }
.score-label { font-size:0.72rem;font-weight:700;font-family:'Josefin Sans',sans-serif;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em; }

/* ── Lists (points forts / faibles / suggestions) ── */
.coach-list { list-style:none;padding:0;margin:0; }
.coach-list li {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--dark);
}
.coach-list li:last-child { border-bottom: none; }
.coach-list-dot {
    width: 22px; height: 22px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.68rem; flex-shrink: 0; margin-top: 1px;
}
.dot-green { background: var(--coach-green-soft); color: var(--coach-green); border:1px solid var(--coach-green-border); }
.dot-red   { background: var(--coach-red-soft);   color: var(--coach-red);   border:1px solid var(--coach-red-border); }
.dot-gold  { background: var(--coach-gold-soft);  color: var(--coach-gold);  border:1px solid var(--coach-gold-border); }

/* ── Description améliorée ── */
.desc-improved {
    background: linear-gradient(135deg, rgba(124,58,237,0.04), rgba(99,102,241,0.04));
    border: 1.5px solid var(--coach-purple-border);
    border-radius: 12px;
    padding: 20px 22px;
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--dark);
    white-space: pre-line;
    margin-bottom: 1.2rem;
}
.btn-apply {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 24px;
    background: linear-gradient(135deg, var(--coach-purple), #6366f1);
    color: #fff; border: none; border-radius: 9px;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
    cursor: pointer; transition: all 0.2s;
}
.btn-apply:hover { opacity: 0.9; transform: translateY(-1px); }
.btn-rerun {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 20px;
    background: transparent;
    color: var(--coach-purple); border: 1.5px solid var(--coach-purple-border);
    border-radius: 9px; font-family: 'Josefin Sans', sans-serif;
    font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em;
    cursor: pointer; transition: all 0.2s;
}
.btn-rerun:hover { background: var(--coach-purple-soft); }

/* ── Flash ── */
.flash-msg { padding:12px 18px;border-radius:10px;margin-bottom:1.2rem;font-size:0.88rem;font-weight:600; }
.flash-success { background:rgba(5,150,105,0.08);color:#059669;border:1px solid rgba(5,150,105,0.2); }
.flash-error   { background:rgba(220,38,38,0.07);color:#dc2626;border:1px solid rgba(220,38,38,0.18); }

/* ── Responsive ── */
@media(max-width:640px) {
    .scores-grid { grid-template-columns:1fr; }
    .coach-trigger { padding:40px 20px; }
}
@media(max-width:700px) {
    .coach-body > div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns:1fr !important; }
}
{% endblock %}

{% block content %}
{# ── Hero ── #}
<div class="coach-hero">
    <div class="coach-hero-inner">
        <a href="{{ path('app_front_projet_show', {'id': projet.project_id}) }}" class="back-link">
            <i class="fa fa-arrow-left"></i> Retour au projet
        </a>
        <div>
            <span class="coach-hero-badge"><i class="fa fa-brain"></i> Coach IA</span>
        </div>
        <div class="coach-hero-title">{{ projet.title }}</div>
        <div class="coach-hero-sub">Analyse intelligente &amp; recommandations pour améliorer votre projet</div>
    </div>
</div>

{# ── Body ── #}
<div class="coach-body">

    {# Flash messages #}
    {% for msg in app.flashes('success') %}
        <div class="flash-msg flash-success"><i class="fa fa-check-circle" style="margin-right:6px;"></i>{{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="flash-msg flash-error"><i class="fa fa-exclamation-circle" style="margin-right:6px;"></i>{{ msg }}</div>
    {% endfor %}

    {% if analysis is null %}

        {# ── État vide : invitation à lancer l'analyse ── #}
        <div class="coach-trigger">
            <div class="coach-trigger-icon"><i class="fa fa-brain"></i></div>
            <h2>Analysez votre projet avec l'IA</h2>
            <p>
                Obtenez en quelques secondes une analyse complète de votre projet :
                points forts, points faibles, suggestions concrètes et une description améliorée
                pour convaincre les investisseurs.
            </p>
            <form method="POST" action="{{ path('app_front_projet_coach_analyze', {'id': projet.project_id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('coach_analyze_' ~ projet.project_id) }}">
                <button type="submit" class="btn-coach-launch">
                    <i class="fa fa-magic"></i> Lancer l'analyse IA
                </button>
            </form>
        </div>

    {% else %}

        {# ── Header de l'analyse ── #}
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.4rem;">
            <div style="display:flex;align-items:center;gap:10px;">
                <span class="source-badge source-{{ analysis.source == 'openai' ? 'openai' : 'local' }}">
                    <i class="fa fa-{{ analysis.source == 'openai' ? 'robot' : 'server' }}"></i>
                    {{ analysis.source == 'openai' ? 'Générée par GPT-4o mini' : 'Analyse locale (hors ligne)' }}
                </span>
                <span style="font-size:0.78rem;color:var(--text-muted);">
                    {{ analysis.analyzed_at|date('d/m/Y à H:i') }}
                </span>
            </div>
            <form method="POST" action="{{ path('app_front_projet_coach_analyze', {'id': projet.project_id}) }}" style="margin:0;">
                <input type="hidden" name="_token" value="{{ csrf_token('coach_analyze_' ~ projet.project_id) }}">
                <button type="submit" class="btn-rerun">
                    <i class="fa fa-sync-alt"></i> Relancer l'analyse
                </button>
            </form>
        </div>

        {# ── Scores ── #}
        {% set scores = analysis.scores %}
        {% set circumference = 251.33 %}{# 2π×40 #}
        <div class="coach-panel">
            <div class="coach-panel-head">
                <div class="coach-panel-icon icon-purple"><i class="fa fa-chart-pie"></i></div>
                <div class="coach-panel-title">Scores d'évaluation</div>
            </div>
            <div class="scores-grid">

                {# Qualité #}
                {% set q = scores.qualite %}
                {% set qColor = q >= 70 ? '#059669' : (q >= 40 ? '#d97706' : '#dc2626') %}
                {% set qOffset = circumference * (1 - q / 100) %}
                <div class="score-card">
                    <div class="score-ring-wrap">
                        <svg width="88" height="88" viewBox="0 0 88 88">
                            <circle class="score-ring-track" cx="44" cy="44" r="40"/>
                            <circle class="score-ring-fill"
                                cx="44" cy="44" r="40"
                                stroke="{{ qColor }}"
                                stroke-dasharray="{{ circumference }}"
                                stroke-dashoffset="{{ qOffset|round(2) }}"/>
                        </svg>
                        <div class="score-center">
                            <span class="score-val" style="color:{{ qColor }};">{{ q }}</span>
                        </div>
                    </div>
                    <div class="score-label">Qualité</div>
                    <div style="font-size:0.72rem;color:var(--text-muted);margin-top:4px;">
                        {{ q >= 70 ? 'Excellent' : (q >= 40 ? 'À améliorer' : 'Insuffisant') }}
                    </div>
                </div>

                {# Clarté #}
                {% set c = scores.clarte %}
                {% set cColor = c >= 70 ? '#059669' : (c >= 40 ? '#d97706' : '#dc2626') %}
                {% set cOffset = circumference * (1 - c / 100) %}
                <div class="score-card">
                    <div class="score-ring-wrap">
                        <svg width="88" height="88" viewBox="0 0 88 88">
                            <circle class="score-ring-track" cx="44" cy="44" r="40"/>
                            <circle class="score-ring-fill"
                                cx="44" cy="44" r="40"
                                stroke="{{ cColor }}"
                                stroke-dasharray="{{ circumference }}"
                                stroke-dashoffset="{{ cOffset|round(2) }}"/>
                        </svg>
                        <div class="score-center">
                            <span class="score-val" style="color:{{ cColor }};">{{ c }}</span>
                        </div>
                    </div>
                    <div class="score-label">Clarté</div>
                    <div style="font-size:0.72rem;color:var(--text-muted);margin-top:4px;">
                        {{ c >= 70 ? 'Très clair' : (c >= 40 ? 'À préciser' : 'Confus') }}
                    </div>
                </div>

                {# Attractivité #}
                {% set a = scores.attractivite %}
                {% set aColor = a >= 70 ? '#059669' : (a >= 40 ? '#d97706' : '#dc2626') %}
                {% set aOffset = circumference * (1 - a / 100) %}
                <div class="score-card">
                    <div class="score-ring-wrap">
                        <svg width="88" height="88" viewBox="0 0 88 88">
                            <circle class="score-ring-track" cx="44" cy="44" r="40"/>
                            <circle class="score-ring-fill"
                                cx="44" cy="44" r="40"
                                stroke="{{ aColor }}"
                                stroke-dasharray="{{ circumference }}"
                                stroke-dashoffset="{{ aOffset|round(2) }}"/>
                        </svg>
                        <div class="score-center">
                            <span class="score-val" style="color:{{ aColor }};">{{ a }}</span>
                        </div>
                    </div>
                    <div class="score-label">Attractivité</div>
                    <div style="font-size:0.72rem;color:var(--text-muted);margin-top:4px;">
                        {{ a >= 70 ? 'Très attractif' : (a >= 40 ? 'Moyen' : 'Peu attractif') }}
                    </div>
                </div>

            </div>
        </div>

        {# ── Analyse globale ── #}
        {% if analysis.analyse_globale %}
        <div class="coach-panel">
            <div class="coach-panel-head">
                <div class="coach-panel-icon icon-purple"><i class="fa fa-brain"></i></div>
                <div class="coach-panel-title">Analyse globale</div>
            </div>
            <p class="coach-analyse-text">{{ analysis.analyse_globale }}</p>
        </div>
        {% endif %}

        {# ── Points forts & faibles (côte à côte) ── #}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.4rem;margin-bottom:1.4rem;">

            {# Points forts #}
            <div class="coach-panel" style="margin-bottom:0;">
                <div class="coach-panel-head">
                    <div class="coach-panel-icon icon-green"><i class="fa fa-thumbs-up"></i></div>
                    <div class="coach-panel-title">Points forts</div>
                </div>
                {% if analysis.points_forts|length > 0 %}
                    <ul class="coach-list">
                        {% for item in analysis.points_forts %}
                            <li>
                                <span class="coach-list-dot dot-green"><i class="fa fa-check"></i></span>
                                <span>{{ item }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p style="color:var(--text-muted);font-style:italic;font-size:0.88rem;">Aucun point fort identifié.</p>
                {% endif %}
            </div>

            {# Points faibles #}
            <div class="coach-panel" style="margin-bottom:0;">
                <div class="coach-panel-head">
                    <div class="coach-panel-icon icon-red"><i class="fa fa-exclamation-triangle"></i></div>
                    <div class="coach-panel-title">Points à améliorer</div>
                </div>
                {% if analysis.points_faibles|length > 0 %}
                    <ul class="coach-list">
                        {% for item in analysis.points_faibles %}
                            <li>
                                <span class="coach-list-dot dot-red"><i class="fa fa-times"></i></span>
                                <span>{{ item }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p style="color:var(--text-muted);font-style:italic;font-size:0.88rem;">Aucun point faible identifié.</p>
                {% endif %}
            </div>

        </div>

        {# ── Suggestions ── #}
        {% if analysis.suggestions|length > 0 %}
        <div class="coach-panel">
            <div class="coach-panel-head">
                <div class="coach-panel-icon icon-gold"><i class="fa fa-lightbulb"></i></div>
                <div class="coach-panel-title">Suggestions concrètes d'amélioration</div>
            </div>
            <ul class="coach-list">
                {% for item in analysis.suggestions %}
                    <li>
                        <span class="coach-list-dot dot-gold">{{ loop.index }}</span>
                        <span>{{ item }}</span>
                    </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        {# ── Description améliorée ── #}
        {% if analysis.description_amelioree %}
        <div class="coach-panel">
            <div class="coach-panel-head">
                <div class="coach-panel-icon icon-purple"><i class="fa fa-magic"></i></div>
                <div class="coach-panel-title">Description améliorée par l'IA</div>
            </div>
            <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:1rem;">
                <i class="fa fa-info-circle" style="margin-right:4px;color:var(--coach-purple);"></i>
                Version optimisée de votre description, réécrite pour maximiser l'attractivité auprès des investisseurs.
            </p>
            <div class="desc-improved">{{ analysis.description_amelioree }}</div>

            <form method="POST" action="{{ path('app_front_projet_apply_description', {'id': projet.project_id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('apply_description_' ~ projet.project_id) }}">
                <input type="hidden" name="description" value="{{ analysis.description_amelioree }}">
                <button type="submit" class="btn-apply"
                    onclick="return confirm('Appliquer cette description à votre projet ? L\'ancienne description sera remplacée.')">
                    <i class="fa fa-check-circle"></i> Appliquer la description améliorée
                </button>
            </form>
        </div>
        {% endif %}

        {# ── Note de bas de page ── #}
        <div style="text-align:center;padding:1rem 0 0.5rem;font-size:0.78rem;color:var(--text-muted);">
            <i class="fa fa-info-circle" style="margin-right:4px;"></i>
            Cette analyse est générée automatiquement et ne remplace pas un conseil professionnel.
            Relancez l'analyse après avoir modifié votre projet pour obtenir une évaluation actualisée.
        </div>

    {% endif %}

</div>
{% endblock %}
