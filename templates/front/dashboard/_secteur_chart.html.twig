{#
    Partial : graphique camembert "Projets par secteur"
    Variables attendues : par_secteur (tableau associatif secteur => count)
    Usage : {% include 'front/dashboard/_secteur_chart.html.twig' %}
#}

{% set secteurLabels = {
    'tech':        'Technologie',
    'fintech':     'FinTech',
    'sante':       'Santé',
    'agriculture': 'Agriculture',
    'education':   'Éducation',
    'commerce':    'Commerce',
    'energie':     'Énergie',
    'immobilier':  'Immobilier',
    'transport':   'Transport',
    'autre':       'Autre'
} %}

{# Couleurs pour chaque secteur dans le même ordre #}
{% set secteurColors = [
    '#ffbe33', '#5b6ef5', '#06d6a0', '#f97316',
    '#3b82f6', '#ec4899', '#a855f7', '#14b8a6',
    '#ef4444', '#6b7280'
] %}

{% set totalProjets = 0 %}
{% for count in par_secteur %}
    {% set totalProjets = totalProjets + count %}
{% endfor %}

<div class="panel" style="margin-bottom:1.5rem;">
    <div class="panel-title">
        <i class="fa fa-chart-pie"></i>Projets par secteur
        <span style="margin-left:auto;font-size:0.75rem;color:var(--text-muted);font-weight:400;text-transform:none;letter-spacing:0;">
            {{ totalProjets }} projet(s) au total
        </span>
    </div>

    {% if par_secteur|length > 0 %}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:center;">

            {# Graphique camembert #}
            <div style="position:relative;max-width:260px;margin:0 auto;">
                <canvas id="secteurPieChart" width="260" height="260"></canvas>
                {# Total au centre — superposé via CSS #}
                <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;">
                    <div style="font-family:'Josefin Sans',sans-serif;font-size:1.5rem;font-weight:700;color:var(--dark);line-height:1;">
                        {{ totalProjets }}
                    </div>
                    <div style="font-size:0.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;font-family:'Josefin Sans',sans-serif;">
                        Projets
                    </div>
                </div>
            </div>

            {# Légende avec barres #}
            <div>
                {% set colorIndex = 0 %}
                {% for secteur, count in par_secteur %}
                    {% set pct = totalProjets > 0 ? ((count / totalProjets) * 100)|round(1) : 0 %}
                    {% set color = secteurColors[colorIndex] ?? '#cccccc' %}
                    <div style="margin-bottom:10px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">
                            <div style="display:flex;align-items:center;gap:7px;">
                                <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:{{ color }};flex-shrink:0;"></span>
                                <span style="font-size:0.8rem;color:var(--dark);font-weight:600;">
                                    {{ secteurLabels[secteur] ?? secteur|capitalize }}
                                </span>
                            </div>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <span style="font-size:0.75rem;color:var(--text-muted);">{{ count }}</span>
                                <span style="font-family:'Josefin Sans',sans-serif;font-size:0.72rem;font-weight:700;color:{{ color }};min-width:36px;text-align:right;">
                                    {{ pct }}%
                                </span>
                            </div>
                        </div>
                        <div style="height:4px;background:var(--border);border-radius:2px;overflow:hidden;">
                            <div style="height:100%;width:{{ pct }}%;background:{{ color }};border-radius:2px;transition:width 0.8s ease;"></div>
                        </div>
                    </div>
                    {% set colorIndex = colorIndex + 1 %}
                {% endfor %}
            </div>

        </div>

        {# Chart.js — chargé depuis CDN, sans installation #}
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script>
        (function() {
            const labels = [
                {% for secteur, count in par_secteur %}
                    "{{ secteurLabels[secteur] ?? secteur|capitalize }}"{% if not loop.last %},{% endif %}
                {% endfor %}
            ];
            const data = [
                {% for secteur, count in par_secteur %}
                    {{ count }}{% if not loop.last %},{% endif %}
                {% endfor %}
            ];
            const colors = [
                {% set ci = 0 %}
                {% for secteur, count in par_secteur %}
                    "{{ secteurColors[ci] ?? '#cccccc' }}"{% if not loop.last %},{% endif %}
                    {% set ci = ci + 1 %}
                {% endfor %}
            ];

            const ctx = document.getElementById('secteurPieChart');
            if (ctx) {
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: data,
                            backgroundColor: colors,
                            borderColor: '#ffffff',
                            borderWidth: 3,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: false,
                        cutout: '62%',
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(ctx) {
                                        const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                        const pct = total > 0 ? ((ctx.parsed / total) * 100).toFixed(1) : 0;
                                        return ' ' + ctx.label + ' : ' + ctx.parsed + ' (' + pct + '%)';
                                    }
                                }
                            }
                        },
                        animation: {
                            animateRotate: true,
                            duration: 900
                        }
                    }
                });
            }
        })();
        </script>

    {% else %}
        <div style="text-align:center;padding:30px 0;color:var(--text-muted);font-size:0.85rem;font-style:italic;">
            <i class="fa fa-chart-pie" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:0.8rem;"></i>
            Aucun projet avec un secteur défini pour l'instant.
        </div>
    {% endif %}
</div>
