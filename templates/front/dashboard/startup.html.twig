{% extends 'front/base.html.twig' %}

{% block title %}Mon Dashboard Startup — BizHub{% endblock %}

{% block extra_styles %}
/* ── Page header ── */
.dash-header {
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark2) 100%);
    padding: 50px 5% 36px;
}
.dash-header h1 {
    font-size: 1.8rem; color: var(--white);
    font-family: 'Josefin Sans', sans-serif; font-weight: 700;
}
.dash-header p { color: rgba(255,255,255,0.5); margin-top: 0.3rem; font-size: 0.9rem; }
.user-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(91,110,245,0.2); border: 1px solid rgba(91,110,245,0.35);
    color: #8b9ef5; border-radius: 20px; padding: 4px 14px;
    font-size: 0.72rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif;
    text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem;
}

/* ── Layout ── */
.dash-body { max-width: 1200px; margin: 0 auto; padding: 32px 5%; }

/* ── KPI cards ── */
.kpi-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem; margin-bottom: 2rem;
}
.kpi-card {
    background: var(--white); border-radius: 14px;
    border: 1.5px solid var(--border); padding: 20px 22px;
    display: flex; align-items: center; gap: 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.kpi-card:hover { border-color: var(--primary); box-shadow: 0 6px 24px rgba(255,190,51,0.1); }
.kpi-icon {
    width: 48px; height: 48px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
}
.kpi-icon.yellow { background: rgba(255,190,51,0.12); color: var(--primary); }
.kpi-icon.blue   { background: rgba(91,110,245,0.12); color: #5b6ef5; }
.kpi-icon.green  { background: rgba(6,214,160,0.12);  color: #06d6a0; }
.kpi-icon.red    { background: rgba(239,68,68,0.1);   color: #ef4444; }
.kpi-num {
    font-family: 'Josefin Sans', sans-serif; font-size: 1.7rem;
    font-weight: 700; color: var(--dark); line-height: 1;
}
.kpi-label { font-size: 0.75rem; color: var(--text-muted); margin-top: 4px; }

/* ── Panels ── */
.dash-row   { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
.dash-row-3 { display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
.panel {
    background: var(--white); border-radius: 14px;
    border: 1.5px solid var(--border); padding: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.panel-title {
    font-size: 0.78rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; font-family: 'Josefin Sans', sans-serif;
    color: var(--dark); margin-bottom: 1.1rem; padding-bottom: 0.7rem;
    border-bottom: 1.5px solid var(--border);
    display: flex; align-items: center; gap: 8px;
}
.panel-title i { color: var(--primary); }

/* ── Progression projet ── */
.projet-prog {
    padding: 14px 0; border-bottom: 1px solid var(--border);
}
.projet-prog:last-child { border-bottom: none; }
.projet-prog-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 6px; gap: 1rem;
}
.projet-prog-title {
    font-size: 0.88rem; font-weight: 700; color: var(--dark);
    font-family: 'Josefin Sans', sans-serif; text-decoration: none;
}
.projet-prog-title:hover { color: var(--primary); }
.pct-text {
    font-family: 'Josefin Sans', sans-serif; font-size: 0.85rem;
    font-weight: 700; color: var(--primary); white-space: nowrap;
}
.prog-bar-wrap { height: 7px; background: var(--border); border-radius: 4px; overflow: hidden; margin: 4px 0; }
.prog-bar-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--primary-dark)); border-radius: 4px; }
.prog-amounts { display: flex; justify-content: space-between; font-size: 0.74rem; color: var(--text-muted); margin-top: 3px; }

/* ── Statut badges ── */
.status-badge { font-size: 0.68rem; font-weight: 700; padding: 2px 9px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.06em; font-family: 'Josefin Sans', sans-serif; display: inline-block; }
.status-brouillon  { background: rgba(107,114,128,0.12); color: #6b7280; }
.status-publie     { background: rgba(59,130,246,0.12);  color: #3b82f6; }
.status-en_cours   { background: rgba(91,110,245,0.12);  color: #5b6ef5; }
.status-finance    { background: rgba(6,214,160,0.15);   color: #06d6a0; }
.status-ferme      { background: rgba(239,68,68,0.08);   color: #ef4444; }

/* ── Répartition statuts ── */
.statut-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 9px 0; border-bottom: 1px solid var(--border); font-size: 0.84rem;
}
.statut-row:last-child { border-bottom: none; }
.statut-count { font-family: 'Josefin Sans', sans-serif; font-weight: 700; font-size: 1rem; color: var(--dark); }

/* ── Tableau investissements reçus ── */
.dash-table { width: 100%; border-collapse: collapse; font-size: 0.84rem; }
.dash-table th {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; font-family: 'Josefin Sans', sans-serif;
    color: var(--text-muted); padding: 0 0 10px 0;
    border-bottom: 1.5px solid var(--border); text-align: left;
}
.dash-table td { padding: 11px 0; border-bottom: 1px solid var(--border); vertical-align: middle; }
.dash-table tr:last-child td { border-bottom: none; }
.dash-table .amount { font-family: 'Josefin Sans', sans-serif; font-weight: 700; color: var(--primary); }
.dash-table .muted  { color: var(--text-muted); font-size: 0.78rem; }

/* ── Barre financement global ── */
.global-progress {
    background: var(--white); border-radius: 14px; border: 1.5px solid var(--border);
    padding: 24px; margin-bottom: 1.5rem; box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}
.global-prog-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.global-prog-label { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'Josefin Sans', sans-serif; color: var(--dark); }
.global-prog-pct { font-family: 'Josefin Sans', sans-serif; font-size: 1.4rem; font-weight: 700; color: var(--primary); }
.global-bar-wrap { height: 12px; background: var(--border); border-radius: 6px; overflow: hidden; margin: 4px 0 8px; }
.global-bar-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--primary-dark)); border-radius: 6px; transition: width 1s ease; }
.global-amounts { display: flex; justify-content: space-between; font-size: 0.8rem; color: var(--text-muted); }

.voir-tout {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.75rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--primary); text-decoration: none; margin-top: 1rem;
}
.voir-tout:hover { color: var(--primary-dark); }
.empty-text { color: var(--text-muted); font-size: 0.85rem; font-style: italic; text-align: center; padding: 20px 0; }

@media (max-width: 1024px) { .kpi-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 768px)  { .dash-row, .dash-row-3 { grid-template-columns: 1fr; } }
@media (max-width: 480px)  { .kpi-grid { grid-template-columns: 1fr; } }
{% endblock %}

{% block content %}
{# ── Header ── #}
<div class="dash-header">
    <div style="max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;">
        <div>
            <div class="user-badge"><i class="fa fa-rocket"></i> Startup</div>
            <h1><i class="fa fa-tachometer-alt" style="color:var(--primary);margin-right:0.5rem;"></i>Mon Dashboard</h1>
            <p>Bonjour <strong style="color:var(--white);">{{ app.user.fullName }}</strong> — voici l'état de vos projets et financements.</p>
        </div>
        <a href="{{ path('app_front_projet_new') }}" class="btn-yellow" style="display:flex;align-items:center;gap:8px;">
            <i class="fa fa-plus"></i> Nouveau projet
        </a>
    </div>
</div>

<div class="dash-body">

    {# ── KPI cards ── #}
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon yellow"><i class="fa fa-folder"></i></div>
            <div>
                <div class="kpi-num">{{ projets|length }}</div>
                <div class="kpi-label">Projet(s) créé(s)</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon blue"><i class="fa fa-coins"></i></div>
            <div>
                <div class="kpi-num">{{ total_demande|number_format(0, ',', ' ') }}</div>
                <div class="kpi-label">TND demandés au total</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon green"><i class="fa fa-hand-holding-usd"></i></div>
            <div>
                <div class="kpi-num">{{ total_finance|number_format(0, ',', ' ') }}</div>
                <div class="kpi-label">TND reçus au total</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon yellow"><i class="fa fa-percentage"></i></div>
            <div>
                <div class="kpi-num">{{ pourcentage_global }}%</div>
                <div class="kpi-label">Taux de financement global</div>
            </div>
        </div>
    </div>

    {# ── Barre de financement global ── #}
    <div class="global-progress">
        <div class="global-prog-header">
            <span class="global-prog-label"><i class="fa fa-chart-line" style="margin-right:6px;color:var(--primary);"></i>Financement global</span>
            <span class="global-prog-pct">{{ pourcentage_global }}%</span>
        </div>
        <div class="global-bar-wrap">
            <div class="global-bar-fill" style="width:{{ pourcentage_global }}%;"></div>
        </div>
        <div class="global-amounts">
            <span>{{ total_finance|number_format(0, ',', ' ') }} TND collectés</span>
            <span>Objectif : {{ total_demande|number_format(0, ',', ' ') }} TND</span>
        </div>
    </div>

    {# ── Ligne 1 : Progression par projet + Répartition statuts ── #}
    <div class="dash-row-3">

        {# Progression par projet #}
        <div class="panel">
            <div class="panel-title"><i class="fa fa-tasks"></i>Progression par projet</div>
            {% if projets_avec_progression|length > 0 %}
                {% for item in projets_avec_progression %}
                    <div class="projet-prog">
                        <div class="projet-prog-top">
                            <div>
                                <a href="{{ path('app_front_projet_show', {'id': item.projet.project_id}) }}" class="projet-prog-title">
                                    {{ item.projet.title }}
                                </a>
                                <div style="margin-top:3px;">
                                    <span class="status-badge status-{{ item.projet.status }}">
                                        {% if item.projet.status == 'brouillon' %}Brouillon
                                        {% elseif item.projet.status == 'publie' %}Publié
                                        {% elseif item.projet.status == 'en_cours' %}En cours
                                        {% elseif item.projet.status == 'finance' %}Financé
                                        {% elseif item.projet.status == 'ferme' %}Fermé
                                        {% else %}{{ item.projet.status }}{% endif %}
                                    </span>
                                </div>
                            </div>
                            <span class="pct-text">{{ item.pct }}%</span>
                        </div>
                        <div class="prog-bar-wrap">
                            <div class="prog-bar-fill" style="width:{{ item.pct }}%;"></div>
                        </div>
                        <div class="prog-amounts">
                            <span>{{ item.investi|number_format(0, ',', ' ') }} TND reçus</span>
                            <span>{{ item.projet.requiredBudget|number_format(0, ',', ' ') }} TND requis</span>
                        </div>
                    </div>
                {% endfor %}
                <a href="{{ path('app_front_projet_index') }}" class="voir-tout">
                    <i class="fa fa-arrow-right"></i> Gérer mes projets
                </a>
            {% else %}
                <div class="empty-text">Aucun projet créé pour l'instant.</div>
                <div style="text-align:center;margin-top:1rem;">
                    <a href="{{ path('app_front_projet_new') }}" class="btn-yellow" style="font-size:0.8rem;padding:10px 20px;">
                        <i class="fa fa-plus" style="margin-right:5px;"></i>Créer mon premier projet
                    </a>
                </div>
            {% endif %}
        </div>

        {# Répartition par statut #}
        <div class="panel">
            <div class="panel-title"><i class="fa fa-chart-pie"></i>Statuts projets</div>
            {% if par_statut|length > 0 %}
                {% set labels = {
                    'brouillon':  'Brouillon',
                    'publie':     'Publié',
                    'en_cours':   'En cours',
                    'finance':    'Financé',
                    'ferme':      'Fermé'
                } %}
                {% for statut, count in par_statut %}
                    <div class="statut-row">
                        <span class="status-badge status-{{ statut }}">
                            {{ labels[statut] ?? statut }}
                        </span>
                        <span class="statut-count">{{ count }}</span>
                    </div>
                {% endfor %}
            {% else %}
                <div class="empty-text">Aucune donnée.</div>
            {% endif %}
        </div>

    </div>

    {# ── Ligne 2 : Derniers investissements reçus ── #}
    <div class="panel">
        <div class="panel-title"><i class="fa fa-users"></i>Derniers investissements reçus</div>
        {% if derniers_recus|length > 0 %}
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Investisseur</th>
                        <th>Projet</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th style="text-align:right;">Montant</th>
                    </tr>
                </thead>
                <tbody>
                    {% for inv in derniers_recus %}
                        <tr>
                            <td style="font-weight:600;">
                                {{ inv.user ? inv.user.fullName : 'Investisseur anonyme' }}
                            </td>
                            <td>
                                {% if inv.project %}
                                    <a href="{{ path('app_front_projet_show', {'id': inv.project.project_id}) }}"
                                       style="color:var(--dark);text-decoration:none;font-size:0.82rem;">
                                        {{ inv.project.title|slice(0,25) }}{% if inv.project.title|length > 25 %}…{% endif %}
                                    </a>
                                {% else %}
                                    <span class="muted">—</span>
                                {% endif %}
                            </td>
                            <td class="muted">
                                {{ inv.investmentDate ? inv.investmentDate|date('d/m/Y') : inv.createdAt|date('d/m/Y') }}
                            </td>
                            <td>
                                {% set s = inv.statut ?? 'en_attente' %}
                                <span class="status-badge" style="
                                    {% if s == 'accepte' or s == 'signe' %}background:rgba(6,214,160,0.15);color:#06d6a0;
                                    {% elseif s == 'refuse' %}background:rgba(239,68,68,0.1);color:#ef4444;
                                    {% elseif s == 'en_negociation' %}background:rgba(59,130,246,0.12);color:#3b82f6;
                                    {% else %}background:rgba(255,190,51,0.15);color:#b8860b;{% endif %}
                                ">
                                    {% if s == 'en_attente' %}En attente
                                    {% elseif s == 'en_negociation' %}Négociation
                                    {% elseif s == 'accepte' %}Accepté
                                    {% elseif s == 'refuse' %}Refusé
                                    {% elseif s == 'contrat_genere' %}Contrat
                                    {% elseif s == 'signe' %}Signé
                                    {% elseif s == 'termine' %}Terminé
                                    {% else %}{{ s }}{% endif %}
                                </span>
                            </td>
                            <td style="text-align:right;" class="amount">
                                {{ inv.amount|number_format(0, ',', ' ') }} TND
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="empty-text">
                Aucun investissement reçu pour l'instant.
                {% if projets|length == 0 %}
                    Créez votre premier projet pour commencer.
                {% elseif par_statut['en_cours'] is not defined %}
                    Publiez un projet avec le statut <strong>En cours</strong> pour recevoir des investissements.
                {% endif %}
            </div>
        {% endif %}
    </div>

    {# ── Graphique : Projets par secteur ── #}
    {% include 'front/dashboard/_secteur_chart.html.twig' %}

</div>
{% endblock %}
