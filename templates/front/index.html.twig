{% extends 'front/base.html.twig' %}

{% block title %}BizHub - Business Collaboration Platform{% endblock %}

{% block content %}

  <style>
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lora', serif;
      background: var(--white);
      color: var(--dark);
      overflow-x: hidden;
    }

    /* Navbar uses the unified styles defined in front/base.html.twig */

    /* ══════════════ HERO ══════════════ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      padding-top: 72px;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: var(--dark2);
    }
    .hero-bg-img {
      position: absolute;
      inset: 0;
      background: url('{{ asset('assets/front/images/hero-bg1.png') }}') center/cover no-repeat;
      opacity: 0.55;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(26,31,39,0.88) 35%, rgba(26,31,39,0.45) 100%);
    }

    .hero-slides-wrap {
      position: relative;
      z-index: 2;
      flex: 1;
      display: flex;
      align-items: center;
    }

    .hero-slide {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      padding: 60px 5%;
      opacity: 0;
      transition: opacity 0.8s ease;
      pointer-events: none;
    }
    .hero-slide.active { opacity: 1; pointer-events: auto; }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,190,51,0.15);
      border: 1px solid rgba(255,190,51,0.35);
      color: var(--primary);
      font-size: 0.72rem;
      font-weight: 700;
      font-family: 'Josefin Sans', sans-serif;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 1.5rem;
    }
    .hero-slide h1 {
      font-size: clamp(2.4rem, 5vw, 4rem);
      font-weight: 700;
      font-family: 'Lora', serif;
      font-style: italic;
      line-height: 1.15;
      color: var(--white);
      margin-bottom: 1.2rem;
      letter-spacing: 0.01em;
      max-width: 580px;
    }
    .hero-slide h1 span { color: var(--primary); }
    .hero-slide p {
      font-size: 1rem;
      line-height: 1.75;
      color: rgba(255,255,255,0.65);
      margin-bottom: 2.5rem;
      max-width: 480px;
    }
    .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

    .btn-yellow {
      background: var(--primary);
      color: var(--dark);
      padding: 14px 32px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.9rem;
      text-decoration: none;
      display: inline-block;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      border: none; cursor: pointer;
    }
    .btn-yellow:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,190,51,0.4); }

    .btn-outline {
      background: transparent;
      color: var(--white);
      padding: 14px 32px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.9rem;
      text-decoration: none;
      display: inline-block;
      border: 1.5px solid rgba(255,255,255,0.25);
      transition: border-color 0.2s, color 0.2s;
    }
    .btn-outline:hover { border-color: var(--primary); color: var(--primary); }

    .carousel-dots {
      position: absolute;
      bottom: 24px;
      left: 5%;
      z-index: 3;
      display: flex;
      gap: 8px;
    }
    .cdot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.3);
      cursor: pointer;
      transition: background 0.3s, width 0.3s;
      border: none;
    }
    .cdot.active { background: var(--primary); width: 24px; border-radius: 4px; }

    /* Stats bar */
    .hero-stats {
      position: relative;
      z-index: 2;
      display: flex;
      background: rgba(0,0,0,0.35);
      border-top: 1px solid rgba(255,190,51,0.15);
    }
    .stat-item {
      flex: 1;
      padding: 22px 5%;
      text-align: center;
      border-right: 1px solid rgba(255,255,255,0.06);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num { font-size: 1.8rem; font-weight: 800; color: var(--primary); display: block; line-height: 1; }
    .stat-label { font-size: 0.72rem; color: rgba(255,255,255,0.4); margin-top: 4px; letter-spacing: 0.04em; }

    /* ══════════════ OFFERS ══════════════ */
    .offers-section { background: var(--light-bg); padding: 70px 5%; }
    .offers-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      max-width: 860px;
      margin: 0 auto;
    }
    .offer-card {
      background: var(--white);
      border-radius: 14px;
      overflow: hidden;
      display: flex;
      box-shadow: 0 4px 20px rgba(0,0,0,0.07);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .offer-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,0,0,0.12); }
    .offer-img { width: 130px; height: 130px; object-fit: cover; flex-shrink: 0; }
    .offer-body { padding: 20px 22px; flex: 1; }
    .offer-tag {
      display: inline-block;
      background: rgba(255,190,51,0.15);
      color: var(--primary-dark);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 100px;
      margin-bottom: 6px;
    }
    .offer-title { font-size: 1rem; font-weight: 700; color: var(--dark); margin-bottom: 4px; }
    .offer-discount { font-size: 1.5rem; font-weight: 800; color: var(--primary); line-height: 1; margin-bottom: 12px; }
    .offer-discount span { font-size: 0.8rem; font-weight: 500; color: var(--text-muted); }
    .offer-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--dark);
      background: var(--primary);
      padding: 7px 16px;
      border-radius: 6px;
      text-decoration: none;
      transition: background 0.2s;
    }
    .offer-btn:hover { background: var(--primary-dark); }

    /* ══════════════ SECTION HEADER ══════════════ */
    .section-header { text-align: center; margin-bottom: 3rem; }
    .section-header .label {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      font-family: 'Josefin Sans', sans-serif;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 0.6rem;
    }
    .section-header h2 {
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      font-weight: 700;
      font-family: 'Lora', serif;
      color: var(--dark);
      margin-bottom: 0.6rem;
      letter-spacing: 0.01em;
    }
    .section-header p { font-size: 0.95rem; color: var(--text-muted); max-width: 520px; margin: 0 auto; line-height: 1.7; }

    /* ══════════════ FEATURES ══════════════ */
    .features-section { padding: 80px 5%; background: var(--white); }
    .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .feature-card {
      background: var(--light-bg);
      border-radius: 14px;
      padding: 36px 28px;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s, background 0.3s, box-shadow 0.3s;
      border: 1.5px solid transparent;
    }
    .feature-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--primary);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.35s ease;
    }
    .feature-card:hover { background: var(--white); transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,0.09); border-color: rgba(255,190,51,0.2); }
    .feature-card:hover::before { transform: scaleX(1); }
    .feature-icon {
      width: 54px; height: 54px;
      background: rgba(255,190,51,0.12);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      color: var(--primary);
      margin-bottom: 20px;
    }
    .feature-card h3 { font-size: 1.1rem; font-weight: 700; font-family: 'Lora', serif; color: var(--dark); margin-bottom: 10px; }
    .feature-card p { font-size: 0.86rem; color: var(--text-muted); line-height: 1.65; }
    .feature-num { position: absolute; top: 18px; right: 22px; font-size: 3rem; font-weight: 800; color: rgba(34,40,49,0.05); line-height: 1; }

    /* ══════════════ ABOUT ══════════════ */
    .about-section { padding: 80px 5%; background: var(--light-bg); }
    .about-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .about-img-wrap { position: relative; }
    .about-img-wrap img { width: 100%; border-radius: 16px; display: block; box-shadow: 0 20px 60px rgba(0,0,0,0.12); }
    .about-badge {
      position: absolute;
      bottom: -20px; right: -20px;
      background: var(--primary);
      color: var(--dark);
      border-radius: 12px;
      padding: 18px 24px;
      box-shadow: 0 12px 32px rgba(255,190,51,0.45);
      text-align: center;
    }
    .about-badge strong { font-size: 2rem; font-weight: 800; display: block; line-height: 1; }
    .about-badge span { font-size: 0.72rem; font-weight: 600; opacity: 0.75; }

    .inline-label { font-size: 0.72rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; letter-spacing: 0.22em; text-transform: uppercase; color: var(--primary); display: block; margin-bottom: 0.6rem; }

    .about-content h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 700; font-family: 'Lora', serif; color: var(--dark); margin-bottom: 1rem; letter-spacing: 0.01em; line-height: 1.25; }
    .about-content p { font-size: 0.92rem; color: var(--text-muted); line-height: 1.75; margin-bottom: 1.2rem; }
    .about-points { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem; }
    .about-points li { display: flex; align-items: center; gap: 10px; font-size: 0.88rem; font-weight: 500; color: var(--dark); }
    .about-points li i { color: var(--primary); }

    /* ══════════════ TESTIMONIALS ══════════════ */
    .testimonials-section { padding: 80px 5%; background: var(--dark); }
    .testimonials-section .section-header h2 { color: var(--white); }
    .testimonials-section .section-header p { color: rgba(255,255,255,0.5); }
    .testi-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .testi-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 32px;
      transition: background 0.3s, border-color 0.3s, transform 0.3s;
    }
    .testi-card:hover { background: rgba(255,255,255,0.07); border-color: rgba(255,190,51,0.3); transform: translateY(-4px); }
    .stars { display: flex; gap: 2px; margin-bottom: 16px; }
    .stars i { color: var(--primary); font-size: 0.8rem; }
    .testi-quote { font-size: 0.92rem; line-height: 1.75; color: rgba(255,255,255,0.72); margin-bottom: 24px; font-style: italic; }
    .testi-author { display: flex; align-items: center; gap: 12px; }
    .testi-avatar { width: 46px; height: 46px; border-radius: 50%; overflow: hidden; border: 2px solid var(--primary); flex-shrink: 0; }
    .testi-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .testi-name { font-weight: 700; font-size: 0.92rem; color: var(--white); }
    .testi-role { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 2px; }

    /* ══════════════ CONTACT ══════════════ */
    .contact-section { padding: 80px 5%; background: var(--white); }
    .contact-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 5rem; align-items: start; }
    .contact-info h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; font-family: 'Lora', serif; color: var(--dark); margin-bottom: 1rem; letter-spacing: 0.01em; }
    .contact-info p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 2rem; }
    .contact-item { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: var(--light-bg); border-radius: 10px; margin-bottom: 0.75rem; border: 1px solid var(--border); font-size: 0.88rem; color: var(--dark); transition: border-color 0.2s; }
    .contact-item:hover { border-color: var(--primary); }
    .contact-item i { color: var(--primary); font-size: 1rem; width: 20px; text-align: center; }
    .contact-form { background: var(--light-bg); border-radius: 16px; padding: 40px; border: 1.5px solid var(--border); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { margin-bottom: 1.1rem; }
    .form-group label { display: block; font-size: 0.75rem; font-weight: 600; color: var(--dark); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 6px; }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 12px 16px;
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      color: var(--dark);
      outline: none;
      transition: border-color 0.2s;
      appearance: none;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus { border-color: var(--primary); }
    .form-group textarea { resize: vertical; min-height: 110px; }
    .form-submit {
      width: 100%;
      background: var(--primary);
      color: var(--dark);
      border: none;
      padding: 15px;
      border-radius: 8px;
      font-family: 'Josefin Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .form-submit:hover { background: var(--primary-dark); transform: translateY(-1px); }

    /* ══════════════ FOOTER ══════════════ */
    footer { background: var(--dark2); color: var(--white); padding: 60px 5% 28px; }
    .footer-grid { display: grid; grid-template-columns: 1.8fr 1fr 1fr 1fr; gap: 3rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
    .footer-brand-name { font-size: 1.4rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; letter-spacing: 0.1em; text-transform: uppercase; color: var(--white); display: inline-block; margin-bottom: 0.8rem; text-decoration: none; }
    .footer-brand-name span { color: var(--primary); }
    .footer-desc { font-size: 0.84rem; color: rgba(255,255,255,0.4); line-height: 1.7; max-width: 210px; margin-bottom: 1.2rem; font-family: 'Lora', serif; }
    .footer-socials { display: flex; gap: 8px; }
    .social-icon { width: 36px; height: 36px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.09); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.5); font-size: 0.85rem; text-decoration: none; transition: background 0.2s, color 0.2s, border-color 0.2s; }
    .social-icon:hover { background: var(--primary); color: var(--dark); border-color: var(--primary); }
    .footer-col h4 { font-size: 0.78rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; letter-spacing: 0.14em; text-transform: uppercase; color: var(--white); margin-bottom: 1.2rem; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; }
    .footer-col ul a { font-size: 0.85rem; font-family: 'Lora', serif; color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
    .footer-col ul a:hover { color: var(--primary); }
    .footer-bottom { padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.78rem; color: rgba(255,255,255,0.25); flex-wrap: wrap; gap: 0.5rem; }

    /* ══════════════ ANIMATIONS ══════════════ */
    .fade-up { opacity: 0; transform: translateY(28px); transition: opacity 0.65s ease, transform 0.65s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .fade-up.delay-1 { transition-delay: 0.1s; }
    .fade-up.delay-2 { transition-delay: 0.2s; }

    /* ══════════════ RESPONSIVE ══════════════ */
    @media (max-width: 1024px) {
      .features-grid { grid-template-columns: 1fr 1fr; }
      .about-inner { grid-template-columns: 1fr; gap: 3rem; }
      .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .offers-grid { grid-template-columns: 1fr; }
      .features-grid { grid-template-columns: 1fr; }
      .testi-grid { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .hero-stats { flex-wrap: wrap; }
      .stat-item { min-width: 50%; border-top: 1px solid rgba(255,255,255,0.06); }
    }
    @media (max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr; }
      .about-badge { display: none; }
    }
  </style>
</head>
<body>

<!-- MOBILE NAV -->
<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <div class="hero-bg-img"></div>
  <div class="hero-overlay"></div>

  <div class="hero-slides-wrap">
    <div class="hero-slide active">
      <div>
        <div class="hero-badge"><i class="fa fa-bolt"></i> Plateforme collaborative</div>
        <h1>Bienvenue sur <span>BizHub</span></h1>
        <p>Une plateforme moderne connectant entreprises, investisseurs, étudiants et créateurs. Centralisez la collaboration, l'entrepreneuriat et la croissance économique.</p>
        <div class="hero-btns">
          <a href="{{ path('app_register') }}" class="btn-yellow">Commencer maintenant</a>
          <a href="#about" class="btn-outline">En savoir plus</a>
        </div>
      </div>
    </div>
    <div class="hero-slide">
      <div>
        <div class="hero-badge"><i class="fa fa-users"></i> Réseau & Opportunités</div>
        <h1>Connectez & <span>Collaborez</span></h1>
        <p>Partagez vos idées, découvrez des opportunités et développez votre activité avec notre réseau d'entrepreneurs, d'investisseurs et d'innovateurs.</p>
        <div class="hero-btns">
          <a href="{{ path('app_register') }}" class="btn-yellow">Rejoindre la communauté</a>
          <a href="#" class="btn-outline">Explorer le marché</a>
        </div>
      </div>
    </div>
    <div class="hero-slide">
      <div>
        <div class="hero-badge"><i class="fa fa-graduation-cap"></i> Formations & Incubation</div>
        <h1>Apprenez & <span>Grandissez</span></h1>
        <p>Accédez à des cours, des programmes de mentorat et un accompagnement à l'incubation pour accélérer votre parcours entrepreneurial.</p>
        <div class="hero-btns">
          <a href="{{ path('app_register') }}" class="btn-yellow">Démarrer une formation</a>
          <a href="#" class="btn-outline">Trouver des fonds</a>
        </div>
      </div>
    </div>

    <div class="carousel-dots">
      <button class="cdot active" data-slide="0"></button>
      <button class="cdot" data-slide="1"></button>
      <button class="cdot" data-slide="2"></button>
    </div>
  </div>

  <div class="hero-stats">
    <div class="stat-item">
      <span class="stat-num">12K+</span>
      <div class="stat-label">Membres actifs</div>
    </div>
    <div class="stat-item">
      <span class="stat-num">340+</span>
      <div class="stat-label">Startups incubées</div>
    </div>
    <div class="stat-item">
      <span class="stat-num">€2.4M</span>
      <div class="stat-label">Investissements</div>
    </div>
    <div class="stat-item">
      <span class="stat-num">98%</span>
      <div class="stat-label">Satisfaction</div>
    </div>
  </div>
</section>

<!-- OFFERS -->
<section class="offers-section">
  <div class="section-header fade-up">
    <span class="label">Offres spéciales</span>
    <h2>Profitez de nos promotions</h2>
  </div>
  <div class="offers-grid fade-up delay-1">
    <div class="offer-card">
      <img src="images/f1.jpg" alt="Tasty Thursdays" class="offer-img">
      <div class="offer-body">
        <div class="offer-tag">Offre limitée</div>
        <div class="offer-title">Tasty Thursdays</div>
        <div class="offer-discount">20% <span>de réduction</span></div>
        <a href="#" class="offer-btn"><i class="fa fa-shopping-cart"></i> Commander</a>
      </div>
    </div>
    <div class="offer-card">
      <img src="images/f2.jpeg" alt="Special Offers" class="offer-img">
      <div class="offer-body">
        <div class="offer-tag">Spécial</div>
        <div class="offer-title">Special Offers</div>
        <div class="offer-discount">15% <span>de réduction</span></div>
        <a href="#" class="offer-btn"><i class="fa fa-shopping-cart"></i> Commander</a>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features-section" id="features">
  <div class="section-header fade-up">
    <span class="label">Ce que nous offrons</span>
    <h2>Tout pour votre business</h2>
    <p>Six modules complets pour couvrir chaque aspect de votre développement entrepreneurial.</p>
  </div>
  <div class="features-grid">
    <div class="feature-card fade-up">
      <div class="feature-num">01</div>
      <div class="feature-icon"><i class="fa fa-store"></i></div>
      <h3>Marketplace</h3>
      <p>Vendez et achetez des produits et services dans un écosystème business sécurisé et optimisé.</p>
