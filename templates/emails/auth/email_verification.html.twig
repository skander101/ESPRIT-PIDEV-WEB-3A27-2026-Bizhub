<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Verify your email</title>
</head>
<body style="font-family: Arial, sans-serif; background: #f5f7fb; padding: 24px;">
<div style="max-width: 640px; margin: 0 auto; background: #ffffff; border-radius: 12px; padding: 24px; border: 1px solid #e6ecf5;">
    <h2 style="margin-top:0; color:#0f172a;">Verify your BizHub email</h2>
    <p>Hello {{ user.fullName ?? 'User' }},</p>
    <p>Welcome to BizHub. Please verify your email address to activate secure sign-in.</p>
    <p>
        <a href="{{ verificationUrl }}" style="display:inline-block; background:#1166ff; color:#ffffff; text-decoration:none; font-weight:700; padding:12px 18px; border-radius:8px;">
            Verify my email
        </a>
    </p>
    <p>This verification link expires in {{ expiresMinutes }} minutes.</p>
    <p>If this wasn't you, please ignore this email.</p>
</div>
</body>
</html>
